---
import BaseHead from "../components/BaseHead.astro";
import DisclaimerBlock from "../components/DisclaimerBlock.astro";
import RvLogo from "../images/brand/logo-horizontal-whitebg.svg";
import PresHeroV2 from "../sections/presentation/PresHeroV2.astro";
import PresTermsSnapshot from "../sections/presentation/PresTermsSnapshot.astro";
import PresWhatHappensNext from "../sections/presentation/PresWhatHappensNext.astro";
import PresScarcityBridge from "../sections/presentation/PresScarcityBridge.astro";
import PresOuterBanks from "../sections/presentation/PresOuterBanks.astro";
import PresBitcoinReserve from "../sections/presentation/PresBitcoinReserve.astro";
import PresHowTheRateWorks from "../sections/presentation/PresHowTheRateWorks.astro";
import PresFounder from "../sections/presentation/PresFounder.astro";
import PresTrackRecordV2 from "../sections/presentation/PresTrackRecordV2.astro";
import ReviewsV3 from "../sections/ReviewsV3.astro";
import PresReviewBeforeInvest from "../sections/presentation/PresReviewBeforeInvest.astro";
import PresFaq from "../sections/presentation/PresFaq.astro";
import PresClosingCta from "../sections/presentation/PresClosingCta.astro";

const pageTitle = "Presentation v2 | Robert Ventures";
const pageDescription =
  "A closer look at the fixed 8 to 10% offering for investors who have already spoken with us.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <meta name="robots" content="noindex" />
    <link
      rel="modulepreload"
      href="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
    />
    <link rel="preconnect" href="https://stream.mux.com" crossorigin />
    <link rel="preconnect" href="https://image.mux.com" crossorigin />
    <script
      type="module"
      src="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
      is:inline></script>
  </head>
  <body>
    <div class="pres-nav-logo" role="img" aria-label="Robert Ventures">
      <RvLogo />
    </div>

    <main>
      <PresHeroV2 />
      <PresScarcityBridge />
      <PresTermsSnapshot />
      <PresOuterBanks />
      <PresBitcoinReserve />
      <PresHowTheRateWorks />
      <PresFounder />
      <PresTrackRecordV2 />
      <ReviewsV3 />
      <PresWhatHappensNext />
      <PresReviewBeforeInvest />
      <PresFaq />
      <PresClosingCta />
    </main>

    <DisclaimerBlock trackLocation="offer_v2_disclaimer" />

    <div class="pres-stickycta" role="region" aria-label="Next steps">
      <div class="pres-stickycta__inner">
        <a
          class="pres-stickycta__btn pres-stickycta__btn--primary"
          href="https://invest.robertventures.com/"
          data-track-cta="create_account"
          data-track-location="sticky_bar"
        >
          Create your account
        </a>
        <a
          class="pres-stickycta__btn pres-stickycta__btn--ghost"
          href="/offer/book-call"
          data-track-cta="book_call"
          data-track-location="sticky_bar"
        >
          Book a 10-minute call
        </a>
      </div>
    </div>
  </body>
</html>

<style is:global>
  /* Continuous narrative band, no margins between sections */
  main section {
    margin-bottom: 0;
  }

  /* Reviews flips to white on this page so the alternation stays clean */
  main > section:has(.reviews-v3-container) {
    background: var(--bg-primary);
  }
  main > section:has(.reviews-v3-container) .review-card {
    background: var(--bg-secondary);
  }

  body {
    padding-bottom: 96px;
  }

  @media only screen and (min-width: 600px) {
    body {
      padding-bottom: 88px;
    }
  }
</style>

<style>
  .pres-nav-logo {
    display: flex;
    justify-content: center;
    padding: 1.25rem 1rem;
    border-bottom: 1px solid var(--border-light);
  }

  .pres-nav-logo :global(svg) {
    display: block;
    height: 30px;
    width: auto;
  }

  @media only screen and (min-width: 600px) {
    .pres-nav-logo {
      padding: 1.5rem 1rem;
    }

    .pres-nav-logo :global(svg) {
      height: 48px;
    }
  }

  .pres-stickycta {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 50;
    background: linear-gradient(to top, #ffffff 0%, #ffffff 55%, rgba(255, 255, 255, 0) 100%);
    padding: 32px 1rem calc(14px + env(safe-area-inset-bottom));
    pointer-events: none;
  }

  .pres-stickycta__inner {
    max-width: 1024px;
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    gap: 8px;
    width: 100%;
    pointer-events: auto;
  }

  .pres-stickycta__btn {
    flex: 1;
    text-decoration: none;
    text-align: center;
    border-radius: 8px;
    font-family: "Roboto", sans-serif;
    font-size: 16px;
    font-weight: 600;
    line-height: 100%;
    padding: 14px 12px;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .pres-stickycta__btn--primary {
    background-color: var(--green-brand);
    border: 1px solid var(--green-brand);
    color: #ffffff;
    animation: stickycta-pulse-primary 2.6s ease-in-out infinite;
  }

  .pres-stickycta__btn--primary:hover,
  .pres-stickycta__btn--primary:active {
    background-color: var(--green-hover);
    border-color: var(--green-hover);
    color: #ffffff;
  }

  .pres-stickycta__btn--ghost {
    background-color: transparent;
    border: 1px solid var(--text-heading);
    color: var(--text-heading);
    animation: stickycta-pulse-ghost 2.6s ease-in-out infinite;
  }

  .pres-stickycta__btn--ghost:hover,
  .pres-stickycta__btn--ghost:active {
    background-color: var(--text-heading);
    color: #ffffff;
  }

  @keyframes stickycta-pulse-primary {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(103, 183, 143, 0.55);
    }
    70% {
      box-shadow: 0 0 0 8px rgba(103, 183, 143, 0);
    }
  }

  @keyframes stickycta-pulse-ghost {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(26, 26, 26, 0.22);
    }
    70% {
      box-shadow: 0 0 0 8px rgba(26, 26, 26, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pres-stickycta__btn--primary,
    .pres-stickycta__btn--ghost {
      animation: none;
    }
  }

  @media only screen and (min-width: 600px) {
    .pres-stickycta {
      padding: 40px 2rem calc(16px + env(safe-area-inset-bottom));
    }

    .pres-stickycta__inner {
      gap: 12px;
    }

    .pres-stickycta__btn {
      font-size: 18px;
      padding: 14px 20px;
    }
  }
</style>

<script is:inline>
  (function () {
    function setupHeroVideo() {
      const player = document.getElementById("pres-mux-player");
      const overlay = document.getElementById("pres-mux-overlay");
      if (!player) return;

      let autoplayState = "pending";
      let isAutoplayPlay = false;
      let engaged = false;

      function showOverlayUnmuteMode() {
        if (!overlay) return;
        overlay.classList.add("is-active");
        overlay.classList.remove("is-play-mode");
        overlay.setAttribute("aria-label", "Your video is playing. Click to unmute.");
      }

      function showOverlayPlayMode() {
        if (!overlay) return;
        overlay.classList.add("is-active", "is-play-mode");
        overlay.setAttribute("aria-label", "Click to play");
      }

      function dismissOverlay() {
        if (!overlay) return;
        overlay.classList.remove("is-active");
      }

      function attemptAutoplay() {
        if (autoplayState !== "pending") return;
        autoplayState = "trying";
        try {
          player.muted = true;
        } catch (e) {}
        isAutoplayPlay = true;
        const promise = player.play();
        if (promise && typeof promise.then === "function") {
          promise
            .then(function () {
              autoplayState = "playing";
              if (!engaged) showOverlayUnmuteMode();
            })
            .catch(function () {
              isAutoplayPlay = false;
              autoplayState = "failed";
              if (!engaged) showOverlayPlayMode();
            });
        } else {
          autoplayState = "playing";
          if (!engaged) showOverlayUnmuteMode();
        }
      }

      function engageFromOverlay(e) {
        if (!overlay || !overlay.classList.contains("is-active")) return;
        e.preventDefault();
        e.stopPropagation();
        const isPlayMode = overlay.classList.contains("is-play-mode");
        try {
          player.muted = false;
        } catch (err) {}
        if (isPlayMode) {
          const result = player.play();
          if (result && typeof result.catch === "function") result.catch(function () {});
        }
        dismissOverlay();
      }

      if (overlay) {
        overlay.addEventListener("click", engageFromOverlay);
        overlay.addEventListener("keydown", function (e) {
          if (e.key === "Enter" || e.key === " ") engageFromOverlay(e);
        });
      }

      player.addEventListener("play", function () {
        const wasAutoplay = isAutoplayPlay;
        isAutoplayPlay = false;
        if (!wasAutoplay) {
          engaged = true;
          dismissOverlay();
        }
      });

      player.addEventListener("volumechange", function () {
        if (engaged) return;
        if (player.muted) return;
        engaged = true;
        dismissOverlay();
        if (window.posthogTrack) {
          window.posthogTrack("video_unmuted", {
            video_id: "offer_v2_hero",
            current_time: Math.round(player.currentTime || 0),
            autoplay_succeeded: autoplayState === "playing",
          });
        }
      });

      if ("IntersectionObserver" in window) {
        const videoIo = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                if (autoplayState === "pending") {
                  attemptAutoplay();
                } else if (autoplayState === "playing" && player.paused && !engaged) {
                  isAutoplayPlay = true;
                  const result = player.play();
                  if (result && typeof result.catch === "function") {
                    result.catch(function () {
                      isAutoplayPlay = false;
                    });
                  }
                }
              } else if (!player.paused) {
                player.pause();
              }
            });
          },
          { threshold: 0, rootMargin: "0px 0px 40% 0px" }
        );
        videoIo.observe(player);
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupHeroVideo);
    } else {
      setupHeroVideo();
    }
  })();
</script>
