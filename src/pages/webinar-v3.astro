---
import BaseHead from "../components/BaseHead.astro";
import RvLogo from "../images/logo-horizontal-whitebg.svg";
import Wf3Slide1 from "../sections/webinar-funnel-v3/Wf3Slide1.astro";
import Wf3Slide2 from "../sections/webinar-funnel-v3/Wf3Slide2.astro";
import Wf3Slide3 from "../sections/webinar-funnel-v3/Wf3Slide3.astro";
import Wf3Slide4 from "../sections/webinar-funnel-v3/Wf3Slide4.astro";
import Wf3Slide5 from "../sections/webinar-funnel-v3/Wf3Slide5.astro";
import Wf3Slide6 from "../sections/webinar-funnel-v3/Wf3Slide6.astro";
import Wf3Slide8 from "../sections/webinar-funnel-v3/Wf3Slide8.astro";


const pageTitle = "Investment Webinar | Robert Ventures";
const pageDescription =
  "Discover how Robert Ventures delivers 8-10% fixed annual returns through Real Estate and Digital Assets.";

export const prerender = false;

// SSR: Fetch webinar data server-side for the /live destination page
let ssrWebinarData = null;
try {
  const scheduledWebinarId = "684ae034de7a164da41abe10";
  const onDemandWebinarId = "696d0df144dee112a61d5db8";
  const apiKey = import.meta.env.WEBINARKIT_API_KEY;

  if (apiKey) {
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 5000);

    const response = await fetch(`https://webinarkit.com/api/webinar/dates/${scheduledWebinarId}`, {
      method: "GET",
      headers: { Authorization: `Bearer ${apiKey}` },
      redirect: "follow",
      signal: controller.signal,
    });
    clearTimeout(timeout);

    if (response.ok) {
      const data = await response.json();
      const filteredResults = data.results.filter(
        (item: any) => item.id !== "instant" && !item.id.startsWith("jit_")
      );
      ssrWebinarData = {
        results: filteredResults,
        webinarIds: { scheduled: scheduledWebinarId, onDemand: onDemandWebinarId },
        onDemandAvailable: true,
      };
    }
  }
} catch (e) {
  // SSR fetch failed — destination pages will fall back to client-side fetch
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={pageTitle}
      description={pageDescription}
      rtkCampaignId="697c996793ba48f6ba89582f"
    />
    <meta name="robots" content="noindex" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/css/splide-core.min.css"
    />
  </head>
  <body>
    {
      ssrWebinarData && (
        <script
          type="application/json"
          id="ssr-webinar-data"
          set:html={JSON.stringify(ssrWebinarData)}
        />
      )
    }

    <!-- Floating logo -->
    <a href="/" class="wf3-nav-logo" aria-label="Back to Robert Ventures home">
      <RvLogo />
    </a>

    <!-- Slide position indicator -->
    <nav class="wf3-indicator" aria-label="Slide navigation">
      <button class="wf3-indicator__dot is-active" data-slide="0" aria-label="Go to slide 1"></button>
      <div class="wf3-indicator__line"></div>
      <button class="wf3-indicator__dot" data-slide="1" aria-label="Go to slide 2"></button>
      <div class="wf3-indicator__line"></div>
      <button class="wf3-indicator__dot" data-slide="2" aria-label="Go to slide 3"></button>
      <div class="wf3-indicator__line"></div>
      <button class="wf3-indicator__dot" data-slide="3" aria-label="Go to slide 4"></button>
      <div class="wf3-indicator__line"></div>
      <button class="wf3-indicator__dot" data-slide="4" aria-label="Go to slide 5"></button>
      <div class="wf3-indicator__line"></div>
      <button class="wf3-indicator__dot" data-slide="5" aria-label="Go to slide 6"></button>
      <div class="wf3-indicator__line"></div>
      <button class="wf3-indicator__dot" data-slide="6" aria-label="Go to slide 7"></button>
    </nav>

    <!-- Swipe hint -->
    <div class="wf3-hint" aria-hidden="true">
      <span class="wf3-hint__chevron"></span>
      <span class="wf3-hint__chevron"></span>
    </div>


    <!-- Swiper container — NOT wrapped in <form> -->
    <div class="swiper wf3-swiper">
      <div class="swiper-wrapper">
        <div class="swiper-slide"><Wf3Slide1 /></div>
        <div class="swiper-slide"><Wf3Slide2 /></div>
        <div class="swiper-slide"><Wf3Slide3 /></div>
        <div class="swiper-slide"><Wf3Slide4 /></div>
        <div class="swiper-slide"><Wf3Slide5 /></div>
        <div class="swiper-slide"><Wf3Slide6 /></div>
        <div class="swiper-slide"><Wf3Slide8 /></div>
      </div>
    </div>
  </body>
</html>

<style is:global>
  body {
    background-color: #ffffff;
    margin: 0 !important;
    padding: 0 !important;
    min-height: calc(100vh + 1px);
    overscroll-behavior: none;
  }

  .wf3-swiper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100svh;
    touch-action: pan-x pinch-zoom;
  }

  .wf3-swiper .swiper-slide {
    height: 100svh;
  }

  section.wf3-slide {
    height: 100%;
    margin: 0 !important;
    border: none !important;
    padding-left: 2rem !important;
  }

  @media only screen and (min-width: 600px) {
    section.wf3-slide {
      padding-left: 2.5rem !important;
    }
  }
</style>

<style>
  /* ── Floating logo ── */
  .wf3-nav-logo {
    position: fixed;
    top: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .wf3-nav-logo:hover {
    opacity: 1;
  }

  .wf3-nav-logo :global(svg) {
    height: 40px;
    width: auto;
  }

  @media only screen and (min-width: 600px) {
    .wf3-nav-logo {
      top: 1.5rem;
    }

    .wf3-nav-logo :global(svg) {
      height: 48px;
    }
  }
</style>

<style>
  /* ── Slide position indicator ── */
  .wf3-indicator {
    position: fixed;
    left: 0.25rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .wf3-indicator__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid #1a1a1a;
    padding: 0;
    background: transparent;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .wf3-indicator__dot:hover {
    background: rgba(26, 26, 26, 0.3);
  }

  .wf3-indicator__line {
    width: 1.5px;
    height: 24px;
    background: rgba(26, 26, 26, 0.25);
    flex-shrink: 0;
    transition: background 0.3s ease;
  }

  .wf3-indicator__dot.is-passed {
    background: #1a1a1a;
    border-color: #1a1a1a;
  }

  .wf3-indicator__line.is-passed {
    background: #1a1a1a;
  }

  .wf3-indicator__dot.is-active {
    background: #1a1a1a;
    border-color: #1a1a1a;
    animation: wf3-dot-pulse 2s ease-in-out infinite;
  }

  @keyframes wf3-dot-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(26, 26, 26, 0.6);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(26, 26, 26, 0);
    }
  }

  @media only screen and (max-width: 479px) {
    .wf3-indicator {
      left: 0.2rem;
    }

    .wf3-indicator__dot {
      width: 8px;
      height: 8px;
    }

    .wf3-indicator__line {
      height: 16px;
    }
  }

  @media only screen and (min-width: 600px) {
    .wf3-indicator {
      left: 0.3rem;
    }

    .wf3-indicator__dot {
      width: 12px;
      height: 12px;
    }

    .wf3-indicator__line {
      height: 28px;
    }
  }
</style>

<style>
  /* ── Swipe hint chevron ── */
  .wf3-hint {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    animation: wf3-bounce 1.5s ease-in-out infinite;
    transition: opacity 0.4s ease;
  }

  .wf3-hint.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .wf3-hint__chevron {
    display: block;
    width: 14px;
    height: 14px;
    border-right: 2.5px solid #555555;
    border-bottom: 2.5px solid #555555;
    transform: rotate(45deg);
    margin-top: -6px;
  }

  .wf3-hint__chevron:first-child {
    margin-top: 0;
    opacity: 0.4;
  }

  @keyframes wf3-bounce {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(8px);
    }
  }

  @media only screen and (min-width: 600px) {
    .wf3-hint__chevron {
      width: 16px;
      height: 16px;
      border-right-width: 3px;
      border-bottom-width: 3px;
      margin-top: -7px;
    }

    .wf3-hint__chevron:first-child {
      margin-top: 0;
    }
  }
</style>

<script is:inline>
  (function () {
    // Safari bottom toolbar trick
    setTimeout(function () {
      window.scrollTo(0, 1);
    }, 0);

    var animatedSlides = {};
    var swiperInstance = null;
    var leadCaptured = false;

    // ── Indicator logic ──
    function updateIndicator(activeIndex) {
      var dots = document.querySelectorAll(".wf3-indicator__dot");
      var lines = document.querySelectorAll(".wf3-indicator__line");

      dots.forEach(function (dot, i) {
        dot.classList.remove("is-active", "is-passed");
        if (i < activeIndex) dot.classList.add("is-passed");
        if (i === activeIndex) dot.classList.add("is-active");
      });

      lines.forEach(function (line, i) {
        line.classList.remove("is-passed");
        if (i < activeIndex) line.classList.add("is-passed");
      });

      // Show chevron only on education slides (no button, user must scroll)
      // Slides 0,1 have buttons; slides 2-5 are education (scroll); slide 6 has cards (no scroll)
      var hint = document.querySelector(".wf3-hint");
      if (hint) {
        var isScrollSlide = activeIndex >= 2 && activeIndex <= 5;
        if (isScrollSlide && leadCaptured) {
          hint.classList.remove("is-hidden");
        } else {
          hint.classList.add("is-hidden");
        }
      }
    }

    // ── GSAP animations ──
    function runSlideAnimation(index, swiper) {
      if (animatedSlides[index]) return;
      if (!window.gsapLoaded || typeof window.gsap === "undefined") return;

      var gsap = window.gsap;
      var slideEl = swiper.slides[index];
      if (!slideEl) return;

      animatedSlides[index] = true;

      if (index === 0) {
        // Hook slide: text + underline + staircase
        var text = slideEl.querySelector(".wf3-slide__text");
        var underline = slideEl.querySelector(".wf3-slide__underline");
        if (text) {
          var tl = gsap.timeline({ delay: 0.3 });
          tl.fromTo(
            text,
            { opacity: 0, y: 60 },
            { opacity: 1, y: 0, duration: 0.8, ease: "power2.out" }
          );
          if (underline) {
            tl.fromTo(
              underline,
              { scaleX: 0 },
              { scaleX: 1, duration: 0.6, ease: "power2.out" },
              "-=0.2"
            );
          }
        }
      } else if (index === 1) {
        // Lead capture: fade in text then fields
        var text = slideEl.querySelector(".wf3-slide__text");
        var fields = slideEl.querySelector(".wf3-slide__fields");
        if (text) {
          gsap.fromTo(
            text,
            { opacity: 0, y: 40 },
            { opacity: 1, y: 0, duration: 0.8, ease: "power2.out", delay: 0.2 }
          );
        }
        if (fields) {
          gsap.fromTo(
            fields,
            { opacity: 0, y: 30 },
            { opacity: 1, y: 0, duration: 0.6, ease: "power2.out", delay: 0.7 }
          );
        }
      } else if (index === 2) {
        // Founder intro: media from left, text from right
        var media = slideEl.querySelector(".wf3-slide__media");
        var text = slideEl.querySelector(".wf3-slide__text");
        var tl = gsap.timeline({ delay: 0.2 });
        if (media) {
          tl.fromTo(
            media,
            { opacity: 0, x: -60 },
            { opacity: 1, x: 0, duration: 0.8, ease: "power2.out" }
          );
        }
        if (text) {
          tl.fromTo(
            text,
            { opacity: 0, x: 60 },
            { opacity: 1, x: 0, duration: 0.8, ease: "power2.out" },
            0.15
          );
        }
      } else if (index === 6) {
        // Choice slide: stagger cards
        var content = slideEl.querySelector(".wf3-slide__content");
        var cards = slideEl.querySelectorAll(".wf3-slide__choice-card");
        if (content) {
          gsap.fromTo(
            content,
            { opacity: 0, y: 40 },
            { opacity: 1, y: 0, duration: 0.8, ease: "power2.out", delay: 0.2 }
          );
        }
        if (cards.length) {
          gsap.fromTo(
            cards,
            { opacity: 0, y: 20 },
            { opacity: 1, y: 0, duration: 0.5, ease: "power2.out", stagger: 0.1, delay: 0.5 }
          );
        }
      } else {
        // Generic education slides: content fade in
        var content = slideEl.querySelector(".wf3-slide__content");
        if (content) {
          gsap.fromTo(
            content,
            { opacity: 0, y: 40 },
            { opacity: 1, y: 0, duration: 0.8, ease: "power2.out", delay: 0.2 }
          );
        }
      }
    }

    // ── Error helpers ──
    function showError(msg) {
      var el = document.getElementById("wf3-form-error");
      if (!el) return;
      el.textContent = msg;
      el.style.display = "block";
    }

    function hideError() {
      var el = document.getElementById("wf3-form-error");
      if (!el) return;
      el.textContent = "";
      el.style.display = "none";
    }

    // ── Cookie / attribution helpers ──
    function getCookie(name) {
      try {
        var value = "; " + document.cookie;
        var parts = value.split("; " + name + "=");
        if (parts.length === 2) {
          var raw = parts.pop().split(";").shift();
          try { return decodeURIComponent(raw); } catch (e) { return raw; }
        }
      } catch (e) {}
      return undefined;
    }

    function getRtkClickId() {
      if (typeof window.rtkClickID !== "undefined" && window.rtkClickID) return window.rtkClickID;
      var cookieName = "rtkclickid-store";
      var cookies = document.cookie.split(";");
      for (var i = 0; i < cookies.length; i++) {
        var cookie = cookies[i].trim();
        if (cookie.startsWith(cookieName + "=")) return cookie.substring(cookieName.length + 1);
      }
      var stored = getCookie("rtk_click_id");
      if (stored) return stored;
      return null;
    }

    function setRtkClickIdField(value) {
      document.querySelectorAll("input[name='rtk_click_id']").forEach(function (input) {
        input.value = value || "";
      });
      if (value) {
        try {
          document.cookie =
            "rtk_click_id=" + encodeURIComponent(value) +
            "; domain=.robertventures.com; path=/; max-age=2592000; SameSite=Lax";
        } catch (e) {}
      }
    }

    function captureCmpid() {
      try {
        var urlParams = new URLSearchParams(window.location.search);
        var cmpid = urlParams.get("cmpid");
        if (cmpid) {
          document.cookie =
            "cmpid=" + encodeURIComponent(cmpid) +
            "; domain=.robertventures.com; path=/; max-age=2592000; SameSite=Lax";
        }
      } catch (e) {}
    }

    function initializeRtkClickIdCapture() {
      var immediate = getRtkClickId();
      if (immediate) { setRtkClickIdField(immediate); return; }
      var maxAttempts = 30;
      var attempts = 0;
      var interval = setInterval(function () {
        attempts++;
        var clickId = getRtkClickId();
        if (clickId || attempts >= maxAttempts) {
          setRtkClickIdField(clickId);
          clearInterval(interval);
        }
      }, 500);
    }

    function getFbp() { return getCookie("_fbp"); }

    function getFbc() {
      var fbcCookie = getCookie("_fbc");
      if (fbcCookie) return fbcCookie;
      try {
        var url = new URL(window.location.href);
        var fbclid = url.searchParams.get("fbclid");
        if (fbclid) {
          var ts = Math.floor(Date.now() / 1000);
          return "fb.1." + ts + "." + fbclid;
        }
      } catch (e) {}
      return undefined;
    }

    function generateEventId() {
      try {
        var buf = new Uint32Array(2);
        crypto.getRandomValues(buf);
        return "rv_lc_" + Date.now().toString(36) + "_" + buf[0].toString(36) + buf[1].toString(36);
      } catch (e) {
        return "rv_lc_" + Date.now() + "_" + Math.random().toString(36).slice(2, 10);
      }
    }

    function detectDeviceFromUA(ua) {
      var isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(ua);
      if (!isMobile) return "desktop";
      if (/iPhone|iPad|iPod/i.test(ua)) return "ios";
      return "android";
    }

    // ── Phone formatting ──
    function setupPhoneFormatting() {
      var phoneInputs = document.querySelectorAll("input[name='phone_number']");
      phoneInputs.forEach(function (input) {
        input.addEventListener("input", function (e) {
          var target = e.target;
          var digits = target.value.replace(/\D/g, "");
          if (digits.length > 10) digits = digits.slice(0, 10);
          var formatted = "";
          if (digits.length > 0) {
            if (digits.length <= 3) {
              formatted = "(" + digits;
            } else if (digits.length <= 6) {
              formatted = "(" + digits.slice(0, 3) + ") " + digits.slice(3);
            } else {
              formatted = "(" + digits.slice(0, 3) + ") " + digits.slice(3, 6) + "-" + digits.slice(6);
            }
          }
          target.value = formatted;
        });

        input.addEventListener("keypress", function (e) {
          if (!/[0-9]/.test(e.key)) e.preventDefault();
        });

        input.addEventListener("paste", function (e) {
          e.preventDefault();
          var clipboardData = e.clipboardData || window.clipboardData;
          var pastedText = clipboardData.getData("text");
          var digits = pastedText.replace(/\D/g, "").slice(0, 10);
          var formatted = "";
          if (digits.length > 0) {
            if (digits.length <= 3) {
              formatted = "(" + digits;
            } else if (digits.length <= 6) {
              formatted = "(" + digits.slice(0, 3) + ") " + digits.slice(3);
            } else {
              formatted = "(" + digits.slice(0, 3) + ") " + digits.slice(3, 6) + "-" + digits.slice(6);
            }
          }
          e.target.value = formatted;
        });
      });
    }

    // ── Lead capture submission ──
    function handleLeadCapture() {
      var nameEl = document.getElementById("wf3-name");
      var emailEl = document.getElementById("wf3-email");
      var phoneEl = document.getElementById("wf3-phone");
      var honeypotEl = document.querySelector("input[name='company']");

      var investEl = document.getElementById("wf3-invest-value");

      var name = nameEl ? nameEl.value.trim() : "";
      var email = emailEl ? emailEl.value.trim() : "";
      var phone = phoneEl ? phoneEl.value.trim() : "";
      var phoneDigits = phone.replace(/\D/g, "");
      var investIntent = investEl ? investEl.value : "";

      hideError();

      // Store lead data locally and advance immediately
      var leadData = { name: name, email: email, phone: phoneDigits, invest_intent: investIntent };
      sessionStorage.setItem("wf3_lead", JSON.stringify(leadData));

      // Advance the slide right away — don't wait for API
      onLeadCaptureSuccess();

      // TEST MODE: Log payload but do NOT send to GHL/WebinarKit/Meta
      // Remove this block and uncomment the real fetch when going live
      console.log("🧪 TEST MODE — lead captured (not sent to API):", leadData);
    }

    function onLeadCaptureSuccess() {
      leadCaptured = true;

      // Store webinar data for destination pages
      var ssrEl = document.getElementById("ssr-webinar-data");
      if (ssrEl) {
        try { sessionStorage.setItem("wf3_webinar_data", ssrEl.textContent); } catch (e) {}
      }

      // Unlock all slides and advance to first education slide
      lastAllowedSlide = 6;
      if (swiperInstance) {
        swiperInstance.slideTo(2);
      }
    }

    // ── Button handlers ──
    function setupButtons() {
      // "See How It Works" on Hook slide
      document.querySelectorAll("[data-action='next-slide']").forEach(function (btn) {
        btn.addEventListener("click", function () {
          if (swiperInstance) swiperInstance.slideTo(1);
        });
      });

      // "Continue" on Lead Capture slide
      document.querySelectorAll("[data-action='capture-lead']").forEach(function (btn) {
        btn.addEventListener("click", function () {
          handleLeadCapture();
        });
      });
    }

    // ── Swiper init ──
    // Same approach as the introduction page: mousewheel + keyboard always enabled.
    // Slides 0-1 are gated — if the user tries to scroll past slide 1 without
    // capturing their lead, we bounce them back.
    var lastAllowedSlide = 1; // updated to 6 after lead capture

    function initSwiper() {
      swiperInstance = new Swiper(".wf3-swiper", {
        direction: "vertical",
        speed: 600,
        touchEventsTarget: "container",
        mousewheel: {
          sensitivity: 1,
          thresholdDelta: 30,
        },
        keyboard: {
          enabled: true,
        },
        on: {
          init: function () {
            updateIndicator(0);
            if (window.gsapLoaded && typeof window.gsap !== "undefined") {
              runSlideAnimation(0, this);
            } else {
              var self = this;
              window.addEventListener("gsapLoaded", function () {
                runSlideAnimation(0, self);
              });
            }
          },
          slideChange: function () {
            // Gate: prevent scrolling past slide 1 until lead is captured
            if (this.activeIndex > lastAllowedSlide) {
              this.slideTo(lastAllowedSlide, 0);
              return;
            }

            updateIndicator(this.activeIndex);

            if (window.gsapLoaded && typeof window.gsap !== "undefined") {
              runSlideAnimation(this.activeIndex, this);
            } else {
              var self = this;
              window.addEventListener("gsapLoaded", function () {
                runSlideAnimation(self.activeIndex, self);
              });
            }
          },
        },
      });

      // Dot navigation
      document.querySelectorAll(".wf3-indicator__dot").forEach(function (dot) {
        dot.addEventListener("click", function () {
          var targetSlide = parseInt(dot.getAttribute("data-slide"), 10);
          if (targetSlide <= lastAllowedSlide) {
            swiperInstance.slideTo(targetSlide);
          }
        });
      });
    }

    // ── Boot ──
    function boot() {
      captureCmpid();
      initializeRtkClickIdCapture();
      setupPhoneFormatting();
      setupButtons();
    }

    // Load Swiper from CDN
    var swiperScript = document.createElement("script");
    swiperScript.src = "https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js";
    swiperScript.onload = function () {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", function () {
          initSwiper();
          boot();
        });
      } else {
        initSwiper();
        boot();
      }
    };
    document.head.appendChild(swiperScript);

    // Load Splide for real estate carousel (Slide 4)
    var splideScript = document.createElement("script");
    splideScript.src = "https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/js/splide.min.js";
    splideScript.onload = function () {
      function initSplide() {
        var el = document.getElementById("wf3-property-carousel");
        if (el) {
          new Splide(el, {
            type: "fade",
            rewind: true,
            autoplay: true,
            interval: 3000,
            speed: 1000,
            pauseOnHover: false,
            arrows: false,
            pagination: false,
          }).mount();
        }
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initSplide);
      } else {
        initSplide();
      }
    };
    document.head.appendChild(splideScript);
  })();
</script>
