---
export const prerender = true;

import BaseHead from "../components/BaseHead.astro";
import DisclaimerBlock from "../components/DisclaimerBlock.astro";
import RvLogo from "../images/brand/logo-horizontal-whitebg.svg";
import ReviewsV3 from "../sections/ReviewsV3.astro";
import PresV2Hero from "../sections/presentation-v2/PresV2Hero.astro";
import PresV2CashAtRest from "../sections/presentation-v2/PresV2CashAtRest.astro";
import PresV2ChoiceCalculator from "../sections/presentation-v2/PresV2ChoiceCalculator.astro";
import PresV2WhatYouHold from "../sections/presentation-v2/PresV2WhatYouHold.astro";
import PresV2WhyTheRateWorks from "../sections/presentation-v2/PresV2WhyTheRateWorks.astro";
import PresV2Proof from "../sections/presentation-v2/PresV2Proof.astro";
import PresV2MoveInClose from "../sections/presentation-v2/PresV2MoveInClose.astro";
import PresV2Faq from "../sections/presentation-v2/PresV2Faq.astro";

const pageTitle = "Robert Ventures | Your fixed 8 to 10% offering";
const pageDescription =
  "One SEC-qualified bond at a fixed 8 to 10%. You choose: a deposit in your bank every month, or let the interest compound and grow.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <meta name="robots" content="noindex" />
    <link
      rel="modulepreload"
      href="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
    />
    <link rel="preconnect" href="https://stream.mux.com" crossorigin />
    <link rel="preconnect" href="https://image.mux.com" crossorigin />
    <script
      type="module"
      src="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
      is:inline></script>
  </head>
  <body>
    <div class="pres-nav-logo" role="img" aria-label="Robert Ventures">
      <RvLogo />
    </div>

    <main>
      <PresV2Hero />
      <PresV2CashAtRest />
      <PresV2ChoiceCalculator />
      <div class="pres-v2-breath" aria-hidden="true"></div>
      <PresV2WhatYouHold />
      <PresV2WhyTheRateWorks />
      <PresV2Proof />
      <ReviewsV3 />
      <PresV2MoveInClose />
      <PresV2Faq />
    </main>

    <DisclaimerBlock trackLocation="offer_v2_disclaimer" />

    <div class="pres-stickycta" role="region" aria-label="Next steps">
      <div class="pres-stickycta__inner">
        <a
          class="pres-stickycta__btn pres-stickycta__btn--primary"
          href="https://invest.robertventures.com/"
          data-track-cta="create_account"
          data-track-location="sticky_bar"
        >
          Open your free account
        </a>
        <a
          class="pres-stickycta__btn pres-stickycta__btn--ghost"
          href="/offer/book-call"
          data-track-cta="book_call"
          data-track-location="sticky_bar"
        >
          Book a 10-minute call
        </a>
      </div>
    </div>
  </body>
</html>

<style is:global>
  /* Continuous narrative band, no margins between sections */
  main section {
    margin-bottom: 0;
  }

  /* Reviews flips to white on this page so the alternation stays clean */
  main > section:has(.reviews-v3-container) {
    background: var(--bg-primary);
  }
  main > section:has(.reviews-v3-container) .review-card {
    background: var(--bg-secondary);
  }

  body {
    padding-bottom: 96px;
  }

  @media only screen and (min-width: 600px) {
    body {
      padding-bottom: 88px;
    }
  }
</style>

<style>
  /* One deliberate breath between the calculator beat (upside math) and the safety beat. */
  .pres-v2-breath {
    height: 64px;
    background: var(--bg-primary);
  }

  @media only screen and (min-width: 600px) {
    .pres-v2-breath {
      height: 88px;
    }
  }

  .pres-nav-logo {
    display: flex;
    justify-content: center;
    padding: 1.25rem 1rem;
    border-bottom: 1px solid var(--border-light);
  }

  .pres-nav-logo :global(svg) {
    display: block;
    height: 30px;
    width: auto;
  }

  @media only screen and (min-width: 600px) {
    .pres-nav-logo {
      padding: 1.5rem 1rem;
    }

    .pres-nav-logo :global(svg) {
      height: 48px;
    }
  }

  .pres-stickycta {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 50;
    background: linear-gradient(to top, #ffffff 0%, #ffffff 55%, rgba(255, 255, 255, 0) 100%);
    padding: 32px 1rem calc(14px + env(safe-area-inset-bottom));
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .pres-stickycta.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .pres-stickycta__inner {
    max-width: 1024px;
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    gap: 8px;
    width: 100%;
    pointer-events: auto;
  }

  .pres-stickycta__btn {
    flex: 1;
    text-decoration: none;
    text-align: center;
    border-radius: 8px;
    font-family: "Roboto", sans-serif;
    font-size: 16px;
    font-weight: 600;
    line-height: 100%;
    padding: 14px 12px;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  /* --green-dark fill: --green-brand on white is ~2:1 and fails WCAG AA. */
  .pres-stickycta__btn--primary {
    background-color: var(--green-dark);
    border: 1px solid var(--green-dark);
    color: #ffffff;
    animation: stickycta-pulse-primary 3.6s ease-in-out infinite;
  }

  .pres-stickycta__btn--primary:hover,
  .pres-stickycta__btn--primary:active {
    background-color: #22573a;
    border-color: #22573a;
    color: #ffffff;
  }

  /* The ghost button does not pulse: a pulsing secondary on an always-on-screen bar is noise. */
  .pres-stickycta__btn--ghost {
    background-color: transparent;
    border: 1px solid var(--text-heading);
    color: var(--text-heading);
  }

  .pres-stickycta__btn--ghost:hover,
  .pres-stickycta__btn--ghost:active {
    background-color: var(--text-heading);
    color: #ffffff;
  }

  @keyframes stickycta-pulse-primary {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(43, 107, 71, 0.35);
    }
    72% {
      box-shadow: 0 0 0 7px rgba(43, 107, 71, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pres-stickycta__btn--primary {
      animation: none;
    }
  }

  @media only screen and (min-width: 600px) {
    .pres-stickycta {
      padding: 40px 2rem calc(16px + env(safe-area-inset-bottom));
    }

    .pres-stickycta__inner {
      gap: 12px;
    }

    .pres-stickycta__btn {
      font-size: 18px;
      padding: 14px 20px;
    }
  }
</style>

<script>
  // Reveal-on-scroll for the page's charts and diagrams (the SVG components key their draw-in
  // CSS transitions on .is-in-view). Reduced-motion is handled inside each component; browsers
  // without IntersectionObserver get the final state immediately.
  (function () {
    const targets = document.querySelectorAll("[data-reveal]");
    if (!targets.length) return;
    if (!("IntersectionObserver" in window)) {
      targets.forEach((el) => el.classList.add("is-in-view"));
      return;
    }
    const io = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-in-view");
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2, rootMargin: "0px 0px -8% 0px" }
    );
    targets.forEach((el) => io.observe(el));
  })();
</script>
