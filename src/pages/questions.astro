---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import FooterNew from "../components/FooterNew.astro";

const pageTitle = "Robert Ventures: Questions";
const pageDescription = "Complete the second step of your account setup with Robert Ventures.";

// Investment timeline options
const investmentTimelineOptions = [
  { value: "Ready to Invest Now", label: "Ready Now" },
  { value: "Within the Next Month", label: "This Month" },
  { value: "Within 3 Months", label: "In 3 Months" },
  { value: "Just Exploring Options", label: "Just Exploring" },
];

// Age bracket options
const ageBracketOptions = [
  { value: "18_34", label: "18 to 34" },
  { value: "35_49", label: "35 to 49" },
  { value: "50_64", label: "50 to 64" },
  { value: "65_plus", label: "65+" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <meta name="robots" content="noindex" />
    <style>
      section {
        background: var(--bg-secondary);
        color: var(--text-body);
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0;
      }

      .section-container {
        max-width: 1280px;
        margin: 0 auto;
        border-radius: 1rem;
        background: transparent;
        padding: 48px 16px;
        width: 100%;
      }

      .section-content {
        max-width: 640px;
        margin: 0 auto;
      }

      h1 {
        color: var(--text-heading);
        text-align: center;
        font-family: var(--font-heading);
        font-size: 32px;
        font-weight: 500;
        margin-bottom: 2rem;
        max-width: 460px;
        margin-left: auto;
        margin-right: auto;
      }

      .portfolio-info {
        font-size: 20px;
        font-family: var(--font-body);
        color: var(--text-body);
        font-weight: 500;
        margin-bottom: 0.75rem;
        line-height: 1.5;
      }

      /* Portfolio value as a grid of selectable boxes */
      .portfolio-value-container {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
        margin-bottom: 2rem;
      }

      /* Grid column adjustments for larger screens */
      @media only screen and (min-width: 768px) {
        .portfolio-value-container {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      form {
        display: flex;
        flex-direction: column;
        max-width: 640px;
        margin: 0 auto;
      }

      button {
        background-color: var(--green-brand);
        color: #ffffff;
        padding: 15px;
        line-height: 1;
        font-family: var(--font-body);
        font-size: 1.125rem;
        font-weight: 600;
        border-radius: 8px;
        border: 1px solid var(--green-brand);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
          background-color 0.2s ease,
          transform 0.1s ease;
      }

      button:hover {
        background-color: var(--green-hover);
        border-color: var(--green-hover);
      }

      button:active {
        background-color: var(--green-hover);
        transform: translateY(1px);
      }

      button:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }

      /* Dark spinner to contrast with light button */
      .loader {
        width: 16px;
        height: 16px;
        border: 2px solid #ffffff;
        border-top: 2px solid transparent;
        border-radius: 50%;
        display: inline-block;
        animation: spin 1s linear infinite;
        margin-left: 10px;
      }

      @keyframes spin {
        0% {
          transform: rotate(0deg);
        }
        100% {
          transform: rotate(360deg);
        }
      }

      input[type="radio"] {
        width: 18px;
        height: 18px;
        accent-color: var(--green-brand);
      }

      label {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        cursor: pointer;
        padding: 0;
        border-radius: 0.5rem;
      }

      /* Portfolio grid item styles */
      .portfolio-option-label {
        display: block;
        padding: 0;
      }
      .portfolio-option-label input[type="radio"] {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
        pointer-events: none;
      }

      .option-box {
        display: block;
        width: 100%;
        text-align: center;
        padding: 1rem 1rem;
        border: 1px solid var(--border-light);
        border-radius: 8px;
        background: var(--bg-primary);
        color: var(--text-body);
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 500;
        line-height: 1.2;
        transition:
          background-color 0.15s ease,
          border-color 0.15s ease,
          color 0.15s ease;
      }

      .portfolio-option-label:hover .option-box {
        border-color: var(--green-brand);
      }

      .portfolio-option-label input[type="radio"]:focus + .option-box {
        border-color: var(--green-brand);
      }

      .portfolio-option-label input[type="radio"]:checked + .option-box {
        border-color: var(--green-brand);
        background-color: var(--green-tint);
        color: var(--green-dark);
        border-width: 1px;
      }

      span.defocus {
        font-weight: 300;
        font-size: 1.125rem;
        color: var(--text-muted);
      }

      @media only screen and (min-width: 600px) and (max-width: 1135px) {
        .section-container {
          padding: 64px 32px;
        }
      }

      @media only screen and (min-width: 1136px) {
        .section-container {
          padding: 96px 112px;
        }
        .section-content {
          max-width: 580px;
        }
      }

      @media only screen and (min-width: 1920px) {
        .section-container {
          padding: 96px 312px;
        }
      }
    </style>
  </head>

  <body>
    <Header />

    <section>
      <div class="section-container">
        <div class="section-content">
          <h1>Questions to Personalize Your Experience</h1>
          <form id="questions" action="/api/questions" method="post">
            <p class="portfolio-info">When are you looking to invest?</p>
            <div class="portfolio-value-container">
              {
                investmentTimelineOptions.map((option) => (
                  <label class="portfolio-option-label">
                    <input
                      type="radio"
                      name="investment_timeline"
                      value={option.value}
                      required={true}
                    />
                    <span class="option-box">{option.label}</span>
                  </label>
                ))
              }
            </div>

            <p class="portfolio-info">What is your age range?</p>
            <div class="portfolio-value-container">
              {
                ageBracketOptions.map((option) => (
                  <label class="portfolio-option-label">
                    <input type="radio" name="age_bracket" value={option.value} required={true} />
                    <span class="option-box">{option.label}</span>
                  </label>
                ))
              }
            </div>

            <button type="submit">
              <span class="button-text">Complete Registration</span>
              <span class="loader" style="display: none;"></span>
            </button>
          </form>
        </div>
      </div>
    </section>

    <FooterNew />
  </body>
</html>

<script>
  function triggerEvent(eventName: string) {
    if ((window as any).dataLayer) {
      (window as any).dataLayer.push({
        event: eventName,
      });
      console.log("GA4 event triggered: " + eventName);
    } else {
      console.warn("dataLayer is not defined. Ensure Google Tag Manager is properly initialized.");
    }
  }

  // Form submission handler
  document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("questions") as HTMLFormElement;
    if (!form) return;

    // Check for ghl_contact_id BEFORE showing the form — if missing, the API will reject
    // This happens when the GHL API failed during webinar registration but the user was still redirected
    const ghlCheck = localStorage.getItem("ghl_contact_id");
    if (!ghlCheck) {
      console.error(
        "ghl_contact_id missing from localStorage — registration may have been incomplete"
      );
      form.innerHTML = `
        <div style="text-align: center; padding: 2rem 0;">
          <p style="font-size: 18px; margin-bottom: 1.5rem;">Your session has expired or registration was incomplete.</p>
          <a href="/webinar" style="display: inline-block; padding: 14px 32px; background: #d3fbd8; color: #101b1f; border-radius: 8px; text-decoration: none; font-weight: 600;">Register Again</a>
        </div>
      `;
      return;
    }

    // =============================================
    // POSTHOG TRACKING — events fired on this page
    // =============================================
    // questions_form_started    → first radio selection   (below)
    // questions_field_selected  → every radio change      (below)
    // questions_completed       → successful submission   (in submit handler)
    // posthogSetPerson          → saves answers to person (in submit handler)
    // =============================================

    // POSTHOG: questions_form_started (fires once on first interaction)
    let questionsStarted = false;
    form.addEventListener("focusin", function (e: FocusEvent) {
      if (questionsStarted) return;
      const target = e.target as HTMLElement;
      if (["INPUT"].includes(target.tagName)) {
        questionsStarted = true;
        if ((window as any).posthogTrack) {
          (window as any).posthogTrack("questions_form_started");
        }
      }
    });

    // POSTHOG: questions_field_selected (fires on every radio change)
    form.addEventListener("change", function (e: Event) {
      const target = e.target as HTMLInputElement;
      if (target.type === "radio") {
        if ((window as any).posthogTrack) {
          (window as any).posthogTrack("questions_field_selected", {
            field_name: target.name,
            field_value: target.value,
          });
        }
      }
    });

    // No multi-select limit needed for primary objective (single select)

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const button = form.querySelector("button[type='submit']") as HTMLButtonElement;
      const buttonText = button.querySelector(".button-text") as HTMLElement;
      const loader = button.querySelector(".loader") as HTMLElement;
      const formData = new FormData(form);

      // Disable button and show loader
      button.disabled = true;
      buttonText.style.display = "none";
      loader.style.display = "inline-block";

      // Retrieve GoHighLevel Contact ID from localStorage
      const ghlContactId = localStorage.getItem("ghl_contact_id");
      if (!ghlContactId) {
        console.warn("GoHighLevel Contact ID not found in localStorage!");
      } else {
        console.log("Retrieved GHL Contact ID from localStorage:", ghlContactId);
        formData.append("ghl_contact_id", ghlContactId);
      }

      // Store form answers in localStorage
      const investmentTimeline = formData.get("investment_timeline");
      const ageBracket = formData.get("age_bracket");

      localStorage.setItem("investment_timeline", investmentTimeline?.toString() || "");
      localStorage.setItem("age_bracket", ageBracket?.toString() || "");

      // Add webinar sign-up date from localStorage if available
      const webinarSignUpDate = localStorage.getItem("webinar_sign_up_date");
      if (webinarSignUpDate) {
        formData.append("webinar_sign_up_date", webinarSignUpDate);
        console.log("✅ Added webinar sign-up date to form data:", webinarSignUpDate);
      }

      console.log("Stored answers in localStorage:", {
        investmentTimeline,
        ageBracket,
      });

      try {
        const response = await fetch(form.action, {
          method: form.method,
          body: formData,
        });

        if (response.ok) {
          const result = await response.json();
          console.log("Questions Completed:", result);

          triggerEvent("questions_completed");
          triggerEvent("portfolio_value_added");

          // POSTHOG: questions_completed
          if ((window as any).posthogTrack) {
            (window as any).posthogTrack("questions_completed", {
              investment_timeline: formData.get("investment_timeline"),
              age_bracket: formData.get("age_bracket"),
            });
          }

          // POSTHOG: save answers to person profile
          if ((window as any).posthogSetPerson) {
            (window as any).posthogSetPerson({
              investment_timeline: formData.get("investment_timeline"),
              age_bracket: formData.get("age_bracket"),
            });
          }

          window.location.href = "/webinar-thank-you";
        } else {
          const error = await response.json();
          console.error("Signup failed:", error.error);
          alert("There was an error completing your registration. Please try again.");
        }
      } catch (err) {
        console.error("Error during signup:", err);
        alert("There was an error completing your registration. Please try again.");
      } finally {
        // Re-enable button and hide loader
        button.disabled = false;
        buttonText.style.display = "inline";
        loader.style.display = "none";
      }
    });
  });
</script>
