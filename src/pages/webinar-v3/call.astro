---
import BaseHead from "../../components/BaseHead.astro";
import RvLogo from "../../images/logo-horizontal-whitebg.svg";

const pageTitle = "Book a Call | Robert Ventures";
const pageDescription = "Schedule a personal consultation call with the Robert Ventures team.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <!-- Floating logo -->
    <a href="/" class="wf3-nav-logo" aria-label="Back to Robert Ventures home">
      <RvLogo />
    </a>

    <section>
      <div class="section-container">
        <div class="section-content">
          <div class="section-heading">
            <h1>Ready to Earn 10% Annually?</h1>
            <p>Start with a Personal Concierge Call.</p>
          </div>
          <iframe
            src="https://api.leadconnectorhq.com/widget/booking/xNXEISjf314X2BFZvdaZ"
            style="width: 100%; height: 700px; border: none; overflow: hidden;"
            scrolling="no"
            id="calendar-iframe"></iframe>
        </div>
      </div>
    </section>

    <script is:inline src="https://link.msgsndr.com/js/form_embed.js" type="text/javascript"></script>

    <script is:inline>
      (function() {
        // Guard: redirect if no lead data
        try {
          var lead = sessionStorage.getItem('wf3_lead');
          if (!lead) {
            window.location.replace('/webinar-v3');
            return;
          }
        } catch(e) {
          window.location.replace('/webinar-v3');
          return;
        }
      })();
    </script>
  </body>
</html>

<style>
  body {
    background-color: #ffffff;
    margin: 0;
  }

  /* ── Floating logo ── */
  .wf3-nav-logo {
    position: fixed;
    top: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .wf3-nav-logo:hover {
    opacity: 1;
  }

  .wf3-nav-logo :global(svg) {
    height: 40px;
    width: auto;
  }

  @media only screen and (min-width: 600px) {
    .wf3-nav-logo {
      top: 1.5rem;
    }

    .wf3-nav-logo :global(svg) {
      height: 48px;
    }
  }

  /* ── Section layout ── */
  section {
    margin-bottom: 1.5rem;
    padding: 0;
  }

  .section-container {
    margin: 0 auto;
    border-radius: 1rem;
    background: #fff;
    padding: 48px 16px;
  }

  .section-content {
    max-width: 640px;
    margin: 0 auto;
  }

  .section-heading {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 32px;
  }

  .section-heading h1 {
    margin-bottom: 0;
  }

  .section-heading p {
    margin-bottom: 0;
    font-size: 20px;
    font-weight: 400;
    line-height: 150%;
    font-family: "Roboto", sans-serif;
  }

  h1 {
    color: var(--text-heading);
    font-size: 32px;
    font-weight: 500;
    line-height: 1.1;
    margin-bottom: 1rem;
    font-variant-numeric: lining-nums;
  }

  p {
    margin-bottom: 3rem;
    text-align: left;
    color: var(--text-body);
  }

  @media only screen and (min-width: 600px) {
    h1 {
      font-size: 40px;
    }
  }

  @media only screen and (min-width: 600px) and (max-width: 1135px) {
    section {
      padding: 0;
    }
    .section-container {
      padding: 64px 32px;
      max-width: none;
    }
  }

  @media only screen and (min-width: 1136px) {
    section {
      padding: 0;
    }
    .section-container {
      padding: 96px 112px;
      max-width: none;
    }
  }

  @media only screen and (min-width: 1920px) {
    section {
      padding: 0;
    }
    .section-container {
      padding: 96px 312px;
      max-width: none;
    }
  }
</style>
