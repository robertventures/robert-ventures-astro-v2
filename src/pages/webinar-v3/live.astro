---
import BaseHead from "../../components/BaseHead.astro";
import RvLogo from "../../images/logo-horizontal-whitebg.svg";

const pageTitle = "Join Joe Live | Robert Ventures";
const pageDescription = "Register for a live Q&A session with Joe Robert.";

export const prerender = false;

// SSR: Fetch webinar data
let ssrWebinarData = null;
try {
  const scheduledWebinarId = "684ae034de7a164da41abe10";
  const onDemandWebinarId = "696d0df144dee112a61d5db8";
  const apiKey = import.meta.env.WEBINARKIT_API_KEY;

  if (apiKey) {
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 5000);
    const response = await fetch(`https://webinarkit.com/api/webinar/dates/${scheduledWebinarId}`, {
      method: "GET",
      headers: { Authorization: `Bearer ${apiKey}` },
      redirect: "follow",
      signal: controller.signal,
    });
    clearTimeout(timeout);

    if (response.ok) {
      const data = await response.json();
      const filteredResults = data.results.filter(
        (item: any) => item.id !== "instant" && !item.id.startsWith("jit_")
      );
      ssrWebinarData = {
        results: filteredResults,
        webinarIds: { scheduled: scheduledWebinarId, onDemand: onDemandWebinarId },
        onDemandAvailable: true,
      };
    }
  }
} catch (e) {}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <meta name="robots" content="noindex" />
  </head>
  <body>
    {
      ssrWebinarData && (
        <script
          type="application/json"
          id="ssr-webinar-data"
          set:html={JSON.stringify(ssrWebinarData)}
        />
      )
    }

    <!-- Floating logo -->
    <a href="/" class="wf3-nav-logo" aria-label="Back to Robert Ventures home">
      <RvLogo />
    </a>

    <!-- Registration form area -->
    <section class="wf3-live" id="wf3-live-form">
      <div class="wf3-live__container">
        <h1 class="wf3-live__heading">Join Joe Live</h1>
        <p class="wf3-live__subtitle">Pick a session that works for you</p>

        <div id="wf3-live-sessions" class="wf3-live__sessions"></div>

        <input type="hidden" id="wf3-live-session-value" />

        <p id="wf3-live-error" style="display:none;color:#e74c3c;font-size:0.875rem;"></p>

        <button type="button" id="wf3-live-submit" class="wf3-live__btn" disabled>
          Reserve My Spot
        </button>
      </div>
    </section>

    <!-- Confirmation area (hidden initially) -->
    <div id="wf3-live-confirmation" style="display:none;">
      <section class="wf3-live wf3-live--confirmation">
        <div class="wf3-live__container">
          <div class="wf3-live__icon">
            <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="28" cy="28" r="28" fill="#ebf5ef" />
              <path d="M18 28.5L24.5 35L38 21.5" stroke="var(--green-brand)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>

          <h2 class="wf3-live__heading">You're All Set!</h2>
          <p class="wf3-live__subtitle">Your spot has been reserved.</p>

          <div class="wf3-live__details" id="wf3-live-details">
            <!-- Populated by JS after successful registration -->
          </div>

          <a href="/webinar-v3/call" class="wf3-live__btn wf3-live__btn--cta">Book a Call</a>
          <a href="/" class="wf3-live__home-link">Back to Robert Ventures</a>
        </div>
      </section>
    </div>
  </body>
</html>

<style>
  /* ── Body ── */
  body {
    background-color: #ffffff;
    margin: 0;
  }

  /* ── Floating logo ── */
  .wf3-nav-logo {
    position: fixed;
    top: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .wf3-nav-logo:hover {
    opacity: 1;
  }

  .wf3-nav-logo :global(svg) {
    height: 40px;
    width: auto;
  }

  @media only screen and (min-width: 600px) {
    .wf3-nav-logo {
      top: 1.5rem;
    }

    .wf3-nav-logo :global(svg) {
      height: 48px;
    }
  }

  /* ── Section ── */
  .wf3-live {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100svh;
    padding: 5rem 1.5rem 3rem;
    box-sizing: border-box;
  }

  .wf3-live--confirmation {
    background: linear-gradient(to bottom, #ffffff, #f4f6f5);
  }

  .wf3-live__container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 480px;
    width: 100%;
  }

  /* ── Heading ── */
  .wf3-live__heading {
    font-family: "Roboto Serif", serif;
    font-weight: 500;
    font-size: 2rem;
    line-height: 125%;
    color: #1a1a1a;
    margin: 0;
    text-align: center;
  }

  @media only screen and (min-width: 600px) {
    .wf3-live__heading {
      font-size: 2.5rem;
    }
  }

  /* ── Subtitle ── */
  .wf3-live__subtitle {
    font-family: "Roboto", sans-serif;
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 160%;
    color: #555555;
    margin: 0;
    text-align: center;
  }

  /* ── Icon (confirmation) ── */
  .wf3-live__icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Session details (confirmation) ── */
  .wf3-live__details {
    width: 100%;
    background: #ffffff;
    border: 1.5px solid #e5e5e5;
    border-radius: 0.75rem;
    padding: 1.25rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* ── CTA button ── */
  .wf3-live__btn {
    width: 100%;
    padding: 0.875rem 1.5rem;
    border: none;
    border-radius: 0.75rem;
    background-color: #67b78f;
    color: #ffffff;
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      background-color 0.2s ease,
      opacity 0.2s ease;
  }

  .wf3-live__btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media (hover: hover) {
    .wf3-live__btn:not(:disabled):hover {
      background-color: #4e9a74;
    }
  }

  .wf3-live__btn--cta {
    border: 1.5px solid #67b78f;
  }

  /* ── Home link ── */
  .wf3-live__home-link {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: #555555;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  @media (hover: hover) {
    .wf3-live__home-link:hover {
      color: var(--green-brand);
    }
  }
</style>

<style is:global>
  /* Session buttons — dynamically created, so must be global */
  .wf3-live__sessions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
  }

  .wf3-live__sessions:empty::after {
    content: "Loading sessions...";
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: #bbbbbb;
    text-align: center;
    padding: 1rem;
  }

  .wf3-live__session-btn {
    width: 100%;
    padding: 1rem;
    border: 1.5px solid #e5e5e5;
    border-radius: 0.75rem;
    background: #ffffff;
    cursor: pointer;
    text-align: center;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    font-family: "Roboto", sans-serif;
  }

  @media (hover: hover) {
    .wf3-live__session-btn:hover {
      border-color: #67b78f;
      background: rgba(235, 245, 239, 0.3);
    }
  }

  .wf3-live__session-btn.is-selected {
    border-color: #67b78f;
    background: #ebf5ef;
  }

  .wf3-live__session-label {
    font-size: 1rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 130%;
    display: block;
    text-align: center;
  }

  .wf3-live__session-meta {
    font-size: 0.8125rem;
    color: #555555;
    line-height: 130%;
    display: block;
    text-align: center;
  }
</style>

<script is:inline>
  (function () {
    // ── Guard: check for lead data ──
    var leadRaw;
    try {
      leadRaw = sessionStorage.getItem("wf3_lead");
      if (!leadRaw) {
        window.location.replace("/webinar-v3");
        return;
      }
    } catch (e) {
      window.location.replace("/webinar-v3");
      return;
    }

    // ── Cookie / attribution helpers ──
    function getCookie(name) {
      try {
        var value = "; " + document.cookie;
        var parts = value.split("; " + name + "=");
        if (parts.length === 2) {
          var raw = parts.pop().split(";").shift();
          try { return decodeURIComponent(raw); } catch (e) { return raw; }
        }
      } catch (e) {}
      return undefined;
    }

    function getRtkClickId() {
      if (typeof window.rtkClickID !== "undefined" && window.rtkClickID) return window.rtkClickID;
      var cookieName = "rtkclickid-store";
      var cookies = document.cookie.split(";");
      for (var i = 0; i < cookies.length; i++) {
        var cookie = cookies[i].trim();
        if (cookie.startsWith(cookieName + "=")) return cookie.substring(cookieName.length + 1);
      }
      var stored = getCookie("rtk_click_id");
      if (stored) return stored;
      return null;
    }

    function getFbp() { return getCookie("_fbp"); }

    function getFbc() {
      var fbcCookie = getCookie("_fbc");
      if (fbcCookie) return fbcCookie;
      try {
        var url = new URL(window.location.href);
        var fbclid = url.searchParams.get("fbclid");
        if (fbclid) {
          var ts = Math.floor(Date.now() / 1000);
          return "fb.1." + ts + "." + fbclid;
        }
      } catch (e) {}
      return undefined;
    }

    function generateEventId() {
      try {
        var buf = new Uint32Array(2);
        crypto.getRandomValues(buf);
        return "rv_reg_" + Date.now().toString(36) + "_" + buf[0].toString(36) + buf[1].toString(36);
      } catch (e) {
        return "rv_reg_" + Date.now() + "_" + Math.random().toString(36).slice(2, 10);
      }
    }

    function detectDeviceFromUA(ua) {
      var isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(ua);
      if (!isMobile) return "desktop";
      if (/iPhone|iPad|iPod/i.test(ua)) return "ios";
      return "android";
    }

    function getFullDateString(isoDateUTC, sessionTimeZone) {
      var date = new Date(isoDateUTC);
      return date.toLocaleString("en-US", {
        weekday: "long",
        month: "long",
        day: "numeric",
        hour: "numeric",
        minute: "2-digit",
        hour12: true,
        timeZone: sessionTimeZone,
        timeZoneName: "short",
      });
    }

    function getLocalDateTimeString(isoDateUTC, userTimeZone) {
      var date = new Date(isoDateUTC);
      var datePart = date.toLocaleDateString("en-US", {
        weekday: "long",
        month: "long",
        day: "numeric",
        timeZone: userTimeZone,
      });
      var timePart = date.toLocaleTimeString("en-US", {
        hour: "numeric",
        minute: "2-digit",
        hour12: true,
        timeZone: userTimeZone,
      });
      return datePart + " at " + timePart;
    }

    function buildGoogleCalendarUrl(isoDateUTC) {
      var startDate = new Date(isoDateUTC);
      var endDate = new Date(startDate.getTime() + 30 * 60 * 1000);
      function fmt(d) {
        var y = d.getUTCFullYear();
        var m = String(d.getUTCMonth() + 1).padStart(2, "0");
        var dy = String(d.getUTCDate()).padStart(2, "0");
        var h = String(d.getUTCHours()).padStart(2, "0");
        var mi = String(d.getUTCMinutes()).padStart(2, "0");
        var s = String(d.getUTCSeconds()).padStart(2, "0");
        return y + m + dy + "T" + h + mi + s + "Z";
      }
      return (
        "https://calendar.google.com/calendar/render?action=TEMPLATE&text=Robert+Ventures+Live+Q%26A+with+Joe&dates=" +
        fmt(startDate) +
        "/" +
        fmt(endDate) +
        "&details=Join+Joe+live+at+robertventures.com/webinar-v3/live"
      );
    }

    function getESTTimestamp(userTimezone) {
      userTimezone = userTimezone || "America/New_York";
      var now = new Date();
      var userLocalTime = new Date(now.toLocaleString("en-US", { timeZone: userTimezone }));
      var utcTime = new Date(now.toLocaleString("en-US", { timeZone: "UTC" }));
      var offsetMinutes = userLocalTime.getTime() - utcTime.getTime();
      var offsetHours = Math.floor(Math.abs(offsetMinutes) / (1000 * 60 * 60));
      var offsetSign = offsetMinutes >= 0 ? "+" : "-";
      var year = userLocalTime.getFullYear();
      var month = String(userLocalTime.getMonth() + 1).padStart(2, "0");
      var day = String(userLocalTime.getDate()).padStart(2, "0");
      var hours = String(userLocalTime.getHours()).padStart(2, "0");
      var mins = String(userLocalTime.getMinutes()).padStart(2, "0");
      var secs = String(userLocalTime.getSeconds()).padStart(2, "0");
      return (
        year + "-" + month + "-" + day + "T" +
        hours + ":" + mins + ":" + secs +
        offsetSign + "0" + offsetHours + ":00"
      );
    }

    // ── Session date calculation ──
    function calculateNextSessionDate(details) {
      var weekdays = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];
      var targetDay = weekdays.indexOf(details.day);
      var timeParts = details.time.split(":").map(Number);
      var hour24 = timeParts[0];
      var minutes = timeParts[1];
      if (details.period.toUpperCase() === "PM" && hour24 < 12) hour24 += 12;
      if (details.period.toUpperCase() === "AM" && hour24 === 12) hour24 = 0;

      var now = new Date();
      var currentTzTime = new Date(
        now.toLocaleString("en-US", { timeZone: details.timeZone || "America/New_York" })
      );
      var currentDay = currentTzTime.getDay();
      var daysToAdd = (targetDay - currentDay + 7) % 7;

      if (daysToAdd === 0) {
        var currentHour = currentTzTime.getHours();
        var currentMinute = currentTzTime.getMinutes();
        if (currentHour > hour24 || (currentHour === hour24 && currentMinute >= minutes)) {
          daysToAdd = 7;
        }
      }

      var sessionDate = new Date(currentTzTime);
      sessionDate.setDate(sessionDate.getDate() + daysToAdd);
      sessionDate.setHours(hour24, minutes, 0, 0);

      var tempDate = new Date(sessionDate.toISOString().slice(0, -1));
      var tzOffset =
        new Date(
          tempDate.toLocaleString("en-US", { timeZone: details.timeZone || "America/New_York" })
        ).getTime() - tempDate.getTime();
      return new Date(sessionDate.getTime() - tzOffset);
    }

    function formatTimeLeft(targetDate) {
      var now = new Date();
      var diff = targetDate.getTime() - now.getTime();
      if (diff <= 0) return "(Started)";

      var days = Math.floor(diff / (1000 * 60 * 60 * 24));
      diff -= days * (1000 * 60 * 60 * 24);
      var hours = Math.floor(diff / (1000 * 60 * 60));
      diff -= hours * (1000 * 60 * 60);
      var mins = Math.floor(diff / (1000 * 60));

      var result = [];
      if (days > 0) result.push(days + (days === 1 ? " day" : " days"));
      if (hours > 0) result.push(hours + (hours === 1 ? " hour" : " hours"));
      if (mins > 0 && days === 0) result.push(mins + (mins === 1 ? " minute" : " minutes"));

      return result.length ? "In " + result.join(" ") : "Soon";
    }

    // ── Load webinar data ──
    var webinarData = null;

    function loadWebinarData() {
      // Try SSR-embedded data first
      var ssrEl = document.getElementById("ssr-webinar-data");
      if (ssrEl) {
        try {
          var ssrData = JSON.parse(ssrEl.textContent || "");
          if (ssrData && ssrData.results) {
            webinarData = ssrData;
            populateSessionButtons(ssrData);
            return;
          }
        } catch (e) {
          // Fall through
        }
      }

      // Try sessionStorage (from webinar-v3 parent page)
      try {
        var storedData = sessionStorage.getItem("wf3_webinar_data");
        if (storedData) {
          var parsed = JSON.parse(storedData);
          if (parsed && parsed.results) {
            webinarData = parsed;
            populateSessionButtons(parsed);
            return;
          }
        }
      } catch (e) {
        // Fall through
      }

      // Fallback: client-side fetch
      fetch("/api/webinar-data", { cache: "no-store" })
        .then(function (res) {
          if (!res.ok) throw new Error("Failed to fetch");
          return res.json();
        })
        .then(function (data) {
          webinarData = data;
          populateSessionButtons(data);
        })
        .catch(function (err) {
          console.error("Failed to load webinar data:", err);
        });
    }

    // ── Populate session buttons (live only, no on-demand) ──
    function populateSessionButtons(data) {
      var container = document.getElementById("wf3-live-sessions");
      var hiddenInput = document.getElementById("wf3-live-session-value");
      var submitBtn = document.getElementById("wf3-live-submit");
      if (!container || !hiddenInput) return;

      var userTz = Intl.DateTimeFormat().resolvedOptions().timeZone;
      container.innerHTML = "";

      function selectSession(btn) {
        // Deselect all
        container.querySelectorAll(".wf3-live__session-btn").forEach(function (b) {
          b.classList.remove("is-selected");
        });
        // Select this one
        btn.classList.add("is-selected");
        // Store full data in hidden input
        hiddenInput.value = btn.getAttribute("data-value");
        hiddenInput.setAttribute("data-date", btn.getAttribute("data-date"));
        hiddenInput.setAttribute("data-timezone", btn.getAttribute("data-timezone"));
        hiddenInput.setAttribute("data-original-timezone", btn.getAttribute("data-original-timezone"));
        hiddenInput.setAttribute("data-webinar-id", btn.getAttribute("data-webinar-id"));
        // Enable submit
        if (submitBtn) submitBtn.disabled = false;
      }

      // Only show live scheduled sessions (no on-demand)
      var sessions = data.results.filter(function (item) {
        try {
          var parsed = JSON.parse(item.id);
          return parsed && parsed.type === "ongoing";
        } catch (e) {
          return false;
        }
      });

      var sessionsWithDates = sessions
        .map(function (session) {
          try {
            var details = JSON.parse(session.id);
            var nextDate = session.date
              ? new Date(session.date)
              : calculateNextSessionDate(details);
            return { session: session, nextDate: nextDate };
          } catch (e) {
            return null;
          }
        })
        .filter(Boolean)
        .sort(function (a, b) {
          return a.nextDate.getTime() - b.nextDate.getTime();
        });

      sessionsWithDates.slice(0, 2).forEach(function (item) {
        var session = item.session;
        var nextDate = item.nextDate;
        var details = JSON.parse(session.id);

        var weekday = nextDate.toLocaleString("en-US", { weekday: "short" });
        var month = nextDate.getMonth() + 1;
        var day = nextDate.getDate();
        var time = nextDate.toLocaleString("en-US", {
          hour: "numeric",
          minute: "2-digit",
          hour12: true,
        });
        var tzMatch = nextDate
          .toLocaleTimeString("en-US", { timeZoneName: "short" })
          .match(/GMT[+-]\d+/);
        var tzShort = tzMatch
          ? tzMatch[0]
          : nextDate.toLocaleString("en-US", { timeZoneName: "short" }).split(" ").pop();
        var timeLeftString = formatTimeLeft(nextDate);

        var btn = document.createElement("button");
        btn.type = "button";
        btn.className = "wf3-live__session-btn";
        btn.setAttribute("data-value", session.id);
        btn.setAttribute("data-date", nextDate.toISOString());
        btn.setAttribute("data-timezone", userTz);
        btn.setAttribute("data-original-timezone", details.timeZone);
        btn.setAttribute("data-webinar-id", (data.webinarIds && data.webinarIds.scheduled) || "");
        btn.innerHTML =
          '<span class="wf3-live__session-label">Live: ' + weekday + ", " + month + "/" + day + ", " + time + " " + tzShort + "</span>" +
          '<span class="wf3-live__session-meta">' + timeLeftString + "</span>";
        btn.addEventListener("click", function () { selectSession(btn); });
        container.appendChild(btn);
      });
    }

    // ── Submit handler ──
    function handleSubmit() {
      var submitBtn = document.getElementById("wf3-live-submit");
      var hiddenInput = document.getElementById("wf3-live-session-value");
      var errorEl = document.getElementById("wf3-live-error");

      if (!hiddenInput || !hiddenInput.value) {
        if (errorEl) { errorEl.textContent = "Please select a session."; errorEl.style.display = "block"; }
        return;
      }

      // Hide error
      if (errorEl) { errorEl.textContent = ""; errorEl.style.display = "none"; }

      // Loading state
      var originalText = submitBtn ? submitBtn.textContent : "";
      if (submitBtn) { submitBtn.textContent = "Reserving..."; submitBtn.disabled = true; }

      // Read lead data from sessionStorage
      var lead;
      try {
        lead = JSON.parse(sessionStorage.getItem("wf3_lead") || "{}");
      } catch (e) {
        lead = {};
      }

      // Parse session data
      var sessionValue = hiddenInput.value;
      var isoDateUTC = hiddenInput.getAttribute("data-date") || "";
      var userTz = hiddenInput.getAttribute("data-timezone") || Intl.DateTimeFormat().resolvedOptions().timeZone;
      var originalTz = hiddenInput.getAttribute("data-original-timezone") || "America/New_York";
      var webinarId = hiddenInput.getAttribute("data-webinar-id") || "";

      var sessionDetails;
      try {
        sessionDetails = JSON.parse(sessionValue);
      } catch (err) {
        if (errorEl) { errorEl.textContent = "Invalid session format."; errorEl.style.display = "block"; }
        if (submitBtn) { submitBtn.textContent = originalText; submitBtn.disabled = false; }
        return;
      }

      // UTM params
      var baseUtmParams = ["utm_source", "utm_medium", "utm_campaign", "utm_content", "utm_term", "utm_id", "utm_adgroup"];
      var urlParams = new URLSearchParams(window.location.search);
      var utmParamSet = new Set(baseUtmParams);
      urlParams.forEach(function (_v, key) {
        if (key.startsWith("utm_")) utmParamSet.add(key);
      });
      var utmData = {};
      utmParamSet.forEach(function (param) {
        var val = urlParams.get(param) || getCookie(param);
        if (val) utmData[param] = val;
      });

      // Attribution fields
      var fbAttribution = {
        fb_ad_id: getCookie("fb_ad_id"),
        fb_adset_id: getCookie("fb_adset_id"),
        fb_placement: getCookie("fb_placement"),
        fb_site_source: getCookie("fb_site_source"),
      };
      var googleAttribution = {
        google_matchtype: getCookie("google_matchtype"),
        google_adgroup_id: getCookie("google_adgroup_id"),
        google_creative_id: getCookie("google_creative_id"),
        google_campaign_id: getCookie("google_campaign_id"),
        google_device: getCookie("google_device"),
        google_ad_position: getCookie("google_ad_position"),
        google_network: getCookie("google_network"),
        google_placement: getCookie("google_placement"),
        wbraid: getCookie("wbraid"),
        gbraid: getCookie("gbraid"),
      };

      var gclid = urlParams.get("gclid") || getCookie("gclid");
      var deviceType;
      try { deviceType = localStorage.getItem("device_type"); } catch (e) {}
      if (!deviceType) deviceType = detectDeviceFromUA(navigator.userAgent);
      var utmCampaignTop = utmData.utm_campaign || getCookie("utm_campaign");
      var webinarCalendarUrl = buildGoogleCalendarUrl(isoDateUTC);
      var rtkClickId = getRtkClickId();

      var payload = {
        session: sessionDetails.id,
        name: lead.name || "",
        email: lead.email || "",
        phone_number: lead.phone || "",
        company: "",
        date: isoDateUTC,
        fullDate: getFullDateString(isoDateUTC, originalTz),
        utm: utmData,
        gclid: gclid || undefined,
        utm_campaign: utmCampaignTop || undefined,
        webinar_sign_up_date: getESTTimestamp(userTz),
        user_timezone: userTz,
        webinar_datetime_user_tz: getLocalDateTimeString(isoDateUTC, userTz),
        device_type: deviceType || undefined,
        webinar_test: "webinar-ux_funnel-v3",
        webinar_calendar_url: webinarCalendarUrl,
        event_id: generateEventId(),
        fbp: getFbp(),
        fbc: getFbc(),
        is_instant: false,
        webinar_id: webinarId,
        rtk_click_id: rtkClickId || undefined,
        cmpid: getCookie("cmpid"),
        fb_ad_id: fbAttribution.fb_ad_id,
        fb_adset_id: fbAttribution.fb_adset_id,
        fb_placement: fbAttribution.fb_placement,
        fb_site_source: fbAttribution.fb_site_source,
        google_matchtype: googleAttribution.google_matchtype,
        google_adgroup_id: googleAttribution.google_adgroup_id,
        google_creative_id: googleAttribution.google_creative_id,
        google_campaign_id: googleAttribution.google_campaign_id,
        google_device: googleAttribution.google_device,
        google_ad_position: googleAttribution.google_ad_position,
        google_network: googleAttribution.google_network,
        google_placement: googleAttribution.google_placement,
        wbraid: googleAttribution.wbraid,
        gbraid: googleAttribution.gbraid,
      };

      // TEST MODE: Log payload but do NOT send to WebinarKit/GHL
      // Remove this block and uncomment the real fetch when going live
      console.log("🧪 TEST MODE — registration payload (not sent to API):", payload);
      setTimeout(function () {
        showConfirmation(payload);
      }, 500);
    }

    // ── Show confirmation ──
    function showConfirmation(payload) {
      var formArea = document.getElementById("wf3-live-form");
      var confirmationArea = document.getElementById("wf3-live-confirmation");
      var detailsEl = document.getElementById("wf3-live-details");

      if (formArea) formArea.style.display = "none";
      if (confirmationArea) confirmationArea.style.display = "block";

      if (detailsEl) {
        detailsEl.innerHTML =
          '<span style="font-family:Roboto,sans-serif;font-size:0.875rem;color:#555555;">Live Session</span>' +
          '<span style="font-family:Roboto,sans-serif;font-size:1.125rem;font-weight:500;color:#1a1a1a;">' +
          payload.fullDate +
          "</span>";
      }
    }

    // ── Boot ──
    function boot() {
      loadWebinarData();

      var submitBtn = document.getElementById("wf3-live-submit");
      if (submitBtn) {
        submitBtn.addEventListener("click", handleSubmit);
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", boot);
    } else {
      boot();
    }
  })();
</script>
