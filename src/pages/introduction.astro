---
import BaseHead from "../components/BaseHead.astro";
import RvLogo from "../images/brand/logo-horizontal-whitebg.svg";
import IntroCompoundingGrowth from "../sections/introduction/IntroCompoundingGrowth.astro";
import IntroValueProposition from "../sections/introduction/IntroValueProposition.astro";
import IntroFounderVideo from "../sections/introduction/IntroFounderVideo.astro";
import IntroRealEstateAssets from "../sections/introduction/IntroRealEstateAssets.astro";
import IntroBondOfferings from "../sections/introduction/IntroBondOfferings.astro";
import IntroFixedYield from "../sections/introduction/IntroFixedYield.astro";
import IntroDigitalStrategy from "../sections/introduction/IntroDigitalStrategy.astro";
import IntroCallToAction from "../sections/introduction/IntroCallToAction.astro";

const pageTitle = "Introduction | Robert Ventures";
const pageDescription =
  "Fixed 8-10% returns through real estate and digital assets. An alternative to today's CDs.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <meta name="robots" content="noindex" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/css/splide-core.min.css"
    />
    <link
      rel="modulepreload"
      href="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
    />
    <link rel="preconnect" href="https://stream.mux.com" crossorigin />
    <link rel="preconnect" href="https://image.mux.com" crossorigin />
    <script
      type="module"
      src="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
      is:inline></script>
  </head>
  <body>
    <!-- Floating logo — always visible, links home -->
    <a href="/" class="intro-nav-logo" aria-label="Back to Robert Ventures home">
      <RvLogo />
    </a>

    <!-- Slide position indicator — dots + lines on left edge -->
    <nav class="slide-indicator" aria-label="Slide navigation">
      <button class="slide-indicator__dot is-active" data-slide="0" aria-label="Go to slide 1"
      ></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-slide="1" aria-label="Go to slide 2"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-slide="2" aria-label="Go to slide 3"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-slide="3" aria-label="Go to slide 4"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-slide="4" aria-label="Go to slide 5"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-slide="5" aria-label="Go to slide 6"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-slide="6" aria-label="Go to slide 7"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-slide="7" aria-label="Go to slide 8"></button>
    </nav>

    <!-- Swipe hint — bouncing chevron at bottom center -->
    <div class="swipe-hint" aria-hidden="true">
      <span class="swipe-hint__chevron"></span>
      <span class="swipe-hint__chevron"></span>
    </div>

    <div class="swiper intro-swiper">
      <div class="swiper-wrapper">
        <div class="swiper-slide">
          <IntroValueProposition />
        </div>
        <div class="swiper-slide">
          <IntroRealEstateAssets />
        </div>
        <div class="swiper-slide">
          <IntroDigitalStrategy />
        </div>
        <div class="swiper-slide">
          <IntroFixedYield />
        </div>
        <div class="swiper-slide">
          <IntroBondOfferings />
        </div>
        <div class="swiper-slide">
          <IntroCompoundingGrowth />
        </div>
        <div class="swiper-slide">
          <IntroFounderVideo />
        </div>
        <div class="swiper-slide">
          <IntroCallToAction />
        </div>
      </div>
    </div>

    <script is:inline src="https://link.msgsndr.com/js/form_embed.js" type="text/javascript"></script>
  </body>
</html>

<style is:global>
  body {
    background-color: #ffffff;
    margin: 0 !important;
    padding: 0 !important;
    /* Safari needs scrollable content to auto-hide the bottom toolbar.
       1px of extra height gives it something to "scroll". */
    min-height: calc(100vh + 1px);
    overscroll-behavior: none;
  }

  .intro-swiper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100svh;
    touch-action: pan-x pinch-zoom;
  }

  .intro-swiper .swiper-slide {
    height: 100svh;
  }

  section.intro-slide {
    height: 100%;
    margin: 0 !important;
    border: none !important;
    padding-left: 2rem !important;
  }

  /* Override the site-wide `p { text-wrap: pretty }` from global.css.
     Safari's `pretty` wraps noticeably narrower than Chrome, which breaks
     these short subtitles into unnecessary extra lines. */
  .intro-slide__subtitle,
  .intro-slide__source,
  .intro-slide__body,
  .intro-slide__transition {
    text-wrap: wrap;
  }

  @media only screen and (min-width: 600px) {
    section.intro-slide {
      padding-left: 2.5rem !important;
    }
  }

  /* Hide chrome while the inline booking calendar is active. The fixed logo
     would otherwise scroll over the heading once the slide becomes scrollable
     in booking mode. */
  body.booking-active .slide-indicator,
  body.booking-active .swipe-hint,
  body.booking-active .intro-nav-logo {
    display: none;
  }
</style>

<style>
  .intro-nav-logo {
    position: fixed;
    top: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .intro-nav-logo:hover {
    opacity: 1;
  }

  .intro-nav-logo :global(svg) {
    height: 40px;
    width: auto;
  }

  @media only screen and (min-width: 600px) {
    .intro-nav-logo {
      top: 1.5rem;
    }

    .intro-nav-logo :global(svg) {
      height: 48px;
    }
  }
</style>

<style>
  /* ── Slide position indicator ── */
  .slide-indicator {
    position: fixed;
    left: 0.25rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  /* Dot — default is hollow with dark green border */
  .slide-indicator__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid #1a1a1a;
    padding: 0;
    background: transparent;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .slide-indicator__dot:hover {
    background: rgba(26, 26, 26, 0.3);
  }

  /* Line between dots — default is dark green at low opacity */
  .slide-indicator__line {
    width: 1.5px;
    height: 24px;
    background: rgba(26, 26, 26, 0.25);
    flex-shrink: 0;
    transition: background 0.3s ease;
  }

  /* Passed state — completed dots and lines become solid dark green */
  .slide-indicator__dot.is-passed {
    background: #1a1a1a;
    border-color: #1a1a1a;
  }

  .slide-indicator__line.is-passed {
    background: #1a1a1a;
  }

  /* Active dot — solid dark green with pulse */
  .slide-indicator__dot.is-active {
    background: #1a1a1a;
    border-color: #1a1a1a;
    animation: dot-pulse 2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(26, 26, 26, 0.6);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(26, 26, 26, 0);
    }
  }

  @media only screen and (max-width: 479px) {
    .slide-indicator {
      left: 0.2rem;
    }

    .slide-indicator__dot {
      width: 8px;
      height: 8px;
    }

    .slide-indicator__line {
      height: 16px;
    }
  }

  @media only screen and (min-width: 600px) {
    .slide-indicator {
      left: 0.3rem;
    }

    .slide-indicator__dot {
      width: 12px;
      height: 12px;
    }

    .slide-indicator__line {
      height: 28px;
    }
  }
</style>

<style>
  /* ── Swipe hint chevron ── */
  .swipe-hint {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    animation: swipe-bounce 1.5s ease-in-out infinite;
    transition: opacity 0.4s ease;
  }

  .swipe-hint.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .swipe-hint__chevron {
    display: block;
    width: 14px;
    height: 14px;
    border-right: 2.5px solid #555555;
    border-bottom: 2.5px solid #555555;
    transform: rotate(45deg);
    margin-top: -6px;
  }

  .swipe-hint__chevron:first-child {
    margin-top: 0;
    opacity: 0.4;
  }

  @keyframes swipe-bounce {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(8px);
    }
  }

  @media only screen and (min-width: 600px) {
    .swipe-hint__chevron {
      width: 16px;
      height: 16px;
      border-right-width: 3px;
      border-bottom-width: 3px;
      margin-top: -7px;
    }

    .swipe-hint__chevron:first-child {
      margin-top: 0;
    }
  }
</style>

<script is:inline>
  (function () {
    // Scroll 1px to trigger Safari's bottom toolbar to minimize
    setTimeout(function () {
      window.scrollTo(0, 1);
    }, 0);

    const animatedSlides = {};

    // ── Slide indicator logic ──
    const totalSlides = document.querySelectorAll(".slide-indicator__dot").length;

    function updateIndicator(activeIndex) {
      const dots = document.querySelectorAll(".slide-indicator__dot");
      const lines = document.querySelectorAll(".slide-indicator__line");

      dots.forEach(function (dot, i) {
        dot.classList.remove("is-active", "is-passed");
        if (i < activeIndex) dot.classList.add("is-passed");
        if (i === activeIndex) dot.classList.add("is-active");
      });

      lines.forEach(function (line, i) {
        line.classList.remove("is-passed");
        if (i < activeIndex) line.classList.add("is-passed");
      });

      // Hide swipe hint on last slide
      const hint = document.querySelector(".swipe-hint");
      if (hint) {
        if (activeIndex >= totalSlides - 1) {
          hint.classList.add("is-hidden");
        } else {
          hint.classList.remove("is-hidden");
        }
      }
    }

    function runSlideAnimation(index, swiperEl) {
      if (animatedSlides[index]) return;
      if (!window.gsapLoaded || typeof window.gsap === "undefined") return;

      const gsap = window.gsap;
      const slideEl = swiperEl.slides[index];
      if (!slideEl) return;

      animatedSlides[index] = true;

      const content = slideEl.querySelector(".intro-slide__content");

      if (content) {
        gsap.fromTo(
          content,
          { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.8, ease: "power2.out", delay: 0.2 }
        );
      }
    }

    function initSwiper() {
      const swiperInstance = new Swiper(".intro-swiper", {
        direction: "vertical",
        speed: 600,
        touchEventsTarget: "container",
        mousewheel: {
          sensitivity: 1,
          thresholdDelta: 30,
        },
        keyboard: {
          enabled: true,
        },
        on: {
          init: function () {
            // Animate first slide on load
            updateIndicator(0);
            if (window.gsapLoaded && typeof window.gsap !== "undefined") {
              runSlideAnimation(0, this);
            } else {
              window.addEventListener("gsapLoaded", () => {
                runSlideAnimation(0, this);
              });
            }
          },
          slideChange: function () {
            // Pause the founder video if the user has left its slide
            const videoPlayer = document.getElementById("intro-mux-player");
            if (videoPlayer && typeof videoPlayer.pause === "function" && !videoPlayer.paused) {
              const activeSlide = this.slides[this.activeIndex];
              if (!activeSlide || !activeSlide.contains(videoPlayer)) {
                videoPlayer.pause();
              }
            }
            updateIndicator(this.activeIndex);
            if (window.gsapLoaded && typeof window.gsap !== "undefined") {
              runSlideAnimation(this.activeIndex, this);
            } else {
              window.addEventListener("gsapLoaded", () => {
                runSlideAnimation(this.activeIndex, this);
              });
            }
          },
        },
      });

      // Click chevron hint → go to next slide
      var hint = document.querySelector(".swipe-hint");
      if (hint) {
        hint.style.cursor = "pointer";
        hint.addEventListener("click", function () {
          swiperInstance.slideNext();
        });
      }

      // Click a dot → navigate to that slide
      document.querySelectorAll(".slide-indicator__dot").forEach(function (dot) {
        dot.addEventListener("click", function () {
          const slideIndex = parseInt(dot.getAttribute("data-slide"), 10);
          swiperInstance.slideTo(slideIndex);
        });
      });

      // When the CTA slide opens its inline calendar, lock the swiper so gestures
      // don't fight with the calendar's internal scrolling.
      document.addEventListener("booking-mode-change", function (e) {
        const active = !!(e.detail && e.detail.active);
        if (active) {
          document.body.classList.add("booking-active");
          swiperInstance.disable();
        } else {
          document.body.classList.remove("booking-active");
          swiperInstance.enable();
        }
      });
    }

    // Load Swiper JS from CDN
    const script = document.createElement("script");
    script.src = "https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js";
    script.onload = function () {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initSwiper);
      } else {
        initSwiper();
      }
    };
    document.head.appendChild(script);

    // Hide the Joe Robert caption once the user plays the video
    function setupFounderCaption() {
      const player = document.getElementById("intro-mux-player");
      const caption = document.querySelector(".intro-slide__photo-caption");
      if (!player || !caption) return;
      player.addEventListener("play", function () {
        caption.classList.add("is-hidden");
      });
    }
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupFounderCaption);
    } else {
      setupFounderCaption();
    }

    // Load Splide JS from CDN
    const splideScript = document.createElement("script");
    splideScript.src = "https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/js/splide.min.js";
    splideScript.onload = function () {
      function initSplide() {
        new Splide("#re-slideshow", {
          type: "fade",
          rewind: true,
          autoplay: true,
          interval: 3000,
          speed: 1000,
          pauseOnHover: false,
          arrows: false,
          pagination: false,
        }).mount();
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initSplide);
      } else {
        initSplide();
      }
    };
    document.head.appendChild(splideScript);
  })();
</script>
