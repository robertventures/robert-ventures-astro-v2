---
import { ClientRouter } from "astro:transitions";
import BaseHead from "../components/BaseHead.astro";
import RvLogo from "../images/brand/logo-horizontal-whitebg.svg";
import IntroCompoundingGrowth from "../sections/introduction/IntroCompoundingGrowth.astro";
import IntroValueProposition from "../sections/introduction/IntroValueProposition.astro";
import IntroFounderVideo from "../sections/introduction/IntroFounderVideo.astro";
import IntroRealEstateAssets from "../sections/introduction/IntroRealEstateAssets.astro";
import IntroBondOfferings from "../sections/introduction/IntroBondOfferings.astro";
import IntroFixedYield from "../sections/introduction/IntroFixedYield.astro";
import IntroDigitalStrategy from "../sections/introduction/IntroDigitalStrategy.astro";
import IntroCallToAction from "../sections/introduction/IntroCallToAction.astro";

const pageTitle = "Introduction | Robert Ventures";
const pageDescription =
  "Fixed 8-10% returns through real estate and digital assets. An alternative to today's CDs.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <meta name="robots" content="noindex" />
    <ClientRouter />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/css/splide-core.min.css"
    />
    <link
      rel="modulepreload"
      href="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
    />
    <link rel="preconnect" href="https://stream.mux.com" crossorigin />
    <link rel="preconnect" href="https://image.mux.com" crossorigin />
    <script
      type="module"
      src="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
      is:inline></script>
  </head>
  <body>
    <!-- Floating logo, always visible, links home -->
    <div class="intro-nav-logo" role="img" aria-label="Robert Ventures">
      <RvLogo />
    </div>

    <!-- Section position indicator: dots + lines on left edge -->
    <nav class="slide-indicator" aria-label="Section navigation">
      <button class="slide-indicator__dot is-active" data-section="0" aria-label="Go to section 1"
      ></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-section="1" aria-label="Go to section 2"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-section="2" aria-label="Go to section 3"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-section="3" aria-label="Go to section 4"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-section="4" aria-label="Go to section 5"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-section="5" aria-label="Go to section 6"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-section="6" aria-label="Go to section 7"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-section="7" aria-label="Go to section 8"></button>
    </nav>

    <main class="intro-scroll">
      <IntroValueProposition />
      <IntroRealEstateAssets />
      <IntroDigitalStrategy />
      <IntroFixedYield />
      <IntroBondOfferings />
      <IntroCompoundingGrowth />
      <IntroFounderVideo />
      <IntroCallToAction />
    </main>

    <script is:inline src="https://link.msgsndr.com/js/form_embed.js" type="text/javascript"></script>
  </body>
</html>

<style is:global>
  body {
    background-color: #ffffff;
    margin: 0 !important;
    padding: 0 !important;
  }

  html {
    scroll-behavior: auto;
  }

  /* View-transition slide animation, matches /introduction/book-call so the
     handoff into the booking flow feels like progressing forward in the funnel. */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 320ms;
    animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
  ::view-transition-old(root) {
    animation-name: ga-old-fwd;
  }
  ::view-transition-new(root) {
    animation-name: ga-new-fwd;
  }
  html[data-astro-transition="back"]::view-transition-old(root) {
    animation-name: ga-old-back;
  }
  html[data-astro-transition="back"]::view-transition-new(root) {
    animation-name: ga-new-back;
  }

  @keyframes ga-new-fwd {
    from {
      transform: translateX(100%);
    }
  }
  @keyframes ga-old-fwd {
    to {
      transform: translateX(-20%);
      opacity: 0.6;
    }
  }
  @keyframes ga-new-back {
    from {
      transform: translateX(-20%);
      opacity: 0.6;
    }
  }
  @keyframes ga-old-back {
    to {
      transform: translateX(100%);
    }
  }

  html[data-astro-transition="traverse"]::view-transition-old(root),
  html[data-astro-transition="traverse"]::view-transition-new(root) {
    animation: none;
  }

  .intro-scroll {
    margin: 0;
    padding: 0;
  }

  /* Unified vertical rhythm for every intro slide. Section files own
     background and content layout. They no longer set padding/height/margin
     on .intro-slide itself, so this block wins by plain specificity, no
     !important needed. */
  section.intro-slide {
    /* Zero out the global `section { margin-bottom: 1.5rem }` from
       global.css so adjacent intro slides with the same background read
       as one continuous block (no white body gap bleeding through). */
    margin-bottom: 0;
    padding-top: 2rem;
    padding-bottom: 2rem;
    padding-left: 2rem;
    padding-right: 1.5rem;
  }

  /* Modifier: extra breathing room on specific slides. Bumps top + bottom
     padding by ~50% over the base values at every breakpoint. */
  section.intro-slide--spacious {
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  /* First section sits below the logo block, so just a small lift. */
  .intro-scroll > section.intro-slide:first-child {
    padding-top: 3rem;
  }

  /* Override the site-wide `p { text-wrap: pretty }` from global.css.
     Safari's `pretty` wraps noticeably narrower than Chrome, which breaks
     these short subtitles into unnecessary extra lines. */
  .intro-slide__subtitle,
  .intro-slide__source,
  .intro-slide__body,
  .intro-slide__transition {
    text-wrap: wrap;
  }

  @media only screen and (min-width: 600px) {
    section.intro-slide {
      padding-top: 3rem;
      padding-bottom: 3rem;
      padding-left: 2.5rem;
      padding-right: 2rem;
    }
    section.intro-slide--spacious {
      padding-top: 4.5rem;
      padding-bottom: 4.5rem;
    }
    .intro-scroll > section.intro-slide:first-child {
      padding-top: 4rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    section.intro-slide {
      padding-top: 4rem;
      padding-bottom: 4rem;
    }
    section.intro-slide--spacious {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }
    .intro-scroll > section.intro-slide:first-child {
      padding-top: 5rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    section.intro-slide {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }
    section.intro-slide--spacious {
      padding-top: 7.5rem;
      padding-bottom: 7.5rem;
    }
    .intro-scroll > section.intro-slide:first-child {
      padding-top: 6rem;
    }
  }

</style>

<style>
  .intro-nav-logo {
    display: flex;
    justify-content: center;
    padding: 1.25rem 1rem;
  }

  .intro-nav-logo :global(svg) {
    display: block;
    height: 40px;
    width: auto;
  }

  @media only screen and (min-width: 600px) {
    .intro-nav-logo {
      padding: 1.5rem 1rem;
    }

    .intro-nav-logo :global(svg) {
      height: 48px;
    }
  }
</style>

<style>
  /* Section position indicator (fixed to left edge) */
  .slide-indicator {
    position: fixed;
    left: 0.25rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .slide-indicator__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid #1a1a1a;
    padding: 0;
    background: transparent;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .slide-indicator__dot:hover {
    background: rgba(26, 26, 26, 0.3);
  }

  .slide-indicator__line {
    width: 1.5px;
    height: 24px;
    background: rgba(26, 26, 26, 0.25);
    flex-shrink: 0;
    transition: background 0.3s ease;
  }

  .slide-indicator__dot.is-passed {
    background: #1a1a1a;
    border-color: #1a1a1a;
  }

  .slide-indicator__line.is-passed {
    background: #1a1a1a;
  }

  .slide-indicator__dot.is-active {
    background: #1a1a1a;
    border-color: #1a1a1a;
    animation: dot-pulse 2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(26, 26, 26, 0.6);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(26, 26, 26, 0);
    }
  }

  @media only screen and (max-width: 479px) {
    .slide-indicator {
      left: 0.2rem;
    }

    .slide-indicator__dot {
      width: 8px;
      height: 8px;
    }

    .slide-indicator__line {
      height: 16px;
    }
  }

  @media only screen and (min-width: 600px) {
    .slide-indicator {
      left: 0.3rem;
    }

    .slide-indicator__dot {
      width: 12px;
      height: 12px;
    }

    .slide-indicator__line {
      height: 28px;
    }
  }
</style>

<script is:inline data-astro-rerun>
  (function () {
    const animatedSections = {};
    let sections = [];

    function updateIndicator(activeIndex) {
      const dots = document.querySelectorAll(".slide-indicator__dot");
      const lines = document.querySelectorAll(".slide-indicator__line");

      dots.forEach(function (dot, i) {
        dot.classList.remove("is-active", "is-passed");
        if (i < activeIndex) dot.classList.add("is-passed");
        if (i === activeIndex) dot.classList.add("is-active");
      });

      lines.forEach(function (line, i) {
        line.classList.remove("is-passed");
        if (i < activeIndex) line.classList.add("is-passed");
      });
    }

    function runSectionAnimation(index, sectionEl) {
      if (animatedSections[index]) return;
      if (!window.gsapLoaded || typeof window.gsap === "undefined") {
        window.addEventListener("gsapLoaded", function () {
          runSectionAnimation(index, sectionEl);
        });
        return;
      }

      animatedSections[index] = true;
      const gsap = window.gsap;
      const content = sectionEl.querySelector(".intro-slide__content");

      if (content) {
        gsap.fromTo(
          content,
          { opacity: 0, y: 40 },
          { opacity: 1, y: 0, duration: 0.8, ease: "power2.out", delay: 0.1 }
        );
      }
    }

    function initScroll() {
      sections = Array.from(document.querySelectorAll("section.intro-slide"));
      sections.forEach(function (section, i) {
        section.setAttribute("data-section-index", String(i));
      });

      // Dot nav: click any dot to smooth-scroll to its section
      document.querySelectorAll(".slide-indicator__dot").forEach(function (dot) {
        dot.addEventListener("click", function () {
          const targetIndex = parseInt(dot.getAttribute("data-section"), 10);
          const target = sections[targetIndex];
          if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });

      const indicatorIo = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              const idx = parseInt(entry.target.getAttribute("data-section-index"), 10);
              updateIndicator(idx);
            }
          });
        },
        { threshold: 0, rootMargin: "-50% 0px -50% 0px" }
      );

      const animIo = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              const idx = parseInt(entry.target.getAttribute("data-section-index"), 10);
              runSectionAnimation(idx, entry.target);
            }
          });
        },
        { threshold: 0, rootMargin: "0px 0px 5% 0px" }
      );

      sections.forEach(function (section) {
        indicatorIo.observe(section);
        animIo.observe(section);
      });

      if (sections[0]) runSectionAnimation(0, sections[0]);
    }

    // Founder video: muted autoplay when section approaches view, with a
    // one-shot overlay nudging the user to unmute. After engagement, Mux's
    // native UI handles pause/play/replay.
    function setupFounderVideo() {
      const player = document.getElementById("intro-mux-player");
      const caption = document.querySelector(".intro-slide__photo-caption");
      const overlay = document.getElementById("intro-mux-overlay");
      if (!player) return;

      let autoplayState = "pending"; // "pending" | "trying" | "playing" | "failed"
      let isAutoplayPlay = false;
      let engaged = false;

      function showOverlayUnmuteMode() {
        if (!overlay) return;
        overlay.classList.add("is-active");
        overlay.classList.remove("is-play-mode");
        overlay.setAttribute("aria-label", "Your video is playing. Click to unmute.");
      }

      function showOverlayPlayMode() {
        if (!overlay) return;
        overlay.classList.add("is-active", "is-play-mode");
        overlay.setAttribute("aria-label", "Click to play");
      }

      function dismissOverlay() {
        if (!overlay) return;
        overlay.classList.remove("is-active");
      }

      function attemptAutoplay() {
        if (autoplayState !== "pending") return;
        autoplayState = "trying";
        try {
          player.muted = true;
        } catch (e) {}
        isAutoplayPlay = true;
        const promise = player.play();
        if (promise && typeof promise.then === "function") {
          promise
            .then(function () {
              autoplayState = "playing";
              if (!engaged) showOverlayUnmuteMode();
            })
            .catch(function () {
              isAutoplayPlay = false;
              autoplayState = "failed";
              if (!engaged) showOverlayPlayMode();
            });
        } else {
          autoplayState = "playing";
          if (!engaged) showOverlayUnmuteMode();
        }
      }

      function engageFromOverlay(e) {
        if (!overlay || !overlay.classList.contains("is-active")) return;
        e.preventDefault();
        e.stopPropagation();
        const isPlayMode = overlay.classList.contains("is-play-mode");
        try {
          player.muted = false;
        } catch (err) {}
        if (isPlayMode) {
          const result = player.play();
          if (result && typeof result.catch === "function") result.catch(function () {});
        }
        dismissOverlay();
      }

      if (overlay) {
        overlay.addEventListener("click", engageFromOverlay);
        overlay.addEventListener("keydown", function (e) {
          if (e.key === "Enter" || e.key === " ") engageFromOverlay(e);
        });
      }

      player.addEventListener("play", function () {
        const wasAutoplay = isAutoplayPlay;
        isAutoplayPlay = false;
        if (caption) caption.classList.add("is-hidden");
        if (!wasAutoplay) {
          engaged = true;
          dismissOverlay();
        }
      });

      player.addEventListener("volumechange", function () {
        if (engaged) return;
        if (player.muted) return;
        engaged = true;
        dismissOverlay();
      });

      if ("IntersectionObserver" in window) {
        const videoIo = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                if (autoplayState === "pending") {
                  attemptAutoplay();
                } else if (autoplayState === "playing" && player.paused && !engaged) {
                  isAutoplayPlay = true;
                  const result = player.play();
                  if (result && typeof result.catch === "function") {
                    result.catch(function () {
                      isAutoplayPlay = false;
                    });
                  }
                }
              } else if (!player.paused) {
                player.pause();
              }
            });
          },
          { threshold: 0, rootMargin: "0px 0px 40% 0px" }
        );
        videoIo.observe(player);
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", function () {
        initScroll();
        setupFounderVideo();
      });
    } else {
      initScroll();
      setupFounderVideo();
    }

    // Load Splide JS from CDN (for the real-estate carousel inside IntroRealEstateAssets)
    const splideScript = document.createElement("script");
    splideScript.src = "https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/js/splide.min.js";
    splideScript.onload = function () {
      function initSplide() {
        new Splide("#re-slideshow", {
          type: "fade",
          rewind: true,
          autoplay: true,
          interval: 3000,
          speed: 1000,
          pauseOnHover: false,
          arrows: false,
          pagination: false,
        }).mount();
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initSplide);
      } else {
        initSplide();
      }
    };
    document.head.appendChild(splideScript);
  })();
</script>
