---
import { ClientRouter } from "astro:transitions";
import BaseHead from "../components/BaseHead.astro";
import DisclaimerBlock from "../components/DisclaimerBlock.astro";
import OfferHero from "../sections/offer-v3/OfferHero.astro";
import PhoneScroller from "../sections/offer-v3/PhoneScroller.astro";
import OuterBanksSlider from "../sections/offer-v3/OuterBanksSlider.astro";
import JoeVideo from "../sections/offer-v3/JoeVideo.astro";
import Proof from "../sections/offer-v3/Proof.astro";
import Documents from "../sections/offer-v3/Documents.astro";

const pageTitle = "Offer | Robert Ventures";
const pageDescription =
  "Fixed 8 to 10% returns, paid to you monthly, built on real estate and digital assets. See how it works.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} loadScrollTrigger loadSplitText />
    <meta name="robots" content="noindex, nofollow" />

    <!-- Mux Player (founder video) -->
    <link
      rel="modulepreload"
      href="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
    />
    <link rel="preconnect" href="https://stream.mux.com" crossorigin />
    <link rel="preconnect" href="https://image.mux.com" crossorigin />
    <script
      type="module"
      src="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
      is:inline></script>

    <ClientRouter />
  </head>
  <body>
    <!-- Each section is self-contained (owns its spacing, styles, and behavior),
         so this list can be reordered freely. -->
    <main class="offer-v3">
      <OfferHero />
      <PhoneScroller />
      <OuterBanksSlider />
      <JoeVideo />
      <Proof />
      <Documents />
    </main>

    <DisclaimerBlock trackLocation="offer_v3_disclaimer" />

    <!-- Page-level reveal engine. Sections opt in with `data-reveal-group` on a
         wrapper and `rv3-reveal` on each element to animate. A headline also
         tagged `data-reveal="lines"` gets a SplitText line-by-line mask reveal
         (falls back to a fade if SplitText is unavailable). No-JS / reduced
         motion shows everything immediately (nothing ever stays hidden). -->
    <script is:inline data-astro-rerun>
      (function () {
        const reduce =
          window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const body = document.body;

        if (reduce) {
          body.classList.add("rv3-reduced");
          return; // CSS keeps all reveal targets visible
        }

        // Signals JS is ready, which arms the pre-hidden CSS state.
        body.classList.add("rv3-ready");

        function lineReveal(el, i) {
          const run = function () {
            if (!window.gsap || !window.SplitText) {
              fadeReveal(el, i);
              return;
            }
            const split = new window.SplitText(el, {
              type: "lines",
              mask: "lines",
              linesClass: "rv3-line",
            });
            window.gsap.set(el, { opacity: 1 });
            el.style.transform = "none";
            window.gsap.from(split.lines, {
              yPercent: 104,
              duration: 1.05,
              ease: "power4.out",
              stagger: 0.065,
              delay: i * 0.05,
              force3D: true,
              onComplete: function () {
                window.gsap.set(split.lines, { clearProps: "willChange" });
              },
            });
          };
          if (document.fonts && document.fonts.ready) {
            document.fonts.ready.then(run);
          } else {
            run();
          }
        }

        function fadeReveal(el, i) {
          el.style.transitionDelay = i * 0.06 + "s";
          el.classList.add("rv3-in");
        }

        function revealEl(el, i) {
          if (el.dataset.rv3Done) return;
          el.dataset.rv3Done = "1";

          if (el.getAttribute("data-reveal") === "lines") {
            if (window.gsap && window.SplitText) {
              lineReveal(el, i);
            } else {
              // SplitText may still be loading; wait briefly, then fall back.
              let done = false;
              const fb = setTimeout(function () {
                if (done) return;
                done = true;
                fadeReveal(el, i);
              }, 700);
              window.addEventListener(
                "splitTextLoaded",
                function () {
                  if (done) return;
                  done = true;
                  clearTimeout(fb);
                  lineReveal(el, i);
                },
                { once: true }
              );
            }
            return;
          }

          fadeReveal(el, i);
        }

        function revealGroup(group) {
          const els = Array.prototype.slice.call(group.querySelectorAll(".rv3-reveal"));
          els.forEach(revealEl);
        }

        function boot() {
          const groups = Array.prototype.slice.call(
            document.querySelectorAll("[data-reveal-group]")
          );
          if (!("IntersectionObserver" in window)) {
            groups.forEach(revealGroup);
            return;
          }
          const io = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (e) {
                if (e.isIntersecting) {
                  revealGroup(e.target);
                  io.unobserve(e.target);
                }
              });
            },
            { threshold: 0.15, rootMargin: "0px 0px -8% 0px" }
          );
          groups.forEach(function (g) {
            io.observe(g);
          });
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", boot);
        } else {
          boot();
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  body {
    background-color: #ffffff;
    margin: 0 !important;
    padding: 0 !important;
  }

  .offer-v3 {
    margin: 0;
    padding: 0;
  }

  /* global.css sets `section { margin-bottom: 1.5rem }`. Our sections stack edge
     to edge and own their spacing, so neutralize it. */
  .offer-v3 > section {
    margin: 0;
  }

  /* Reveal engine. Pre-hidden state is armed only after JS adds `.rv3-ready`,
     so a no-JS / slow-JS visitor still sees everything. */
  body.rv3-ready .rv3-reveal {
    opacity: 0;
    transform: translate3d(0, 16px, 0);
    will-change: opacity, transform;
  }
  body.rv3-ready .rv3-reveal.rv3-in {
    opacity: 1;
    transform: translate3d(0, 0, 0);
    transition:
      opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* SplitText line-mask reveal */
  .rv3-line {
    display: block;
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .offer-v3 .rv3-reveal {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
