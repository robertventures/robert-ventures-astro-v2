---
import BaseHead from "../components/BaseHead.astro";
import DisclaimerBlock from "../components/DisclaimerBlock.astro";
import RvLogo from "../images/brand/logo-horizontal-whitebg.svg";
import WfLeadCapture from "../sections/webinar/WfLeadCapture.astro";
import WfHero from "../sections/webinar/WfHero.astro";
import WfAudience from "../sections/webinar/WfAudience.astro";
import ReviewsV3 from "../sections/ReviewsV3.astro";
// Joe founder-intro slide is hidden for now; kept on disk for easy restore.
// import WfFounderIntro from "../sections/webinar/WfFounderIntro.astro";
import { ClientRouter } from "astro:transitions";

const pageTitle = "Learn More | Robert Ventures";
const pageDescription =
  "See how CD savers are moving into a fixed 8-10% yield built on real estate and Bitcoin.";

export const prerender = false;

// SSR: Fetch webinar data server-side to eliminate client-side waterfall
let ssrWebinarData = null;
try {
  const scheduledWebinarId = "684ae034de7a164da41abe10";
  const apiKey = import.meta.env.WEBINARKIT_API_KEY;

  if (apiKey) {
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 5000);

    const response = await fetch(`https://webinarkit.com/api/webinar/dates/${scheduledWebinarId}`, {
      method: "GET",
      headers: { Authorization: `Bearer ${apiKey}` },
      redirect: "follow",
      signal: controller.signal,
    });
    clearTimeout(timeout);

    if (response.ok) {
      const data = await response.json();
      const filteredResults = data.results.filter(
        (item: any) => item.id !== "instant" && !item.id.startsWith("jit_")
      );
      ssrWebinarData = {
        results: filteredResults,
        webinarIds: { scheduled: scheduledWebinarId },
      };
    }
  }
} catch (e) {
  // SSR fetch failed, form will fall back to client-side fetch
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={pageTitle}
      description={pageDescription}
      rtkCampaignId="697c996793ba48f6ba89582f"
    />
    <meta name="robots" content="noindex" />
    <link
      rel="modulepreload"
      href="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
    />
    <ClientRouter />
    <script is:inline>
      // History traversals already come with native browser UX on mobile Safari.
      // Mark them with a custom Astro direction, then skip the view transition
      // entirely so the page restores immediately with no duplicate slide-in.
      document.addEventListener("astro:before-preparation", function (event) {
        if (event.navigationType === "traverse") {
          event.direction = "traverse";
        }
      });
      document.addEventListener("astro:before-swap", function (event) {
        if (event.direction === "traverse") {
          event.viewTransition.skipTransition();
        }
      });
    </script>
  </head>
  <body>
    {
      ssrWebinarData && (
        <script
          is:inline
          type="application/json"
          id="ssr-webinar-data"
          set:html={JSON.stringify(ssrWebinarData)}
        />
      )
    }

    <!-- Floating logo, always visible, links home -->
    <div class="wf-nav-logo" role="img" aria-label="Robert Ventures">
      <RvLogo />
    </div>

    <!-- Section position indicator: dots + lines on left edge -->
    <nav class="wf-indicator" aria-label="Section navigation">
      <button class="wf-indicator__dot is-active" data-section="0" aria-label="Go to section 1"
      ></button>
      <div class="wf-indicator__line"></div>
      <button class="wf-indicator__dot" data-section="1" aria-label="Go to section 2"></button>
      <div class="wf-indicator__line"></div>
      <button class="wf-indicator__dot" data-section="2" aria-label="Go to section 3"></button>
      <div class="wf-indicator__line"></div>
      <button class="wf-indicator__dot" data-section="3" aria-label="Go to section 4"></button>
    </nav>

    <form class="wf-form" id="wf-registration-form" novalidate>
      <WfHero />
      <WfAudience />
      <WfLeadCapture />
      <ReviewsV3 />
      <DisclaimerBlock trackLocation="webinar_disclaimer" withSmsConsent={false} />
    </form>
  </body>
</html>

<style is:global>
  /* The site-wide `scroll-behavior: smooth` from global.css turns ClientRouter's
     scroll restoration into a visible animated jump on back-nav. Disable it here
     so restoration is instant. */
  html {
    scroll-behavior: auto;
  }

  /* View-transition slide animation, matches /webinar/capital
     so the handoff from the registration page into the question flow stays
     continuous. */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 320ms;
    animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
  ::view-transition-old(root) {
    animation-name: ga-old-fwd;
  }
  ::view-transition-new(root) {
    animation-name: ga-new-fwd;
  }
  html[data-astro-transition="back"]::view-transition-old(root) {
    animation-name: ga-old-back;
  }
  html[data-astro-transition="back"]::view-transition-new(root) {
    animation-name: ga-new-back;
  }

  @keyframes ga-new-fwd {
    from {
      transform: translateX(100%);
    }
  }
  @keyframes ga-old-fwd {
    to {
      transform: translateX(-20%);
      opacity: 0.6;
    }
  }
  @keyframes ga-new-back {
    from {
      transform: translateX(-20%);
      opacity: 0.6;
    }
  }
  @keyframes ga-old-back {
    to {
      transform: translateX(100%);
    }
  }

  html[data-astro-transition="traverse"]::view-transition-old(root),
  html[data-astro-transition="traverse"]::view-transition-new(root) {
    animation: none;
  }

  body {
    background-color: #ffffff;
  }

  .wf-form {
    margin: 0;
    padding: 0;
  }

  /* Per-page override for the shared ReviewsV3 section: white background here,
     with the testimonial card flipped to grey so it still stands out. Mirrors
     the same override used on offer-v2. */
  section:has(.reviews-v3-container) {
    background: var(--bg-primary);
  }

  section:has(.reviews-v3-container) .review-card {
    background: var(--bg-secondary);
  }

  /* Default vertical rhythm for webinar slides. Each section can override
     these in its own scoped <style> block; Astro's scoping bump means scoped
     rules win without needing !important. */
  section.wf-slide {
    height: auto;
    min-height: 0;
    max-height: none;
    margin: 0;
    border: none;
    padding: 3rem 1.5rem;
  }

  @media only screen and (min-width: 600px) {
    section.wf-slide {
      padding: 4rem 2rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    section.wf-slide {
      padding: 5rem 2rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    section.wf-slide {
      padding: 6rem 2rem;
    }
  }
</style>

<style>
  .wf-nav-logo {
    display: flex;
    justify-content: center;
    padding: 1.25rem 1rem;
    border-bottom: 1px solid var(--border-light);
  }

  .wf-nav-logo :global(svg) {
    display: block;
    height: 30px;
    width: auto;
  }

  @media only screen and (min-width: 600px) {
    .wf-nav-logo {
      padding: 1.5rem 1rem;
    }

    .wf-nav-logo :global(svg) {
      height: 48px;
    }
  }
</style>

<style>
  /* Section position indicator (fixed to left edge) */
  .wf-indicator {
    position: fixed;
    left: 0.25rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .wf-indicator__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid #1a1a1a;
    padding: 0;
    background: transparent;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .wf-indicator__dot:hover {
    background: rgba(26, 26, 26, 0.3);
  }

  .wf-indicator__line {
    width: 1.5px;
    height: 24px;
    background: rgba(26, 26, 26, 0.25);
    flex-shrink: 0;
    transition: background 0.3s ease;
  }

  .wf-indicator__dot.is-passed {
    background: #1a1a1a;
    border-color: #1a1a1a;
  }

  .wf-indicator__line.is-passed {
    background: #1a1a1a;
  }

  .wf-indicator__dot.is-active {
    background: #1a1a1a;
    border-color: #1a1a1a;
    animation: wf-dot-pulse 2s ease-in-out infinite;
  }

  @keyframes wf-dot-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(26, 26, 26, 0.6);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(26, 26, 26, 0);
    }
  }

  @media only screen and (max-width: 479px) {
    .wf-indicator {
      left: 0.2rem;
    }

    .wf-indicator__dot {
      width: 8px;
      height: 8px;
    }

    .wf-indicator__line {
      height: 16px;
    }
  }

  @media only screen and (min-width: 600px) {
    .wf-indicator {
      left: 0.3rem;
    }

    .wf-indicator__dot {
      width: 12px;
      height: 12px;
    }

    .wf-indicator__line {
      height: 28px;
    }
  }
</style>

<script>
  import { navigate } from "astro:transitions/client";
  (window as any).rvNavigate = navigate;
</script>

<script is:inline data-astro-rerun>
  (function () {
    const animatedSections = {};
    let hasPlayedFounderVideo = false;
    let sections = [];

    // Indicator: update .is-active / .is-passed on dots + lines
    function updateIndicator(activeIndex) {
      const dots = document.querySelectorAll(".wf-indicator__dot");
      const lines = document.querySelectorAll(".wf-indicator__line");

      dots.forEach(function (dot, i) {
        dot.classList.remove("is-active", "is-passed");
        if (i < activeIndex) dot.classList.add("is-passed");
        if (i === activeIndex) dot.classList.add("is-active");
      });

      lines.forEach(function (line, i) {
        line.classList.remove("is-passed");
        if (i < activeIndex) line.classList.add("is-passed");
      });
    }

    // GSAP entry animations, one-shot per section
    function runSectionAnimation(index, sectionEl) {
      if (animatedSections[index]) return;
      if (!window.gsapLoaded || typeof window.gsap === "undefined") {
        window.addEventListener("gsapLoaded", function () {
          runSectionAnimation(index, sectionEl);
        });
        return;
      }

      animatedSections[index] = true;
      const gsap = window.gsap;

      if (index === 0) {
        const introContent = sectionEl.querySelector(".wf-slide__content");
        const introUnderline = sectionEl.querySelector(".wf-slide__underline");
        if (introContent) {
          const introTl = gsap.timeline({ delay: 0.2 });
          introTl.fromTo(
            introContent,
            { opacity: 0, y: 40 },
            { opacity: 1, y: 0, duration: 0.8, ease: "power2.out" }
          );
          if (introUnderline) {
            introTl.fromTo(
              introUnderline,
              { scaleX: 0 },
              { scaleX: 1, duration: 0.6, ease: "power2.out" },
              "-=0.2"
            );
          }
        }
      } else if (index === 2) {
        const text = sectionEl.querySelector(".wf-slide__text");
        const underline = sectionEl.querySelector(".wf-slide__underline");
        if (text) {
          const tl = gsap.timeline({ delay: 0.1 });
          tl.fromTo(
            text,
            { opacity: 0, y: 60 },
            { opacity: 1, y: 0, duration: 0.8, ease: "power2.out" }
          );
          if (underline) {
            tl.fromTo(
              underline,
              { scaleX: 0 },
              { scaleX: 1, duration: 0.6, ease: "power2.out" },
              "-=0.2"
            );
          }
        }
        const fields = sectionEl.querySelector(".wf-slide__fields");
        if (fields) {
          gsap.fromTo(
            fields,
            { opacity: 0, y: 30 },
            { opacity: 1, y: 0, duration: 0.6, ease: "power2.out", delay: 0.5 }
          );
        }
      } else {
        const content = sectionEl.querySelector(".wf-slide__content");
        if (content) {
          gsap.fromTo(
            content,
            { opacity: 0, y: 40 },
            { opacity: 1, y: 0, duration: 0.8, ease: "power2.out", delay: 0.1 }
          );
        }
      }
    }

    // Form validation (gate submission only)
    function validateForm() {
      const form = document.getElementById("wf-registration-form");
      if (!form) return true;
      const errorEl = document.querySelector(".wf-slide__field-error");
      const nameEl = form.querySelector("input[name='full_name']");
      const emailEl = form.querySelector("input[name='email']");
      const phoneEl = form.querySelector("input[name='phone_number']");
      const investEl = document.getElementById("wf-invest-select");

      const name = (nameEl && nameEl.value.trim()) || "";
      const email = (emailEl && emailEl.value.trim()) || "";
      const phoneDigits = phoneEl ? phoneEl.value.replace(/\D/g, "") : "";
      const invest = (investEl && investEl.value) || "";

      let firstInvalid = null;
      let message = "";

      if (!name || name.indexOf("@") !== -1) {
        firstInvalid = nameEl;
        message = "Please enter your full name.";
      } else if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        firstInvalid = emailEl;
        message = "Please enter a valid email address.";
      } else if (phoneDigits.length !== 10) {
        firstInvalid = phoneEl;
        message = "Please enter a valid 10-digit phone number.";
      } else if (!invest) {
        firstInvalid = investEl;
        message = "Please select how much you are looking to invest.";
      }

      if (firstInvalid) {
        showError(errorEl, message);
        try {
          firstInvalid.focus({ preventScroll: true });
        } catch (e) {
          firstInvalid.focus();
        }
        return false;
      }

      hideError(errorEl);
      return true;
    }

    function showError(el, msg) {
      if (!el) return;
      el.textContent = msg;
      el.style.display = "block";
    }

    function hideError(el) {
      if (!el) return;
      el.textContent = "";
      el.style.display = "none";
    }

    // "Continue" chevron buttons scroll to the next section
    function setupContinueButtons() {
      document.querySelectorAll("[data-next-slide]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          const nextIndex = parseInt(btn.getAttribute("data-next-slide"), 10);
          const target = sections[nextIndex];
          if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });
    }

    // Phone formatting
    function setupPhoneFormatting() {
      // Strip a leading "1" country code that browser autofill commonly
      // prepends (e.g. "+14155551234"). Without this, slicing to 10 digits
      // would drop the last real digit and yield a plausible-looking but
      // wrong number. No US area code starts with 1, so a leading 1 in 11
      // digits is always country code.
      function normalizeAndFormat(rawValue) {
        let digits = (rawValue || "").replace(/\D/g, "");
        if (digits.length === 11 && digits[0] === "1") digits = digits.slice(1);
        if (digits.length > 10) digits = digits.slice(0, 10);
        if (digits.length === 0) return "";
        if (digits.length <= 3) return "(" + digits;
        if (digits.length <= 6) return "(" + digits.slice(0, 3) + ") " + digits.slice(3);
        return "(" + digits.slice(0, 3) + ") " + digits.slice(3, 6) + "-" + digits.slice(6);
      }

      const phoneInputs = document.querySelectorAll("input[name='phone_number']");
      phoneInputs.forEach(function (input) {
        input.addEventListener("input", function (e) {
          e.target.value = normalizeAndFormat(e.target.value);
        });

        input.addEventListener("keypress", function (e) {
          if (!/[0-9]/.test(e.key)) e.preventDefault();
        });

        input.addEventListener("paste", function (e) {
          e.preventDefault();
          var clipboardData = e.clipboardData || /** @type {any} */ (window).clipboardData;
          const pastedText = clipboardData.getData("text");
          e.target.value = normalizeAndFormat(pastedText);
        });
      });
    }

    // Webinar data loading
    let _webinarData = null;

    function loadWebinarData() {
      const ssrEl = document.getElementById("ssr-webinar-data");
      if (ssrEl) {
        try {
          const ssrData = JSON.parse(ssrEl.textContent || "");
          if (ssrData && ssrData.results) {
            _webinarData = ssrData;
            populateSessionsDropdown(ssrData);
            return;
          }
        } catch (e) {
          // Fall through to client fetch
        }
      }

      fetch("/api/webinar-data", { cache: "no-store" })
        .then(function (res) {
          if (!res.ok) throw new Error("Failed to fetch");
          return res.json();
        })
        .then(function (data) {
          _webinarData = data;
          populateSessionsDropdown(data);
        })
        .catch(function (err) {
          console.error("Failed to load webinar data:", err);
        });
    }

    function populateSessionsDropdown(data) {
      const list = document.getElementById("wf-dates-list");
      if (!list) return;

      const userTz = Intl.DateTimeFormat().resolvedOptions().timeZone;
      const scheduledWebinarId = (data.webinarIds && data.webinarIds.scheduled) || "";

      const sessionList = data.results.filter(function (item) {
        try {
          const parsed = JSON.parse(item.id);
          return parsed && parsed.type === "ongoing";
        } catch (e) {
          return false;
        }
      });

      let sessionsWithDates = sessionList
        .map(function (session) {
          try {
            const details = JSON.parse(session.id);
            const nextDate = session.date
              ? new Date(session.date)
              : calculateNextSessionDate(details);
            return { session: session, details: details, nextDate: nextDate };
          } catch (e) {
            return null;
          }
        })
        .filter(Boolean)
        .sort(function (a, b) {
          return a.nextDate.getTime() - b.nextDate.getTime();
        });

      // Fallback: if WebinarKit returns nothing usable, synthesize the Sunday 2pm
      // session so there is still a valid option to pick.
      if (sessionsWithDates.length === 0) {
        const fallbackDetails = {
          type: "ongoing",
          day: "Sunday",
          time: "2:00",
          period: "PM",
          timeZone: "America/New_York",
        };
        sessionsWithDates = [
          {
            session: { id: JSON.stringify(fallbackDetails) },
            details: fallbackDetails,
            nextDate: calculateNextSessionDate(fallbackDetails),
          },
        ];
      }

      // Show at most 3 upcoming sessions as buttons, soonest first. Each button
      // carries the same attributes the submit handler reads off the selection.
      const confirmBtn = document.getElementById("wf-confirm");
      list.innerHTML = "";
      if (confirmBtn) confirmBtn.disabled = true;
      sessionsWithDates.slice(0, 3).forEach(function (entry) {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "wf-date-option";
        btn.value = entry.session.id;
        const text = document.createElement("span");
        text.className = "wf-date-option__text";
        const when = document.createElement("span");
        when.className = "wf-date-option__when";
        when.textContent = formatSessionLabel(entry.nextDate, userTz);
        const countdown = document.createElement("span");
        countdown.className = "wf-date-option__countdown";
        countdown.textContent = formatCountdown(entry.nextDate);
        text.appendChild(when);
        text.appendChild(countdown);
        // Decorative radio circle; selection is announced via aria-pressed on the button.
        const indicator = document.createElement("span");
        indicator.className = "wf-date-option__indicator";
        indicator.setAttribute("aria-hidden", "true");
        btn.appendChild(text);
        btn.appendChild(indicator);
        btn.setAttribute("aria-pressed", "false");
        btn.setAttribute("data-date", entry.nextDate.toISOString());
        btn.setAttribute("data-timezone", userTz);
        btn.setAttribute("data-original-timezone", entry.details.timeZone || "America/New_York");
        btn.setAttribute("data-webinar-id", scheduledWebinarId);
        btn.addEventListener("click", function () {
          const options = list.querySelectorAll(".wf-date-option");
          for (let i = 0; i < options.length; i++) {
            options[i].classList.remove("is-selected");
            options[i].setAttribute("aria-pressed", "false");
          }
          btn.classList.add("is-selected");
          btn.setAttribute("aria-pressed", "true");
          if (confirmBtn) confirmBtn.disabled = false;
        });
        list.appendChild(btn);
      });
    }

    // Build a compact option label in the visitor's local timezone, e.g.
    // "Today, Jun 8 at 2:00 PM ET" or "Sunday, Jun 8 at 2:00 PM PT". The zone
    // uses the generic US form (ET/CT/MT/PT) so it does not flip with daylight
    // saving. Offset-only zones with no friendly name (which resolve to "GMT-4")
    // get no label; the list header covers them with "shown in your local time".
    function formatSessionLabel(date, tz) {
      const dayKey = function (d) {
        return new Intl.DateTimeFormat("en-CA", {
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
          timeZone: tz,
        }).format(d);
      };
      const now = new Date();
      const tomorrow = new Date(now.getTime() + 24 * 60 * 60 * 1000);
      let relative;
      if (dayKey(date) === dayKey(now)) {
        relative = "Today";
      } else if (dayKey(date) === dayKey(tomorrow)) {
        relative = "Tomorrow";
      } else {
        relative = new Intl.DateTimeFormat("en-US", {
          weekday: "long",
          timeZone: tz,
        }).format(date);
      }
      const monthDay = new Intl.DateTimeFormat("en-US", {
        month: "short",
        day: "numeric",
        timeZone: tz,
      }).format(date);
      const time = new Intl.DateTimeFormat("en-US", {
        hour: "numeric",
        minute: "2-digit",
        timeZone: tz,
      }).format(date);
      // Generic US zone label (ET / CT / MT / PT). Pulled out via formatToParts so we
      // can drop it when the browser can only offer a raw "GMT-4" style offset (happens
      // for offset-only zones with no friendly name). In that case the list header still
      // tells visitors the times are in their local time.
      const tzPart = new Intl.DateTimeFormat("en-US", {
        timeZoneName: "shortGeneric",
        timeZone: tz,
      })
        .formatToParts(date)
        .find(function (part) {
          return part.type === "timeZoneName";
        });
      const tzLabel = tzPart && tzPart.value.indexOf("GMT") === -1 ? " " + tzPart.value : "";
      return relative + ", " + monthDay + " at " + time + tzLabel;
    }

    // How long until the session starts, e.g. "Starts in 6 days" / "Starts in 3 hours".
    function formatCountdown(date) {
      const ms = date.getTime() - Date.now();
      if (ms <= 0) return "Starting now";
      const days = Math.floor(ms / 86400000);
      if (days >= 1) return "Starts in " + days + (days === 1 ? " day" : " days");
      const hours = Math.floor(ms / 3600000);
      if (hours >= 1) return "Starts in " + hours + (hours === 1 ? " hour" : " hours");
      const minutes = Math.floor(ms / 60000);
      if (minutes >= 1) return "Starts in " + minutes + (minutes === 1 ? " minute" : " minutes");
      return "Starting soon";
    }

    function calculateNextSessionDate(details) {
      const weekdays = [
        "Sunday",
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
      ];
      const targetDay = weekdays.indexOf(details.day);
      const timeParts = details.time.split(":").map(Number);
      let hour24 = timeParts[0];
      const minutes = timeParts[1];
      if (details.period.toUpperCase() === "PM" && hour24 < 12) hour24 += 12;
      if (details.period.toUpperCase() === "AM" && hour24 === 12) hour24 = 0;

      const now = new Date();
      const currentTzTime = new Date(
        now.toLocaleString("en-US", { timeZone: details.timeZone || "America/New_York" })
      );
      const currentDay = currentTzTime.getDay();
      let daysToAdd = (targetDay - currentDay + 7) % 7;

      if (daysToAdd === 0) {
        const currentHour = currentTzTime.getHours();
        const currentMinute = currentTzTime.getMinutes();
        if (currentHour > hour24 || (currentHour === hour24 && currentMinute >= minutes)) {
          daysToAdd = 7;
        }
      }

      const sessionDate = new Date(currentTzTime);
      sessionDate.setDate(sessionDate.getDate() + daysToAdd);
      sessionDate.setHours(hour24, minutes, 0, 0);

      const tempDate = new Date(sessionDate.toISOString().slice(0, -1));
      const tzOffset =
        new Date(
          tempDate.toLocaleString("en-US", { timeZone: details.timeZone || "America/New_York" })
        ).getTime() - tempDate.getTime();
      return new Date(sessionDate.getTime() - tzOffset);
    }

    // Analytics helpers
    function getESTTimestamp(userTimezone) {
      userTimezone = userTimezone || "America/New_York";
      const now = new Date();
      const userLocalTime = new Date(now.toLocaleString("en-US", { timeZone: userTimezone }));
      const utcTime = new Date(now.toLocaleString("en-US", { timeZone: "UTC" }));
      const offsetMinutes = userLocalTime.getTime() - utcTime.getTime();
      const offsetHours = Math.floor(Math.abs(offsetMinutes) / (1000 * 60 * 60));
      const offsetSign = offsetMinutes >= 0 ? "+" : "-";
      const year = userLocalTime.getFullYear();
      const month = String(userLocalTime.getMonth() + 1).padStart(2, "0");
      const day = String(userLocalTime.getDate()).padStart(2, "0");
      const hours = String(userLocalTime.getHours()).padStart(2, "0");
      const mins = String(userLocalTime.getMinutes()).padStart(2, "0");
      const secs = String(userLocalTime.getSeconds()).padStart(2, "0");
      return (
        year +
        "-" +
        month +
        "-" +
        day +
        "T" +
        hours +
        ":" +
        mins +
        ":" +
        secs +
        offsetSign +
        "0" +
        offsetHours +
        ":00"
      );
    }

    function getCookie(name) {
      try {
        const value = "; " + document.cookie;
        const parts = value.split("; " + name + "=");
        if (parts.length === 2) {
          const raw = parts.pop().split(";").shift();
          try {
            return decodeURIComponent(raw);
          } catch (e) {
            return raw;
          }
        }
      } catch (e) {}
      return undefined;
    }

    function getRtkClickId() {
      if (typeof window.rtkClickID !== "undefined" && window.rtkClickID) return window.rtkClickID;
      const cookieName = "rtkclickid-store";
      const cookies = document.cookie.split(";");
      for (let i = 0; i < cookies.length; i++) {
        const cookie = cookies[i].trim();
        if (cookie.startsWith(cookieName + "=")) return cookie.substring(cookieName.length + 1);
      }
      const stored = getCookie("rtk_click_id");
      if (stored) return stored;
      return null;
    }

    function setRtkClickIdField(value) {
      document.querySelectorAll("input[name='rtk_click_id']").forEach(function (input) {
        input.value = value || "";
      });
      if (value) {
        try {
          document.cookie =
            "rtk_click_id=" +
            encodeURIComponent(value) +
            "; domain=.robertventures.com; path=/; max-age=2592000; SameSite=Lax";
        } catch (e) {}
      }
    }

    function captureCmpid() {
      try {
        const urlParams = new URLSearchParams(window.location.search);
        const cmpid = urlParams.get("cmpid");
        if (cmpid) {
          document.cookie =
            "cmpid=" +
            encodeURIComponent(cmpid) +
            "; domain=.robertventures.com; path=/; max-age=2592000; SameSite=Lax";
        }
      } catch (e) {}
    }

    function initializeRtkClickIdCapture() {
      const immediate = getRtkClickId();
      if (immediate) {
        setRtkClickIdField(immediate);
        return;
      }
      const maxAttempts = 30;
      let attempts = 0;
      const interval = setInterval(function () {
        attempts++;
        const clickId = getRtkClickId();
        if (clickId || attempts >= maxAttempts) {
          setRtkClickIdField(clickId);
          clearInterval(interval);
        }
      }, 500);
    }

    function getFbp() {
      return getCookie("_fbp");
    }

    function getFbc() {
      const fbcCookie = getCookie("_fbc");
      if (fbcCookie) return fbcCookie;
      try {
        const url = new URL(window.location.href);
        const fbclid = url.searchParams.get("fbclid");
        if (fbclid) {
          const ts = Math.floor(Date.now() / 1000);
          return "fb.1." + ts + "." + fbclid;
        }
      } catch (e) {}
      return undefined;
    }

    function generateEventId() {
      try {
        const buf = new Uint32Array(2);
        crypto.getRandomValues(buf);
        return (
          "rv_reg_" + Date.now().toString(36) + "_" + buf[0].toString(36) + buf[1].toString(36)
        );
      } catch (e) {
        return "rv_reg_" + Date.now() + "_" + Math.random().toString(36).slice(2, 10);
      }
    }

    function getFullDateString(isoDateUTC, sessionTimeZone) {
      const date = new Date(isoDateUTC);
      return date.toLocaleString("en-US", {
        weekday: "long",
        month: "long",
        day: "numeric",
        hour: "numeric",
        minute: "2-digit",
        hour12: true,
        timeZone: sessionTimeZone,
        timeZoneName: "short",
      });
    }

    function getLocalDateTimeString(isoDateUTC, userTimeZone) {
      const date = new Date(isoDateUTC);
      const datePart = date.toLocaleDateString("en-US", {
        weekday: "long",
        month: "long",
        day: "numeric",
        timeZone: userTimeZone,
      });
      const timePart = date.toLocaleTimeString("en-US", {
        hour: "numeric",
        minute: "2-digit",
        hour12: true,
        timeZone: userTimeZone,
      });
      return datePart + " at " + timePart;
    }

    function buildGoogleCalendarUrl(isoDateUTC) {
      const startDate = new Date(isoDateUTC);
      const endDate = new Date(startDate.getTime() + 30 * 60 * 1000);
      function fmt(d) {
        const y = d.getUTCFullYear();
        const m = String(d.getUTCMonth() + 1).padStart(2, "0");
        const dy = String(d.getUTCDate()).padStart(2, "0");
        const h = String(d.getUTCHours()).padStart(2, "0");
        const mi = String(d.getUTCMinutes()).padStart(2, "0");
        const s = String(d.getUTCSeconds()).padStart(2, "0");
        return y + m + dy + "T" + h + mi + s + "Z";
      }
      return (
        "https://calendar.google.com/calendar/render?action=TEMPLATE&text=Robert+Ventures+Investment+Webinar&dates=" +
        fmt(startDate) +
        "/" +
        fmt(endDate) +
        "&details=Join+us+live+at+robertventures.com/webinar"
      );
    }

    function detectDeviceFromUA(ua) {
      const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(ua);
      if (!isMobile) return "desktop";
      if (/iPhone|iPad|iPod/i.test(ua)) return "ios";
      return "android";
    }

    // Form submission
    function setupFormSubmission() {
      const form = document.getElementById("wf-registration-form");
      if (!form) return;
      // Guard against double-binding the submit listener. With `data-astro-rerun`
      // this script re-runs on every ClientRouter navigation, and a stale bind
      // would fire rvNavigate() twice, pushing duplicate /webinar/capital entries
      // so browser back lands on /webinar/capital instead of /webinar.
      if (form.dataset.boundSubmit === "1") return;
      form.dataset.boundSubmit = "1";

      let formStartedFired = false;
      form.addEventListener("focusin", function (e) {
        if (formStartedFired) return;
        const target = e.target;
        if (target.tagName === "INPUT" || target.tagName === "SELECT") {
          formStartedFired = true;
          if (window.dataLayer) window.dataLayer.push({ event: "webinar_form_started" });
          if (window.posthogTrack) window.posthogTrack("webinar_form_started");
        }
      });

      form.addEventListener("submit", function (e) {
        e.preventDefault();

        const datesList = document.getElementById("wf-dates-list");
        const submitButton = form.querySelector("button[type='submit']");
        const buttonText = submitButton
          ? submitButton.querySelector(".wf-slide__button-text")
          : null;
        const loader = submitButton ? submitButton.querySelector(".wf-slide__loader") : null;
        const errorEl = document.querySelector(".wf-slide__field-error");

        // No date buttons loaded at all = technical failure, distinct from the
        // visitor not having picked a date yet (handled just below).
        if (!datesList || !datesList.querySelector(".wf-date-option")) {
          showError(errorEl, "Session unavailable. Please refresh the page.");
          return;
        }

        if (!validateForm()) {
          const formSection = sections[2];
          if (formSection) formSection.scrollIntoView({ behavior: "smooth", block: "start" });
          return;
        }

        const selectedOption = datesList.querySelector(".wf-date-option.is-selected");
        if (!selectedOption) {
          showError(errorEl, "Please select the date of the webinar.");
          return;
        }

        hideError(errorEl);
        if (buttonText) buttonText.style.display = "none";
        if (loader) loader.style.display = "inline-block";
        if (submitButton) submitButton.disabled = true;

        if (window.posthogTrack) {
          window.posthogTrack("webinar_form_submitted", {
            invest_intent: document.getElementById("wf-invest-select")
              ? document.getElementById("wf-invest-select").value
              : "",
            session_type: "live",
          });
        }

        const formData = new FormData(form);

        const isoDateUTC = selectedOption ? selectedOption.getAttribute("data-date") || "" : "";
        const sessionValue = selectedOption ? selectedOption.value : "";
        if (!isoDateUTC || !sessionValue) {
          showError(errorEl, "Invalid session data.");
          resetForm(buttonText, loader, submitButton);
          return;
        }
        let sessionDetails;
        try {
          sessionDetails = JSON.parse(sessionValue);
        } catch (err) {
          showError(errorEl, "Invalid session format.");
          resetForm(buttonText, loader, submitButton);
          return;
        }

        const selectedInvest = formData.get("invest_intent") || "";
        try {
          localStorage.setItem("invest_intent", selectedInvest);
        } catch (e) {}

        const baseUtmParams = [
          "utm_source",
          "utm_medium",
          "utm_campaign",
          "utm_content",
          "utm_term",
          "utm_id",
          "utm_adgroup",
        ];
        const urlParams = new URLSearchParams(window.location.search);
        const utmParamSet = new Set(baseUtmParams);
        urlParams.forEach(function (_v, key) {
          if (key.startsWith("utm_")) utmParamSet.add(key);
        });
        const utmData = {};
        utmParamSet.forEach(function (param) {
          const val = urlParams.get(param) || getCookie(param);
          if (val) utmData[param] = val;
        });

        const fbAttribution = {
          fb_ad_id: getCookie("fb_ad_id"),
          fb_adset_id: getCookie("fb_adset_id"),
          fb_placement: getCookie("fb_placement"),
          fb_site_source: getCookie("fb_site_source"),
        };
        const googleAttribution = {
          google_matchtype: getCookie("google_matchtype"),
          google_adgroup_id: getCookie("google_adgroup_id"),
          google_creative_id: getCookie("google_creative_id"),
          google_campaign_id: getCookie("google_campaign_id"),
          google_device: getCookie("google_device"),
          google_ad_position: getCookie("google_ad_position"),
          google_network: getCookie("google_network"),
          google_placement: getCookie("google_placement"),
          wbraid: getCookie("wbraid"),
          gbraid: getCookie("gbraid"),
        };
        const gclid = urlParams.get("gclid") || getCookie("gclid");
        let deviceType;
        try {
          deviceType = localStorage.getItem("device_type");
        } catch (e) {}
        if (!deviceType) deviceType = detectDeviceFromUA(navigator.userAgent);
        const utmCampaignTop = utmData.utm_campaign || getCookie("utm_campaign");
        const webinarCalendarUrl = buildGoogleCalendarUrl(isoDateUTC);
        const webinarId = selectedOption
          ? selectedOption.getAttribute("data-webinar-id") || ""
          : "";
        const rtkClickId = getRtkClickId();
        setRtkClickIdField(rtkClickId);

        const payload = {
          session: sessionDetails.id,
          name: formData.get("full_name"),
          email: formData.get("email"),
          phone_number: (function () {
            const v = formData.get("phone_number");
            return typeof v === "string" ? v.replace(/\D/g, "") : "";
          })(),
          invest_intent: formData.get("invest_intent"),
          company: formData.get("company"),
          date: isoDateUTC,
          fullDate: getFullDateString(isoDateUTC, sessionDetails.timeZone),
          utm: utmData,
          gclid: gclid || undefined,
          utm_campaign: utmCampaignTop || undefined,
          webinar_sign_up_date: getESTTimestamp(
            selectedOption ? selectedOption.getAttribute("data-timezone") : null
          ),
          user_timezone: selectedOption ? selectedOption.getAttribute("data-timezone") : "",
          webinar_datetime_user_tz: getLocalDateTimeString(
            isoDateUTC,
            selectedOption ? selectedOption.getAttribute("data-timezone") : "America/New_York"
          ),
          device_type: deviceType || undefined,
          webinar_test: "webinar-cd",
          webinar_calendar_url: webinarCalendarUrl,
          event_id: generateEventId(),
          fbp: getFbp(),
          fbc: getFbc(),
          webinar_id: webinarId,
          rtk_click_id: rtkClickId || undefined,
          cmpid: getCookie("cmpid"),
          fb_ad_id: fbAttribution.fb_ad_id,
          fb_adset_id: fbAttribution.fb_adset_id,
          fb_placement: fbAttribution.fb_placement,
          fb_site_source: fbAttribution.fb_site_source,
          google_matchtype: googleAttribution.google_matchtype,
          google_adgroup_id: googleAttribution.google_adgroup_id,
          google_creative_id: googleAttribution.google_creative_id,
          google_campaign_id: googleAttribution.google_campaign_id,
          google_device: googleAttribution.google_device,
          google_ad_position: googleAttribution.google_ad_position,
          google_network: googleAttribution.google_network,
          google_placement: googleAttribution.google_placement,
          wbraid: googleAttribution.wbraid,
          gbraid: googleAttribution.gbraid,
          landing_video: hasPlayedFounderVideo ? "Yes" : "No",
        };

        localStorage.setItem(
          "webinar_sign_up_date",
          getESTTimestamp(selectedOption ? selectedOption.getAttribute("data-timezone") : null)
        );

        fetch("/api/webinar-registration", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        })
          .then(function (res) {
            if (!res.ok) throw new Error("Registration failed (" + res.status + ")");
            return res.json();
          })
          .then(function (result) {
            if (result && result.ghl_contact_id) {
              localStorage.setItem("ghl_contact_id", result.ghl_contact_id);
            }

            const emailStr = typeof payload.email === "string" ? payload.email : "";
            const nameStr = typeof payload.name === "string" ? payload.name : "";
            const phoneStr = typeof payload.phone_number === "string" ? payload.phone_number : "";
            if (emailStr) localStorage.setItem("userEmail", emailStr);
            if (nameStr) localStorage.setItem("full_name", nameStr);
            if (phoneStr) localStorage.setItem("phone_number", phoneStr);
            localStorage.setItem(
              "user_timezone",
              (selectedOption && selectedOption.getAttribute("data-timezone")) ||
                Intl.DateTimeFormat().resolvedOptions().timeZone ||
                "America/New_York"
            );

            localStorage.setItem(
              "webinarSession",
              JSON.stringify({
                title: "Robert Ventures Webinar",
                date: isoDateUTC,
                timeZone: sessionDetails.timeZone,
                fullDate: getFullDateString(isoDateUTC, sessionDetails.timeZone),
                email: emailStr,
                name: nameStr,
              })
            );

            // Attach registrant details as person properties on the anonymous
            // PostHog profile. We deliberately do NOT identify(email) here: the
            // real stable user id only exists once they sign up on the investor
            // portal, which calls identify(user.id) and merges this journey in.
            if (window.posthogSetPerson) {
              window.posthogSetPerson({
                name: nameStr,
                email: emailStr,
                phone: phoneStr,
                ghl_contact_id: result ? result.ghl_contact_id : undefined,
                invest_intent: payload.invest_intent,
                session_type: "live",
                registration_page: window.location.pathname,
              });
            }
            if (window.posthogTrack) {
              window.posthogTrack("webinar_registered", {
                invest_intent: payload.invest_intent,
                session_date: isoDateUTC,
                session_type: "live",
                ghl_contact_id: result ? result.ghl_contact_id : undefined,
                landing_video_played: hasPlayedFounderVideo,
              });
            }

            const investForMeta = payload.invest_intent;
            if (investForMeta !== "1000" && investForMeta !== "5000") {
              try {
                if (typeof window.fbq === "function") {
                  window.fbq("track", "CompleteRegistration", {}, { eventID: payload.event_id });
                }
              } catch (e) {}
            }

            if (window.rvNavigate) window.rvNavigate("/webinar/capital");
            else window.location.href = "/webinar/capital";
          })
          .catch(function (err) {
            console.error("Registration error:", err);
            showError(errorEl, "Registration failed. Please try again.");
            resetForm(buttonText, loader, submitButton);
            if (window.posthogTrack) {
              window.posthogTrack("webinar_registration_failed", {
                invest_intent: payload.invest_intent,
                session_type: "live",
              });
            }
          });
      });
    }

    function resetForm(buttonText, loader, submitButton) {
      if (buttonText) buttonText.style.display = "";
      if (loader) loader.style.display = "none";
      if (submitButton) submitButton.disabled = false;
    }

    // Scroll-based init: collect sections, wire up two IntersectionObservers
    function initScroll() {
      sections = Array.from(document.querySelectorAll("section.wf-slide"));
      // The testimonials section is a plain <section> (shared ReviewsV3 component),
      // so it is not a .wf-slide. Append it so it gets its own indicator dot.
      var reviewsContainer = document.querySelector(".reviews-v3-container");
      var reviewsSection = reviewsContainer ? reviewsContainer.closest("section") : null;
      if (reviewsSection) sections.push(reviewsSection);
      sections.forEach(function (section, i) {
        section.setAttribute("data-section-index", String(i));
      });

      // Dot nav: click any dot to smooth-scroll to its section
      document.querySelectorAll(".wf-indicator__dot").forEach(function (dot) {
        dot.addEventListener("click", function () {
          const targetIndex = parseInt(dot.getAttribute("data-section"), 10);
          const target = sections[targetIndex];
          if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });

      // Indicator IO: flips active dot when a section crosses the viewport midline
      const indicatorIo = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              const idx = parseInt(entry.target.getAttribute("data-section-index"), 10);
              updateIndicator(idx);
            }
          });
        },
        { threshold: 0, rootMargin: "-50% 0px -50% 0px" }
      );

      // Animation IO: fires entry animation as soon as the section starts
      // entering the viewport (rootMargin extends the bottom edge by 5%),
      // so the next slide doesn't feel empty while the user is scrolling in.
      const animIo = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              const idx = parseInt(entry.target.getAttribute("data-section-index"), 10);
              runSectionAnimation(idx, entry.target);
            }
          });
        },
        { threshold: 0, rootMargin: "0px 0px 5% 0px" }
      );

      sections.forEach(function (section) {
        indicatorIo.observe(section);
        animIo.observe(section);
      });

      // Trigger first-section animation immediately if it's already in view on load
      if (sections[0]) runSectionAnimation(0, sections[0]);
    }

    // Invest dropdown
    function setupInvestDropdown() {
      const investSelect = document.getElementById("wf-invest-select");
      if (!investSelect) return;
      investSelect.selectedIndex = 0;
      investSelect.addEventListener("change", function () {
        investSelect.classList.add("has-value");
      });
    }

    // Slide the two-step form between the details panel and the date panel,
    // mirroring the 320ms /webinar -> /webinar/capital page transition.
    function goToDatesStep() {
      const steps = document.getElementById("wf-steps");
      const track = document.getElementById("wf-steps-track");
      const details = document.getElementById("wf-step-details");
      const dates = document.getElementById("wf-step-dates");
      if (!steps || !track || !details || !dates) return;
      // Lock to the current height, force a reflow, then animate to the date height.
      steps.style.height = details.offsetHeight + "px";
      void steps.offsetHeight;
      track.classList.add("is-dates");
      steps.style.height = dates.offsetHeight + "px";
      details.setAttribute("inert", "");
      dates.removeAttribute("inert");
    }

    function backToDetailsStep() {
      const steps = document.getElementById("wf-steps");
      const track = document.getElementById("wf-steps-track");
      const details = document.getElementById("wf-step-details");
      const dates = document.getElementById("wf-step-dates");
      if (!steps || !track || !details || !dates) return;
      track.classList.remove("is-dates");
      steps.style.height = details.offsetHeight + "px";
      dates.setAttribute("inert", "");
      details.removeAttribute("inert");
    }

    // Step 1: validate the details, then slide to the date buttons.
    function setupDateSelection() {
      const steps = document.getElementById("wf-steps");
      const details = document.getElementById("wf-step-details");
      const selectDateBtn = document.getElementById("wf-select-date");
      const backBtn = document.getElementById("wf-dates-back");
      const list = document.getElementById("wf-dates-list");
      if (!steps || !details || !selectDateBtn || !list) return;
      // Pin the slider height to the details panel (from auto, so this does not animate).
      steps.style.height = details.offsetHeight + "px";
      // Assign onclick (not addEventListener) so the ClientRouter re-run cannot stack handlers.
      selectDateBtn.onclick = function () {
        if (!validateForm()) return;
        if (!list.querySelector(".wf-date-option")) {
          showError(
            document.querySelector(".wf-slide__field-error"),
            "Session unavailable. Please refresh the page."
          );
          return;
        }
        goToDatesStep();
        if (window.posthogTrack) {
          window.posthogTrack("webinar_date_step_opened", {
            invest_intent: document.getElementById("wf-invest-select")
              ? document.getElementById("wf-invest-select").value
              : "",
            session_type: "live",
          });
        }
      };
      if (backBtn) backBtn.onclick = backToDetailsStep;
    }

    // Mux Video analytics + pause-when-offscreen
    function setupMuxAnalytics() {
      const player = document.getElementById("wf-mux-player");
      const caption = document.querySelector(".wf-slide__photo-caption");
      const overlay = document.getElementById("wf-mux-overlay");
      if (!player) return;

      // One-shot UX nudge model:
      //   - Section in view: try muted autoplay.
      //   - Autoplay succeeds: show unmute overlay. Click anywhere to unmute.
      //   - Autoplay rejected: show play overlay. Click anywhere to play (with sound).
      //   - After engagement, overlay vanishes. Mux's native UI handles
      //     pause/play/replay from then on.
      // Engagement (= "landing_video: Yes" sent to GHL) fires on either path.
      let autoplayState = "pending"; // "pending" | "trying" | "playing" | "failed"
      let isAutoplayPlay = false;
      let engaged = false;

      function showOverlayUnmuteMode() {
        if (!overlay) return;
        overlay.classList.add("is-active");
        overlay.classList.remove("is-play-mode");
        overlay.setAttribute("aria-label", "Your video is playing. Click to unmute.");
      }

      function showOverlayPlayMode() {
        if (!overlay) return;
        overlay.classList.add("is-active", "is-play-mode");
        overlay.setAttribute("aria-label", "Click to play");
      }

      function dismissOverlay() {
        if (!overlay) return;
        overlay.classList.remove("is-active");
      }

      // The video autoplays muted. The only interaction worth tracking is the
      // user clicking the video (which unmutes it, or restarts it unmuted if it
      // already ended). We treat that single interaction as the "video_play".
      function markEngaged() {
        if (engaged) return;
        engaged = true;
        hasPlayedFounderVideo = true;
        dismissOverlay();
        if (window.posthogTrack) {
          window.posthogTrack("video_play", {
            video_id: "wf-intro-joe-robert",
            current_time: Math.round(player.currentTime || 0),
          });
        }
      }

      function attemptAutoplay() {
        if (autoplayState !== "pending") return;
        autoplayState = "trying";
        try {
          player.muted = true;
        } catch (e) {}
        isAutoplayPlay = true;
        const promise = player.play();
        if (promise && typeof promise.then === "function") {
          promise
            .then(function () {
              autoplayState = "playing";
              if (!engaged) showOverlayUnmuteMode();
            })
            .catch(function () {
              isAutoplayPlay = false;
              autoplayState = "failed";
              if (!engaged) showOverlayPlayMode();
            });
        } else {
          autoplayState = "playing";
          if (!engaged) showOverlayUnmuteMode();
        }
      }

      function engageFromOverlay(e) {
        if (!overlay || !overlay.classList.contains("is-active")) return;
        e.preventDefault();
        e.stopPropagation();
        try {
          player.muted = false;
        } catch (err) {}
        dismissOverlay();
      }

      if (overlay) {
        overlay.addEventListener("click", engageFromOverlay);
        overlay.addEventListener("keydown", function (e) {
          if (e.key === "Enter" || e.key === " ") engageFromOverlay(e);
        });
      }

      player.addEventListener("play", function () {
        const wasAutoplay = isAutoplayPlay;
        isAutoplayPlay = false;
        if (caption) caption.classList.add("is-hidden");
        // A non-autoplay play means the user clicked the (paused/ended) video.
        if (!wasAutoplay) markEngaged();
      });

      player.addEventListener("volumechange", function () {
        if (engaged) return;
        if (player.muted) return;
        try {
          player.pause();
          player.currentTime = 0;
        } catch (e) {}
        const result = player.play();
        if (result && typeof result.catch === "function") result.catch(function () {});
        markEngaged();
      });

      player.addEventListener("pause", function () {
        if (player.ended) return;
        if (caption) caption.classList.remove("is-hidden");
      });

      player.addEventListener("ended", function () {
        if (caption) caption.classList.remove("is-hidden");
      });

      // Trigger muted autoplay while the section is still approaching, so
      // the video buffers during the user's scroll and is already playing
      // by the time they actually see the slide. The bottom rootMargin
      // extends the trigger zone ~40% of viewport-height below the visible
      // area. Pause when section leaves the viewport.
      if ("IntersectionObserver" in window) {
        const videoIo = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                if (autoplayState === "pending") {
                  attemptAutoplay();
                } else if (autoplayState === "playing" && player.paused && !hasPlayedFounderVideo) {
                  isAutoplayPlay = true;
                  const result = player.play();
                  if (result && typeof result.catch === "function") {
                    result.catch(function () {
                      isAutoplayPlay = false;
                    });
                  }
                }
              } else if (!player.paused) {
                player.pause();
              }
            });
          },
          { threshold: 0, rootMargin: "0px 0px 40% 0px" }
        );
        videoIo.observe(player);
      }
    }

    // Mux Video preloading: metadata on init, upgrade to auto after page load
    function setupMuxPreloading() {
      const player = document.getElementById("wf-mux-player");
      if (!player) return;

      if (document.readyState === "complete") {
        player.setAttribute("preload", "auto");
      } else {
        window.addEventListener("load", function () {
          player.setAttribute("preload", "auto");
        });
      }
    }

    function setupDevSkip() {
      const detailsBtn = document.getElementById("wf-dev-skip");
      const datesBtn = document.getElementById("wf-dev-skip-dates");
      // Prefill test data so the downstream pages skip their real API calls too.
      function setDevTestData() {
        try {
          localStorage.setItem("test_mode", "1");
          localStorage.setItem("ghl_contact_id", "test_contact_123");
          localStorage.setItem("userEmail", "test@example.com");
          localStorage.setItem("full_name", "Test User");
          localStorage.setItem("phone_number", "5555551234");
          localStorage.setItem("invest_intent", "10000");
        } catch (e) {}
      }
      // Details step: skip filling the fields, slide to the date step.
      // Date step: skip the real registration, jump straight to the capital page.
      // onclick (not addEventListener) stays idempotent across ClientRouter re-runs.
      if (detailsBtn) {
        detailsBtn.onclick = function () {
          setDevTestData();
          goToDatesStep();
        };
      }
      if (datesBtn) {
        datesBtn.onclick = function () {
          setDevTestData();
          if (window.rvNavigate) window.rvNavigate("/webinar/capital");
          else window.location.href = "/webinar/capital";
        };
      }
    }

    function boot() {
      captureCmpid();
      initializeRtkClickIdCapture();
      setupPhoneFormatting();
      setupContinueButtons();
      setupInvestDropdown();
      setupDevSkip();
      setupDateSelection();
      loadWebinarData();
      setupFormSubmission();
      setupMuxPreloading();
      setupMuxAnalytics();
      initScroll();

      // Refresh webinar data every 5 minutes
      setInterval(
        function () {
          fetch("/api/webinar-data", { cache: "no-store" })
            .then(function (res) {
              if (res.ok) return res.json();
            })
            .then(function (data) {
              if (data) {
                _webinarData = data;
                populateSessionsDropdown(data);
              }
            })
            .catch(function () {});
        },
        5 * 60 * 1000
      );
    }

    // Load Mux Player from CDN (module script, non-blocking)
    const muxScript = document.createElement("script");
    muxScript.src = "https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs";
    muxScript.type = "module";
    document.head.appendChild(muxScript);

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", boot);
    } else {
      boot();
    }
  })();
</script>
