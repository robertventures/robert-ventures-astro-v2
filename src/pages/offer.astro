---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import DisclaimerBlock from "../components/DisclaimerBlock.astro";
// Offer landing page built from the Figma design "Offer Page I - Simplified".
// Retargeting traffic lands here. Each section is self-contained (owns its
// spacing, styles, and behavior), so this list can be reordered freely.
import OfferHero from "../sections/offer/OfferHero.astro";
import OfferSceneDrain from "../sections/offer/OfferSceneDrain.astro";
import OfferSceneGrowth from "../sections/offer/OfferSceneGrowth.astro";
import OfferCtaMini from "../sections/offer/OfferCtaMini.astro";
import OfferTestimonialsMarquee from "../sections/offer/OfferTestimonialsMarquee.astro";
import OfferStrategy from "../sections/offer/OfferStrategy.astro";
import OfferJoeVideo from "../sections/offer/OfferJoeVideo.astro";
import OfferTestimonialsFaces from "../sections/offer/OfferTestimonialsFaces.astro";
import OfferNextSteps from "../sections/offer/OfferNextSteps.astro";
import OfferDocuments from "../sections/offer/OfferDocuments.astro";

const pageTitle = "Offer | Robert Ventures";
const pageDescription =
  "Fixed 8 to 10% returns, compounding or paid monthly, built on real estate and digital assets. See how it works.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <meta name="robots" content="noindex" />

    <!-- Mux Player (founder video in OfferJoeVideo) -->
    <link
      rel="modulepreload"
      href="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
    />
    <link rel="preconnect" href="https://stream.mux.com" crossorigin />
    <link rel="preconnect" href="https://image.mux.com" crossorigin />
    <script
      type="module"
      src="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
      is:inline></script>
  </head>
  <body>
    <Header />

    <main class="offer-page">
      <OfferHero />
      <OfferSceneDrain />
      <OfferSceneGrowth />
      <OfferCtaMini />
      <OfferTestimonialsMarquee />
      <OfferStrategy />
      <OfferJoeVideo />
      <OfferTestimonialsFaces />
      <OfferNextSteps />
      <OfferDocuments />
    </main>

    <DisclaimerBlock
      trackLocation="offer_disclaimer"
      footnote="*After the minimum commitment period, withdrawals are processed within 90 days of your request."
    />

    <!-- Page-level reveal engine. Sections opt in by putting `data-reveal` on
         their major blocks; nothing is hidden by CSS, so without JS (or with
         reduced motion, or if GSAP fails to load) everything stays visible.
         Blocks already on screen at init are left alone to avoid a flash. -->
    <script is:inline data-astro-rerun>
      (function () {
        const reduce =
          window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduce || !("IntersectionObserver" in window)) return;

        function start() {
          if (!window.gsap) return;
          const els = Array.prototype.slice.call(document.querySelectorAll("[data-reveal]"));
          const pending = els.filter(function (el) {
            if (el.dataset.revealDone === "1") return false;
            const rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight * 0.9) {
              el.dataset.revealDone = "1";
              return false;
            }
            return true;
          });
          if (!pending.length) return;

          pending.forEach(function (el) {
            window.gsap.set(el, { autoAlpha: 0, y: 24 });
          });

          const io = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;
                const el = entry.target;
                io.unobserve(el);
                el.dataset.revealDone = "1";
                window.gsap.to(el, {
                  autoAlpha: 1,
                  y: 0,
                  duration: 0.7,
                  ease: "power2.out",
                  clearProps: "transform,opacity,visibility",
                });
              });
            },
            { threshold: 0.12 }
          );

          pending.forEach(function (el) {
            io.observe(el);
          });
        }

        if (window.gsapLoaded && window.gsap) {
          start();
        } else {
          window.addEventListener("gsapLoaded", start, { once: true });
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  /* Sections own their spacing; keep the page a continuous band. */
  main.offer-page section {
    margin-bottom: 0;
  }
</style>
