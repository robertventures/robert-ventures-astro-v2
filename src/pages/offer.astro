---
import BaseHead from "../components/BaseHead.astro";
import DisclaimerBlock from "../components/DisclaimerBlock.astro";
import RvLogo from "../images/brand/logo-horizontal-whitebg.svg";
// 7-section diligence page for warm investors who booked a call and asked
// for more information. Rational tone, numbers and filings led, single CTA
// at the end. Reads as a story: opening, bond, math, assets, trust anchor,
// investor voices, create account.
import PresFounder from "../sections/presentation/PresFounder.astro";
import RationalTerms from "../sections/presentation/rational/Terms.astro";
import RationalMath from "../sections/presentation/rational/Math.astro";
import RationalAssets from "../sections/presentation/rational/Assets.astro";
import RationalTrackRecord from "../sections/presentation/rational/TrackRecord.astro";
import ReviewsV3 from "../sections/ReviewsV3.astro";
import RationalCta from "../sections/presentation/rational/Cta.astro";

const pageTitle = "Presentation | Robert Ventures";
const pageDescription =
  "A closer look at the fixed 8 to 10% offering for investors who have already spoken with us.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <meta name="robots" content="noindex" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/css/splide-core.min.css"
    />
    <link
      rel="modulepreload"
      href="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
    />
    <link rel="preconnect" href="https://stream.mux.com" crossorigin />
    <link rel="preconnect" href="https://image.mux.com" crossorigin />
    <script
      type="module"
      src="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
      is:inline></script>
  </head>
  <body>
    <div class="pres-nav-logo" role="img" aria-label="Robert Ventures">
      <RvLogo />
    </div>

    <!-- Section position indicator: dots + lines on left edge -->
    <nav class="slide-indicator" aria-label="Section navigation">
      <button class="slide-indicator__dot is-active" data-section="0" aria-label="Go to section 1"
      ></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-section="1" aria-label="Go to section 2"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-section="2" aria-label="Go to section 3"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-section="3" aria-label="Go to section 4"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-section="4" aria-label="Go to section 5"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-section="5" aria-label="Go to section 6"></button>
      <div class="slide-indicator__line"></div>
      <button class="slide-indicator__dot" data-section="6" aria-label="Go to section 7"></button>
    </nav>

    <main>
      {
        /* 1. Opening: video 1 + diligence frame, sets the page as the answer to "I want more info" */
      }
      <PresFounder />

      {/* 2. The bond in one screen: 8% / 10% terms + monthly distribution examples */}
      <RationalTerms />

      {/* 3. The math: what 8% and 10% compounded monthly do over 10 years */}
      <RationalMath />

      {/* 4. Where your capital goes: Outer Banks real estate + Bitcoin reserve, real numbers */}
      <RationalAssets />

      {
        /* 5. Trust anchor: video 2 + Joe's 25-year track record + $750K subordination + SEC + operating record */
      }
      <!-- <RationalTrackRecord /> -->

      {/* 6. Investor voices: theme-tagged testimonials */}
      <ReviewsV3 />

      {/* 7. Final CTA: open an account, with stars + social proof */}
      <RationalCta />
    </main>

    <DisclaimerBlock trackLocation="offer_disclaimer" />
  </body>
</html>

<style is:global>
  /* Continuous narrative band, no margins between sections */
  main section {
    margin-bottom: 0;
  }

  /* Unified vertical rhythm for offer page sections. Mirrors .intro-slide
     on introduction.astro and .wf-slide on webinar.astro. Each section file
     owns its content layout, but no longer its own outer padding. */
  section.offer-slide {
    margin-bottom: 0;
    padding: 2rem 1.5rem;
  }

  @media only screen and (min-width: 600px) {
    section.offer-slide {
      padding: 3rem 2rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    section.offer-slide {
      padding: 4rem 2rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    section.offer-slide {
      padding: 5rem 2rem;
    }
  }
</style>

<style>
  .pres-nav-logo {
    display: flex;
    justify-content: center;
    padding: 1.25rem 1rem;
    border-bottom: 1px solid var(--border-light);
  }

  .pres-nav-logo :global(svg) {
    display: block;
    height: 30px;
    width: auto;
  }

  @media only screen and (min-width: 600px) {
    .pres-nav-logo {
      padding: 1.5rem 1rem;
    }

    .pres-nav-logo :global(svg) {
      height: 48px;
    }
  }
</style>

<style>
  /* Section position indicator (fixed to left edge) */
  .slide-indicator {
    position: fixed;
    left: 0.25rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .slide-indicator__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid #1a1a1a;
    padding: 0;
    background: transparent;
    cursor: pointer;
    position: relative;
    flex-shrink: 0;
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .slide-indicator__dot:hover {
    background: rgba(26, 26, 26, 0.3);
  }

  .slide-indicator__line {
    width: 1.5px;
    height: 24px;
    background: rgba(26, 26, 26, 0.25);
    flex-shrink: 0;
    transition: background 0.3s ease;
  }

  .slide-indicator__dot.is-passed {
    background: #1a1a1a;
    border-color: #1a1a1a;
  }

  .slide-indicator__line.is-passed {
    background: #1a1a1a;
  }

  .slide-indicator__dot.is-active {
    background: #1a1a1a;
    border-color: #1a1a1a;
    animation: dot-pulse 2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(26, 26, 26, 0.6);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(26, 26, 26, 0);
    }
  }

  @media only screen and (max-width: 479px) {
    .slide-indicator {
      left: 0.2rem;
    }

    .slide-indicator__dot {
      width: 8px;
      height: 8px;
    }

    .slide-indicator__line {
      height: 16px;
    }
  }

  @media only screen and (min-width: 600px) {
    .slide-indicator {
      left: 0.3rem;
    }

    .slide-indicator__dot {
      width: 12px;
      height: 12px;
    }

    .slide-indicator__line {
      height: 28px;
    }
  }
</style>

<script is:inline>
  (function () {
    function updateIndicator(activeIndex) {
      const dots = document.querySelectorAll(".slide-indicator__dot");
      const lines = document.querySelectorAll(".slide-indicator__line");

      dots.forEach(function (dot, i) {
        dot.classList.remove("is-active", "is-passed");
        if (i < activeIndex) dot.classList.add("is-passed");
        if (i === activeIndex) dot.classList.add("is-active");
      });

      lines.forEach(function (line, i) {
        line.classList.remove("is-passed");
        if (i < activeIndex) line.classList.add("is-passed");
      });
    }

    function initIndicator() {
      const sections = Array.from(document.querySelectorAll("main > section"));
      sections.forEach(function (section, i) {
        section.setAttribute("data-section-index", String(i));
      });

      // Dot nav: click any dot to smooth-scroll to its section
      document.querySelectorAll(".slide-indicator__dot").forEach(function (dot) {
        dot.addEventListener("click", function () {
          const targetIndex = parseInt(dot.getAttribute("data-section"), 10);
          const target = sections[targetIndex];
          if (target) target.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });

      const indicatorIo = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              const idx = parseInt(entry.target.getAttribute("data-section-index"), 10);
              updateIndicator(idx);
            }
          });
        },
        { threshold: 0, rootMargin: "-50% 0px -50% 0px" }
      );

      sections.forEach(function (section) {
        indicatorIo.observe(section);
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initIndicator);
    } else {
      initIndicator();
    }
  })();
</script>

<script is:inline>
  (function () {
    function setupHeroVideo() {
      const player = document.getElementById("pres-mux-player");
      const overlay = document.getElementById("pres-mux-overlay");
      if (!player) return;

      let autoplayState = "pending";
      let isAutoplayPlay = false;
      let engaged = false;

      function showOverlayUnmuteMode() {
        if (!overlay) return;
        overlay.classList.add("is-active");
        overlay.classList.remove("is-play-mode");
        overlay.setAttribute("aria-label", "Your video is playing. Click to unmute.");
      }

      function showOverlayPlayMode() {
        if (!overlay) return;
        overlay.classList.add("is-active", "is-play-mode");
        overlay.setAttribute("aria-label", "Click to play");
      }

      function dismissOverlay() {
        if (!overlay) return;
        overlay.classList.remove("is-active");
      }

      // Video autoplays muted. The interaction worth tracking is the user
      // clicking the video (unmutes it, or restarts it unmuted if ended).
      // We treat that single interaction as the "video_play".
      function markEngaged() {
        if (engaged) return;
        engaged = true;
        dismissOverlay();
        if (window.posthogTrack) {
          window.posthogTrack("video_play", {
            video_id: "offer_hero",
            current_time: Math.round(player.currentTime || 0),
          });
        }
      }

      function attemptAutoplay() {
        if (autoplayState !== "pending") return;
        autoplayState = "trying";
        try {
          player.muted = true;
        } catch (e) {}
        isAutoplayPlay = true;
        const promise = player.play();
        if (promise && typeof promise.then === "function") {
          promise
            .then(function () {
              autoplayState = "playing";
              if (!engaged) showOverlayUnmuteMode();
            })
            .catch(function () {
              isAutoplayPlay = false;
              autoplayState = "failed";
              if (!engaged) showOverlayPlayMode();
            });
        } else {
          autoplayState = "playing";
          if (!engaged) showOverlayUnmuteMode();
        }
      }

      function engageFromOverlay(e) {
        if (!overlay || !overlay.classList.contains("is-active")) return;
        e.preventDefault();
        e.stopPropagation();
        try {
          player.muted = false;
        } catch (err) {}
        dismissOverlay();
      }

      if (overlay) {
        overlay.addEventListener("click", engageFromOverlay);
        overlay.addEventListener("keydown", function (e) {
          if (e.key === "Enter" || e.key === " ") engageFromOverlay(e);
        });
      }

      player.addEventListener("play", function () {
        const wasAutoplay = isAutoplayPlay;
        isAutoplayPlay = false;
        if (!wasAutoplay) markEngaged();
      });

      player.addEventListener("volumechange", function () {
        if (engaged) return;
        if (player.muted) return;
        try {
          player.pause();
          player.currentTime = 0;
        } catch (e) {}
        const result = player.play();
        if (result && typeof result.catch === "function") result.catch(function () {});
        markEngaged();
      });

      if ("IntersectionObserver" in window) {
        const videoIo = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                if (autoplayState === "pending") {
                  attemptAutoplay();
                } else if (autoplayState === "playing" && player.paused && !engaged) {
                  isAutoplayPlay = true;
                  const result = player.play();
                  if (result && typeof result.catch === "function") {
                    result.catch(function () {
                      isAutoplayPlay = false;
                    });
                  }
                }
              } else if (!player.paused) {
                player.pause();
              }
            });
          },
          { threshold: 0, rootMargin: "0px 0px 40% 0px" }
        );
        videoIo.observe(player);
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupHeroVideo);
    } else {
      setupHeroVideo();
    }
  })();
</script>
