---
import BaseHead from "../components/BaseHead.astro";
import DisclaimerBlock from "../components/DisclaimerBlock.astro";
import RvLogo from "../images/brand/logo-horizontal-whitebg.svg";
import ExploreChat from "../sections/ExploreChat.astro";

const pageTitle = "Explore Your Questions | Robert Ventures";
const pageDescription =
  "Pick a question, get a straight answer, then keep exploring. Everything you want to know about Robert Ventures bonds, in your own order.";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
    <meta name="robots" content="noindex" />
    <link
      rel="modulepreload"
      href="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
    />
    <link rel="preconnect" href="https://stream.mux.com" crossorigin />
    <link rel="preconnect" href="https://image.mux.com" crossorigin />
    <script
      type="module"
      src="https://cdn.jsdelivr.net/npm/@mux/mux-player@3/dist/mux-player.mjs"
      is:inline></script>
    <style>
      body {
        background-color: var(--bg-secondary);
        padding-bottom: 96px;
      }
      @media only screen and (min-width: 600px) {
        body {
          padding-bottom: 88px;
        }
      }
    </style>
  </head>
  <body>
    <div class="explore-nav-logo" role="img" aria-label="Robert Ventures">
      <RvLogo />
    </div>

    <main>
      <ExploreChat />
    </main>

    <DisclaimerBlock trackLocation="explore_disclaimer" />
  </body>
</html>

<style>
  .explore-nav-logo {
    display: flex;
    justify-content: center;
    padding: 1.25rem 1rem;
    background: var(--bg-secondary);
  }

  .explore-nav-logo :global(svg) {
    display: block;
    height: 40px;
    width: auto;
  }

  @media only screen and (min-width: 600px) {
    .explore-nav-logo {
      padding: 1.5rem 1rem;
    }
    .explore-nav-logo :global(svg) {
      height: 48px;
    }
  }

</style>
