---
import Rvlogo from "../images/brand/logo-horizontal-whitebg.svg";
import GetStartedCta from "./GetStartedCta.astro";

const menuItems = [
  {
    label: "Home",
    href: "/",
    description: "The offering at a glance: bonds paying a fixed 8% to 10%.",
    trackNav: "home",
  },
  {
    label: "Strategy",
    href: "/strategy",
    description: "Where your capital goes: Outer Banks real estate and digital assets.",
    trackNav: "strategy",
  },
  {
    label: "About Us",
    href: "/about-us",
    description: "Meet Joe Robert and the team behind Robert Ventures.",
    trackNav: "about_us",
  },
  {
    label: "Articles",
    href: "/articles/",
    description: "Insights on investing, real estate, and digital assets.",
    trackNav: "articles",
  },
  {
    label: "Reviews",
    href: "/reviews",
    description: "What our investors say, in their own words.",
    trackNav: "reviews",
  },
  {
    label: "Contact",
    href: "/calendar",
    description: "Schedule a call with our team.",
    trackNav: "contact",
  },
];
---

<style>
  body.menu-open {
    overflow: hidden;
  }

  header {
    margin: 0;
    padding: 0 16px;
    position: relative;
    z-index: 1001; /* Ensure the header is above the mobile menu */
    background-color: var(--bg-primary);
    border-bottom: 1px solid var(--border-light);
    height: 64px;
  }

  .header-container {
    margin: 0 auto;
    height: 100%;
    display: flex;
    align-items: center;
    width: 100%;
  }
  h2 {
    margin: 0;
    padding: 0;
    font-size: 1em;
    line-height: 0;
  }

  h2 a {
    display: block;
    line-height: 0;
    margin: 0;
    padding: 0;
    text-decoration: none;
    width: fit-content;
  }

  h2 a svg {
    display: block;
    margin: 0;
    padding: 0;
  }

  .top-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 100%;
  }

  .top-nav a {
    padding: 1em 0.5em;
    color: var(--text-heading);
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }

  .top-nav h2 a {
    padding: 0;
    border-bottom: none;
  }
  .top-nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }
  .social-links,
  .social-links a {
    display: flex;
  }
  @media (max-width: 720px) {
    .social-links {
      display: none;
    }
  }

  h2 svg {
    max-height: 36px;
    width: auto;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
  }

  .hamburger__bar {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text-heading);
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease;
  }

  .hamburger.open .hamburger__bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger.open .hamburger__bar:nth-child(2) {
    opacity: 0;
  }

  .hamburger.open .hamburger__bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    top: 64px;
    left: 0;
    width: 100%;
    height: calc(100dvh - 64px);
    background: var(--bg-primary);
    z-index: 1000;
    display: flex;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    transform: translateY(12px);
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.25s ease,
      visibility 0.25s;
  }

  .mobile-menu.show {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .menu-list {
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 8px 0 16px;
  }

  .menu-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 18px 24px;
    text-decoration: none;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.35s ease,
      transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Alternating row fill so each destination reads as its own block */
  .menu-item:nth-child(odd) {
    background: var(--bg-secondary);
  }

  .mobile-menu.show .menu-item {
    opacity: 1;
    transform: translateY(0);
  }

  /* Staggered reveal: each row settles in slightly after the previous one.
     The delays only apply under .show, so closing is instant. */
  .mobile-menu.show .menu-item:nth-child(1) {
    transition-delay: 0.05s;
  }
  .mobile-menu.show .menu-item:nth-child(2) {
    transition-delay: 0.09s;
  }
  .mobile-menu.show .menu-item:nth-child(3) {
    transition-delay: 0.13s;
  }
  .mobile-menu.show .menu-item:nth-child(4) {
    transition-delay: 0.17s;
  }
  .mobile-menu.show .menu-item:nth-child(5) {
    transition-delay: 0.21s;
  }
  .mobile-menu.show .menu-item:nth-child(6) {
    transition-delay: 0.25s;
  }

  .menu-item__text {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .menu-item__title {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--text-heading);
    font-variant-numeric: lining-nums;
  }

  .menu-item__desc {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--text-body);
  }

  .menu-item__chevron {
    flex-shrink: 0;
    color: var(--text-muted);
  }

  .menu-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding: 16px 24px calc(20px + env(safe-area-inset-bottom));
    border-top: 1px solid var(--border-light);
    background: var(--bg-primary);
  }

  .menu-signin {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-body);
    margin: 0;
  }

  .menu-signin a {
    color: var(--text-heading);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .desktop-links {
    display: none;
  }

  .login-link {
    display: none;
  }

  @media only screen and (min-width: 600px) and (max-width: 1135px) {
    header {
      padding: 0 32px;
    }
  }

  @media only screen and (min-width: 768px) {
    .menu-list {
      max-width: 560px;
      margin: 0 auto;
      padding: 16px 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu,
    .menu-item,
    .hamburger__bar {
      transition: none;
    }

    .mobile-menu.show .menu-item {
      transition-delay: 0s;
    }
  }

  @media (min-width: 1024px) {
    .hamburger {
      display: none;
    }

    .mobile-menu {
      display: none;
    }

    .desktop-links {
      display: flex;
      gap: 16px;
      align-items: center;
    }

    .login-link {
      display: flex;
      align-items: center;
    }

    .top-nav {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 32px;
    }

    .top-nav h2 {
      margin-right: auto;
    }

    .desktop-links {
      justify-content: flex-end;
    }

    .login-link {
      margin-left: 0;
    }

    .desktop-links a {
      color: var(--text-heading);
      text-decoration: none;
      font-size: 1rem;
      font-weight: 500;
      font-family: var(--font-body);
      line-height: 100%; /* 1rem */
      white-space: nowrap;
      padding: 16px;
    }

    .login-link a {
      color: var(--text-heading);
      text-decoration: none;
      font-size: 1rem;
      font-weight: 500;
      font-family: var(--font-body);
      line-height: 100%; /* 1rem */
      white-space: nowrap;
    }

    .desktop-links a:hover,
    .login-link a:hover {
      text-decoration: underline;
    }

    .login-link a {
      display: inline-flex;
      padding: 0.6875rem 2rem;
      align-items: center;
      gap: 0.625rem;

      border-radius: 1.5625rem;
      border: 1px solid var(--green-brand);
      background: var(--green-brand);
      color: #ffffff;
    }
  }

  @media (min-width: 1136px) {
    header {
      padding: 0 112px;
    }
  }

  @media (min-width: 1920px) {
    header {
      padding: 0 312px;
    }
  }
</style>

<header>
  <div class="header-container">
    <nav class="top-nav">
      <h2>
        <a href="/"><Rvlogo /></a>
      </h2>
      <div class="desktop-links">
        <a href="/" data-track-nav="home" data-track-location="header">Home</a>
        <a href="/strategy" data-track-nav="strategy" data-track-location="header">Strategy</a>
        <a href="/about-us" data-track-nav="about_us" data-track-location="header">About Us</a>
        <a href="/articles/" data-track-nav="articles" data-track-location="header">Articles</a>
        <a href="/calendar" data-track-nav="contact" data-track-location="header">Contact</a>
        <a href="/reviews" data-track-nav="reviews" data-track-location="header">Reviews</a>
      </div>
      <div class="login-link">
        <a
          href="https://invest.robertventures.com/login"
          data-track-cta="sign_in"
          data-track-location="header">Sign in</a
        >
      </div>
      <button
        class="hamburger"
        id="hamburger"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobileMenu"
      >
        <span class="hamburger__bar"></span>
        <span class="hamburger__bar"></span>
        <span class="hamburger__bar"></span>
      </button>
    </nav>
    <div class="mobile-menu" id="mobileMenu">
      <nav class="menu-list" aria-label="Mobile navigation">
        {
          menuItems.map((item) => (
            <a
              href={item.href}
              class="menu-item"
              data-track-nav={item.trackNav}
              data-track-location="mobile_menu"
            >
              <span class="menu-item__text">
                <span class="menu-item__title">{item.label}</span>
                <span class="menu-item__desc">{item.description}</span>
              </span>
              <svg
                class="menu-item__chevron"
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path
                  d="M6 3.5L10.5 8L6 12.5"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </a>
          ))
        }
      </nav>
      <div class="menu-footer">
        <p class="menu-signin">
          Already an investor?
          <a
            href="https://invest.robertventures.com"
            data-track-cta="login"
            data-track-location="mobile_menu">Sign in</a
          >
        </p>
        <GetStartedCta trackCta="get_started" trackLocation="mobile_menu" />
      </div>
    </div>
  </div>

  <script>
    const hamburger = document.getElementById("hamburger");
    const mobileMenu = document.getElementById("mobileMenu");

    function setMenu(open: boolean) {
      mobileMenu.classList.toggle("show", open);
      hamburger.classList.toggle("open", open);
      hamburger.setAttribute("aria-expanded", String(open));
      hamburger.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      document.body.classList.toggle("menu-open", open);
    }

    hamburger.addEventListener("click", function () {
      setMenu(!mobileMenu.classList.contains("show"));
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && mobileMenu.classList.contains("show")) {
        setMenu(false);
      }
    });
  </script>
</header>
