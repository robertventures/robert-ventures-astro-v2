---
import Arrow from "../images/icons/right-arrow.svg";
---

<style>
  .cta-block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  a {
    text-decoration: none;
    text-align: center;
    border-radius: 8px;

    font-size: 20px;
    font-weight: 700;
    font-family: var(--font-heading);

    padding: 12px;

    max-width: 366px;
    width: 100%;

    margin: 0 auto;
  }

  .invest {
    background-color: var(--green-brand);
    border: 1px solid var(--green-brand);

    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;

    color: #ffffff;
  }

  .webinar {
    color: var(--green-brand);
    font-weight: 500;

    border: 1px solid var(--green-brand);
  }
  svg {
    width: 20px;
    height: 20px;
    transform: translateY(1px);
  }
</style>

<div class="cta-block">
  <a class="invest invest-cta-homepage-v2" href="https://invest.robertventures.com/"
    >Invest<Arrow /></a
  >
  <a class="webinar webinar-cta-homepage-v2" href="/webinar">Join Our Webinar</a>
</div>

<script>
  function triggerEvent(eventName: string) {
    if ((window as any).dataLayer) {
      (window as any).dataLayer.push({
        event: eventName,
      });
      console.log("GA4 event triggered: " + eventName);
    } else {
      console.warn("dataLayer is not defined. Ensure Google Tag Manager is properly initialized.");
    }
  }

  // Add event listeners when DOM is loaded
  document.addEventListener("DOMContentLoaded", function () {
    // Invest CTA event listeners - target all instances
    const investCTAs = document.querySelectorAll(".invest-cta-homepage-v2");
    investCTAs.forEach(function (investCTA) {
      investCTA.addEventListener("click", function () {
        triggerEvent("invest_cta_homepage_click");
      });
    });

    // Webinar CTA event listeners - target all instances
    const webinarCTAs = document.querySelectorAll(".webinar-cta-homepage-v2");
    webinarCTAs.forEach(function (webinarCTA) {
      webinarCTA.addEventListener("click", function () {
        triggerEvent("webinar_cta_homepage_click");
      });
    });
  });
</script>
