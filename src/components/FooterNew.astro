---
import Rvlogo from "../images/brand/logo-whitebg.svg";
import DisclaimerBlock from "./DisclaimerBlock.astro";

import X from "../images/socials/x.svg";
import Instagram from "../images/socials/instagram.svg";
import Linkedin from "../images/socials/linkedin.svg";
import Facebook from "../images/socials/facebook.svg";
---

<style>
  footer {
    margin-bottom: 0;
    background: var(--bg-primary);
    width: 100%;
  }

  .footer-container {
    background: var(--bg-primary);
    border-radius: 0;
    border-top: 1px solid var(--border-light);
    padding-top: 16px;
    padding-bottom: 0;
    padding-left: 16px;
    padding-right: 16px;
    text-align: left;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }

  .footer-content {
    margin: 0 auto;
  }

  .intro {
    display: flex;
    align-items: center;
    justify-content: space-between;

    margin-bottom: 1rem;
  }

  .socials {
    display: flex;
    gap: 1rem;
  }

  hr {
    border: 0;
    height: 1px;
    background: var(--border-light);
    margin: 0;
    margin-bottom: 0;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
  }

  .footer-link-lists {
    display: flex;
    justify-content: space-between;
    padding-top: 48px;
    padding-bottom: 48px;
    margin-bottom: 0;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    flex: 1;
  }

  .list a {
    text-decoration: none;
    color: var(--text-heading);
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    font-weight: 500;
    line-height: 100%;
    display: inline-block;
    width: fit-content;
  }

  .list a.phone {
    text-decoration: underline;
  }

  .risk p,
  .risk a {
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 400;
    line-height: 150%; /* 1.3125rem */

    margin-bottom: 32px;
  }

  .end {
    color: var(--text-muted);
    text-align: left;
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 100%;
    padding-top: 16px;
    padding-bottom: 16px;
    border-top: 1px solid var(--border-light);
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    padding-left: 16px;
    padding-right: 16px;
    box-sizing: border-box;
  }

  @media only screen and (min-width: 600px) and (max-width: 1135px) {
    .footer-container {
      padding-top: 16px;
      padding-bottom: 0;
      padding-left: 32px;
      padding-right: 32px;
    }

    .end {
      padding-left: 32px;
      padding-right: 32px;
    }
  }

  @media only screen and (min-width: 1136px) {
    .footer-container {
      padding-top: 16px;
      padding-bottom: 0;
      padding-left: 112px;
      padding-right: 112px;
      margin: 0;
      width: 100%;
    }

    .end {
      padding-left: 112px;
      padding-right: 112px;
    }
  }

  @media only screen and (min-width: 1920px) {
    .footer-container {
      padding-top: 16px;
      padding-bottom: 0;
      padding-left: 312px;
      padding-right: 312px;
    }

    .end {
      padding-left: 312px;
      padding-right: 312px;
    }
  }
</style>

<footer>
  <div class="footer-container">
    <div class="footer-content">
      <div class="intro">
        <a href="/"><Rvlogo /></a>

        <div class="socials">
          <a
            href="https://twitter.com/RobertVentures_"
            target="_blank"
            data-track-social="twitter"
            data-track-location="footer"><X /></a
          >
          <a
            href="https://www.instagram.com/robert_ventures/"
            target="_blank"
            data-track-social="instagram"
            data-track-location="footer"><Instagram /></a
          >
          <a
            href="https://www.linkedin.com/company/robertventures"
            target="_blank"
            data-track-social="linkedin"
            data-track-location="footer"><Linkedin /></a
          >
          <a
            href="https://www.facebook.com/Robertventures"
            target="_blank"
            data-track-social="facebook"
            data-track-location="footer"><Facebook /></a
          >
        </div>
      </div>

      <hr />

      <div class="footer-link-lists">
        <div class="list">
          <a href="/strategy" class="link" data-track-nav="strategy" data-track-location="footer">
            Strategy
          </a>
          <a href="/about-us" class="link" data-track-nav="about_us" data-track-location="footer">
            About Us
          </a>
          <a href="/articles/" class="link" data-track-nav="articles" data-track-location="footer">
            Articles
          </a>
          <a href="/calendar" class="link" data-track-nav="contact" data-track-location="footer">
            Contact
          </a>
          <a
            href="https://invest.robertventures.com/login"
            class="link"
            data-track-cta="login"
            data-track-location="footer"
          >
            Login
          </a>
        </div>

        <div class="list">
          <a href="/privacy-policy" class="link">Privacy Policy</a>
          <a href="/terms-of-use" class="link">Terms of use</a>
          <a href="/cookie-policy" class="link">Cookie Policy</a>
          <a href="/disclaimer" class="link">Disclaimer</a>
          <a
            class="phone"
            href="tel:+13024046341"
            data-track-phone="+13024046341"
            data-track-location="footer">+1 302 404 6341</a
          >
          <a
            class="phone"
            href="tel:+19195827575"
            data-track-phone="+19195827575"
            data-track-location="footer">+1 919 582 7575</a
          >
        </div>
      </div>

      <div class="risk">
        <DisclaimerBlock variant="embedded" paragraphsOnly={true} trackLocation="footer" />

        <div class="end">
          © {new Date().getFullYear()} Robert Ventures LLC. All rights reserved.
        </div>
      </div>
    </div>
  </div>
</footer>
