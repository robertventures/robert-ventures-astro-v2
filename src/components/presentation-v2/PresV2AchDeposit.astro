---
/**
 * Icon-grade illustration for the Path 1 ("Get paid every month") card: a deposit landing in a
 * plain bank-account shape, with two faded "ghosts" behind it to read as "every month". Abstract
 * line + fill in the brand palette. Not a phone-with-banking-app. Decorative; the card's copy
 * carries the meaning, so this is a labeled image.
 */
---

<div
  class="presv2-ach"
  data-reveal
  role="img"
  aria-label="A deposit lands in your bank account every month."
>
  <svg viewBox="0 0 200 96" aria-hidden="true" focusable="false">
    <!-- the account "card" -->
    <rect x="86" y="44" width="100" height="42" rx="7" class="presv2-ach__card" />
    <rect x="86" y="44" width="100" height="11" rx="7" class="presv2-ach__card-band" />
    <line x1="96" y1="68" x2="146" y2="68" class="presv2-ach__card-line" />
    <line x1="96" y1="76" x2="128" y2="76" class="presv2-ach__card-line presv2-ach__card-line--short" />

    <!-- two faded "every month" ghost deposits -->
    <g class="presv2-ach__coin presv2-ach__coin--ghost2">
      <circle cx="34" cy="22" r="13" />
      <path d="M34 15 v14 M30 19 h8 M30 25 h8" class="presv2-ach__plus" />
    </g>
    <g class="presv2-ach__coin presv2-ach__coin--ghost1">
      <circle cx="48" cy="34" r="14" />
      <path d="M48 26 v16 M43.5 31 h9 M43.5 37 h9" class="presv2-ach__plus" />
    </g>

    <!-- the arriving deposit -->
    <g class="presv2-ach__coin presv2-ach__coin--front">
      <circle cx="64" cy="48" r="16" />
      <path d="M64 39 v18 M59 44 h10 M59 51 h10" class="presv2-ach__plus" />
    </g>

    <!-- it drops into the card -->
    <path d="M80 56 q12 8 22 4" class="presv2-ach__arrow" />
    <path d="M101 62 l4 -2 l-1 5 z" class="presv2-ach__arrowhead" />
  </svg>
</div>

<style>
  .presv2-ach {
    width: 100%;
    max-width: 240px;
  }

  .presv2-ach svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .presv2-ach__card {
    fill: var(--bg-primary);
    stroke: var(--green-dark);
    stroke-width: 1.6;
  }

  .presv2-ach__card-band {
    fill: var(--green-tint);
    stroke: none;
  }

  .presv2-ach__card-line {
    stroke: var(--green-dark);
    stroke-width: 2;
    stroke-linecap: round;
    opacity: 0.55;
  }

  .presv2-ach__card-line--short {
    opacity: 0.3;
  }

  .presv2-ach__coin circle {
    fill: var(--green-tint);
    stroke: var(--green-dark);
    stroke-width: 1.6;
  }

  .presv2-ach__plus {
    fill: none;
    stroke: var(--green-dark);
    stroke-width: 1.8;
    stroke-linecap: round;
  }

  .presv2-ach__coin--ghost1 {
    opacity: 0.35;
  }

  .presv2-ach__coin--ghost2 {
    opacity: 0.18;
  }

  .presv2-ach__coin--front {
    opacity: 0;
    transform: translate(-6px, -6px);
    transition:
      opacity 0.45s ease 0.15s,
      transform 0.45s ease 0.15s;
  }

  .presv2-ach__arrow {
    fill: none;
    stroke: var(--green-dark);
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-dasharray: 40;
    stroke-dashoffset: 40;
    transition: stroke-dashoffset 0.5s ease 0.45s;
  }

  .presv2-ach__arrowhead {
    fill: var(--green-dark);
    opacity: 0;
    transition: opacity 0.2s ease 0.9s;
  }

  .presv2-ach.is-in-view .presv2-ach__coin--front {
    opacity: 1;
    transform: translate(0, 0);
  }
  .presv2-ach.is-in-view .presv2-ach__arrow {
    stroke-dashoffset: 0;
  }
  .presv2-ach.is-in-view .presv2-ach__arrowhead {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .presv2-ach__coin--front,
    .presv2-ach__arrow,
    .presv2-ach__arrowhead {
      transition: none;
      opacity: 1;
      transform: none;
      stroke-dashoffset: 0;
    }
  }
</style>
