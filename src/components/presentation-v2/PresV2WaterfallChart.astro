---
/**
 * Net-real-return chart for Beat 2 (the dark "Safe money is the lazy money" band).
 * Four steps: a typical savings/CD yield, minus taxes, minus inflation, leaving the
 * real return (which lands close to zero). Rendered as CSS bars so it stays crisp,
 * reflows, and is accessible. Designed to read on --dark-bg.
 *
 * Phase 3 will add the staggered "fall" animation on scroll-in; this is the static version.
 *
 * All rates are illustrative national directional figures and are exposed as props so
 * a reviewer can tune or blank them.
 */
interface Step {
  label: string;
  /** Percentage points. Positive for the starting yield, negative for the deductions, the leftover for the final step. */
  pct: number;
  kind: "gross" | "minus" | "left";
}

interface Props {
  grossPct?: number;
  taxPct?: number;
  inflationPct?: number;
  /** "as of" line for the caveat. */
  asOf?: string;
  class?: string;
}

const {
  grossPct = 4.0,
  taxPct = 1.0,
  inflationPct = 3.0,
  asOf = "Illustrative national figures. Yields, tax brackets, and inflation change.",
  class: className,
} = Astro.props as Props;

const leftPct = Math.round((grossPct - taxPct - inflationPct) * 10) / 10;

const steps: Step[] = [
  { label: "A typical savings or CD yield", pct: grossPct, kind: "gross" },
  { label: "Minus federal and state tax on the interest", pct: -taxPct, kind: "minus" },
  { label: "Minus what inflation takes from what those dollars buy", pct: -inflationPct, kind: "minus" },
  { label: "What you actually keep", pct: leftPct, kind: "left" },
];

const maxMagnitude = Math.max(grossPct, taxPct, inflationPct, Math.abs(leftPct), 1);
const fmt = (n: number) => `${n > 0 ? "+" : n < 0 ? "−" : ""}${Math.abs(n)}%`;

const ariaLabel = `Chart: a typical savings or CD yield of about ${grossPct} percent, minus roughly ${taxPct} points to tax and roughly ${inflationPct} points to inflation, leaves a real return of about ${leftPct} percent.`;
---

<figure class:list={["presv2-waterfall", className]} data-reveal role="img" aria-label={ariaLabel}>
  <ul class="presv2-waterfall__bars">
    {
      steps.map((s) => (
        <li class:list={["presv2-waterfall__row", `is-${s.kind}`]}>
          <span class="presv2-waterfall__label">{s.label}</span>
          <span class="presv2-waterfall__track">
            <span
              class="presv2-waterfall__bar"
              style={`width: ${Math.max((Math.abs(s.pct) / maxMagnitude) * 100, 2)}%`}
            />
            <span class="presv2-waterfall__value">{fmt(s.pct)}</span>
          </span>
        </li>
      ))
    }
  </ul>
  <figcaption class="presv2-waterfall__caption">{asOf}</figcaption>

  <table class="sr-only">
    <caption>Net real return, illustrative</caption>
    <tbody>
      {
        steps.map((s) => (
          <tr>
            <th scope="row">{s.label}</th>
            <td>{fmt(s.pct)}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</figure>

<style>
  .presv2-waterfall {
    margin: 0;
    width: 100%;
    max-width: 640px;
  }

  .presv2-waterfall__bars {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .presv2-waterfall__row {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .presv2-waterfall__label {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--dark-text-body, rgba(255, 255, 255, 0.6));
  }

  .presv2-waterfall__track {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 24px;
  }

  .presv2-waterfall__bar {
    display: block;
    height: 18px;
    border-radius: 4px;
    flex-shrink: 0;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.55s ease;
  }

  .presv2-waterfall.is-in-view .presv2-waterfall__bar {
    transform: scaleX(1);
  }

  .presv2-waterfall.is-in-view .presv2-waterfall__row:nth-child(2) .presv2-waterfall__bar {
    transition-delay: 0.18s;
  }
  .presv2-waterfall.is-in-view .presv2-waterfall__row:nth-child(3) .presv2-waterfall__bar {
    transition-delay: 0.36s;
  }
  .presv2-waterfall.is-in-view .presv2-waterfall__row:nth-child(4) .presv2-waterfall__bar {
    transition-delay: 0.54s;
  }

  @media (prefers-reduced-motion: reduce) {
    .presv2-waterfall__bar {
      transform: scaleX(1);
      transition: none;
    }
  }

  .presv2-waterfall__value {
    font-family: "Roboto Serif", serif;
    font-size: 0.9375rem;
    font-weight: 500;
    font-variant-numeric: lining-nums;
    color: #ffffff;
    white-space: nowrap;
  }

  /* The starting yield: a calm light bar. */
  .is-gross .presv2-waterfall__bar {
    background: rgba(255, 255, 255, 0.55);
  }

  /* The deductions: muted. */
  .is-minus .presv2-waterfall__bar {
    background: rgba(255, 255, 255, 0.22);
  }
  .is-minus .presv2-waterfall__label,
  .is-minus .presv2-waterfall__value {
    color: var(--dark-text-body, rgba(255, 255, 255, 0.5));
  }

  /* What's left: the point of the chart. */
  .is-left .presv2-waterfall__bar {
    background: var(--warning);
  }
  .is-left .presv2-waterfall__label {
    color: #ffffff;
    font-weight: 500;
  }
  .is-left .presv2-waterfall__value {
    color: var(--warning);
    font-size: 1.0625rem;
  }

  .presv2-waterfall__caption {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--dark-text-body, rgba(255, 255, 255, 0.4));
    margin-top: 14px;
  }

  @media only screen and (min-width: 600px) {
    .presv2-waterfall__row {
      flex-direction: row;
      align-items: center;
      gap: 16px;
    }

    .presv2-waterfall__label {
      flex: 0 0 44%;
      font-size: 0.9375rem;
    }

    .presv2-waterfall__track {
      flex: 1;
    }
  }
</style>
