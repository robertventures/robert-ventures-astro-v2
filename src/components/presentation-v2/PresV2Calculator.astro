---
/**
 * "Run your own number" calculator for Beat 3. Forked from src/sections/Calculator.astro.
 * Changes from the original:
 *  - shows BOTH outcomes at once (monthly income AND compounding total) — no compound/monthly toggle
 *  - keeps only the term toggle (10% / 3-year vs 8% / 1-year)
 *  - default amount $50,000; preset chips plus a free-entry input; no slider
 *  - adds the held-to-10-year-maturity figure and a dynamic daily-accrual line
 *  - CTA points to invest.robertventures.com (the original pointed at /webinar) and uses --green-dark
 * Designed to live inside a <details> expander; it is not a full-bleed section.
 */
import ComplianceMicroline from "../ComplianceMicroline.astro";
import PresV2Cta from "./PresV2Cta.astro";

const presets = [1000, 10000, 50000, 100000, 250000];
---

<div class="presv2-calc">
  <div class="presv2-calc__grid">
    <div class="presv2-calc__controls">
      <div class="presv2-calc__group">
        <span class="presv2-calc__label" id="pv2c-term-label">Choose your term</span>
        <div class="presv2-calc__buttons" role="group" aria-labelledby="pv2c-term-label">
          <button
            type="button"
            class="presv2-calc__btn presv2-calc__btn--term is-active"
            data-term-years="3"
            data-apy="10"
            aria-pressed="true"
          >
            <span class="presv2-calc__term-period">3-year minimum</span>
            <span class="presv2-calc__term-apy">10%</span>
          </button>
          <button
            type="button"
            class="presv2-calc__btn presv2-calc__btn--term"
            data-term-years="1"
            data-apy="8"
            aria-pressed="false"
          >
            <span class="presv2-calc__term-period">1-year minimum</span>
            <span class="presv2-calc__term-apy">8%</span>
          </button>
        </div>
      </div>

      <div class="presv2-calc__group">
        <span class="presv2-calc__label" id="pv2c-amount-label">Your amount</span>
        <div class="presv2-calc__chips" role="group" aria-labelledby="pv2c-amount-label">
          {
            presets.map((p) => (
              <button
                type="button"
                class:list={["presv2-calc__btn", "presv2-calc__btn--chip", { "is-active": p === 50000 }]}
                data-amount={p}
                aria-pressed={p === 50000 ? "true" : "false"}
              >
                ${p >= 1000 ? `${p / 1000}k` : p}
              </button>
            ))
          }
        </div>
        <label class="presv2-calc__entry">
          <span class="presv2-calc__entry-prefix" aria-hidden="true">$</span>
          <input
            type="text"
            inputmode="numeric"
            id="pv2c-amount-input"
            class="presv2-calc__entry-input"
            value="50,000"
            aria-label="Or enter an amount in dollars"
            autocomplete="off"
          />
        </label>
      </div>
    </div>

    <div class="presv2-calc__results" aria-live="polite">
      <div class="presv2-calc__result presv2-calc__result--primary">
        <span class="presv2-calc__result-label">If you compound, at the end of your <span id="pv2c-term-text">3-year</span> term</span>
        <span class="presv2-calc__result-value" id="pv2c-compound-term">$67,409</span>
      </div>
      <div class="presv2-calc__result">
        <span class="presv2-calc__result-label">If you take income, every month</span>
        <span class="presv2-calc__result-value presv2-calc__result-value--mid" id="pv2c-monthly">$417/mo</span>
      </div>
      <div class="presv2-calc__divider"></div>
      <p class="presv2-calc__sub">
        Held to the 10-year maturity, compounding:
        <strong id="pv2c-compound-10yr">$135,352</strong>
      </p>
      <p class="presv2-calc__accrual" id="pv2c-accrual">
        On $50,000, that's about $14 a day in interest that isn't running yet.
      </p>
      <ComplianceMicroline variant="projections" align="left" class="presv2-calc__disclaimer" />
      <PresV2Cta
        location="calculator"
        primaryLabel="Lock in your rate"
        ghostAsTextLink={true}
        align="left"
        class="presv2-calc__cta"
      />
    </div>
  </div>
</div>

<style>
  .presv2-calc {
    width: 100%;
  }

  .presv2-calc__grid {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .presv2-calc__controls {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .presv2-calc__group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .presv2-calc__label {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-body);
  }

  .presv2-calc__buttons {
    display: flex;
    gap: 12px;
  }

  .presv2-calc__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .presv2-calc__btn {
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    color: var(--text-heading);
    border-radius: 8px;
    cursor: pointer;
    font-family: "Roboto", sans-serif;
    transition:
      border-color 0.15s ease,
      background-color 0.15s ease;
  }

  .presv2-calc__btn.is-active {
    border-color: var(--green-dark);
    background: var(--green-tint);
  }

  .presv2-calc__btn--term {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    padding: 14px 16px;
  }

  .presv2-calc__term-period {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-body);
    line-height: 1;
  }

  .presv2-calc__term-apy {
    font-family: "Roboto Serif", serif;
    font-size: 2.25rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 1;
    font-variant-numeric: lining-nums;
  }

  .presv2-calc__btn--chip {
    padding: 10px 16px;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1;
    font-variant-numeric: lining-nums;
  }

  .presv2-calc__entry {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 10px 14px;
    background: var(--bg-primary);
    max-width: 200px;
  }

  .presv2-calc__entry:focus-within {
    border-color: var(--green-dark);
  }

  .presv2-calc__entry-prefix {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: var(--text-body);
  }

  .presv2-calc__entry-input {
    border: none;
    outline: none;
    background: transparent;
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: var(--text-heading);
    width: 100%;
    font-variant-numeric: lining-nums;
  }

  .presv2-calc__results {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .presv2-calc__result {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .presv2-calc__result-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-body);
    line-height: 1.4;
  }

  .presv2-calc__result-value {
    font-family: "Roboto Serif", serif;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 1;
    font-variant-numeric: lining-nums;
  }

  .presv2-calc__result--primary .presv2-calc__result-value {
    font-size: 2.75rem;
    color: var(--green-dark);
  }

  .presv2-calc__result-value--mid {
    font-size: 2rem;
  }

  .presv2-calc__divider {
    height: 1px;
    background: var(--border-light);
    margin: 4px 0;
  }

  .presv2-calc__sub {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-body);
    line-height: 1.5;
    margin: 0;
  }

  .presv2-calc__sub strong {
    font-family: "Roboto Serif", serif;
    color: var(--text-heading);
    font-variant-numeric: lining-nums;
    font-weight: 600;
  }

  .presv2-calc__accrual {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-heading);
    line-height: 1.5;
    margin: 4px 0 0;
  }

  .presv2-calc__disclaimer {
    margin-top: 4px;
  }

  .presv2-calc__cta {
    margin-top: 12px;
  }

  @media only screen and (min-width: 800px) {
    .presv2-calc__grid {
      flex-direction: row;
      gap: 56px;
      align-items: flex-start;
    }

    .presv2-calc__controls {
      flex: 0 0 320px;
    }

    .presv2-calc__results {
      flex: 1;
    }
  }
</style>

<script>
  (function () {
    const calc = document.querySelector<HTMLElement>(".presv2-calc");
    if (!calc) return;

    let termYears = 3;
    let apy = 0.1;
    let amount = 50000;

    const termButtons = calc.querySelectorAll<HTMLElement>("[data-term-years]");
    const chipButtons = calc.querySelectorAll<HTMLElement>("[data-amount]");
    const amountInput = calc.querySelector<HTMLInputElement>("#pv2c-amount-input");
    const termText = calc.querySelector("#pv2c-term-text");
    const elCompoundTerm = calc.querySelector("#pv2c-compound-term");
    const elMonthly = calc.querySelector("#pv2c-monthly");
    const elCompound10 = calc.querySelector("#pv2c-compound-10yr");
    const elAccrual = calc.querySelector("#pv2c-accrual");

    const usd = (n: number) =>
      new Intl.NumberFormat("en-US", {
        style: "currency",
        currency: "USD",
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      }).format(Math.round(n));

    const numAttr = (el: HTMLElement, name: string, fallback: number) => {
      const v = parseInt(el.getAttribute(name) || "", 10);
      return isNaN(v) ? fallback : v;
    };

    function setActive(buttons: NodeListOf<HTMLElement>, active: HTMLElement) {
      buttons.forEach((b) => {
        const on = b === active;
        b.classList.toggle("is-active", on);
        b.setAttribute("aria-pressed", on ? "true" : "false");
      });
    }

    function syncChips() {
      chipButtons.forEach((b) => {
        const on = numAttr(b, "data-amount", -1) === amount;
        b.classList.toggle("is-active", on);
        b.setAttribute("aria-pressed", on ? "true" : "false");
      });
    }

    function recalc() {
      const m = apy / 12;
      const compoundTerm = amount * Math.pow(1 + m, termYears * 12);
      const monthly = amount * m;
      const compound10 = amount * Math.pow(1 + m, 120);
      const dailyAccrual = (amount * apy) / 365;

      if (termText) termText.textContent = `${termYears}-year`;
      if (elCompoundTerm) elCompoundTerm.textContent = usd(compoundTerm);
      if (elMonthly) elMonthly.textContent = `${usd(monthly)}/mo`;
      if (elCompound10) elCompound10.textContent = usd(compound10);
      if (elAccrual) {
        const day = dailyAccrual < 1 ? "$1" : usd(dailyAccrual);
        elAccrual.textContent = `On ${usd(amount)}, that's about ${day} a day in interest that isn't running yet.`;
      }
    }

    function parseAmount(raw: string) {
      let n = parseInt(String(raw).replace(/[^0-9]/g, ""), 10);
      if (isNaN(n) || n < 0) n = 0;
      // Reasonable ceiling so a typo doesn't blow up the formatting.
      if (n > 100000000) n = 100000000;
      return n;
    }

    function syncInput() {
      if (amountInput) amountInput.value = amount.toLocaleString("en-US");
    }

    termButtons.forEach((b) => {
      b.addEventListener("click", () => {
        termYears = numAttr(b, "data-term-years", 3);
        apy = numAttr(b, "data-apy", 10) / 100;
        setActive(termButtons, b);
        recalc();
      });
    });

    chipButtons.forEach((b) => {
      b.addEventListener("click", () => {
        amount = numAttr(b, "data-amount", 50000);
        syncChips();
        syncInput();
        recalc();
      });
    });

    if (amountInput) {
      amountInput.addEventListener("input", () => {
        amount = parseAmount(amountInput.value);
        syncChips();
        recalc();
      });
      amountInput.addEventListener("blur", () => {
        if (amount <= 0) amount = 1000;
        syncChips();
        syncInput();
        recalc();
      });
    }

    syncInput();
    recalc();
  })();
</script>
