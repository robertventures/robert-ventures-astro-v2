---
/**
 * The compounding curve for the Path 2 ("Let it grow") card.
 * One curved line (interest on interest) over a faint straight reference line ("if it didn't
 * compound") so the gap between them is the story. Fixed, illustrative: a $10,000 bond at 10%,
 * compounding monthly, over its 10-year life. Not interactive. The curve draws itself left to
 * right when it scrolls into view (CSS transition keyed on .is-in-view; reduced-motion shows it
 * fully drawn).
 */
---

<figure
  class="presv2-curve"
  data-reveal
  role="img"
  aria-label="A $10,000 bond at 10% compounding monthly grows to about $27,000 over 10 years, versus about $20,000 if the interest were taken out instead of compounded."
>
  <svg class="presv2-curve__svg" viewBox="0 0 320 200" aria-hidden="true" focusable="false">
    <!-- baseline -->
    <line x1="0" y1="170" x2="320" y2="170" class="presv2-curve__axis" />
    <!-- "if it didn't compound" reference line -->
    <line x1="0" y1="170" x2="320" y2="81" class="presv2-curve__ref" />
    <!-- the compounding curve -->
    <path
      class="presv2-curve__line"
      d="M0 170 L64 150 L128 126 L192 97 L256 61 L320 18"
    />
    <!-- labeled points -->
    <circle cx="32" cy="161" r="3.5" class="presv2-curve__pt" />
    <circle cx="160" cy="113" r="3.5" class="presv2-curve__pt" />
    <circle cx="320" cy="18" r="4" class="presv2-curve__pt presv2-curve__pt--end" />
  </svg>

  <div class="presv2-curve__points">
    <span><b>~$11k</b> by year 1</span>
    <span><b>~$16k</b> by year 5</span>
    <span><b>~$27k</b> by year 10</span>
  </div>

  <div class="presv2-curve__legend">
    <span class="presv2-curve__key presv2-curve__key--line">Compounding (interest on interest)</span>
    <span class="presv2-curve__key presv2-curve__key--ref">If it did not compound</span>
  </div>

  <figcaption class="presv2-curve__caption">
    Illustrative: a $10,000 bond at 10%, compounding monthly. The bond rate is set by contract.
  </figcaption>
</figure>

<style>
  .presv2-curve {
    margin: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .presv2-curve__svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .presv2-curve__axis {
    stroke: var(--border-light);
    stroke-width: 1;
  }

  .presv2-curve__ref {
    stroke: var(--text-muted);
    stroke-width: 2;
    stroke-dasharray: 4 4;
    opacity: 0;
    transition: opacity 0.4s ease 0.5s;
  }

  .presv2-curve__line {
    fill: none;
    stroke: var(--green-dark);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
    transition: stroke-dashoffset 1s ease;
  }

  .presv2-curve__pt {
    fill: var(--green-dark);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .presv2-curve__pt--end {
    transition-delay: 0.9s;
  }

  .presv2-curve.is-in-view .presv2-curve__ref {
    opacity: 1;
  }

  .presv2-curve.is-in-view .presv2-curve__line {
    stroke-dashoffset: 0;
  }

  .presv2-curve.is-in-view .presv2-curve__pt {
    opacity: 1;
  }

  .presv2-curve.is-in-view .presv2-curve__pt:nth-of-type(2) {
    transition-delay: 0.3s;
  }
  .presv2-curve.is-in-view .presv2-curve__pt:nth-of-type(3) {
    transition-delay: 0.6s;
  }

  .presv2-curve__points {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    font-family: "Roboto", sans-serif;
    font-size: 0.6875rem;
    color: var(--text-body);
    line-height: 1.3;
  }

  .presv2-curve__points span {
    flex: 1;
    text-align: center;
  }

  .presv2-curve__points b {
    font-family: "Roboto Serif", serif;
    color: var(--green-dark);
    font-variant-numeric: lining-nums;
    display: block;
    font-size: 0.875rem;
  }

  .presv2-curve__legend {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    font-family: "Roboto", sans-serif;
    font-size: 0.6875rem;
    color: var(--text-body);
  }

  .presv2-curve__key {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .presv2-curve__key::before {
    content: "";
    width: 14px;
    height: 0;
    border-top-width: 3px;
    border-top-style: solid;
  }

  .presv2-curve__key--line::before {
    border-top-color: var(--green-dark);
  }

  .presv2-curve__key--ref::before {
    border-top-style: dashed;
    border-top-color: var(--text-muted);
  }

  .presv2-curve__caption {
    font-family: "Roboto", sans-serif;
    font-size: 0.6875rem;
    color: var(--text-muted);
    line-height: 1.4;
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .presv2-curve__ref,
    .presv2-curve__line,
    .presv2-curve__pt {
      transition: none;
    }
    .presv2-curve__ref,
    .presv2-curve__pt {
      opacity: 1;
    }
    .presv2-curve__line {
      stroke-dashoffset: 0;
    }
  }
</style>
