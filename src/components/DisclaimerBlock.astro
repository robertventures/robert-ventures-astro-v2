---
interface Props {
  trackLocation?: string;
  withSmsConsent?: boolean;
  smsConsentName?: string;
  variant?: "standalone" | "embedded";
  paragraphsOnly?: boolean;
}

const {
  trackLocation = "footer",
  withSmsConsent = false,
  smsConsentName = "sms_consent",
  variant = "standalone",
  paragraphsOnly = false,
} = Astro.props;

const year = new Date().getFullYear();
const wrapperClass = variant === "standalone" ? "rv-disclaimer rv-disclaimer--standalone" : "rv-disclaimer";
---

<section class={wrapperClass} aria-label="Important disclosures">
  <div class="rv-disclaimer__inner">
    {
      withSmsConsent && (
        <label class="rv-disclaimer__sms">
          <input
            type="checkbox"
            name={smsConsentName}
            value="yes"
            checked
            class="rv-disclaimer__sms-input"
          />
          <span class="rv-disclaimer__sms-text">
            I agree to receive recurring automated marketing text messages from Robert Ventures at
            the number provided. Msg & data rates may apply. Msg frequency varies. Reply STOP to
            cancel.
          </span>
        </label>
      )
    }

    <p class="rv-disclaimer__body">
      Important Risk Information: Investing involves risk. There is a potential that Robert
      Ventures Holdings LLC (the "Company") may not be able to make the scheduled payments of
      interest or principal on the bonds related to its existing securities offering. While the
      Company believes the assumptions and forward-looking statements contained throughout this
      website are reasonable, the Company cannot guarantee future results, performance, or
      achievements. Anticipated returns, expense estimates, and investor payments discussed
      throughout this website are based on the Company's assumptions and beliefs and are not
      reflective of past operations of the Company. <a
        href="https://l.robertventures.com/OfferingCircular"
        data-track-cta="offering_circular"
        data-track-location={trackLocation}
        >Robert Ventures Holdings LLC Preliminary Offering Circular</a
      >
    </p>

    <p class="rv-disclaimer__body">
      This communication is neither an offer to sell nor a solicitation of an offer to buy any
      securities. Any offer to sell or solicitation of an offer to buy securities will be made
      solely by means of the Preliminary Offering Circular. The Company's offering has been
      qualified by the U.S. Securities and Exchange Commission under Regulation A Tier 2. SEC
      qualification is a disclosure review only and does not mean the SEC has approved, passed upon
      the merits of, or recommended these securities. The bonds are unsecured general obligations
      of the Company. They are not bank deposits and are not insured by the FDIC or any government
      agency. Past performance does not guarantee future results.
    </p>

    {
      !paragraphsOnly && (
        <>
          <nav class="rv-disclaimer__links" aria-label="Legal">
            <a href="/disclaimer">Disclaimer</a>
            <a href="/privacy-policy">Privacy Policy</a>
            <a href="/terms-of-use">Terms of Use</a>
            <a href="/cookie-policy">Cookie Policy</a>
          </nav>

          <p class="rv-disclaimer__copy">© {year} Robert Ventures LLC. All rights reserved.</p>
        </>
      )
    }
  </div>
</section>

<style>
  .rv-disclaimer {
    width: 100%;
  }

  .rv-disclaimer--standalone {
    background: var(--bg-primary);
    border-top: 1px solid var(--border-light);
    padding: 24px 1.5rem 32px;
  }

  .rv-disclaimer__inner {
    max-width: 1024px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .rv-disclaimer__sms {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    cursor: pointer;
    margin: 0;
  }

  .rv-disclaimer__sms-input {
    margin-top: 2px;
    flex-shrink: 0;
    accent-color: var(--green-brand);
    width: 13px;
    height: 13px;
    cursor: pointer;
  }

  .rv-disclaimer__sms-text {
    font-family: "Roboto", sans-serif;
    font-size: 12px;
    color: var(--text-muted);
    line-height: 160%;
  }

  .rv-disclaimer__body {
    font-family: "Roboto", sans-serif;
    font-size: 12px;
    color: var(--text-muted);
    line-height: 160%;
    margin: 0;
  }

  .rv-disclaimer__body a {
    color: inherit;
    text-decoration: underline;
  }

  .rv-disclaimer__body a:hover {
    color: var(--text-body);
  }

  .rv-disclaimer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
    margin: 0;
  }

  .rv-disclaimer__links a {
    font-family: "Roboto", sans-serif;
    font-size: 12px;
    color: var(--text-muted);
    text-decoration: underline;
    line-height: 100%;
  }

  .rv-disclaimer__links a:hover {
    color: var(--text-body);
  }

  .rv-disclaimer__copy {
    font-family: "Roboto", sans-serif;
    font-size: 12px;
    color: var(--text-muted);
    line-height: 100%;
    margin: 0;
  }

  @media only screen and (min-width: 600px) {
    .rv-disclaimer--standalone {
      padding: 32px 2rem 40px;
    }
    .rv-disclaimer__body,
    .rv-disclaimer__copy,
    .rv-disclaimer__sms-text,
    .rv-disclaimer__links a {
      font-size: 13px;
    }
  }

  @media only screen and (min-width: 1136px) {
    .rv-disclaimer--standalone {
      padding: 40px 2rem 56px;
    }
  }
</style>
