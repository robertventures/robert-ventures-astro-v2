---

<section class="wf-slide" id="wf-slide-5">
  <div class="wf-slide__content">
    <h2 class="wf-slide__heading">Almost Done — Two More Questions.</h2>

    <!-- When are you looking to invest? -->
    <div class="wf-slide__question">
      <p class="wf-slide__question-label">When are you looking to invest?</p>
      <div class="wf-slide__options" id="wf-invest-timing">
        <button type="button" class="wf-slide__option-btn" data-value="ready_now">Ready Now</button>
        <button type="button" class="wf-slide__option-btn" data-value="this_month">This Month</button>
        <button type="button" class="wf-slide__option-btn" data-value="in_3_months">In 3 Months</button>
        <button type="button" class="wf-slide__option-btn" data-value="just_exploring">Just Exploring</button>
      </div>
      <input type="hidden" name="invest_timing" id="wf-invest-timing-value" />
    </div>

    <!-- What is your age range? -->
    <div class="wf-slide__question">
      <p class="wf-slide__question-label">What is your age range?</p>
      <div class="wf-slide__options" id="wf-age-range">
        <button type="button" class="wf-slide__option-btn" data-value="18-34">18 to 34</button>
        <button type="button" class="wf-slide__option-btn" data-value="35-49">35 to 49</button>
        <button type="button" class="wf-slide__option-btn" data-value="50-64">50 to 64</button>
        <button type="button" class="wf-slide__option-btn" data-value="65+">65+</button>
      </div>
      <input type="hidden" name="age_range" id="wf-age-range-value" />
    </div>

    <!-- Honeypot -->
    <input
      type="text"
      name="company"
      class="company-field"
      tabindex="-1"
      autocomplete="off"
      aria-hidden="true"
      style="position:absolute;left:-9999px;width:1px;height:1px;"
    />
    <input type="hidden" name="rtk_click_id" class="rtk-click-id" />

    <p class="wf-slide__field-error"></p>

    <button type="submit" class="wf-slide__submit">
      <span class="wf-slide__button-text">Complete</span>
      <span class="wf-slide__loader"></span>
    </button>

  </div>
</section>

<style>
  .wf-slide {
    height: 100svh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    margin: 0;
    padding: 5rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  .wf-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 480px;
    width: 100%;
    opacity: 0;
  }

  .wf-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 1.75rem;
    font-weight: 500;
    line-height: 125%;
    margin: 0;
    text-align: center;
  }

  .wf-slide__question {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
  }

  .wf-slide__question-label {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: #333333;
    margin: 0;
    text-align: center;
  }

  .wf-slide__options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    width: 100%;
  }

  .wf-slide__option-btn {
    padding: 0.875rem 0.5rem;
    border: 1.5px solid #e5e5e5;
    border-radius: 0.75rem;
    background: #ffffff;
    cursor: pointer;
    text-align: center;
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #1a1a1a;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  @media (hover: hover) {
    .wf-slide__option-btn:hover {
      border-color: var(--green-brand);
      background: rgba(235, 245, 239, 0.3);
    }
  }

  .wf-slide__option-btn.is-selected {
    border-color: var(--green-brand);
    background: #ebf5ef;
  }

  .wf-slide__field-error {
    display: none;
    color: red;
    text-align: center;
    margin: 0;
    font-size: 0.875rem;
    font-family: "Roboto", sans-serif;
  }

  .wf-slide__submit {
    font-family: "Roboto", sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: #ffffff;
    background: var(--green-brand);
    border: none;
    border-radius: 8px;
    padding: 1rem;
    width: 100%;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
    text-align: center;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  @media (hover: hover) {
    .wf-slide__submit:hover {
      background-color: var(--green-hover);
    }
  }

  .wf-slide__submit:active {
    transform: translateY(1px);
  }

  .wf-slide__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .wf-slide__loader {
    border: 2px solid #ffffff80;
    border-top: 2px solid #fff;
    border-radius: 50%;
    width: 24px;
    height: 24px;
    animation: wf-spin 1s linear infinite;
    display: none;
  }

  @keyframes wf-spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }


  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .wf-slide {
      padding: 5rem 2rem 1.5rem;
    }

    .wf-slide__heading {
      font-size: 2.25rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .wf-slide__content {
      max-width: 520px;
    }

    .wf-slide__heading {
      font-size: 2.5rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .wf-slide__content {
      max-width: 560px;
    }

    .wf-slide__heading {
      font-size: 2.75rem;
    }
  }
</style>
