<section class="wf-slide" id="wf-slide-6">
  <div class="wf-slide__content">
    <!-- Compact confirmation -->
    <div class="wf-slide__confirmed">
      <svg width="20" height="20" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="28" cy="28" r="28" fill="var(--green-brand)" />
        <path d="M18 28.5L24.5 35L38 21.5" stroke="#ffffff" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="wf-slide__confirmed-label">Webinar Confirmed</span>
      <span class="wf-slide__confirmed-date" id="wf-confirmation-session"></span>
    </div>

    <div class="wf-slide__divider"></div>

    <!-- Main CTA -->
    <div class="wf-slide__upsell">
      <h2 class="wf-slide__heading">Qualify for a Free<br />1-on-1 Strategy Call</h2>
      <p class="wf-slide__upsell-text">Go through a quick introduction to see if you're a fit — it only takes a minute.</p>
      <a href="/introduction-v2" class="wf-slide__upsell-btn">Get Started</a>
    </div>
  </div>
</section>

<style>
  .wf-slide {
    height: 100svh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: linear-gradient(to bottom, #ffffff, #f4f6f5);
    margin: 0;
    padding: 5rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  .wf-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 480px;
    width: 100%;
    opacity: 0;
  }

  /* Compact confirmation */
  .wf-slide__confirmed {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .wf-slide__confirmed-label {
    font-family: "Roboto", sans-serif;
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--green-brand);
  }

  .wf-slide__confirmed-date {
    font-family: "Roboto", sans-serif;
    font-size: 1.125rem;
    color: #888888;
  }

  /* Divider */
  .wf-slide__divider {
    width: 48px;
    height: 1px;
    background: #dddddd;
  }

  /* Upsell — main focus */
  .wf-slide__upsell {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .wf-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 2rem;
    font-weight: 500;
    line-height: 125%;
    margin: 0;
    text-align: center;
  }

  .wf-slide__upsell-text {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: #555555;
    text-align: center;
    text-wrap: balance;
    line-height: 160%;
    margin: 0;
  }

  .wf-slide__upsell-btn {
    font-family: "Roboto", sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: #ffffff;
    background: var(--green-brand);
    border: none;
    border-radius: 8px;
    padding: 1.125rem;
    width: 100%;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
    text-align: center;
    box-sizing: border-box;
    text-decoration: none;
    display: block;
  }

  @media (hover: hover) {
    .wf-slide__upsell-btn:hover {
      background-color: var(--green-hover);
    }
  }

  .wf-slide__upsell-btn:active {
    transform: translateY(1px);
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .wf-slide {
      padding: 5rem 2rem 1.5rem;
    }

    .wf-slide__heading {
      font-size: 2.5rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .wf-slide__content {
      max-width: 520px;
    }

    .wf-slide__heading {
      font-size: 2.75rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .wf-slide__content {
      max-width: 560px;
    }

    .wf-slide__heading {
      font-size: 3rem;
    }
  }
</style>
