---
import Opener from "../images/icons/caretdown.svg";
const formatAnswer = (raw: string) => {
  if (!raw) return "";
  const normalized = String(raw).trim().replace(/\r\n/g, "\n");
  const paragraphs = normalized.split(/\n{2,}/);
  return paragraphs.map((p) => `<p>${p.trim().replace(/\n/g, "<br />")}</p>`).join("");
};
const faqs = [
  {
    question: "Is it FDIC-insured? What's the real risk?",
    slug: "fdic_insured",
    answer: `No. FDIC insurance only applies to bank deposits, like savings accounts. It doesn't cover investments such as stocks, bonds, mutual funds, or REITs. Our bonds are investments, not bank deposits.

We're SEC-qualified under Regulation A Tier 2, which means our offering went through the SEC's review process, and our financials are audited annually by an independent CPA.

Like any investment, there is risk. We mitigate it through diversification across Outer Banks real estate and digital assets. Our founder, Joe Robert, has managed investor capital for 25 years, and every investor in his offerings has been repaid in full, with all interest owed.`,
  },
  {
    question: "How can we realistically pay 10% in this market?",
    slug: "how_pay_10_percent",
    answer: `Our bonds are structured as debt, not equity. The 8% and 10% rates aren't projections built on a pro forma. They're contractual obligations of the company to you as the investor.

Your capital funds Outer Banks real estate development and a long-term digital asset reserve. We build only two to three units at a time, starting the next one once a sale is pending, and the sales of those units currently fund operations and investor payments. We invest only when the timing and demand are right.`,
  },
  {
    question: "Are there any fees?",
    slug: "fees",
    answer: `No. We issue bonds directly, with no broker or third party in between, and zero intermediary or management fees. Nothing is taken from your monthly payments, so your returns are sent directly to you.`,
  },
  {
    question: "How are my investments taxed?",
    slug: "taxes",
    answer: `The same as any other interest-bearing investment. Each January you'll receive a Form 1099-INT covering all interest paid during the prior year.`,
  },
  {
    question: "Who's behind Robert Ventures?",
    slug: "experience",
    answer: `Our founder, Joe Robert, has 25 years of asset management experience: $150 million in total assets managed across real estate, mortgages, and digital assets, including 200+ properties and 1,500+ mortgage investments. In past offerings he has raised over $10 million from private investors, with every offering completed and every investor repaid in full, with all interest owed.

Robert Ventures is his SEC-qualified offering, open to both accredited and non-accredited investors. We work directly with investors, with full transparency and no middlemen.`,
  },
  {
    question: "Why are digital assets part of our strategy?",
    slug: "digital_assets",
    answer: `For the same reason we buy land on the Outer Banks: scarcity. We hold a long-term digital asset reserve, accumulated monthly, the same way institutions like BlackRock and Fidelity now do. We don't trade. Our reserve is anchored by Bitcoin, which has a fixed supply of 21 million, ever, with Ethereum as a secondary holding.

Everything is custodied at BitGo Bank & Trust, N.A., a federally chartered bank regulated by the U.S. government, with $250 million in insurance against hacks, theft, and security breaches.`,
  },
  {
    question: "Can I get my money out early?",
    slug: "early_withdrawal",
    answer: `Our bonds have a 1-year or 3-year commitment period depending on the term you choose, with a 10-year maturity. After your commitment period ends, you can request a withdrawal at any time, and we're obligated to return your capital with accrued interest within 90 days.

This is designed for long-term compound growth. If you need this money for near-term expenses, it's not the right fit.`,
  },
];
---

<style>
  section {
    background: var(--bg-secondary);
    margin-bottom: 0;
    padding: 0;
    border-top: 1px solid var(--border-light);
  }

  .section-container {
    background: transparent;
    border-radius: 0;
    padding: var(--section-pad-y) var(--section-pad-x);
    text-align: left;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }

  .section-content {
    padding: 0;
    margin: 0;
    max-width: 100%;
    width: 100%;
  }

  h3 {
    font-family: "Roboto Serif", serif;
    font-size: 32px;
    font-weight: 500;
    margin: 0 0 32px 0;
    line-height: 125%;
    text-align: center;
    color: var(--text-heading);
    font-variant-numeric: lining-nums;
  }

  .faqs {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-bottom: 0;
    align-items: start;
    max-width: 860px;
    margin-left: auto;
    margin-right: auto;
  }

  .faq-container {
    background: var(--bg-primary);
    border-radius: 8px;
    padding: 0;
    border: none;
    transition: none;
    display: flex;
    flex-direction: column;
    width: 100%;
    min-height: 0;
  }

  .accordion {
    background-color: transparent;
    cursor: pointer;
    width: 100%;
    border: none;
    text-align: left;
    outline: none;
    font-size: 15px;
    padding: 16px;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }

  button.accordion {
    color: var(--text-heading);
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    font-weight: 500;
    line-height: 150%;
  }

  button.accordion svg {
    flex-shrink: 0;
    margin-left: 16px;
    transition: transform 0.3s ease;
  }

  button.accordion.active svg {
    transform: rotate(180deg);
  }

  .active,
  .accordion:hover {
    /* background-color: #ccc; */
  }

  .panel {
    max-height: 0;
    overflow: hidden;
    background-color: transparent;
    padding: 0 16px;
    transition: max-height 0.35s ease;
  }

  .panel.expanded {
    padding: 0 16px 24px 16px;
  }

  .panel > div {
    display: block;
  }

  .panel :global(p) {
    color: var(--text-body);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.7;
    max-width: 62ch;
    margin: 0;
  }

  .panel :global(p + p) {
    margin-top: 1em;
  }

  @media only screen and (min-width: 600px) and (max-width: 1135px) {
    h3 {
      font-size: 40px;
    }
  }

  @media only screen and (min-width: 1136px) {
    .faqs {
      grid-template-columns: 1fr;
    }

    h3 {
      font-size: 40px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .panel {
      transition: none;
    }
    button.accordion svg {
      transition: none;
    }
  }
</style>

<section>
  <div class="section-container">
    <div class="section-content">
      <h3>Frequently Asked Questions</h3>
      <div class="faqs">
        {
          faqs.map((faq, index) => (
            <div class="faq-container">
              <button
                class="accordion"
                type="button"
                aria-expanded="false"
                aria-controls={`faq-panel-${index}`}
                id={`faq-button-${index}`}
                data-faq-slug={faq.slug}
              >
                {faq.question}
                <Opener />
              </button>
              <div
                class="panel"
                id={`faq-panel-${index}`}
                role="region"
                aria-labelledby={`faq-button-${index}`}
              >
                <div set:html={formatAnswer(faq.answer)} />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  function triggerEvent(eventName: string, eventData: Record<string, string> = {}) {
    if ((window as any).dataLayer) {
      (window as any).dataLayer.push({
        event: eventName,
        ...eventData,
      });
      console.log("GA4 event triggered: " + eventName, eventData);
    } else {
      console.warn("dataLayer is not defined. Ensure Google Tag Manager is properly initialized.");
    }
  }

  document.addEventListener("DOMContentLoaded", function () {
    const container = document.querySelector(".faqs");
    if (!container) return;

    // Initialize all panels to be closed
    const allPanels = container.querySelectorAll(".panel");
    allPanels.forEach((panel) => {
      panel.classList.remove("expanded");
      (panel as HTMLElement).style.maxHeight = "0";
    });

    // Clean up max-height after expand animation completes
    container.addEventListener("transitionend", function (event) {
      const panel = event.target as HTMLElement;
      if (!panel.classList.contains("panel")) return;
      if (panel.classList.contains("expanded")) {
        panel.style.maxHeight = "none";
      }
    });

    container.addEventListener("click", function (event) {
      const target = event.target;
      const button = target instanceof Element ? target.closest("button.accordion") : null;
      if (!button || !container.contains(button)) return;

      const clickedPanel = button.nextElementSibling;
      if (!clickedPanel) return;

      const isCurrentlyOpen = button.classList.contains("active");
      const allButtons = container.querySelectorAll("button.accordion");
      const allPanels = container.querySelectorAll(".panel");

      // Close all other buttons and panels
      allButtons.forEach((btn) => {
        if (btn !== button) {
          btn.classList.remove("active");
          btn.setAttribute("aria-expanded", "false");
        }
      });

      allPanels.forEach((panel) => {
        if (panel !== clickedPanel) {
          const el = panel as HTMLElement;
          if (panel.classList.contains("expanded")) {
            el.style.maxHeight = el.scrollHeight + "px";
            el.offsetHeight; // force reflow
            el.style.maxHeight = "0";
            panel.classList.remove("expanded");
          }
        }
      });

      // Toggle the clicked button and panel
      if (isCurrentlyOpen) {
        // Collapsing: animate from current height to 0
        button.classList.remove("active");
        button.setAttribute("aria-expanded", "false");
        const panel = clickedPanel as HTMLElement;
        panel.style.maxHeight = panel.scrollHeight + "px";
        panel.offsetHeight; // force reflow
        panel.style.maxHeight = "0";
        clickedPanel.classList.remove("expanded");
      } else {
        // Expanding: measure content height and animate to it
        button.classList.add("active");
        button.setAttribute("aria-expanded", "true");
        clickedPanel.classList.add("expanded");
        const panel = clickedPanel as HTMLElement;
        panel.style.maxHeight = panel.scrollHeight + "px";

        // Track FAQ open event
        const faqSlug = (button as HTMLElement).dataset.faqSlug || "unknown";
        triggerEvent("faq_clicked", { faq_question: faqSlug });
        if ((window as any).posthogTrack) {
          (window as any).posthogTrack("faq_clicked", { faq_slug: faqSlug });
        }
      }
    });
  });
</script>
