<section class="wf3-slide" id="wf3-slide-3">
  <div class="wf3-slide__content">
    <div class="wf3-slide__media">
      <div class="wf3-slide__video-wrapper">
        <div class="wf3-slide__video-placeholder">
          <!-- Replace this div with a <video> element once the file is ready -->
          <svg
            class="wf3-slide__play-icon"
            viewBox="0 0 64 64"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <circle cx="32" cy="32" r="32" fill="rgba(26, 26, 26, 0.6)"></circle>
            <polygon points="26,20 26,44 46,32" fill="#ffffff"></polygon>
          </svg>
        </div>
        <div class="wf3-slide__photo-caption">
          <span class="wf3-slide__photo-name">Joe Robert</span>
          <span class="wf3-slide__photo-role">Manager & Founder</span>
        </div>
      </div>
    </div>

    <div class="wf3-slide__text">
      <h2 class="wf3-slide__heading">Hello, I'm Joe Robert</h2>
      <p class="wf3-slide__subheading">Manager & Founder of Robert Ventures</p>

      <div class="wf3-slide__stats-grid">
        <div class="wf3-slide__stat">
          <span class="wf3-slide__stat-value">20+</span>
          <span class="wf3-slide__stat-label">Years of Experience</span>
        </div>
        <div class="wf3-slide__stat">
          <span class="wf3-slide__stat-value">100%</span>
          <span class="wf3-slide__stat-label">Payments Record</span>
        </div>
        <div class="wf3-slide__stat">
          <span class="wf3-slide__stat-value">$10M+</span>
          <span class="wf3-slide__stat-label">Raised from Private Investors</span>
        </div>
        <div class="wf3-slide__stat">
          <span class="wf3-slide__stat-value">200+</span>
          <span class="wf3-slide__stat-label">Properties Sold</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .wf3-slide {
    height: 100svh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    margin: 0;
    padding: 8rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  .wf3-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    width: 100%;
    max-width: 1136px;
  }

  /* Photo wrapper */
  .wf3-slide__media {
    opacity: 0;
    width: 100%;
  }

  .wf3-slide__video-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .wf3-slide__video-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #152429;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wf3-slide__play-icon {
    width: 64px;
    height: 64px;
    opacity: 0.8;
  }

  .wf3-slide__photo-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem;
    background: linear-gradient(to top, rgba(26, 26, 26, 0.8), transparent);
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .wf3-slide__photo-name {
    font-family: "Roboto Serif", serif;
    color: #ffffff;
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 130%;
  }

  .wf3-slide__photo-role {
    font-family: "Roboto", sans-serif;
    color: #67b78f;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 130%;
  }

  /* Text & stats */
  .wf3-slide__text {
    opacity: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .wf3-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 1.75rem;
    font-weight: 500;
    line-height: 130%;
    margin: 0;
    text-align: center;
  }

  .wf3-slide__subheading {
    font-family: "Roboto", sans-serif;
    color: #555555;
    text-align: center;
    margin: -1.65rem 0 0;
    font-weight: 400;
    font-size: 1rem;
  }

  .wf3-slide__stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .wf3-slide__stat {
    background: linear-gradient(to right, rgba(235, 245, 239, 0.5), transparent);
    border-left: 3px solid #67b78f;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .wf3-slide__stat-value {
    font-family: "Roboto Serif", serif;
    font-size: 1.75rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 100%;
  }

  .wf3-slide__stat-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    color: #555555;
    line-height: 130%;
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .wf3-slide {
      padding: 0 2rem;
    }

    .wf3-slide__content {
      gap: 3rem;
    }

    .wf3-slide__text {
      flex: 1;
      gap: 2rem;
    }

    .wf3-slide__heading {
      font-size: 2.5rem;
    }

    .wf3-slide__subheading {
      font-size: 1.25rem;
    }

    .wf3-slide__stats-grid {
      gap: 1rem;
    }

    .wf3-slide__stat {
      padding: 1.25rem;
    }

    .wf3-slide__stat-value {
      font-size: 2.25rem;
    }

    .wf3-slide__stat-label {
      font-size: 0.9375rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .wf3-slide__content {
      gap: 4rem;
    }

    .wf3-slide__heading {
      font-size: 3.25rem;
    }

    .wf3-slide__subheading {
      font-size: 1.5rem;
    }

    .wf3-slide__stat-value {
      font-size: 2.5rem;
    }

    .wf3-slide__stat-label {
      font-size: 1rem;
    }

    .wf3-slide__photo-name {
      font-size: 1.5rem;
    }

    .wf3-slide__photo-role {
      font-size: 1rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .wf3-slide__content {
      max-width: 1440px;
    }

    .wf3-slide__heading {
      font-size: 3.75rem;
    }

    .wf3-slide__subheading {
      font-size: 1.75rem;
    }

    .wf3-slide__stat-value {
      font-size: 2.75rem;
    }
  }
</style>
