---

<section class="wf3-slide" id="wf3-slide-choice">
  <div class="wf3-slide__content">
    <div class="wf3-slide__header">
      <h2 class="wf3-slide__heading">What Would You Like to Do Next?</h2>
      <p class="wf3-slide__subtitle">Choose the path that fits you best</p>
    </div>

    <div class="wf3-slide__cards">
      <a href="/webinar-v3/watch" class="wf3-card">
        <div class="wf3-card__icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="24" r="20" stroke="#67b78f" stroke-width="2" fill="none" />
            <polygon points="20,16 34,24 20,32" stroke="#67b78f" stroke-width="2" fill="none" stroke-linejoin="round" />
          </svg>
        </div>
        <div class="wf3-card__text">
          <span class="wf3-card__title">Watch the Webinar</span>
          <span class="wf3-card__desc">Deep dive at your own pace</span>
        </div>
      </a>

      <a href="/webinar-v3/live" class="wf3-card">
        <div class="wf3-card__icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="8" y="10" width="32" height="28" rx="3" stroke="#67b78f" stroke-width="2" fill="none" />
            <line x1="8" y1="18" x2="40" y2="18" stroke="#67b78f" stroke-width="2" />
            <circle cx="20" cy="30" r="3" stroke="#67b78f" stroke-width="1.5" fill="none" />
            <circle cx="28" cy="30" r="3" stroke="#67b78f" stroke-width="1.5" fill="none" />
          </svg>
        </div>
        <div class="wf3-card__text">
          <span class="wf3-card__title">Join Joe Live</span>
          <span class="wf3-card__desc">Got questions? Ask Joe directly</span>
        </div>
      </a>

      <a href="/webinar-v3/call" class="wf3-card">
        <div class="wf3-card__icon">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 16c0-1 0.5-2 1.5-2h3l2 5-2.5 2c1.5 3.5 4 6 7.5 7.5l2-2.5 5 2v3c0 1-1 1.5-2 1.5C20 32.5 15.5 28 14 16z" stroke="#67b78f" stroke-width="2" fill="none" stroke-linejoin="round" stroke-linecap="round" />
          </svg>
        </div>
        <div class="wf3-card__text">
          <span class="wf3-card__title">Book a Call</span>
          <span class="wf3-card__desc">Ready to talk? Schedule a consultation</span>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .wf3-slide {
    height: 100svh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    margin: 0;
    padding: 5rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  .wf3-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    max-width: 480px;
    width: 100%;
    opacity: 0;
  }

  .wf3-slide__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .wf3-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 2rem;
    font-weight: 500;
    line-height: 120%;
    margin: 0;
  }

  .wf3-slide__subtitle {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: #555555;
    margin: 0;
    line-height: 150%;
  }

  .wf3-slide__cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
  }

  .wf3-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #ffffff;
    border: 1.5px solid #e5e5e5;
    border-radius: 0.75rem;
    padding: 1.25rem;
    text-decoration: none;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  @media (hover: hover) {
    .wf3-card:hover {
      border-color: #67b78f;
      background: #ebf5ef;
    }
  }

  .wf3-card__icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }

  .wf3-card__icon svg {
    display: block;
  }

  .wf3-card__text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .wf3-card__title {
    font-family: "Roboto", sans-serif;
    font-weight: 600;
    font-size: 1.0625rem;
    color: #1a1a1a;
    line-height: 1.3;
  }

  .wf3-card__desc {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: #555555;
    line-height: 1.4;
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .wf3-slide {
      padding: 5rem 2rem 1.5rem;
    }

    .wf3-slide__heading {
      font-size: 2.5rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .wf3-slide__content {
      max-width: 520px;
    }

    .wf3-slide__heading {
      font-size: 2.75rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .wf3-slide__content {
      max-width: 560px;
    }

    .wf3-slide__heading {
      font-size: 3rem;
    }
  }
</style>

<script is:inline>
  (function () {
    function initWf3Slide8Animation() {
      if (!window.gsapLoaded || typeof window.gsap === "undefined") {
        return;
      }

      var gsapLib = window.gsap;

      // Fade in the content container
      var content = document.querySelector("#wf3-slide-choice .wf3-slide__content");
      if (content) {
        gsapLib.to(content, {
          opacity: 1,
          duration: 0.6,
          ease: "power2.out",
        });
      }

      // Stagger cards in from below
      var cards = document.querySelectorAll("#wf3-slide-choice .wf3-card");
      if (cards.length > 0) {
        gsapLib.from(cards, {
          y: 20,
          opacity: 0,
          duration: 0.5,
          stagger: 0.1,
          delay: 0.3,
          ease: "power2.out",
        });
      }
    }

    function startAnimation() {
      if (window.gsapLoaded && typeof window.gsap !== "undefined") {
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initWf3Slide8Animation);
        } else {
          initWf3Slide8Animation();
        }
      } else {
        window.addEventListener("gsapLoaded", function () {
          if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initWf3Slide8Animation);
          } else {
            initWf3Slide8Animation();
          }
        });
      }
    }

    startAnimation();
  })();
</script>
