<style>
  .wf3-slide {
    height: 100%;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: linear-gradient(to bottom, #ffffff, #f4f6f5);
    margin: 0;
    padding: 0 1.5rem;
    box-sizing: border-box;
  }

  /* Staircase SVG — background animation */
  #wf3-staircase-svg {
    position: absolute;
    bottom: -200px;
    right: -200px;
    width: 800px;
    height: 800px;
    min-width: 800px;
    min-height: 800px;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    opacity: 1;
  }

  #wf3-staircase-svg rect {
    fill: none;
    stroke: #bbbbbb;
    stroke-opacity: 0.15;
    stroke-width: 1;
  }

  .wf3-slide__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    width: 100%;
    max-width: 1136px;
    text-align: center;
  }

  .wf3-slide__text {
    opacity: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .wf3-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 12vw;
    font-weight: 500;
    line-height: 130%;
    margin: 0;
  }

  .wf3-slide__accent {
    color: #1a1a1a;
    position: relative;
    display: inline-block;
  }

  .wf3-slide__underline {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 5px;
    background: var(--green-brand);
    transform: scaleX(0);
    transform-origin: left;
  }

  .wf3-slide__statements {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .wf3-slide__statement {
    font-family: "Roboto Serif", serif;
    color: #555555;
    font-size: 6vw;
    font-weight: 400;
    line-height: 140%;
    margin: 0;
  }

  /* Highlights row (trust badges) */
  .wf3-slide__highlights {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .wf3-slide__highlight {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    color: #555555;
    letter-spacing: 0.02em;
  }

  .wf3-slide__highlight-divider {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #bbbbbb;
    flex-shrink: 0;
  }

  /* CTA button */
  .wf3-slide__btn {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
    background: var(--green-brand);
    border: none;
    border-radius: 8px;
    padding: 1rem 2rem;
    width: 100%;
    max-width: 480px;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
    text-align: center;
    box-sizing: border-box;
  }

  @media (hover: hover) {
    .wf3-slide__btn:hover {
      background-color: var(--green-hover);
    }
  }

  .wf3-slide__btn:active {
    transform: translateY(1px);
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .wf3-slide {
      padding: 0 2rem;
    }

    .wf3-slide__heading {
      font-size: 8vw;
    }

    .wf3-slide__statement {
      font-size: 3.25vw;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .wf3-slide__heading {
      font-size: 6rem;
    }

    .wf3-slide__statement {
      font-size: 2.25rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .wf3-slide__content {
      max-width: 1440px;
    }

    .wf3-slide__heading {
      font-size: 7rem;
    }

    .wf3-slide__statement {
      font-size: 2.625rem;
    }
  }
</style>

<script is:inline>
  (function () {
    function initWf3Slide1Animation() {
      if (!window.gsapLoaded || typeof window.gsap === "undefined") {
        return;
      }

      var gsapLib = window.gsap;

      // Staircase shimmer animation
      var svg = document.getElementById("wf3-staircase-svg");
      if (svg) {
        var rects = svg.querySelectorAll("rect");
        if (rects.length > 0) {
          gsapLib.set(rects, { strokeOpacity: 0.15 });

          var tl = gsapLib.timeline({ repeat: -1 });

          // Pause before shimmer
          tl.to({}, { duration: 3 });

          // Shimmer forward — rects brighten
          tl.to(rects, {
            strokeOpacity: 0.6,
            duration: 0.2,
            stagger: {
              amount: 0.5,
              from: "start",
            },
          });

          // Fade back — rects dim
          tl.to(rects, {
            strokeOpacity: 0.15,
            duration: 0.5,
            stagger: {
              amount: 1,
              from: "start",
            },
          });
        }
      }

      // Content entrance animation
      var textBlock = document.querySelector("#wf3-slide-1 .wf3-slide__text");
      if (textBlock) {
        gsapLib.to(textBlock, {
          opacity: 1,
          duration: 0.8,
          ease: "power2.out",
        });
      }

      // Underline animation
      var underline = document.querySelector("#wf3-slide-1 .wf3-slide__underline");
      if (underline) {
        gsapLib.to(underline, {
          scaleX: 1,
          duration: 0.6,
          delay: 0.6,
          ease: "power2.out",
        });
      }
    }

    function startAnimation() {
      if (window.gsapLoaded && typeof window.gsap !== "undefined") {
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initWf3Slide1Animation);
        } else {
          initWf3Slide1Animation();
        }
      } else {
        window.addEventListener("gsapLoaded", function () {
          if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initWf3Slide1Animation);
          } else {
            initWf3Slide1Animation();
          }
        });
      }
    }

    startAnimation();
  })();
</script>
