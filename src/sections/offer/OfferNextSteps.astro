---
// "Next steps" slide for /offer, placed directly below OfferCallToAction.
// Mirrors the design pattern and tone of the "Let's start a conversation"
// section above it: same staircase background, same gradient surface, same
// heading/subtitle type, and the same testimonial carousel beneath. Where that
// section offers one path (book a call), this one leads with the same main
// action ("Let's start a conversation") as a featured deep-fill card, then an
// "or" divider, then two white alternative cards (join a live webinar, create
// an account), each with an on-brand icon chip and a short descriptor. Warm,
// invitational, no-obligation tone.
//
// Each button carries data-track-cta + data-track-location so the global
// delegated listener in public/scripts/analytics/ctaTracking.js fires a
// `cta_click` event (GA4 + PostHog) with button_location = "offer_next_steps".
const trackLocation = "offer_next_steps";

// Testimonial data, fetched the same way as OfferCallToAction (Senja via
// /api/testimonials, live investor count via /api/stats, with a static
// fallback). Rendered into the cycling review card beneath the buttons.
interface Review {
  name: string;
  avatar: string;
  text: string;
  date: string;
  rating: number;
}

function mapSenjaToReview(raw: any): Review {
  const dateStr = raw?.date ?? raw?.created_at ?? raw?.timestamp ?? "";
  let formattedDate = "";
  if (dateStr) {
    try {
      const date = new Date(dateStr);
      formattedDate = date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
      });
    } catch (e) {
      formattedDate = dateStr;
    }
  }

  return {
    name: raw?.customer_name ?? raw?.name ?? raw?.customer?.name ?? "Anonymous",
    avatar:
      raw?.customer_avatar ??
      raw?.avatar ??
      raw?.profile_picture ??
      raw?.profile_pic ??
      raw?.customer?.avatar ??
      raw?.user?.avatar ??
      "",
    text: raw?.text ?? raw?.content ?? raw?.testimonial ?? "",
    date: formattedDate,
    rating: raw?.rating ?? raw?.stars ?? 5,
  };
}

let reviews: Review[] = [];

try {
  const apiUrl = new URL("/api/testimonials", Astro.url);
  const response = await fetch(apiUrl);
  if (response.ok) {
    const payload = await response.json();

    const rawList = Array.isArray(payload)
      ? payload
      : (payload?.testimonials ?? payload?.data ?? payload?.results ?? []);

    const approvedOnly = (rawList as any[])
      .filter((t) => t?.approved === true)
      .filter((t) => !t?.video_url && !t?.video && t?.type !== "video" && !t?.has_video)
      .map(mapSenjaToReview)
      .filter((r) => r.text && r.text.trim().length > 0);

    const nonVideoOnly = (rawList as any[])
      .filter((t) => !t?.video_url && !t?.video && t?.type !== "video" && !t?.has_video)
      .map(mapSenjaToReview)
      .filter((r) => r.text && r.text.trim().length > 0);

    reviews = approvedOnly.length > 0 ? approvedOnly : nonVideoOnly;
  }
} catch (error) {
  console.error("Failed to fetch reviews from Senja:", error);
}

let uniqueInvestors = 68;

try {
  const statsUrl = new URL("/api/stats", Astro.url);
  const statsResponse = await fetch(statsUrl);
  if (statsResponse.ok) {
    const statsData = await statsResponse.json();
    if (typeof statsData.usersWithInvestments === "number") {
      uniqueInvestors = statsData.usersWithInvestments;
    }
  }
} catch (error) {
  // Fallback value is already set
}

