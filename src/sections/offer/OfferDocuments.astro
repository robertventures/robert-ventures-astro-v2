---
// Diligence section for /offer: public offering documents, no account needed.
// Each card is a full-bleed anchor; first three open PDFs, the fourth opens
// SEC EDGAR. All links open in a new tab.
const documents = [
  {
    title: "Offering Circular",
    meta: "PDF attachment",
    href: "https://l.robertventures.com/OfferingCircular",
    slug: "offering_circular",
    icon: "pdf",
  },
  {
    title: "Sample Bond Agreement",
    meta: "PDF attachment",
    href: "/documents/sample-bond-agreement.pdf",
    slug: "sample_bond_agreement",
    icon: "pdf",
  },
  {
    title: "Delaware Initial Filing",
    meta: "PDF attachment",
    href: "/documents/delaware-initial-filing.pdf",
    slug: "delaware_initial_filing",
    icon: "pdf",
  },
  {
    title: "Full history of SEC filings",
    meta: "View on SEC.gov",
    href: "https://www.sec.gov/edgar/browse/?CIK=1991519",
    slug: "sec_filings_history",
    icon: "external",
  },
];
const trackLocation = "offer_documents";
---

<section class="offer-docs" id="offer-documents">
  <div class="offer-docs__content">
    <div class="offer-docs__heading-block" data-reveal>
      <p class="offer-docs__eyebrow">On the public record</p>
      <h2 class="offer-docs__heading">Offering Documents</h2>
      <p class="offer-docs__sub">
        No account needed. The core offering documents are publicly available.
      </p>
    </div>

    <ul class="offer-docs__list" aria-label="Offering documents" data-reveal>
      {
        documents.map((doc) => (
          <li class="offer-docs__item">
            <a
              class="offer-doc-card"
              href={doc.href}
              target="_blank"
              rel="noopener"
              data-track-document={doc.slug}
              data-track-location={trackLocation}
            >
              <span class={`offer-doc-card__icon offer-doc-card__icon--${doc.icon}`} aria-hidden="true">
                {doc.icon === "pdf" ? (
                  <svg width="20" height="24" viewBox="0 0 20 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path
                      d="M2 0C0.895 0 0 0.895 0 2V22C0 23.105 0.895 24 2 24H18C19.105 24 20 23.105 20 22V7L13 0H2Z"
                      fill="#F5F5F5"
                      stroke="#D9D9D9"
                      stroke-width="0.5"
                    />
                    <path d="M13 0V7H20L13 0Z" fill="#E8E8E8" />
                    <rect x="2" y="11" width="16" height="9" rx="1.5" fill="#E63946" />
                    <text
                      x="10"
                      y="17.6"
                      text-anchor="middle"
                      font-family="Roboto, sans-serif"
                      font-size="5"
                      font-weight="700"
                      fill="#ffffff"
                    >
                      PDF
                    </text>
                  </svg>
                ) : (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path
                      d="M14 3H21V10"
                      stroke="#1a1a1a"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M21 3L10 14"
                      stroke="#1a1a1a"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M19 13V19C19 20.105 18.105 21 17 21H5C3.895 21 3 20.105 3 19V7C3 5.895 3.895 5 5 5H11"
                      stroke="#1a1a1a"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                )}
              </span>
              <span class="offer-doc-card__text">
                <span class="offer-doc-card__title">{doc.title}</span>
                <span class="offer-doc-card__meta">{doc.meta}</span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .offer-docs {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    background: var(--bg-secondary);
    padding: 4.875rem 1.5rem;
  }

  .offer-docs__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 366px;
  }

  .offer-docs__heading-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
    text-align: center;
  }

  .offer-docs__eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.105rem;
    text-transform: uppercase;
    color: var(--green-hover);
    margin: 0;
  }

  .offer-docs__heading {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 2rem;
    line-height: 1.18;
    letter-spacing: -0.019rem;
    color: var(--text-heading);
    margin: 0;
  }

  .offer-docs__sub {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--text-body);
    margin: 0;
  }

  .offer-docs__list {
    list-style: none;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 0.75rem 0 0;
    padding: 0;
  }

  .offer-docs__item {
    display: flex;
  }

  .offer-doc-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex: 1;
    text-align: left;
    text-decoration: none;
    background: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 0.875rem 1rem;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .offer-doc-card:hover {
    border-color: var(--green-brand);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    transform: translateY(-1px);
  }

  .offer-doc-card__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 9px;
    background: var(--bg-secondary);
  }

  .offer-doc-card__text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .offer-doc-card__title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-heading);
    line-height: 1.3;
  }

  .offer-doc-card__meta {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: #8a969c;
    line-height: 1.3;
  }

  @media only screen and (min-width: 600px) {
    .offer-docs {
      padding: 2.5rem 2rem;
    }
    .offer-docs__content {
      max-width: 640px;
    }
  }

  @media only screen and (min-width: 1136px) {
    .offer-docs {
      padding: 4rem 2rem;
    }
    .offer-docs__content {
      max-width: 1100px;
    }
    .offer-docs__heading-block {
      max-width: 720px;
    }
    .offer-docs__list {
      max-width: 720px;
    }
  }

  @media only screen and (min-width: 1920px) {
    .offer-docs {
      padding: 7rem 2rem;
    }
  }
</style>
