---
// Mid-page conversion moment: a short serif prompt plus one dark featured
// action card ("Book a 10-min call"). Visually the featured card here shares
// the exact same recipe as the featured card in OfferNextSteps (same hex,
// radius, spacing) so the two sections read as one consistent CTA language
// wherever they land on the page.
---

<section class="offer-cta-mini">
  <div class="offer-cta-mini__container">
    <h2 class="offer-cta-mini__heading" data-reveal>Want to talk through the numbers?</h2>
    <p class="offer-cta-mini__subheading" data-reveal>
      Bring your questions. A real person will walk you through everything.
    </p>
    <a
      class="offer-cta-mini__card"
      href="/offer/book-call"
      data-reveal
      data-track-cta="book_call"
      data-track-location="offer_cta_mini"
    >
      <span class="offer-cta-mini__chip" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M5.5 3h2.2c.3 0 .55.2.63.48l.7 2.5c.08.28-.02.58-.25.75l-1.4 1.05c.75 1.68 2.1 3.03 3.78 3.78l1.05-1.4c.17-.23.47-.33.75-.25l2.5.7c.28.08.48.33.48.63V13.5c0 .83-.7 1.5-1.53 1.44C8.9 14.5 5.5 11.1 5.06 6.53 5 5.7 5.67 5 6.5 5"
            stroke="#ffffff"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
      </span>
      <span class="offer-cta-mini__text">
        <span class="offer-cta-mini__title">Book a 10-min call</span>
        <span class="offer-cta-mini__sub">A direct, one-on-one conversation with our team</span>
      </span>
      <span class="offer-cta-mini__arrow" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M7.5 4.5l5 5.5-5 5.5"
            stroke="#ffffff"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
      </span>
    </a>
  </div>
</section>

<style>
  .offer-cta-mini {
    background: var(--bg-primary);
    width: 100%;
    box-sizing: border-box;
    padding: 32px 24px;
  }

  .offer-cta-mini__container {
    max-width: 366px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .offer-cta-mini__heading {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 32px;
    line-height: 1.2;
    color: var(--text-heading);
    text-align: center;
    margin: 0;
  }

  .offer-cta-mini__subheading {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 18px;
    line-height: 1.5;
    color: var(--text-body);
    text-align: center;
    margin: 0;
  }

  /* Featured dark card: identical recipe to the featured card in
     OfferNextSteps (#152429, radius 14px, 18/16 padding, 44px chip). */
  .offer-cta-mini__card {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    box-sizing: border-box;
    padding: 16px 18px;
    border-radius: 14px;
    background: #152429;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .offer-cta-mini__card:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(21, 36, 41, 0.24);
  }

  .offer-cta-mini__card:active {
    transform: translateY(0);
  }

  .offer-cta-mini__chip {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.12);
  }

  .offer-cta-mini__text {
    display: flex;
    flex: 1 0 0;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .offer-cta-mini__title {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 600;
    line-height: 1.2;
    color: #ffffff;
  }

  .offer-cta-mini__sub {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    line-height: 1.3;
    color: rgba(255, 255, 255, 0.72);
  }

  .offer-cta-mini__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    opacity: 0.6;
  }

  /* This section has no dedicated tablet/desktop Figma frame: on tablet it
     stays centered with the heading + card capped at 640px, and on desktop
     (1136px and up) it is hidden entirely because it never looked balanced
     at that size. */
  @media only screen and (min-width: 600px) {
    .offer-cta-mini {
      padding: 48px 32px;
    }

    .offer-cta-mini__container {
      max-width: 640px;
    }
  }

  @media only screen and (min-width: 1136px) {
    .offer-cta-mini {
      display: none;
    }
  }
</style>
