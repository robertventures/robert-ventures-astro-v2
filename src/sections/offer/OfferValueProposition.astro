---

---

<section class="intro-slide" id="intro-slide-value-proposition">
  <div class="intro-slide__content">
    <h2 class="intro-slide__heading">Fixed 8-10%, built on real assets.</h2>
    <p class="intro-slide__body">Predictable income you can plan around.</p>

    <div class="intro-hero-video__wrapper">
      <div class="intro-hero-video__container">
        <mux-player
          id="intro-mux-player-hero"
          playback-id="f0001008WTnbtX8UDcYUFO3IMcwmMdI1MgFO2KYwH40002vQ"
          env-key="hr9aevib299lcvfdoip01jd60"
          preload="metadata"
          stream-type="on-demand"
          max-resolution="1080p"
          rendition-order="desc"
          poster="https://image.mux.com/f0001008WTnbtX8UDcYUFO3IMcwmMdI1MgFO2KYwH40002vQ/thumbnail.png?width=214&height=161&time=1"
          placeholder="https://image.mux.com/f0001008WTnbtX8UDcYUFO3IMcwmMdI1MgFO2KYwH40002vQ/thumbnail.webp?time=1&width=16"
          muted
          playsinline
          default-show-captions></mux-player>
        <div
          class="intro-hero-video__overlay"
          id="intro-mux-overlay-hero"
          role="button"
          tabindex="0"
        >
          <div class="intro-hero-video__overlay-pill">
            <svg
              class="intro-hero-video__overlay-icon intro-hero-video__overlay-icon--unmute"
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"
                fill="#ffffff"></path>
            </svg>
            <svg
              class="intro-hero-video__overlay-icon intro-hero-video__overlay-icon--play"
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path d="M8 5v14l11-7z" fill="#ffffff"></path>
            </svg>
            <span class="intro-hero-video__overlay-text intro-hero-video__overlay-text--unmute">
              Your video is playing. Click to unmute.
            </span>
            <span class="intro-hero-video__overlay-text intro-hero-video__overlay-text--play">
              Click to play
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="vp-onramp">
      <p class="vp-onramp__text">Let's walk through how it works.</p>
      <span class="vp-onramp__arrow" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M6 9l6 6 6-6"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </span>
    </div>
  </div>
</section>

<style>
  .intro-slide {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    box-sizing: border-box;
    /* Exception to the shared section rhythm: this hero ends in a downward
       scroll cue, so it carries no bottom padding. The next section's own top
       padding supplies the (tight, even) separation, keeping the chevron close
       to what it points at instead of floating above a gap. */
    padding-bottom: 0;
  }

  .intro-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    max-width: 480px;
    opacity: 0;
  }

  .intro-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 2rem;
    font-weight: 500;
    line-height: 120%;
    margin: 0;
    text-align: center;
  }

  .intro-slide__body {
    font-family: "Roboto", sans-serif;
    color: #555555;
    font-size: 1rem;
    font-weight: 400;
    line-height: 150%;
    margin: 0;
    text-align: center;
  }

  .intro-slide__heading + .intro-slide__body {
    margin-top: -0.5rem;
  }

  /* On-ramp under the hero video: a short bridge line + a downward cue that
     hands the lead from Joe's intro into the rest of the presentation.
     No content summary, just momentum to keep scrolling. Negative margin pulls
     it snug under the video. */
  .vp-onramp {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    margin-top: -0.25rem;
  }

  .vp-onramp__text {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 140%;
    margin: 0;
    text-align: center;
  }

  .vp-onramp__arrow {
    display: inline-flex;
    color: #9aa3a0;
    animation: vp-onramp-bounce 1.8s ease-in-out infinite;
  }

  .vp-onramp__arrow svg {
    width: 28px;
    height: 28px;
    display: block;
  }

  @keyframes vp-onramp-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(6px);
    }
  }

  /* Hero video: square (1:1) Mux player with one-shot unmute overlay,
     mirroring the founder-video pattern. */
  .intro-hero-video__wrapper {
    width: 100%;
    margin: 0.25rem 0;
  }

  .intro-hero-video__container {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #152429;
    border-radius: 8px;
  }

  .intro-hero-video__container mux-player {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    --media-object-fit: cover;
    --media-object-position: center;
    --time-range: none;
  }

  .intro-hero-video__container mux-player[mediaisfullscreen] {
    --time-range: initial;
  }

  .intro-hero-video__overlay {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
    background: rgba(0, 0, 0, 0.18);
  }

  .intro-hero-video__overlay.is-active {
    display: flex;
  }

  .intro-hero-video__overlay:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: -4px;
  }

  .intro-hero-video__overlay-pill {
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 999px;
    padding: 0.625rem 1rem 0.625rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.01em;
    white-space: nowrap;
    animation: intro-hero-pill-glow 2.4s ease-in-out infinite;
    pointer-events: none;
  }

  .intro-hero-video__overlay-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .intro-hero-video__overlay-icon--play {
    display: none;
    margin-left: 2px;
  }

  .intro-hero-video__overlay-text--play {
    display: none;
  }

  .intro-hero-video__overlay.is-play-mode .intro-hero-video__overlay-icon--unmute,
  .intro-hero-video__overlay.is-play-mode .intro-hero-video__overlay-text--unmute {
    display: none;
  }

  .intro-hero-video__overlay.is-play-mode .intro-hero-video__overlay-icon--play,
  .intro-hero-video__overlay.is-play-mode .intro-hero-video__overlay-text--play {
    display: inline-block;
  }

  @keyframes intro-hero-pill-glow {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(103, 183, 143, 0.55);
    }
    70% {
      box-shadow: 0 0 0 14px rgba(103, 183, 143, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .intro-hero-video__overlay-pill,
    .vp-onramp__arrow {
      animation: none;
    }
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .intro-slide__content {
      gap: 1.5rem;
      max-width: 520px;
    }

    .intro-slide__heading {
      font-size: 2.75rem;
    }

    .intro-slide__body {
      font-size: 1.125rem;
    }

    .vp-onramp__text {
      font-size: 1.25rem;
    }

    .intro-hero-video__overlay-pill {
      padding: 0.75rem 1.25rem 0.75rem 1rem;
      font-size: 0.9375rem;
    }

    .intro-hero-video__overlay-icon {
      width: 24px;
      height: 24px;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .intro-slide__content {
      max-width: 560px;
    }

    .intro-slide__heading {
      font-size: 2.75rem;
    }

    .intro-slide__body {
      font-size: 1.25rem;
    }

    .vp-onramp__text {
      font-size: 1.375rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .intro-slide__content {
      max-width: 600px;
    }

    .intro-slide__heading {
      font-size: 3rem;
    }

    .intro-slide__body {
      font-size: 1.375rem;
    }

    .vp-onramp__text {
      font-size: 1.5rem;
    }
  }
</style>
