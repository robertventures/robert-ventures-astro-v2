<script>
  // One-time on-enter animation for the growth scene. Idempotent: guarded by a
  // dataset flag so re-running (view transitions fire astro:page-load) is safe.
  function initSceneGrowth() {
    const cards = document.querySelectorAll<HTMLElement>(".scene-growth .scene-card");
    cards.forEach((card) => {
      if (card.dataset.growthInit === "true") return;
      card.dataset.growthInit = "true";

      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const countEl = card.querySelector<HTMLElement>("[data-countup]");
      const bars = card.querySelectorAll<HTMLElement>(".growth-bar__fill");

      // Reduced motion (or no support): leave the final state as-is, done.
      if (prefersReduced || !("IntersectionObserver" in window)) return;

      // Set the collapsed initial state ONLY now that JS is running, so the
      // markup's default (final) state is what non-JS users always see.
      card.classList.add("is-animating");
      bars.forEach((bar) => {
        bar.style.setProperty("--s", "0");
      });
      const target = countEl ? parseInt(countEl.dataset.target || "0", 10) : 0;
      const prefix = countEl ? countEl.dataset.prefix || "" : "";
      if (countEl && target > 0) {
        countEl.textContent = prefix + "0";
      }

      const runAnimation = () => {
        // Grow the bars to their real heights.
        bars.forEach((bar) => {
          bar.style.setProperty("--s", "1");
        });

        // Count the figure up over ~1.2s with an ease-out curve.
        if (countEl && target > 0) {
          const duration = 1200;
          const start = performance.now();
          const step = (now: number) => {
            const t = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - t, 3);
            const value = Math.round(eased * target);
            countEl.textContent = prefix + value.toLocaleString("en-US");
            if (t < 1) {
              requestAnimationFrame(step);
            } else {
              countEl.textContent = prefix + target.toLocaleString("en-US");
            }
          };
          requestAnimationFrame(step);
        }
      };

      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              runAnimation();
              obs.disconnect();
            }
          });
        },
        { threshold: 0.35 }
      );
      observer.observe(card);
    });
  }

  document.addEventListener("DOMContentLoaded", initSceneGrowth);
  document.addEventListener("astro:page-load", initSceneGrowth);
</script>
