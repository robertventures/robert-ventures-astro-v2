    .work-panel {
      position: static;
      flex: 1 1 0;
      width: 250px;
      min-width: 0;
      height: auto;
      padding: 24px;
      border-radius: 16px;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
