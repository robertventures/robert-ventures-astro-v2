<!-- Splide.js JavaScript — deferred since reviews are below the fold -->
<script
  src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js"
  defer
  is:inline></script>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    // Get page name for analytics
    function getPageName() {
      const path = window.location.pathname;
      const pageMap = {
        "/": "homepage",
        "/about-us": "about_us",
        "/reviews": "reviews",
      };
      return (
        pageMap[path] || path.replace(/^\//, "").replace(/\/$/, "").replace(/-/g, "_") || "unknown"
      );
    }

    function triggerEvent(eventName, eventData) {
      eventData = eventData || {};

      if (window.dataLayer) {
        window.dataLayer.push(Object.assign({ event: eventName }, eventData));
        console.log("GA4 " + eventName + " event triggered:", eventData);
      } else {
        console.warn(
          "dataLayer is not defined. Ensure Google Tag Manager is properly initialized."
        );
      }
    }

    // Flag to track if carousel interaction has been logged this session
    let carouselInteractionTracked = false;

    // Check sessionStorage to see if already tracked this session
    try {
      carouselInteractionTracked = sessionStorage.getItem("reviews_carousel_tracked") === "true";
    } catch (e) {
      // sessionStorage not available, use memory flag only
    }

    const splideOptions = {
      type: "slide",
      rewind: false,
      pagination: false,
      arrows: false,
      drag: true,
      snap: true,
      focus: 0,
      omitEnd: true,
      gap: "16px",
      padding: { left: "0", right: "0" },
      autoWidth: true,
      perMove: 1,
      speed: 600,
      easing: "cubic-bezier(0.25, 1, 0.5, 1)",
      flickPower: 600,
      flickMaxPages: 1,
      waitForTransition: false,
    };

    // Initialize Splide slider with the SSG-rendered fallback slides
    const splide = new Splide("#reviews-slider", splideOptions);

    splide.mount();

    // Track carousel interaction (drag/swipe) - fires once per session
    splide.on("drag", function () {
      if (!carouselInteractionTracked) {
        carouselInteractionTracked = true;
        try {
          sessionStorage.setItem("reviews_carousel_tracked", "true");
        } catch (e) {
          // sessionStorage not available
        }
        triggerEvent("reviews_carousel_interaction", {
          page_name: getPageName(),
        });
      }
    });

    // Bind read-more behavior to whichever slides are currently in the DOM.
    // Called once for the fallback slides and again after fresh data replaces them.
    function bindReadMoreHandlers() {
      const readMoreLinks = document.querySelectorAll("#reviews-slider .read-more");

      readMoreLinks.forEach((link) => {
        const quoteId = link.getAttribute("data-readmore");
        const quote = document.querySelector(
          '#reviews-slider [data-quote="' + quoteId + '"]'
        );

        if (!quote) return;

        const scrollHeight = quote.scrollHeight;
        const clientHeight = quote.clientHeight;

        if (scrollHeight <= clientHeight + 2) {
          link.style.display = "none";
          return;
        }

        link.addEventListener("click", function (e) {
          e.preventDefault();
          const isExpanded = quote.classList.contains("expanded");

          if (isExpanded) {
            quote.classList.remove("expanded");
            link.textContent = "Read more";
          } else {
            quote.classList.add("expanded");
            link.textContent = "Read less";

            triggerEvent("review_read_more_click", {
              page_name: getPageName(),
            });
          }
        });
      });
    }

    bindReadMoreHandlers();

    // Convert raw Senja testimonial to a normalized review object.
    function mapSenjaToReview(raw) {
      const dateStr = (raw && (raw.date || raw.created_at || raw.timestamp)) || "";
      let formattedDate = "";
      if (dateStr) {
        try {
          const d = new Date(dateStr);
          formattedDate = d.toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
            day: "numeric",
          });
        } catch (e) {
          formattedDate = dateStr;
        }
      }
      return {
        name:
          (raw && (raw.customer_name || raw.name || (raw.customer && raw.customer.name))) ||
          "Anonymous",
        avatar:
          (raw &&
            (raw.customer_avatar ||
              raw.avatar ||
              raw.profile_picture ||
              raw.profile_pic ||
              (raw.customer && raw.customer.avatar) ||
              (raw.user && raw.user.avatar))) ||
          "",
        text: (raw && (raw.text || raw.content || raw.testimonial)) || "",
        date: formattedDate,
        rating: (raw && (raw.rating || raw.stars)) || 5,
      };
    }

    function processTestimonials(payload) {
      if (!payload) return null;
      const rawList = Array.isArray(payload)
        ? payload
        : payload.testimonials || payload.data || payload.results || [];
      function notVideo(t) {
        return t && !t.video_url && !t.video && t.type !== "video" && !t.has_video;
      }
      const approvedOnly = rawList
        .filter((t) => t && t.approved === true)
        .filter(notVideo)
        .map(mapSenjaToReview)
        .filter((r) => r.text && r.text.trim().length > 0);
      const nonVideoOnly = rawList
        .filter(notVideo)
        .map(mapSenjaToReview)
        .filter((r) => r.text && r.text.trim().length > 0);
      return approvedOnly.length > 0 ? approvedOnly : nonVideoOnly;
    }

    function escapeHtml(s) {
      return String(s)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    // Reuse the star SVG markup that the SSG-rendered fallback slides already
    // contain in the DOM. Avoids hardcoding the SVG twice.
    function getStarInnerHtml() {
      const sampleStar = document.querySelector("#reviews-slider .star");
      return sampleStar ? sampleStar.innerHTML : "";
    }

    function getPlaceholderSrc() {
      const sampleImg = document.querySelector("#reviews-slider .reviewer-image");
      return sampleImg ? sampleImg.getAttribute("src") || "" : "";
    }

    function buildSlideHtml(review, index, starInner, placeholderSrc) {
      const starCount = Math.min(Math.max(Math.round(review.rating || 5), 1), 5);
      let starsHtml = "";
      for (let s = 0; s < starCount; s++) {
        starsHtml += '<span class="star">' + starInner + "</span>";
      }
      const avatar = review.avatar
        ? '<img src="' +
          escapeHtml(review.avatar) +
          '" alt="' +
          escapeHtml(review.name) +
          '" class="reviewer-image" loading="lazy" onerror="this.onerror=null;this.src=\'' +
          placeholderSrc +
          "';\" />"
        : '<img src="' +
          placeholderSrc +
          '" alt="' +
          escapeHtml(review.name) +
          '" class="reviewer-image" />';
      const dateHtml = review.date
        ? '<p class="review-date">' + escapeHtml(review.date) + "</p>"
        : "";
      const quoteId = index + 1;

      return (
        '<li class="splide__slide">' +
        '<div class="review-card">' +
        '<div class="reviewer-info">' +
        avatar +
        "</div>" +
        '<div class="quote-container">' +
        '<p class="quote" data-quote="' +
        quoteId +
        '">' +
        escapeHtml(review.text) +
        "</p>" +
        '<a class="read-more" data-readmore="' +
        quoteId +
        '" href="javascript:void(0)">Read more</a>' +
        "</div>" +
        '<div class="review-footer">' +
        '<div class="reviewer-details">' +
        '<div class="stars">' +
        starsHtml +
        "</div>" +
        '<p class="reviewer-name">' +
        escapeHtml(review.name) +
        "</p>" +
        "</div>" +
        dateHtml +
        "</div>" +
        "</div>" +
        "</li>"
      );
    }

    // Fetch fresh data and swap slides + investor count.
    Promise.all([
      fetch("/api/testimonials")
        .then((r) => (r.ok ? r.json() : null))
        .then(processTestimonials)
        .catch((err) => {
          console.error("Failed to fetch reviews from Senja:", err);
          return null;
        }),
      fetch("/api/stats")
        .then((r) => (r.ok ? r.json() : null))
        .catch(() => null),
    ]).then(function (results) {
      const freshReviews = results[0];
      const stats = results[1];

      if (stats && typeof stats.usersWithInvestments === "number") {
        const countEl = document.querySelector(".reviews-v2-investor-count");
        if (countEl) countEl.textContent = String(stats.usersWithInvestments);
      }

      if (!freshReviews || freshReviews.length === 0) return;

      const list = document.querySelector("#reviews-slider .splide__list");
      if (!list) return;

      const starInner = getStarInnerHtml();
      const placeholderSrc = getPlaceholderSrc();
      const newHtml = freshReviews
        .map((r, i) => buildSlideHtml(r, i, starInner, placeholderSrc))
        .join("");

      list.innerHTML = newHtml;
      splide.refresh();
      bindReadMoreHandlers();
    });
  });
</script>
