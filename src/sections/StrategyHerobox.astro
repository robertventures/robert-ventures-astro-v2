---
import { Image } from "astro:assets";
import graphAllocationImg from "../images/illustrations/graph-allocation.png";
---

<style>
  section {
    background: #ffffff;
    position: relative;
    color: var(--text-body);
    padding: 0 var(--section-pad-x);
    margin: 0;
    overflow: hidden;
  }

  .section-container {
    position: relative;
    z-index: 1;
    padding: var(--section-pad-y) 0;
    background: transparent;
    text-align: center;
    width: 100%;
    max-width: var(--content-max);
    margin: 0 auto;
  }

  h1 {
    font-size: var(--fs-hero);
    font-weight: 500;
    margin: 0;
    margin-bottom: 32px;
    line-height: 110%;
    text-decoration-style: solid;
    text-align: left;
    color: var(--text-heading);
    max-width: 640px;
    font-family: var(--font-heading);
  }

  .hero-subtitle {
    font-size: 20px;
    line-height: 150%;
    color: var(--text-body);
    text-align: left;
    margin-bottom: 32px;
    max-width: 512px;
    font-family: var(--font-body);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 32px;
    width: 100%;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 24px;
    width: 100%;
    align-items: flex-start;
  }

  .top-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .section-divider {
    width: 100%;
    height: 1px;
    background-color: var(--border-light);
    margin: 0;
  }

  .aum-section {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .aum-value {
    font-family: var(--font-heading);
    font-size: 40px;
    font-weight: 500;
    line-height: 1;
    color: var(--text-heading);
    font-variant-numeric: lining-nums;
    text-align: left;
  }

  .aum-label {
    font-family: var(--font-body);
    font-size: 24px;
    font-weight: 400;
    line-height: 100%;
    color: var(--text-heading);
    text-align: left;
  }

  .allocation-section {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
  }

  .allocation-label {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 400;
    line-height: 100%;
    color: var(--text-heading);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .allocation-bullet {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--green-brand);
    display: inline-block;
  }

  .chart-legend-wrapper {
    display: flex;
    flex-direction: row;
    gap: 32px;
    align-items: center;
    justify-content: flex-start;
    width: 100%;
    min-width: 0;
  }

  .chart-container {
    flex: 0 1 auto;
    max-height: 192px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    min-width: 0;
  }

  .chart-image {
    max-width: 100%;
    max-height: 192px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .legend {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 0 0 auto;
    align-items: flex-start;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .legend-color {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .legend-color.real-estate {
    background-color: #1f6469;
  }

  .legend-color.digital-assets {
    background-color: #79eaad;
  }

  .legend-text {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    line-height: 100%;
    color: var(--text-heading);
  }

  @media only screen and (min-width: 600px) and (max-width: 1135px) {
    h1 {
      line-height: 110%;
    }

    .aum-value {
      font-size: 40px;
    }
  }

  @media only screen and (min-width: 800px) {
    .hero-content {
      flex-direction: row;
      align-items: center;
      gap: 48px;
    }

    .hero-left {
      flex: 1;
    }

    .hero-right {
      flex: 1;
      max-width: 400px;
    }

    .chart-legend-wrapper {
      max-height: 192px;
      overflow: hidden;
    }
  }

  @media only screen and (min-width: 1136px) {
    h1 {
      margin-bottom: 32px;
      line-height: 110%;
    }

    .hero-content {
      flex-direction: row;
      align-items: center;
      gap: 64px;
    }

    .hero-left {
      flex: 1;
    }

    .hero-right {
      flex: 1;
      max-width: 480px;
    }

    .aum-value {
      font-size: 40px;
    }

    .chart-legend-wrapper {
      flex-direction: row;
      align-items: center;
    }
  }

</style>

<section>
  <div class="section-container">
    <div class="hero-content">
      <div class="hero-left">
        <h1>Dual Sector Strategy</h1>
        <p class="hero-subtitle">
          A strategy that delivers consistent fixed-rate returns, pairing the security of real
          estate with the growth of digital assets. Built on Joe Robert's 25 years of investing.
        </p>
      </div>
      <div class="hero-right">
        <div class="allocation-section">
          <div class="allocation-label">
            <span class="allocation-bullet"></span>
            Portfolio Allocation
          </div>
          <div class="chart-legend-wrapper">
            <div class="chart-container">
              <Image
                src={graphAllocationImg}
                alt="Portfolio Allocation Chart"
                class="chart-image"
              />
            </div>
            <div class="legend">
              <div class="legend-item">
                <span class="legend-color real-estate"></span>
                <span class="legend-text">75.6% Real Estate</span>
              </div>
              <div class="legend-item">
                <span class="legend-color digital-assets"></span>
                <span class="legend-text">24.4% Digital Assets</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
