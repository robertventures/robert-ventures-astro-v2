---
import Image from "astro/components/Image.astro";
import joe from "../images/joerobertaboutus.jpg";
import matheus from "../images/mattaboutus.jpg";
import eduardo from "../images/eduardoaboutus.jpg";
import william from "../images/will.jpg";
---

<style>
  section {
    background: linear-gradient(to bottom, #101b1f, #111111);
    color: #e1eeea;
    padding: 0;
    margin: 0;
  }

  .section-container {
    padding: 48px 16px;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    background: transparent;
    border-radius: 0;
  }

  .section-content {
    width: 100%;
    max-width: none;
    margin: 0;
  }

  h1 {
    font-size: 56px;
    font-weight: 500;
    margin: 0;
    margin-bottom: 32px;
    line-height: 110%;
    text-decoration-style: solid;
    text-align: left;
    color: #e1eeea;
    max-width: 640px;
    font-family: var(--font-heading);
  }

  .info p {
    color: #bfd1d7;
    text-align: left;
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 400;
    line-height: 150%;
    margin: 0;
    max-width: 512px;
    margin-bottom: 32px;
  }

  .team-cards-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    width: 100%;
  }

  .team-card {
    background: #152429;
    border-radius: 8px;
    padding: 24px;
    display: flex;
    flex-direction: column;
  }

  .team-card-full-width {
    grid-column: 1 / -1;
  }

  .team-card-image {
    width: 120px;
    height: 120px;
    border-radius: 0;
    overflow: hidden;
    flex-shrink: 0;
  }

  .team-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .team-card-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 16px;
  }

  .team-card-name {
    font-family: var(--font-body);
    font-size: 24px;
    font-weight: 500;
    color: #e1eeea;
    margin: 0;
    line-height: 100%;
  }

  .team-card-position {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: #bfd1d7;
    margin: 0;
    text-transform: none;
    letter-spacing: normal;
    line-height: 100%;
  }

  .team-card-description {
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 400;
    color: #e1eeea;
    line-height: 150%;
    margin: 0;
    margin-top: 32px;
  }

  .team-card-highlights {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    color: #e1eeea;
    line-height: 150%;
    margin: 0;
    margin-top: 16px;
    padding-left: 20px;
    list-style: disc;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .team-card-highlights li::marker {
    color: #30414d;
  }

  .track-record-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    width: 100%;
    margin-top: 32px;
  }

  .track-record-stat {
    background: linear-gradient(to right, rgba(48, 65, 77, 0.25), transparent);
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-left: 4px solid #30414d;
    padding: 16px 0 16px 16px;
  }

  .track-record-value {
    font-family: "Roboto Serif", serif;
    font-size: 28px;
    font-weight: 500;
    color: #d3fbd8;
    line-height: 100%;
    font-variant-numeric: lining-nums;
    margin: 0;
  }

  .track-record-label {
    font-size: 14px;
    color: #e1eeea;
    line-height: 100%;
    margin: 0;
  }

  @media only screen and (min-width: 600px) and (max-width: 1135px) {
    .section-container {
      padding: 64px 32px;
    }

    h1 {
      font-size: 64px;
      line-height: 110%;
    }

    .team-cards-container {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .team-card-full-width {
      grid-column: 1 / -1;
    }

    .track-record-stats {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
    }

    .track-record-stat {
      flex: 0 0 calc(50% - 8px);
      padding: 24px 0 24px 24px;
      gap: 8px;
    }

    .track-record-value {
      font-size: 40px;
    }

    .track-record-label {
      font-size: 20px;
    }
  }

  @media only screen and (min-width: 1136px) {
    .section-container {
      padding-top: 96px;
      padding-bottom: 96px;
      padding-left: 112px;
      padding-right: 112px;
      margin: 0;
      width: 100%;
    }

    h1 {
      margin-bottom: 32px;
      font-size: 80px;
      line-height: 110%;
    }

    .team-cards-container {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }

    .team-card-full-width {
      grid-column: 1 / -1;
    }

    .track-record-stats {
      display: flex;
      flex-direction: row;
    }

    .track-record-stat {
      flex: 1;
      padding: 24px 0 24px 24px;
      gap: 8px;
    }

    .track-record-value {
      font-size: 40px;
    }

    .track-record-label {
      font-size: 20px;
    }
  }

  @media only screen and (min-width: 1920px) {
    .section-container {
      padding-top: 96px;
      padding-bottom: 96px;
      padding-left: 312px;
      padding-right: 312px;
    }
  }
</style>

<section>
  <div class="section-container">
    <div class="section-content">
      <h1>Meet the Team</h1>
      <div class="info">
        <p>Our mission is to help investors grow and protect their wealth.</p>
      </div>
      <div class="team-cards-container">
        <div class="team-card team-card-full-width">
          <div class="team-card-image">
            <Image src={joe} alt="Joe Robert" width={120} height={120} densities={[1.5, 2]} quality={90} />
          </div>
          <div class="team-card-header">
            <h3 class="team-card-name">Joe Robert</h3>
            <p class="team-card-position">Manager of Operations and Founder</p>
          </div>
          <p class="team-card-description">
            Joe Robert is the Manager and Founder of Robert Ventures with over 20 years of asset
            management experience in real estate investing. He has raised capital from individuals
            and partners that he paid double-digit returns annually for years.
          </p>
          <div class="track-record-stats">
            <div class="track-record-stat">
              <span class="track-record-value">20 yrs</span>
              <span class="track-record-label">Experience</span>
            </div>
            <div class="track-record-stat">
              <span class="track-record-value">200+</span>
              <span class="track-record-label">Properties</span>
            </div>
            <div class="track-record-stat">
              <span class="track-record-value">1,500+</span>
              <span class="track-record-label">Mortgages</span>
            </div>
            <div class="track-record-stat">
              <span class="track-record-value">40+</span>
              <span class="track-record-label">Tech Investments</span>
            </div>
          </div>
        </div>

        <div class="team-card">
          <div class="team-card-image">
            <Image src={matheus} alt="Matt Brandão" width={120} height={120} densities={[1.5, 2]} quality={90} />
          </div>
          <div class="team-card-header">
            <h3 class="team-card-name">Matt Brandão</h3>
            <p class="team-card-position">Investor Relations</p>
          </div>
          <p class="team-card-description">
            Matheus leverages his dual expertise in economics and accounting to manage investor
            relations and ensure the highest financial standards at Robert Ventures.
          </p>
          <ul class="team-card-highlights">
            <li>PwC wealth management background</li>
            <li>Economics and Accounting degree</li>
            <li>Onboarded investors over the last year</li>
            <li>3.5 years at the company</li>
          </ul>
        </div>

        <div class="team-card">
          <div class="team-card-image">
            <Image src={eduardo} alt="Eduardo De Matos" width={120} height={120} densities={[1.5, 2]} quality={90} />
          </div>
          <div class="team-card-header">
            <h3 class="team-card-name">Eduardo De Matos</h3>
            <p class="team-card-position">Engineering & Analytics</p>
          </div>
          <p class="team-card-description">
            Eduardo leads the technology, analytics, and AI systems that power the Robert Ventures
            investor platform.
          </p>
          <ul class="team-card-highlights">
            <li>Built the Robert Ventures investor platform</li>
            <li>Manages reporting and investor analytics</li>
            <li>8+ years in financial technology</li>
            <li>2.5 years at the company</li>
          </ul>
        </div>

        <div class="team-card">
          <div class="team-card-image">
            <Image src={william} alt="William Forte" width={120} height={120} densities={[1.5, 2]} quality={90} />
          </div>
          <div class="team-card-header">
            <h3 class="team-card-name">William Forte</h3>
            <p class="team-card-position">Customer Relations & Business Development</p>
          </div>
          <p class="team-card-description">
            William drives investor outreach and CRM operations, ensuring every investor and lead
            receives a seamless, personal experience from first contact onward.
          </p>
          <ul class="team-card-highlights">
            <li>Leads investor and lead outreach</li>
            <li>Manages CRM and pipeline operations</li>
            <li>Background in client relationship management</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
