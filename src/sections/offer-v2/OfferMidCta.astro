---
// Mid-page CTA for /offer, placed right after the rate options
// (OfferBondOfferings) and before the compounding section. A lighter,
// shorter counterpart to the bottom CTA (OfferNextSteps): a primary
// "Book a 10-min call" button, a secondary "Create your account" link,
// and a compact, stat-only social-proof line. White background so it reads
// as a distinct band between the two #f4f6f5 sections around it; reuses the
// bottom CTA's vocabulary (staircase motif + dark pill button) otherwise.
//
// The button carries data-track-cta + data-track-location so the global
// delegated listener in public/scripts/analytics/ctaTracking.js fires a
// `cta_click` event (GA4 + PostHog) with button_location = "offer_mid_cta".
const trackLocation = "offer_mid_cta";

// Live investor count, fetched the same way as OfferNextSteps/OfferCallToAction
// (via /api/stats, with a static fallback). Stat-only here, so no testimonials.
let uniqueInvestors = 68;

try {
  const statsUrl = new URL("/api/stats", Astro.url);
  const statsResponse = await fetch(statsUrl);
  if (statsResponse.ok) {
    const statsData = await statsResponse.json();
    if (typeof statsData.usersWithInvestments === "number") {
      uniqueInvestors = statsData.usersWithInvestments;
    }
  }
} catch (error) {
  // Fallback value is already set
}

const starSvg = `<svg width="13" height="12" viewBox="0 0 13 12" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5.30273 0.52603C5.53081 -0.175921 6.52388 -0.175919 6.75196 0.526032L7.6524 3.2973C7.7544 3.61122 8.04693 3.82376 8.37701 3.82376H11.2909C12.029 3.82376 12.3358 4.76823 11.7387 5.20206L9.38135 6.9148C9.11431 7.10881 9.00257 7.45271 9.10457 7.76663L10.005 10.5379C10.2331 11.2398 9.42968 11.8236 8.83256 11.3897L6.47518 9.677C6.20814 9.48298 5.84655 9.48298 5.57951 9.677L3.22213 11.3897C2.62501 11.8236 1.8216 11.2399 2.04968 10.5379L2.95012 7.76663C3.05211 7.45271 2.94038 7.10881 2.67334 6.9148L0.315955 5.20206C-0.28116 4.76823 0.0257183 3.82376 0.763793 3.82376H3.67768C4.00775 3.82376 4.30029 3.61122 4.40229 3.2973L5.30273 0.52603Z" fill="#FBBF24"/></svg>`;
---

<section class="intro-slide intro-slide--spacious" id="offer-mid-cta">
  <!-- Staircase SVG animation — background element (unique id so its GSAP
       timeline doesn't collide with the CTA / next-steps staircases). -->
  <svg
    class="intro-slide__staircase"
    width="800"
    height="800"
    xmlns="http://www.w3.org/2000/svg"
    id="offer-mid-cta-staircase-svg"
  >
    <rect x="0.5" y="735.5" width="64" height="64"></rect>
    <rect x="80.5" y="655.5" width="64" height="64"></rect>
    <rect x="80.5" y="735.5" width="64" height="64"></rect>
