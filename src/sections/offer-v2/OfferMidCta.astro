    <rect x="720.5" y="335.5" width="64" height="64"></rect>
    <rect x="720.5" y="415.5" width="64" height="64"></rect>
    <rect x="720.5" y="495.5" width="64" height="64"></rect>
    <rect x="720.5" y="575.5" width="64" height="64"></rect>
