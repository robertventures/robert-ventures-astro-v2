<section class="intro-slide intro-slide--dark" id="intro-slide-math">
  <div class="intro-slide__content">
    <p class="m-eyebrow">Not a projection. Just math.</p>
    <h2 class="m-heading">10% compounded monthly. Up to 17% a year, on average.</h2>
    <p class="m-body">
      A fixed rate, set the day you invest. It does not move when the markets do.
    </p>

    <div class="m-card">
      <div class="m-bars" aria-hidden="true">
        <div class="m-bar-col">
          <span class="m-bar-cap">Today</span>
          <div class="m-bar" style="height: 30px; background: #3a5560;"></div>
        </div>
        <div class="m-bar-col">
          <div class="m-bar" style="height: 56px; background: #4e7a63;"></div>
        </div>
        <div class="m-bar-col">
          <div class="m-bar" style="height: 88px; background: #67b78f;"></div>
        </div>
        <div class="m-bar-col">
          <span class="m-bar-cap m-bar-cap--accent">Year 10</span>
          <div class="m-bar" style="height: 140px; background: #8fe0b4;"></div>
        </div>
      </div>

      <div class="m-result">
        <div class="m-result__side">
          <span class="m-result__label">You invest</span>
          <span class="m-result__value">$10,000</span>
        </div>
        <span class="m-result__arrow" aria-hidden="true">&rarr;</span>
        <div class="m-result__side m-result__side--right">
          <span class="m-result__label">Becomes about</span>
          <span class="m-result__value m-result__value--accent">$27,070</span>
        </div>
      </div>
    </div>

    <p class="m-disclaimer">
      For illustrative purposes only. Not APY. Not IRR. Compound interest at the stated rate,
      monthly, over the bonds' full 10-year maturity.
    </p>
  </div>
</section>

