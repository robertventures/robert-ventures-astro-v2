---
import { Image } from "astro:assets";
import outerBanks3 from "../../assets/outer-banks/outer-banks-3.jpg";

const investUrl = "https://invest.robertventures.com/";
const trackLocation = "offer_v2_hero";
---

<section class="offer-hero" id="offer-hero">
  <div class="offer-hero__bg" aria-hidden="true">
    <Image
      src={outerBanks3}
      alt=""
      widths={[800, 1400, 1920]}
      sizes="100vw"
      format="webp"
      quality={70}
      class="offer-hero__img"
    />
    <div class="offer-hero__scrim"></div>
  </div>

  <div class="offer-hero__inner">
    <div class="offer-hero__text">
      <p class="offer-hero__eyebrow">For the saver who's done everything right</p>
      <h1 class="offer-hero__heading">You did everything right.<br />Your money didn't.</h1>
      <p class="offer-hero__body">
        Savings sitting still. A renewal smaller than last year. Money you worked for, earning
        almost nothing back.
      </p>
      <div class="offer-hero__cta">
        <a
          class="offer-hero__button"
          href={investUrl}
          data-track-cta="create_account"
          data-track-location={trackLocation}>Create your account</a
        >
        <span class="offer-hero__note">Free to open. Invest when you're ready.</span>
      </div>
    </div>

    <div class="offer-hero__chart">
      <p class="offer-hero__chart-label">Where your money is vs. where it could be</p>
      <svg
        viewBox="0 0 380 150"
        role="img"
        aria-label="Money left where it is stays flat while money put to work rises away"
      >
        <defs>
          <linearGradient id="v3-wedge" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#67b78f" stop-opacity=".30"></stop>
            <stop offset="1" stop-color="#67b78f" stop-opacity="0"></stop>
          </linearGradient>
        </defs>
        <path
          d="M16 112 C150 112 250 60 364 26 L364 118 C250 116 150 115 16 113 Z"
          fill="url(#v3-wedge)"></path>
        <path
          d="M16 112 C150 112 250 60 364 26"
          fill="none"
          stroke="#67b78f"
          stroke-width="11"
          stroke-linecap="round"
          opacity=".15"></path>
        <path
          d="M16 113 C150 115 250 116 364 118"
          fill="none"
          stroke="#93a8b0"
          stroke-width="8"
          stroke-linecap="round"
          opacity=".12"></path>
        <path
          d="M16 112 C150 112 250 60 364 26"
          fill="none"
          stroke="#8fe0b4"
          stroke-width="3.5"
          stroke-linecap="round"></path>
        <path
          d="M16 113 C150 115 250 116 364 118"
          fill="none"
          stroke="#aec2c9"
          stroke-width="3"
          stroke-linecap="round"></path>
        <circle cx="16" cy="112" r="4" fill="#ffffff" opacity=".85"></circle>
        <circle cx="364" cy="118" r="5" fill="#aec2c9"></circle>
        <circle cx="364" cy="26" r="10" fill="#8fe0b4" opacity=".22"></circle>
        <circle cx="364" cy="26" r="5" fill="#8fe0b4"></circle>
        <text x="20" y="135" font-family="Roboto, sans-serif" font-size="12.5" fill="#9db2b8"
          >Where it is now</text
        >
        <text
          x="360"
          y="14"
          text-anchor="end"
          font-family="Roboto, sans-serif"
          font-size="12.5"
          font-weight="600"
          fill="#8fe0b4">Where it could be</text
        >
      </svg>
    </div>
  </div>

  <!-- Mobile-only scroll cue. Hidden at >=600px, where the CTA button carries the action. -->
  <button class="offer-hero__seehow" type="button" aria-label="Scroll to see how it works">
    <span>See how</span>
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
      <path
        d="M6 9l6 6 6-6"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </button>
</section>

<style>
  .offer-hero {
    position: relative;
    width: 100%;
    min-height: 620px;
    /* Cap the height so tall screens don't inflate the hero past the design.
       Dial the 660px cap up/down to taste; 560px floors it on short screens. */
    min-height: clamp(560px, 86svh, 660px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: #0e1b20;
    box-sizing: border-box;
  }

  /* Background photo + scrim */
  .offer-hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .offer-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }
  .offer-hero__scrim {
    position: absolute;
    inset: 0;
    /* Keep the sky visible up top, then darken hard through the lower half
       where the eyebrow, heading, and body sit, so the text stays legible over
       the bright sky and house behind it. */
    background: linear-gradient(
      180deg,
      rgba(14, 27, 32, 0.35) 0%,
      rgba(14, 27, 32, 0.15) 26%,
      rgba(14, 27, 32, 0.62) 52%,
      rgba(14, 27, 32, 0.88) 76%,
      rgba(14, 27, 32, 0.98) 100%
    );
  }

  /* Content wrapper, anchored to the bottom of the hero */
  .offer-hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 0 1.25rem 4.5rem;
  }

  .offer-hero__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 1rem;
    max-width: 620px;
  }

  .offer-hero__eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #b4e2c9;
    margin: 0;
    /* Dark halo so the small mint text separates from bright patches behind it. */
    text-shadow:
      0 1px 3px rgba(0, 0, 0, 0.6),
      0 0 14px rgba(0, 0, 0, 0.45);
  }

  .offer-hero__heading {
    font-family: var(--font-heading);
    color: #ffffff;
    font-size: clamp(2.25rem, 10vw, 2.875rem);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.4);
  }

  .offer-hero__body {
    font-family: var(--font-body);
    color: #dce7ea;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    max-width: 34rem;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.55);
  }

  /* CTA. Hidden on mobile (the "See how" cue carries the action there). */
  .offer-hero__cta {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.625rem;
    margin-top: 0.25rem;
  }
  .offer-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.75rem;
    border-radius: 8px;
    background: var(--green-brand);
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
  }
  .offer-hero__button:hover {
    background: var(--green-hover);
  }
  .offer-hero__button:active {
    transform: translateY(1px);
  }
  .offer-hero__note {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: #9db6bd;
  }

  /* Chart */
  .offer-hero__chart {
    width: 100%;
    max-width: 420px;
  }
  .offer-hero__chart-label {
    display: none;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #9db2b8;
    margin: 0 0 0.75rem;
  }
  .offer-hero__chart svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  /* Mobile-only "See how" scroll cue, pinned to the hero bottom edge */
  .offer-hero__seehow {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    background: transparent;
    color: #cfdde1;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .offer-hero__seehow svg {
    animation: offer-hero-bob 2s ease-in-out infinite;
  }
  @keyframes offer-hero-bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(4px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .offer-hero__seehow svg {
      animation: none;
    }
  }

  /* Tablet and up: show the CTA, hide the mobile scroll cue */
  @media only screen and (min-width: 600px) {
    .offer-hero__inner {
      padding: 0 2.5rem 3.5rem;
      gap: 1.75rem;
    }
    .offer-hero__heading {
      font-size: 3rem;
    }
    .offer-hero__body {
      font-size: 1.125rem;
    }
    .offer-hero__cta {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 1rem;
    }
    .offer-hero__note {
      max-width: 12rem;
    }
    .offer-hero__seehow {
      display: none;
    }
  }

  /* Desktop: text lower-left, chart lower-right */
  @media only screen and (min-width: 1136px) {
    .offer-hero {
      min-height: max(680px, 88svh);
    }
    .offer-hero__inner {
      display: grid;
      grid-template-columns: minmax(0, 620px) minmax(0, 1fr);
      align-items: end;
      column-gap: 3rem;
      max-width: 1600px;
      margin: 0 auto;
      padding: 0 4rem 4.5rem;
    }
    .offer-hero__heading {
      font-size: 3.5rem;
    }
    .offer-hero__chart {
      justify-self: end;
      max-width: 460px;
      margin-bottom: 0.25rem;
    }
    .offer-hero__chart-label {
      display: block;
      text-align: right;
    }
  }
</style>

<script>
  // "See how" cue: scroll to the next section, or one viewport down if the
  // hero is still the only section on the page.
  const cue = document.querySelector(".offer-hero__seehow");
  if (cue) {
    cue.addEventListener("click", () => {
      const hero = document.getElementById("offer-hero");
      const next = hero && hero.nextElementSibling;
      if (next) next.scrollIntoView({ behavior: "smooth", block: "start" });
      else window.scrollTo({ top: window.innerHeight, behavior: "smooth" });
    });
  }
</script>
