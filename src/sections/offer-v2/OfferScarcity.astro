---
import { Image } from "astro:assets";
// Placeholder photo for the real-estate card. Swap for the finished-home interior
// used in the design whenever it's available.
import outerBanks2 from "../../assets/outer-banks/outer-banks-2.jpg";
---

<section class="intro-slide" id="intro-slide-scarcity">
  <div class="intro-slide__content">
    <p class="sc-eyebrow">What your capital funds</p>
    <h2 class="sc-heading">Two things the world can't make more of.</h2>
    <p class="sc-intro">
      On the Outer Banks we develop scarce coastal land into homes and sell them. Every month we
      accumulate digital assets and hold them. One fixed-rate bond, two scarce assets.
    </p>

    <div class="sc-cards">
      <article class="sc-card">
        <div class="sc-card__media">
          <Image
            src={outerBanks2}
            alt="A finished Outer Banks home"
            widths={[600, 1000, 1200]}
            sizes="(min-width: 1136px) 520px, 90vw"
            format="webp"
            quality={75}
            class="sc-card__img"
          />
        </div>
        <div class="sc-card__body">
          <p class="sc-card__eyebrow">Outer Banks</p>
          <h3 class="sc-card__title">Finite by geography</h3>
          <p class="sc-card__desc">
            88% of Dare County is protected. Prices doubled in 9 years ($311K to $622K).
          </p>
        </div>
      </article>

      <article class="sc-card sc-card--dark">
        <div class="sc-card__figure">
          <span class="sc-card__figure-value">21,000,000</span>
          <span class="sc-card__figure-label">Total supply. Ever.</span>
        </div>
        <div class="sc-card__body">
          <p class="sc-card__eyebrow">Digital assets</p>
          <h3 class="sc-card__title">A cap no one can change</h3>
          <p class="sc-card__desc">
            We accumulate digital assets monthly and hold them as a long-term reserve, custodied at
            BitGo.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .intro-slide {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    box-sizing: border-box;
    padding: 3rem 1.25rem 3rem 1.25rem;
  }

  .intro-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    max-width: 640px;
    text-align: center;
  }

  .sc-eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #4e9a74;
    margin: 0;
  }

  .sc-heading {
    font-family: var(--font-heading);
    color: #1a1a1a;
    font-size: 2rem;
    font-weight: 500;
    line-height: 1.16;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .sc-intro {
    font-family: var(--font-body);
    color: #555555;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    max-width: 34rem;
  }

  .sc-cards {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .sc-card {
    background: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(21, 36, 41, 0.06);
    text-align: left;
    display: flex;
    flex-direction: column;
  }

  .sc-card__media {
    width: 100%;
  }

  .sc-card__img {
    display: block;
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  /* Dark "figure" block replaces the design's supply-number visual. */
  .sc-card__figure {
    min-height: 200px;
    background: #152429;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.5rem;
    text-align: center;
  }

  .sc-card__figure-value {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 500;
    color: #8fe0b4;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .sc-card__figure-label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #9db2b8;
  }

  .sc-card__body {
    padding: 1.125rem 1.25rem 1.375rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .sc-card__eyebrow {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #4e9a74;
    margin: 0;
  }

  .sc-card__title {
    font-family: var(--font-heading);
    font-size: 1.375rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 1.25;
    margin: 0;
  }

  .sc-card__desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: #555555;
    line-height: 1.5;
    margin: 0;
  }

  @media only screen and (min-width: 600px) {
    .intro-slide__content {
      gap: 1.5rem;
    }
    .sc-heading {
      font-size: 2.5rem;
    }
    .sc-intro {
      font-size: 1.0625rem;
    }
    .sc-card__img,
    .sc-card__figure {
      height: 240px;
      min-height: 240px;
    }
    .sc-card__figure-value {
      font-size: 2.5rem;
    }
    .sc-card__title {
      font-size: 1.5rem;
    }
    .sc-card__desc {
      font-size: 0.9375rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .intro-slide__content {
      max-width: var(--content-max-wide);
    }
    .sc-heading {
      font-size: 2.75rem;
    }
    .sc-cards {
      flex-direction: row;
      gap: 1.5rem;
      margin-top: 1rem;
    }
    .sc-card {
      flex: 1;
      min-width: 0;
    }
  }

  /* Self-contained outer spacing (previously provided by the page shell). */
  @media only screen and (min-width: 600px) {
    .intro-slide {
      padding: 4rem 2rem 4rem 2.5rem;
    }
  }
  @media only screen and (min-width: 1136px) {
    .intro-slide {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }
  }
  @media only screen and (min-width: 1920px) {
    .intro-slide {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }
  }
</style>
