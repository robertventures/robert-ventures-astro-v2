---
const faqs = [
  {
    q: "What if digital assets drop?",
    a: "Your rate is fixed and does not move with digital-asset prices. We hold them as a long-term reserve, not a trade, so a swing in the market does not change what you are paid.",
  },
  {
    q: "Can I get my money out?",
    a: "You choose a 1 or 3-year lockup when you invest. That lockup is the minimum time before you can withdraw, not when the investment ends. The bonds mature in 10 years. You also choose whether your interest is paid out monthly or compounded.",
  },
  {
    q: "Can I use my IRA or SDIRA?",
    a: "Yes. You can invest through an IRA or SDIRA. Note that SDIRA accounts use compounding rather than the monthly payout option.",
  },
  {
    q: "How does 10% become 17%?",
    a: "10% is the fixed annual rate. When you compound it monthly and hold to the bonds' full 10-year maturity, your interest earns interest too. Over those 10 years, that averages out to about 17% a year.",
  },
];
---

<section class="intro-slide" id="intro-slide-faq">
  <div class="intro-slide__content">
    <h2 class="intro-slide__heading">The questions you're already asking.</h2>

    <div class="faq-list">
      {
        faqs.map((item, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-q">
              <span class="faq-q__text">{item.q}</span>
              <span class="faq-q__icon" aria-hidden="true" />
            </summary>
            <p class="faq-a">{item.a}</p>
          </details>
        ))
      }
    </div>

    <p class="faq-foot">
      Still unsure? <a href="/offer/book-call" class="faq-foot__link">Talk to a real person</a>
    </p>
  </div>
</section>

<style>
  .intro-slide {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    box-sizing: border-box;
    padding: 3rem 1.25rem 3rem 1.25rem;
  }

  .intro-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
    max-width: 600px;
  }

  .intro-slide__heading {
    font-family: var(--font-heading);
    color: #1a1a1a;
    font-size: 2rem;
    font-weight: 500;
    line-height: 1.18;
    letter-spacing: -0.01em;
    margin: 0;
    text-align: center;
  }

  .faq-list {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .faq-item {
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 0 1.125rem;
    overflow: hidden;
  }

  .faq-q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1.05rem 0;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    color: #1a1a1a;
  }

  .faq-q::-webkit-details-marker {
    display: none;
  }

  .faq-q__icon {
    position: relative;
    flex-shrink: 0;
    width: 18px;
    height: 18px;
  }

  .faq-q__icon::before,
  .faq-q__icon::after {
    content: "";
    position: absolute;
    background: #67b78f;
    transition: transform 0.2s ease;
  }

  .faq-q__icon::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 2px;
    transform: translateY(-50%);
  }

  .faq-q__icon::after {
    left: 50%;
    top: 0;
    width: 2px;
    height: 100%;
    transform: translateX(-50%);
  }

  .faq-item[open] .faq-q__icon::after {
    transform: translateX(-50%) scaleY(0);
  }

  .faq-a {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #555555;
    margin: 0;
    padding: 0 0 1.05rem;
  }

  .faq-foot {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: #8a969c;
    text-align: center;
    margin: 0;
  }

  .faq-foot__link {
    color: var(--green-dark);
    font-weight: 500;
    text-decoration: none;
  }

  .faq-foot__link:hover {
    text-decoration: underline;
  }

  @media only screen and (min-width: 600px) {
    .intro-slide__heading {
      font-size: 2.5rem;
    }
    .faq-q {
      font-size: 1.0625rem;
    }
    .faq-a {
      font-size: 1rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .intro-slide__heading {
      font-size: 2.75rem;
    }
  }

  /* Self-contained outer spacing (previously provided by the page shell). */
  @media only screen and (min-width: 600px) {
    .intro-slide {
      padding: 4rem 2rem 4rem 2.5rem;
    }
  }
  @media only screen and (min-width: 1136px) {
    .intro-slide {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }
  }
  @media only screen and (min-width: 1920px) {
    .intro-slide {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }
  }
</style>
