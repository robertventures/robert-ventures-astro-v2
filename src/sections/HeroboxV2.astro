---
// Live unique-investor count for the social-proof line inside the CTA.
// Same source and fallback as the Track Record section (BondsTrustedByNumbers).
let uniqueInvestors = 68;
try {
  const statsUrl = new URL("/api/stats", Astro.url);
  const response = await fetch(statsUrl);
  if (response.ok) {
    const data = await response.json();
    if (typeof data.usersWithInvestments === "number") {
      uniqueInvestors = data.usersWithInvestments;
    }
  }
} catch (error) {
  console.error("Failed to fetch stats for hero social proof:", error);
}
---

<style>
  section {
    background: #ffffff;
    position: relative;
    color: var(--text-heading);
    padding: 0;
    margin: 0;
    overflow: hidden;
  }

  /* Background media layer plus white gradient overlay so the dark,
     left-aligned text stays readable. The poster paints first, then a tiny
     native video loop loads only when the browser has room for it. */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url("/images/hero/home-hero-poster.webp");
    background-size: cover;
    background-position: center;
    transform: scale(1.02);
    will-change: transform;
  }

  .hero-bg-video {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 300ms ease;
  }

  .hero-bg-video.is-loaded {
    opacity: 1;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      to right,
      rgba(255, 255, 255, 0.97) 0%,
      rgba(255, 255, 255, 0.9) 50%,
      rgba(255, 255, 255, 0.68) 100%
    );
    pointer-events: none;
  }

  /* Respect users who prefer reduced motion: keep the poster, skip the video. */
  @media (prefers-reduced-motion: reduce) {
    .hero-bg-video {
      display: none;
    }
  }

  .section-container {
    position: relative;
    z-index: 1;
  }

  .section-container {
    padding: 64px 16px 40px;
    background: transparent;
    text-align: center;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }

  .section-container svg {
    margin: 0 auto;
  }

  h1 {
    font-size: 44px;
    font-weight: 500;
    margin: 0;
    margin-bottom: 40px;
    line-height: 115%;
    text-decoration-style: solid;
    text-align: left;
    color: var(--text-heading);

    max-width: 640px;
  }

  .hero-subtitle {
    font-size: 20px;
    line-height: 170%;
    color: var(--text-body);
    text-align: left;
    margin-bottom: 24px;
    max-width: 512px;
  }

  h1 .underlined-value {
    font-family: "Roboto Serif", serif;
    font-weight: 500;
    color: var(--green-brand);
    text-decoration-line: underline;
    text-decoration-style: solid;
    text-decoration-skip-ink: auto;
    text-decoration-thickness: 5%;
    text-underline-offset: 0px;
    text-underline-position: from-font;
    font-variant-numeric: lining-nums;
  }

  /* Headline accent: text stays the same color as the rest of the headline,
     only the underline uses the brand green. */
  h1 .accent-underline {
    text-decoration-line: underline;
    text-decoration-color: var(--green-brand);
    text-decoration-style: solid;
    text-decoration-skip-ink: auto;
    text-decoration-thickness: 5%;
    text-underline-offset: 0px;
    text-underline-position: from-font;
  }

  .hero-kicker {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green-dark);
    text-align: left;
    margin: 0 0 16px;
    max-width: 640px;
  }

  .hero-proof {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    padding: 0;
    margin: 0 0 32px;
    max-width: 512px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-body);
  }

  .hero-proof li {
    display: flex;
    align-items: center;
  }

  .hero-proof li:not(:first-child)::before {
    content: "·";
    color: var(--green-brand);
    font-weight: 700;
    margin: 0 10px;
  }

  /* Glassmorphism test: frosted, translucent green with a backdrop blur.
     Kept darker than brand green so the white text (especially the small
     proof line) stays readable over the semi-transparent fill. */
  .hero-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    width: 100%;
    max-width: 384px;
    box-sizing: border-box;
    padding: 15px 28px;
    border-radius: 14px;
    text-decoration: none;
    text-align: center;
    color: #ffffff;
    background-image: linear-gradient(
      180deg,
      rgba(60, 134, 99, 0.85) 0%,
      rgba(42, 110, 78, 0.88) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.45),
      0 8px 28px -6px rgba(42, 110, 78, 0.4),
      0 2px 6px rgba(0, 0, 0, 0.1);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .hero-cta:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.55);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      0 16px 36px -8px rgba(42, 110, 78, 0.5),
      0 3px 8px rgba(0, 0, 0, 0.12);
  }

  .hero-cta:active {
    transform: translateY(0);
    filter: brightness(0.97);
  }

  .hero-cta__label {
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: 0.01em;
  }

  .hero-cta__proof {
    font-family: "Roboto", sans-serif;
    font-size: 12.5px;
    font-weight: 400;
    line-height: 1.15;
    color: rgba(255, 255, 255, 0.9);
  }

  .hero-cta__proof strong {
    font-weight: 700;
    color: #ffffff;
  }

  .form-cta {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    max-width: 384px;
  }

  .form-cta :global(a) {
    margin: 0;
  }

  @media only screen and (min-width: 768px) {
    section {
      padding: 0;
      margin: 0;
    }
  }

  @media only screen and (min-width: 600px) and (max-width: 1135px) {
    .section-container {
      padding: 80px 32px 56px;
    }

    h1 {
      font-size: 48px;
      line-height: 110%;
    }
  }

  @media only screen and (min-width: 1136px) {
    .section-container {
      padding: 112px 112px 88px;
      margin: 0;
      width: 100%;
    }

    h1 {
      margin-bottom: 40px;
      font-size: 58px;
      line-height: 110%;
    }
  }

  @media only screen and (min-width: 1920px) {
    .section-container {
      padding: 112px 312px 88px;
    }
  }
</style>

<section>
  <div class="hero-bg">
    <video
      class="hero-bg-video"
      data-hero-bg-video
      autoplay
      muted
      loop
      playsinline
      preload="none"
      poster="/images/hero/home-hero-poster.webp"
      aria-hidden="true"></video>
    <div class="hero-bg-overlay"></div>
  </div>
  <div class="section-container">
    <p class="hero-kicker">A founder-led investment company</p>

    <h1>
      Reliable returns, built on <span class="accent-underline"
        >25 years of experience</span
      >.
    </h1>

    <p class="hero-subtitle">
      Earn up to 10% a year, paid monthly, from real estate and digital
      assets.
    </p>

    <ul class="hero-proof">
      <li>SEC-qualified (Reg A Tier 2)</li>
      <li>100% on-time payments</li>
    </ul>

    <div class="form-cta">
      <a
        class="hero-cta"
        href="/create-account"
        data-track-cta="hero_primary_cta"
        data-track-location="hero"
      >
        <span class="hero-cta__label">Get started</span>
        <span class="hero-cta__proof">Join <strong>{uniqueInvestors}+</strong> investors</span>
      </a>
    </div>
  </div>
</section>

<script is:inline>
  const heroVideo = document.querySelector("[data-hero-bg-video]");
  const canLoadHeroVideo =
    heroVideo instanceof HTMLVideoElement &&
    !window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const loadHeroVideo = () => {
    if (!canLoadHeroVideo) {
      return;
    }

    const isMobileViewport = window.matchMedia("(max-width: 767px)").matches;
    heroVideo.src = isMobileViewport
      ? "/videos/home-hero-mobile.mp4"
      : "/videos/home-hero-loop.mp4";

    heroVideo.addEventListener(
      "loadeddata",
      () => {
        heroVideo.classList.add("is-loaded");
      },
      { once: true },
    );

    heroVideo.load();
    heroVideo.play().catch(() => {});
  };

  if (canLoadHeroVideo) {
    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(loadHeroVideo, { timeout: 1500 });
    } else {
      window.addEventListener("load", () => setTimeout(loadHeroVideo, 300), {
        once: true,
      });
    }
  }
</script>
