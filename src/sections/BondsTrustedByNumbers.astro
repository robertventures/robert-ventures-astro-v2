---
// Fetch stats from local API with fallback values
// Default fallback values
let reinvestmentRate = 24;
let uniqueInvestors = 68;

try {
  const statsUrl = new URL("/api/stats", Astro.url);
  const response = await fetch(statsUrl);
  if (response.ok) {
    const data = await response.json();

    // Use usersWithInvestments directly
    if (typeof data.usersWithInvestments === "number") {
      uniqueInvestors = data.usersWithInvestments;
    }

    // Round reinvestment rate to nearest integer
    if (typeof data.percentUsersWithMultipleInvestments === "number") {
      reinvestmentRate = Math.round(data.percentUsersWithMultipleInvestments);
    }
  }
} catch (error) {
  console.error("Failed to fetch stats from API:", error);
  // Fallback values are already set
}
---

<style>
  section {
    background: var(--bg-secondary);
    color: var(--text-body);
    padding: 0;
    margin: 0;
  }

  .section-container {
    padding: 32px var(--section-pad-x);
    text-align: left;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    background: transparent;
    border-radius: 0;
  }

  h3 {
    font-family: "Roboto Serif", serif;
    font-size: var(--fs-heading-md);
    font-weight: 500;
    margin: 0;
    margin-bottom: 16px;
    line-height: 100%;
    text-align: left;
    color: var(--text-heading);
  }

  .columns-container {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
  }

  .column {
    width: 100%;
    background: linear-gradient(to right, rgba(103, 183, 143, 0.08), transparent);
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-left: 4px solid var(--green-brand);
    padding: 16px 0 16px 20px;
  }

  .stat-value {
    font-family: "Roboto Serif", serif;
    font-size: 32px;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 100%;
    font-variant-numeric: lining-nums;
  }

  .description {
    font-size: 16px;
    color: var(--text-body);
    line-height: 100%;
  }

  .results-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .results-label svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  .results-text {
    font-size: 16px;
    color: var(--text-body);
    line-height: 100%;
  }

  @media only screen and (min-width: 600px) and (max-width: 1135px) {
    .section-container {
      padding: 48px var(--section-pad-x);
    }

    .columns-container {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .column {
      flex: 0 0 calc(50% - 8px);
    }
  }

  @media only screen and (min-width: 1136px) {
    .section-container {
      padding: 64px var(--section-pad-x);
      margin: 0;
      width: 100%;
    }

    .columns-container {
      flex-direction: row;
    }

    .column {
      flex: 1;
    }
  }
</style>

<section>
  <div class="section-container">
    <h3>Our Track Record</h3>

    <div class="results-label">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12">
        <circle cx="6" cy="6" r="6" fill="#67B78F"></circle>
      </svg>
      <span class="results-text">Since Inception</span>
    </div>

    <div class="columns-container">
      <div class="column">
        <span class="stat-value">100%</span>
        <span class="description">On-Time Distributions</span>
      </div>
      <div class="column">
        <span class="stat-value">{reinvestmentRate}%</span>
        <span class="description">Reinvestment Rate</span>
      </div>
      <div class="column">
        <span class="stat-value">{uniqueInvestors}</span>
        <span class="description">Unique Investors</span>
      </div>
      <div class="column">
        <span class="stat-value">$150M</span>
        <span class="description">Managed by founder Joe Robert</span>
      </div>
    </div>
  </div>
</section>
