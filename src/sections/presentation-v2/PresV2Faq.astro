---
/**
 * Tail FAQ accordion for offer-v2. Forked from src/sections/presentation/PresFaq.astro.
 * Same accessibility-correct accordion mechanics (aria-expanded / aria-controls, single-open,
 * keyboard, reduced-motion-aware, fires faq_clicked to the GA dataLayer).
 * Changes: revised question set, compliant answers (no "backed by", no forward-looking returns on
 * the underlying assets, all of Joe's figures scoped to Joe personally), faq_location "offer_v2".
 */
import Opener from "../../images/icons/caretdown.svg";

const formatAnswer = (raw: string) => {
  if (!raw) return "";
  const normalized = String(raw).trim().replace(/\r\n/g, "\n");
  const paragraphs = normalized.split(/\n{2,}/);
  return paragraphs.map((p) => `<p>${p.trim().replace(/\n/g, "<br />")}</p>`).join("");
};

const faqs = [
  {
    question: "What's the catch?",
    slug: "whats_the_catch",
    answer: `The honest trade-offs: it's not FDIC-insured, your capital is at risk, and your money is committed for the minimum term (then 90 days' notice to redeem). In exchange you get a fixed rate that doesn't move with the market and the choice of monthly income or compounding.\n\nIf those trade-offs work for you, the math is straightforward. If they don't, it isn't the right product. The offering documents are public if you want to read every word.`,
  },
  {
    question: "Is it FDIC-insured? What's the real risk?",
    slug: "fdic_insured",
    answer: `FDIC insurance applies to bank deposits, not to most investments people already own, including stocks, bonds, mutual funds, and REITs. This bond is an unsecured general obligation of Robert Ventures and is not FDIC-insured. Like any investment, it carries risk, including possible loss of principal.\n\nWe work to manage that risk through real estate and a digital reserve, and the offering's record since 2024 is 100% on-time distributions. Past performance is not an indicator of future results.`,
  },
  {
    question: "How can you realistically pay 8 to 10%?",
    slug: "how_pay_10_percent",
    answer: `Three structural reasons. We build on Outer Banks lots we already control, in a supply-constrained market. We're not a REIT, so there's no fund layer or manager fee skimming the yield. And we don't use leverage on the digital side: we hold, we don't trade.\n\nYour rate is a fixed contractual rate, not a projection of those assets' returns. If conditions cool, we can hold capital in the reserve rather than being forced to deploy it.`,
  },
  {
    question: "What if I need my money before the term ends?",
    slug: "early_access",
    answer: `You commit for the minimum: 1 year at 8%, or 3 years at 10%. After that, the bond continues month-to-month and you can redeem with 90 days' notice. Both bonds mature in 10 years.\n\nIf you might need all of it back on short notice, a more liquid product may fit you better. See "who this fits" above.`,
  },
  {
    question: "Can I invest from my IRA, or roll over a CD?",
    slug: "ira_rollover",
    answer: `Yes. The bond is IRA-compatible. You can invest from an existing IRA or roll over from another retirement account, including a CD held in an IRA. IRA bonds compound through the term, and the portal walks you through the IRA process.`,
  },
  {
    question: "Is $1,000 too small to bother with?",
    slug: "minimum_amount",
    answer: `No. $1,000 is the minimum, and there's no upper limit. Plenty of investors start with a slice to see how it works, then add more. About a quarter of investors reinvest.`,
  },
  {
    question: "Are there any fees?",
    slug: "fees",
    answer: `No intermediary or management fees are taken from your payments. Returns go directly to you.`,
  },
  {
    question: "How are my investments taxed?",
    slug: "taxes",
    answer: `Taxed the same as any other interest-bearing investment. You receive a Form 1099-INT each year for the prior year's interest. For an IRA, the usual retirement-account tax treatment applies. This isn't tax advice, talk to your advisor about your situation.`,
  },
  {
    question: "How experienced is Robert Ventures?",
    slug: "experience",
    answer: `This offering launched to the public in 2024, after about a year of SEC qualification. It's built on the experience of our manager and founder, Joe Robert: about 25 years in real estate, roughly 200 properties sold, and more than $10 million raised from around 60 private investors over his career, including past partnerships. He completed every one of those offerings and repaid investors in full.\n\nRobert Ventures, the company, is newer. Joe leads it and works directly with investors.`,
  },
  {
    question: "Why is Bitcoin part of the strategy?",
    slug: "digital_assets",
    answer: `We hold Bitcoin, with a small Ethereum allocation, as a long-term reserve, custodied at BitGo Bank & Trust and audited and disclosed in our annual SEC reporting. We don't trade it, and your bond return is not indexed to its price. It's a fixed contractual rate paid from company cash flows.`,
  },
];
---

<section class="pres-v2-faq">
  <div class="pres-v2-faq__container">
    <div class="pres-v2-faq__intro">
      <p class="pres-v2-faq__eyebrow">Before you click invest</p>
      <h2 class="pres-v2-faq__heading">The questions investors ask <em>most often.</em></h2>
    </div>

    <div class="pres-v2-faq__list">
      {
        faqs.map((faq, index) => (
          <div class="pres-v2-faq__item">
            <button
              class="pres-v2-faq__btn"
              type="button"
              aria-expanded="false"
              aria-controls={`pres-v2-faq-panel-${index}`}
              id={`pres-v2-faq-button-${index}`}
              data-faq-slug={faq.slug}
            >
              <span class="pres-v2-faq__btn-text">{faq.question}</span>
              <Opener class="pres-v2-faq__btn-icon" />
            </button>
            <div
              class="pres-v2-faq__panel"
              id={`pres-v2-faq-panel-${index}`}
              role="region"
              aria-labelledby={`pres-v2-faq-button-${index}`}
            >
              <div class="pres-v2-faq__panel-inner" set:html={formatAnswer(faq.answer)} />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .pres-v2-faq {
    background: var(--bg-primary);
    padding: 0;
    margin: 0;
  }

  .pres-v2-faq__container {
    max-width: 860px;
    margin: 0 auto;
    padding: 3rem 1.5rem 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .pres-v2-faq__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
  }

  .pres-v2-faq__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 130%;
    text-align: center;
  }

  .pres-v2-faq__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 120%;
    text-align: center;
    margin: 0;
  }

  .pres-v2-faq__heading em {
    color: var(--green-dark);
    font-style: italic;
  }

  .pres-v2-faq__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pres-v2-faq__item {
    background: var(--bg-secondary);
    border-radius: 8px;
    border: 1px solid var(--border-light);
  }

  .pres-v2-faq__btn {
    width: 100%;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    padding: 16px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 140%;
  }

  .pres-v2-faq__btn-text {
    flex: 1;
  }

  .pres-v2-faq__btn-icon {
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .pres-v2-faq__btn.is-active .pres-v2-faq__btn-icon {
    transform: rotate(180deg);
  }

  .pres-v2-faq__panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  .pres-v2-faq__panel-inner {
    padding: 0 18px 16px 18px;
  }

  .pres-v2-faq__panel-inner :global(p) {
    margin: 0;
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    color: var(--text-body);
    line-height: 165%;
  }

  .pres-v2-faq__panel-inner :global(p + p) {
    margin-top: 0.75rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .pres-v2-faq__panel {
      transition: none;
    }

    .pres-v2-faq__btn-icon {
      transition: none;
    }
  }

  @media only screen and (min-width: 600px) {
    .pres-v2-faq__container {
      padding: 4rem 2rem 4.5rem;
      gap: 36px;
    }

    .pres-v2-faq__intro {
      gap: 1.5rem;
    }

    .pres-v2-faq__heading {
      font-size: 2.5rem;
    }

    .pres-v2-faq__btn {
      font-size: 19px;
      padding: 18px 22px;
    }

    .pres-v2-faq__panel-inner {
      padding: 0 22px 18px 22px;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-v2-faq__container {
      padding: 5rem 2rem 5.5rem;
    }

    .pres-v2-faq__heading {
      font-size: 2.75rem;
    }
  }
</style>

<script>
  function triggerEvent(eventName: string, eventData: Record<string, string> = {}) {
    if ((window as any).dataLayer) {
      (window as any).dataLayer.push({
        event: eventName,
        ...eventData,
      });
    }
  }

  document.addEventListener("DOMContentLoaded", function () {
    const list = document.querySelector(".pres-v2-faq__list");
    if (!list) return;

    const initialPanels = list.querySelectorAll(".pres-v2-faq__panel");
    initialPanels.forEach((panel) => {
      (panel as HTMLElement).style.maxHeight = "0";
    });

    list.addEventListener("transitionend", function (event) {
      const panel = event.target as HTMLElement;
      if (!panel.classList.contains("pres-v2-faq__panel")) return;
      if (panel.classList.contains("is-open")) {
        panel.style.maxHeight = "none";
      }
    });

    list.addEventListener("click", function (event) {
      const target = event.target;
      const button = target instanceof Element ? target.closest("button.pres-v2-faq__btn") : null;
      if (!button || !list.contains(button)) return;

      const clickedPanel = button.nextElementSibling as HTMLElement | null;
      if (!clickedPanel) return;

      const isCurrentlyOpen = button.classList.contains("is-active");
      const allButtons = list.querySelectorAll("button.pres-v2-faq__btn");
      const allPanels = list.querySelectorAll(".pres-v2-faq__panel");

      allButtons.forEach((btn) => {
        if (btn !== button) {
          btn.classList.remove("is-active");
          btn.setAttribute("aria-expanded", "false");
        }
      });

      allPanels.forEach((panel) => {
        if (panel !== clickedPanel) {
          const el = panel as HTMLElement;
          if (panel.classList.contains("is-open")) {
            el.style.maxHeight = el.scrollHeight + "px";
            el.offsetHeight;
            el.style.maxHeight = "0";
            panel.classList.remove("is-open");
          }
        }
      });

      if (isCurrentlyOpen) {
        button.classList.remove("is-active");
        button.setAttribute("aria-expanded", "false");
        clickedPanel.style.maxHeight = clickedPanel.scrollHeight + "px";
        clickedPanel.offsetHeight;
        clickedPanel.style.maxHeight = "0";
        clickedPanel.classList.remove("is-open");
      } else {
        button.classList.add("is-active");
        button.setAttribute("aria-expanded", "true");
        clickedPanel.classList.add("is-open");
        clickedPanel.style.maxHeight = clickedPanel.scrollHeight + "px";

        const faqSlug = (button as HTMLElement).dataset.faqSlug || "unknown";
        triggerEvent("faq_clicked", {
          faq_question: faqSlug,
          faq_location: "offer_v2",
        });
      }
    });
  });
</script>
