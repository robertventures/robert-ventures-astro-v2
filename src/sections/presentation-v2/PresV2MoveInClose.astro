---
/**
 * Beat 7 — "How to move your money in, and the close."
 * Makes the external-domain handoff feel small and reversible (the "next few minutes" walkthrough),
 * walks the 6 steps, handles the IRA / rollover question, gives the two honest timing facts as
 * urgency (no fake countdown), then closes with the post-call frame and the final CTA.
 * Hides the page's sticky CTA bar once this section is on screen (it has its own big CTAs here).
 */
import ComplianceMicroline from "../../components/ComplianceMicroline.astro";
import PresV2Cta from "../../components/presentation-v2/PresV2Cta.astro";

const steps = [
  {
    n: "1",
    t: "Create or log into InvestorDesk",
    d: "Free to create, about a minute, just your email. No commitment until you sign and fund.",
  },
  { n: "2", t: "Choose your bond term", d: "1-year at 8% APY, or 3-year at 10% APY." },
  {
    n: "3",
    t: "Choose monthly distributions or compounding",
    d: "Cash flow each month, or let interest compound through the term.",
  },
  { n: "4", t: "Enter your investment amount", d: "$1,000 minimum. No upper limit." },
  { n: "5", t: "Sign the bond agreement", d: "Reviewed on screen, signed electronically." },
  {
    n: "6",
    t: "Fund your bond",
    d: "ACH, wire, credit card, or the IRA process. Interest accrues the day after your funds are confirmed.",
  },
];
---

<section class="pres-v2-move" id="move-in-close">
  <div class="pres-v2-move__container">
    <div class="pres-v2-move__intro">
      <p class="pres-v2-move__eyebrow">Moving your money in</p>
      <h2 class="pres-v2-move__heading">What the next <em>few minutes</em> look like.</h2>
    </div>

    <div class="pres-v2-move__walkthrough">
      <p>
        Here's exactly what happens when you click. You go to InvestorDesk, our secure portal.
        Creating the account is free and takes about a minute, just your email, no card or bank info.
        Inside, you choose your term (1 year at 8%, or 3 years at 10%), choose monthly income or
        compounding, enter your amount ($1,000 minimum), review the bond agreement on screen, and
        sign electronically. Then you fund it: ACH, wire, credit card, or the IRA process. Interest
        starts accruing the day after your funds are confirmed. You can stop at any point before you
        sign. Nothing is committed until then.
      </p>
    </div>

    <div class="pres-v2-move__cta pres-v2-move__cta--mid">
      <PresV2Cta
        location="move_in"
        primaryLabel="Open your free InvestorDesk account"
        ghostAsTextLink={true}
      />
    </div>

    <ol class="pres-v2-move__steps" aria-label="How to move your money in">
      {
        steps.map((s) => (
          <li class="pres-v2-move__step">
            <span class="pres-v2-move__step-num">{s.n}</span>
            <div class="pres-v2-move__step-text">
              <span class="pres-v2-move__step-title">{s.t}</span>
              <span class="pres-v2-move__step-desc">{s.d}</span>
            </div>
          </li>
        ))
      }
    </ol>

    <div class="pres-v2-move__ira">
      <span class="pres-v2-move__ira-title">Bringing a retirement account or a maturing CD?</span>
      <p class="pres-v2-move__ira-body">
        This bond is IRA-compatible. You can invest from an existing IRA or roll over funds from
        another retirement account, including a CD held in an IRA. IRA bonds compound through the
        term, and the portal walks you through the IRA process when you choose that funding method.
      </p>
    </div>

    <div class="pres-v2-move__timing">
      <p>
        Two honest things about timing. Your rate is locked the day your funds are confirmed, not
        the day you create the account. And interest starts accruing the day after. CD and savings
        rates drift; this rate doesn't, once you're funded. There's no countdown here. But the
        sooner your funds confirm, the sooner the rate is yours.
      </p>
    </div>

    <div class="pres-v2-move__close">
      <p class="pres-v2-move__close-eyebrow">The next step</p>
      <h2 class="pres-v2-move__close-heading">
        You've had the conversation. This is the part where you <em>decide.</em>
      </h2>
      <p class="pres-v2-move__close-body">
        Create your free InvestorDesk account to choose your term, choose monthly income or
        compounding, enter your amount, sign, and fund. Still have a question? Book a 10-minute call
        first.
      </p>
      <PresV2Cta location="closing_cta" primaryLabel="Create your account" class="pres-v2-move__close-cta" />
      <ComplianceMicroline lines={["sec", "not-fdic", "risk"]} class="pres-v2-move__close-microline" />
    </div>
  </div>
</section>

<style>
  .pres-v2-move {
    background: var(--bg-secondary);
    padding: 0;
    margin: 0;
  }

  .pres-v2-move__container {
    max-width: 1136px;
    margin: 0 auto;
    /* Extra bottom clearance so the close CTAs sit clear of the disclaimer / sticky bar. */
    padding: 3.5rem 1.5rem 4.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .pres-v2-move__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
  }

  .pres-v2-move__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 130%;
    margin: 0;
  }

  .pres-v2-move__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 118%;
    margin: 0;
  }

  .pres-v2-move__heading em {
    color: var(--green-dark);
    font-style: italic;
  }

  .pres-v2-move__walkthrough {
    max-width: 640px;
  }

  .pres-v2-move__walkthrough p {
    font-family: "Roboto", sans-serif;
    font-size: 1.0625rem;
    color: var(--text-body);
    line-height: 1.65;
    margin: 0;
    text-align: center;
  }

  .pres-v2-move__cta {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .pres-v2-move__cta--mid {
    margin: 0.25rem 0;
  }

  .pres-v2-move__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    max-width: 880px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .pres-v2-move__step {
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 16px 20px;
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .pres-v2-move__step-num {
    width: 30px;
    height: 30px;
    border-radius: 999px;
    background: var(--green-tint);
    color: var(--green-dark);
    font-family: "Roboto Serif", serif;
    font-weight: 700;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-variant-numeric: lining-nums;
  }

  .pres-v2-move__step-text {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .pres-v2-move__step-title {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 1.3;
  }

  .pres-v2-move__step-desc {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-body);
    line-height: 1.45;
  }

  .pres-v2-move__ira {
    width: 100%;
    max-width: 880px;
    background: linear-gradient(to right, rgba(235, 245, 239, 0.5), transparent);
    border-left: 3px solid var(--green-brand);
    border-radius: 4px;
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pres-v2-move__ira-title {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--text-heading);
  }

  .pres-v2-move__ira-body {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-body);
    line-height: 1.6;
    margin: 0;
  }

  .pres-v2-move__timing {
    max-width: 640px;
  }

  .pres-v2-move__timing p {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-body);
    line-height: 1.6;
    margin: 0;
    text-align: center;
  }

  .pres-v2-move__close {
    width: 100%;
    max-width: 680px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-radius: 16px;
    padding: 28px 24px;
    margin-top: 1rem;
  }

  .pres-v2-move__close-eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 130%;
    margin: 0;
  }

  .pres-v2-move__close-heading {
    font-family: "Roboto Serif", serif;
    font-size: 1.75rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 1.2;
    margin: 0;
  }

  .pres-v2-move__close-heading em {
    color: var(--green-dark);
    font-style: italic;
  }

  .pres-v2-move__close-body {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: var(--text-body);
    line-height: 1.6;
    margin: 0;
    max-width: 520px;
  }

  .pres-v2-move__close-cta {
    margin-top: 4px;
  }

  .pres-v2-move__close-microline {
    margin-top: 2px;
    max-width: 480px;
  }

  @media only screen and (min-width: 600px) {
    .pres-v2-move__container {
      padding: 4.5rem 2rem 5.5rem;
      gap: 2rem;
    }

    .pres-v2-move__heading {
      font-size: 2.5rem;
    }

    .pres-v2-move__walkthrough p {
      font-size: 1.125rem;
    }

    .pres-v2-move__steps {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    .pres-v2-move__close {
      padding: 36px 32px;
    }

    .pres-v2-move__close-heading {
      font-size: 2rem;
    }

    .pres-v2-move__close-body {
      font-size: 1.0625rem;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-v2-move__container {
      padding: 5.5rem 2rem 6.5rem;
    }

    .pres-v2-move__heading {
      font-size: 2.75rem;
    }

    .pres-v2-move__steps {
      grid-template-columns: repeat(3, 1fr);
    }

    .pres-v2-move__close-heading {
      font-size: 2.25rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .pres-v2-move__heading {
      font-size: 3rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    .pres-v2-move__container {
      max-width: 1440px;
      padding: 6.5rem 6rem 7.5rem;
    }
  }
</style>

<script>
  (function () {
    const section = document.getElementById("move-in-close");
    const sticky = document.querySelector(".pres-stickycta");
    if (!section || !sticky || !("IntersectionObserver" in window)) return;
    const io = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          sticky.classList.toggle("is-hidden", entry.isIntersecting);
        });
      },
      { threshold: 0, rootMargin: "0px 0px -30% 0px" }
    );
    io.observe(section);
  })();
</script>
