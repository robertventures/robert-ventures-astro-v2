---
/**
 * Beat 5 — "Why the rate works, and where the capital goes." (the one allowed dense beat)
 * Answers "how can you pay 8 to 10%?" with structure, not magic: four reason cards, a tight
 * Outer Banks slot (slider + 3 stats, the data-dump trimmed away), one BitGo / Bitcoin card,
 * and an honest comparison table that includes the rows where the bond loses (FDIC, liquidity).
 *
 * Phase 1: the comparison table is a horizontally-scrollable <table>. Phase 3 can pin the RV
 * column / offer a stacked-card variant on mobile.
 */
import ImageSlider from "../../components/ImageSlider.astro";
import outerBanks1 from "../../assets/outer-banks/outer-banks-1.jpg";
import outerBanks2 from "../../assets/outer-banks/outer-banks-2.jpg";
import outerBanks3 from "../../assets/outer-banks/outer-banks-3.jpg";
import outerBanks4 from "../../assets/outer-banks/outer-banks-4.jpg";
import outerBanks5 from "../../assets/outer-banks/outer-banks-5.jpg";
import outerBanks6 from "../../assets/outer-banks/outer-banks-6.jpg";
import outerBanks7 from "../../assets/outer-banks/outer-banks-7.jpg";

const obxPhotos = [
  { src: outerBanks1, alt: "Coastal home built by Robert Ventures in the Outer Banks" },
  { src: outerBanks2, alt: "Coastal home built by Robert Ventures in the Outer Banks" },
  { src: outerBanks3, alt: "Coastal home built by Robert Ventures in the Outer Banks" },
  { src: outerBanks4, alt: "Coastal home built by Robert Ventures in the Outer Banks" },
  { src: outerBanks5, alt: "Coastal home built by Robert Ventures in the Outer Banks" },
  { src: outerBanks6, alt: "Coastal home built by Robert Ventures in the Outer Banks" },
  { src: outerBanks7, alt: "Coastal home built by Robert Ventures in the Outer Banks" },
];

const reasons = [
  {
    title: "Scarce coastal land we already own",
    body: "Outer Banks land is hard-capped by federal parks, setbacks, and septic rules. Demand keeps coming. We build on lots we already control, and regional prices have roughly doubled over the past ten years.",
  },
  {
    title: "No fund layer",
    body: "We're not a REIT. There's no manager fee skimming the yield before it reaches you.",
  },
  {
    title: "No leverage on the digital side",
    body: "We hold Bitcoin and Ethereum. We don't trade them. No margin-call risk.",
  },
  {
    title: "Founder-run, not committee-run",
    body: "Decisions are made by the person whose name is on the door, deploying when timing and demand line up rather than on a schedule.",
  },
];

const obxStats = [
  { val: "5M+", label: "Annual visitors to the region" },
  { val: "~100%", label: "10-year property-price appreciation" },
  { val: "Owned", label: "We build on lots we already control" },
];

// Comparison table. Rates are illustrative ranges, exposed here as constants so a reviewer can
// tune or blank them. The bond's rate is the only one that is contractual; the rest vary.
const compareRows = [
  {
    label: "Typical rate",
    rv: "Fixed 8% / 10% by contract",
    cd: "~4% example, varies",
    hysa: "~0.4% to ~4%, varies",
    treas: "~4% example, varies",
    stocks: "No set rate",
    rvWins: true,
  },
  {
    label: "FDIC-insured?",
    rv: "No",
    cd: "Yes",
    hysa: "Yes",
    treas: "Government-backed",
    stocks: "No",
    rvWins: false,
  },
  {
    label: "Income option",
    rv: "Monthly ACH, or compound",
    cd: "At maturity, or periodic",
    hysa: "Monthly interest",
    treas: "Coupon payments",
    stocks: "Dividends, if any",
    rvWins: false,
  },
  {
    label: "Access to your money",
    rv: "1 or 3-year minimum, then 90-day notice",
    cd: "Term, early-withdrawal penalty",
    hysa: "Anytime",
    treas: "Sell on the secondary market",
    stocks: "Anytime, price varies",
    rvWins: false,
  },
  {
    label: "Price moves day to day?",
    rv: "No",
    cd: "No",
    hysa: "No",
    treas: "Yes, if sold early",
    stocks: "Yes",
    rvWins: false,
  },
];
---

<section class="pres-v2-rate">
  <div class="pres-v2-rate__container">
    <div class="pres-v2-rate__intro">
      <p class="pres-v2-rate__eyebrow">Why the rate works</p>
      <h2 class="pres-v2-rate__heading">How the rate actually <em>works.</em></h2>
      <p class="pres-v2-rate__sub">It isn't magic. It's structure.</p>
    </div>

    <ul class="pres-v2-rate__reasons" aria-label="Why the rate is feasible">
      {
        reasons.map((r) => (
          <li class="pres-v2-rate__reason">
            <span class="pres-v2-rate__reason-title">{r.title}</span>
            <span class="pres-v2-rate__reason-body">{r.body}</span>
          </li>
        ))
      }
    </ul>

    <p class="pres-v2-rate__contractual">
      Your rate is a fixed contractual rate, not a projection of these assets' future returns.
    </p>

    <div class="pres-v2-rate__obx">
      <div class="pres-v2-rate__obx-slider">
        <ImageSlider
          id="pres-v2-obx-slideshow"
          photos={obxPhotos}
          ariaLabel="Coastal homes built by Robert Ventures in the Outer Banks"
        />
      </div>
      <ul class="pres-v2-rate__obx-stats" aria-label="Outer Banks market, in brief">
        {
          obxStats.map((s) => (
            <li class="pres-v2-rate__obx-stat">
              <span class="pres-v2-rate__obx-val">{s.val}</span>
              <span class="pres-v2-rate__obx-label">{s.label}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="pres-v2-rate__btc">
      <span class="pres-v2-rate__btc-title">Held, not traded</span>
      <p class="pres-v2-rate__btc-body">
        We accumulate Bitcoin alongside our real estate as a long-term reserve. It's not traded, and
        your bond return is not indexed to Bitcoin's price. It's a fixed contractual rate paid from
        company cash flows. The reserve is custodied at BitGo Bank &amp; Trust, a federally chartered
        qualified custodian, with $250M of insurance coverage. Ethereum is held as a small secondary
        allocation. The reserve is audited and disclosed in our annual SEC reporting.
      </p>
    </div>

    <div class="pres-v2-rate__compare">
      <h3 class="pres-v2-rate__compare-title">How it stacks up against your other options.</h3>
      <p class="pres-v2-rate__compare-hint" aria-hidden="true">Scroll to compare &rarr;</p>
      <div class="pres-v2-rate__compare-scroll">
        <table class="pres-v2-rate__compare-table">
          <caption class="sr-only">
            Robert Ventures bond compared with a CD, a high-yield savings account, Treasuries, and
            stocks
          </caption>
          <thead>
            <tr>
              <th scope="col"></th>
              <th scope="col" class="is-rv">Robert Ventures bond</th>
              <th scope="col">CD</th>
              <th scope="col">High-yield savings</th>
              <th scope="col">Treasuries</th>
              <th scope="col">Stocks</th>
            </tr>
          </thead>
          <tbody>
            {
              compareRows.map((row) => (
                <tr>
                  <th scope="row">{row.label}</th>
                  <td class:list={["is-rv", { "is-win": row.rvWins }]}>{row.rv}</td>
                  <td>{row.cd}</td>
                  <td>{row.hysa}</td>
                  <td>{row.treas}</td>
                  <td>{row.stocks}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="pres-v2-rate__compare-foot">
        Rates shown for CDs, savings, Treasuries, and stocks are illustrative national ranges, not
        offers, and change over time. Robert Ventures' rate is a fixed contractual rate. This is a
        comparison of stated and illustrative rates, not a prediction. CDs and savings accounts are
        FDIC-insured; this bond is not.
      </p>
    </div>

    <a
      class="pres-v2-rate__call"
      href="/offer/book-call"
      data-track-cta="book_call"
      data-track-location="why_rate"
    >
      Still weighing it? Book a 10-minute call <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</section>

<style>
  .pres-v2-rate {
    background: var(--bg-secondary);
    padding: 0;
    margin: 0;
  }

  .pres-v2-rate__container {
    max-width: 1136px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .pres-v2-rate__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    max-width: 640px;
    text-align: center;
  }

  .pres-v2-rate__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 130%;
    margin: 0;
  }

  .pres-v2-rate__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 118%;
    margin: 0;
  }

  .pres-v2-rate__heading em {
    color: var(--green-dark);
    font-style: italic;
  }

  .pres-v2-rate__sub {
    font-family: "Roboto", sans-serif;
    font-size: 1.0625rem;
    color: var(--text-body);
    line-height: 150%;
    margin: 0;
  }

  .pres-v2-rate__reasons {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    max-width: 880px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .pres-v2-rate__reason {
    background: linear-gradient(to right, rgba(235, 245, 239, 0.5), transparent);
    border-left: 3px solid var(--green-brand);
    border-radius: 4px;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .pres-v2-rate__reason-title {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 1.3;
  }

  .pres-v2-rate__reason-body {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-body);
    line-height: 1.5;
  }

  .pres-v2-rate__contractual {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-body);
    line-height: 1.5;
    text-align: center;
    margin: 0;
    max-width: 620px;
  }

  .pres-v2-rate__obx {
    width: 100%;
    max-width: 900px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 0.5rem;
  }

  .pres-v2-rate__obx-slider {
    width: 100%;
  }

  .pres-v2-rate__obx-stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .pres-v2-rate__obx-stat {
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pres-v2-rate__obx-val {
    font-family: "Roboto Serif", serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--green-dark);
    line-height: 1.1;
    font-variant-numeric: lining-nums;
  }

  .pres-v2-rate__obx-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-body);
    line-height: 1.4;
  }

  .pres-v2-rate__btc {
    width: 100%;
    max-width: 880px;
    background: linear-gradient(to right, rgba(235, 245, 239, 0.5), transparent);
    border-left: 3px solid var(--green-brand);
    border-radius: 4px;
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pres-v2-rate__btc-title {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--text-heading);
  }

  .pres-v2-rate__btc-body {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-body);
    line-height: 1.6;
    margin: 0;
  }

  .pres-v2-rate__compare {
    width: 100%;
    max-width: 980px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 0.5rem;
  }

  .pres-v2-rate__compare-title {
    font-family: "Roboto Serif", serif;
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 1.3;
    margin: 0;
    text-align: center;
  }

  .pres-v2-rate__compare-hint {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    color: var(--text-muted);
    text-align: right;
    margin: 0;
  }

  .pres-v2-rate__compare-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    background: var(--bg-primary);
  }

  .pres-v2-rate__compare-table {
    width: 100%;
    min-width: 720px;
    border-collapse: collapse;
    font-family: "Roboto", sans-serif;
  }

  .pres-v2-rate__compare-table th,
  .pres-v2-rate__compare-table td {
    padding: 12px 14px;
    text-align: left;
    font-size: 0.875rem;
    border-bottom: 1px solid var(--border-light);
    vertical-align: top;
  }

  .pres-v2-rate__compare-table thead th {
    font-weight: 600;
    color: var(--text-heading);
    background: var(--bg-secondary);
    font-size: 0.8125rem;
  }

  .pres-v2-rate__compare-table tbody th[scope="row"] {
    font-weight: 600;
    color: var(--text-heading);
    white-space: nowrap;
  }

  .pres-v2-rate__compare-table td {
    color: var(--text-body);
  }

  .pres-v2-rate__compare-table .is-rv {
    background: var(--green-tint);
    color: var(--text-heading);
  }

  .pres-v2-rate__compare-table thead th.is-rv {
    color: var(--green-dark);
  }

  .pres-v2-rate__compare-table td.is-win {
    font-weight: 600;
    color: var(--green-dark);
  }

  .pres-v2-rate__compare-table tbody tr:last-child th,
  .pres-v2-rate__compare-table tbody tr:last-child td {
    border-bottom: none;
  }

  .pres-v2-rate__compare-foot {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }

  .pres-v2-rate__call {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--green-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
    line-height: 1.4;
    margin-top: 0.5rem;
  }

  .pres-v2-rate__call:hover {
    color: #22573a;
  }

  @media only screen and (min-width: 600px) {
    .pres-v2-rate__container {
      padding: 4.5rem 2rem;
      gap: 2rem;
    }

    .pres-v2-rate__heading {
      font-size: 2.5rem;
    }

    .pres-v2-rate__sub {
      font-size: 1.125rem;
    }

    .pres-v2-rate__reasons {
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .pres-v2-rate__obx-stats {
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .pres-v2-rate__compare-hint {
      display: none;
    }

    .pres-v2-rate__compare-table {
      min-width: 0;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-v2-rate__container {
      padding: 5.5rem 2rem;
    }

    .pres-v2-rate__heading {
      font-size: 2.75rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .pres-v2-rate__heading {
      font-size: 3rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    .pres-v2-rate__container {
      max-width: 1440px;
      padding: 6.5rem 6rem;
    }
  }
</style>
