---
/**
 * Beat 4 — "What you actually hold." (the last fast-path screen)
 * Reframes the FDIC / risk question as a confident, owned trade-off, right after the calculator
 * so the prospect who just got excited about the numbers immediately gets the honest version.
 * Then points at the public SEC documents, then a short "who this fits / who it doesn't" qualifier.
 */
const holdCards = [
  {
    title: "SEC-qualified, Regulation A Tier 2",
    body: "Reviewed and qualified by the SEC. Qualification is a disclosure review, not an endorsement.",
  },
  {
    title: "A direct obligation of the company",
    body: "An unsecured general obligation of Robert Ventures. No fund layer, no manager fee skimming the yield. Not a REIT.",
  },
  {
    title: "Not FDIC-insured",
    body: "Unlike a CD or a savings account, this is not a bank deposit and is not FDIC-insured. Investing involves risk, including possible loss of principal.",
  },
  {
    title: "The rate is contractual, not indexed to Bitcoin",
    body: "Your rate is a fixed contractual rate. It does not move with Bitcoin's price or with the real estate market.",
  },
];

const documents = [
  {
    title: "Offering Circular",
    type: "PDF attachment",
    href: "https://l.robertventures.com/OfferingCircular",
    slug: "offering_circular",
    icon: "pdf",
  },
  {
    title: "Sample Bond Agreement",
    type: "PDF attachment",
    href: "/documents/sample-bond-agreement.pdf",
    slug: "sample_bond_agreement",
    icon: "pdf",
  },
  {
    title: "Delaware Initial Filing",
    type: "PDF attachment",
    href: "/documents/delaware-initial-filing.pdf",
    slug: "delaware_initial_filing",
    icon: "pdf",
  },
  {
    title: "Full history of SEC filings",
    type: "View on SEC.gov",
    href: "https://www.sec.gov/edgar/browse/?CIK=1991519",
    slug: "sec_filings_history",
    icon: "external",
  },
];

const fitsYouIf = [
  "you have idle cash in a CD, a savings or money-market account, an IRA, or from a sale or inheritance",
  "you want a predictable rate, not market swings",
  "you want monthly income, or you are fine letting it compound",
  "you can leave it for the minimum term (1 year, or 3 for the higher rate)",
];

const notForYouIf = [
  "you need FDIC insurance on every dollar",
  "you may need all of it back on short notice (after the minimum, redeeming takes 90 days' notice)",
  "you want a position you can sell any day",
  "you are not comfortable with any risk of loss",
];
---

<section class="pres-v2-hold">
  <div class="pres-v2-hold__container">
    <div class="pres-v2-hold__intro">
      <p class="pres-v2-hold__eyebrow">What you hold</p>
      <h2 class="pres-v2-hold__heading">This isn't a bank deposit. Here's what it <em>is.</em></h2>
      <p class="pres-v2-hold__lead">
        Let's be straight. This isn't a bank deposit. It's not FDIC-insured, and your capital is at
        risk, the same way it is with most bonds, funds, and REITs people already own. What you're
        holding is a direct obligation of Robert Ventures, qualified by the SEC. Here's exactly what
        that means, and here's how we're positioned to pay it.
      </p>
    </div>

    <ul class="pres-v2-hold__cards" aria-label="What you are holding">
      {
        holdCards.map((c) => (
          <li class="pres-v2-hold__card">
            <span class="pres-v2-hold__card-title">{c.title}</span>
            <span class="pres-v2-hold__card-body">{c.body}</span>
          </li>
        ))
      }
    </ul>

    <p class="pres-v2-hold__risk">
      Like any investment, this carries risk, including the possibility that scheduled payments are
      not made and that you could lose money.
    </p>

    <div class="pres-v2-hold__docs">
      <p class="pres-v2-hold__docs-label">On the public record</p>
      <p class="pres-v2-hold__docs-sub">
        No account needed. The core documents are public. SEC CIK 1991519.
      </p>
      <ul class="pres-v2-hold__docs-list" aria-label="Offering documents">
        {
          documents.map((doc) => (
            <li>
              <a
                class="pres-v2-hold__docs-link"
                href={doc.href}
                target="_blank"
                rel="noopener"
                data-track-cta={doc.slug}
                data-track-location="offer_v2_safety"
              >
                <span class="pres-v2-hold__docs-icon" aria-hidden="true">
                  {doc.icon === "pdf" ? (
                    <svg width="18" height="22" viewBox="0 0 20 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path
                        d="M2 0C0.895 0 0 0.895 0 2V22C0 23.105 0.895 24 2 24H18C19.105 24 20 23.105 20 22V7L13 0H2Z"
                        fill="#F5F5F5"
                        stroke="#D9D9D9"
                        stroke-width="0.5"
                      />
                      <path d="M13 0V7H20L13 0Z" fill="#E8E8E8" />
                      <rect x="2" y="11" width="16" height="9" rx="1.5" fill="#E63946" />
                      <text
                        x="10"
                        y="17.6"
                        text-anchor="middle"
                        font-family="Roboto, sans-serif"
                        font-size="5"
                        font-weight="700"
                        fill="#ffffff"
                      >
                        PDF
                      </text>
                    </svg>
                  ) : (
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M14 3H21V10" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                      <path d="M21 3L10 14" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                      <path
                        d="M19 13V19C19 20.105 18.105 21 17 21H5C3.895 21 3 20.105 3 19V7C3 5.895 3.895 5 5 5H11"
                        stroke="#1a1a1a"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  )}
                </span>
                <span class="pres-v2-hold__docs-text">
                  <span class="pres-v2-hold__docs-title">{doc.title}</span>
                  <span class="pres-v2-hold__docs-type">{doc.type}</span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="pres-v2-hold__fit">
      <div class="pres-v2-hold__fit-col">
        <p class="pres-v2-hold__fit-head pres-v2-hold__fit-head--yes">This fits you if</p>
        <ul>
          {fitsYouIf.map((line) => <li>{line}</li>)}
        </ul>
      </div>
      <div class="pres-v2-hold__fit-col">
        <p class="pres-v2-hold__fit-head pres-v2-hold__fit-head--no">It's probably not for you if</p>
        <ul>
          {notForYouIf.map((line) => <li>{line}</li>)}
        </ul>
      </div>
    </div>

    <a
      class="pres-v2-hold__call"
      href="/offer/book-call"
      data-track-cta="book_call"
      data-track-location="safety"
    >
      Have a question first? Book a 10-minute call <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</section>

<style>
  .pres-v2-hold {
    background: var(--bg-primary);
    padding: 0;
    margin: 0;
  }

  .pres-v2-hold__container {
    max-width: 1136px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .pres-v2-hold__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    max-width: 640px;
    text-align: center;
  }

  .pres-v2-hold__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 130%;
    margin: 0;
  }

  .pres-v2-hold__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 118%;
    margin: 0;
  }

  .pres-v2-hold__heading em {
    color: var(--green-dark);
    font-style: italic;
  }

  .pres-v2-hold__lead {
    font-family: "Roboto", sans-serif;
    font-size: 1.0625rem;
    color: var(--text-body);
    line-height: 1.6;
    margin: 0;
  }

  .pres-v2-hold__cards {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    max-width: 880px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .pres-v2-hold__card {
    background: linear-gradient(to right, rgba(235, 245, 239, 0.5), transparent);
    border-left: 3px solid var(--green-brand);
    border-radius: 4px;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .pres-v2-hold__card-title {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 1.3;
  }

  .pres-v2-hold__card-body {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-body);
    line-height: 1.5;
  }

  .pres-v2-hold__risk {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: var(--text-body);
    line-height: 1.5;
    text-align: center;
    margin: 0;
    max-width: 620px;
  }

  .pres-v2-hold__docs {
    width: 100%;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pres-v2-hold__docs-label {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
    text-align: center;
  }

  .pres-v2-hold__docs-sub {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: var(--text-body);
    line-height: 1.4;
    margin: 0 0 8px;
    text-align: center;
  }

  .pres-v2-hold__docs-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .pres-v2-hold__docs-link {
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 12px 14px;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 12px;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .pres-v2-hold__docs-link:hover {
    border-color: var(--green-brand);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.05);
  }

  .pres-v2-hold__docs-icon {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    border-radius: 7px;
    background: var(--bg-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .pres-v2-hold__docs-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .pres-v2-hold__docs-title {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-heading);
    line-height: 1.3;
  }

  .pres-v2-hold__docs-type {
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.3;
  }

  .pres-v2-hold__fit {
    width: 100%;
    max-width: 880px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    margin-top: 0.5rem;
  }

  .pres-v2-hold__fit-col {
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 18px 20px;
  }

  .pres-v2-hold__fit-head {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    font-weight: 500;
    margin: 0 0 10px;
    line-height: 1.3;
  }

  .pres-v2-hold__fit-head--yes {
    color: var(--green-dark);
  }

  .pres-v2-hold__fit-head--no {
    color: var(--text-heading);
  }

  .pres-v2-hold__fit-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pres-v2-hold__fit-col li {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-body);
    line-height: 1.45;
    padding-left: 18px;
    position: relative;
  }

  .pres-v2-hold__fit-col li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--text-muted);
  }

  .pres-v2-hold__fit-head--yes ~ ul li::before {
    background: var(--green-brand);
  }

  .pres-v2-hold__call {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--green-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
    line-height: 1.4;
  }

  .pres-v2-hold__call:hover {
    color: #22573a;
  }

  @media only screen and (min-width: 600px) {
    .pres-v2-hold__container {
      padding: 4.5rem 2rem;
      gap: 2rem;
    }

    .pres-v2-hold__heading {
      font-size: 2.5rem;
    }

    .pres-v2-hold__lead {
      font-size: 1.125rem;
    }

    .pres-v2-hold__cards {
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .pres-v2-hold__fit {
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-v2-hold__container {
      padding: 5.5rem 2rem;
    }

    .pres-v2-hold__heading {
      font-size: 2.75rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .pres-v2-hold__heading {
      font-size: 3rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    .pres-v2-hold__container {
      max-width: 1440px;
      padding: 6.5rem 6rem;
    }
  }
</style>
