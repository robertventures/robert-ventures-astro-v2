---
/**
 * Beat 2 — "Safe money is the lazy money." (the page's one dark band)
 * Dramatizes, calmly, the problem the post-call prospect already half-knows: the cash
 * they've been most careful with is doing the least, and even a good rate treads water
 * after taxes and inflation. Two angles only (opportunity cost + "not keeping up"),
 * the net-real-return chart, and a soft link to the calculator. No button here.
 */
import PresV2WaterfallChart from "../../components/presentation-v2/PresV2WaterfallChart.astro";
---

<section class="pres-v2-rest">
  <div class="pres-v2-rest__container">
    <p class="pres-v2-rest__eyebrow">Your cash today</p>
    <h2 class="pres-v2-rest__heading">The safe option isn't keeping <em>up.</em></h2>

    <div class="pres-v2-rest__copy">
      <p>
        You did the responsible thing. You put the money somewhere safe: a CD, a savings account, an
        IRA, the proceeds from a sale. It is the part of your money you have guarded the most. It is
        also the part working the least.
      </p>
      <p>
        The dollars on the screen go up a little. What those dollars buy goes down a little. Even at
        a good rate, once taxes and inflation take their share, careful money tends to tread water.
      </p>
    </div>

    <PresV2WaterfallChart class="pres-v2-rest__chart" />

    <p class="pres-v2-rest__close">
      There is a version of careful that also pays you. Picture the same balance somewhere it is
      actually working.
    </p>

    <a
      class="pres-v2-rest__jump"
      href="#your-choice"
      data-track-cta="jump_to_calculator"
      data-track-location="problem"
    >
      See what that balance does in one bond <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</section>

<style>
  .pres-v2-rest {
    background: var(--dark-bg);
    padding: 0;
    margin: 0;
  }

  .pres-v2-rest__container {
    max-width: 1136px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .pres-v2-rest__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--dark-eyebrow);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 130%;
    margin: 0;
    text-align: center;
  }

  .pres-v2-rest__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--dark-text-heading);
    line-height: 118%;
    text-align: center;
    margin: 0;
    max-width: 720px;
  }

  .pres-v2-rest__heading em {
    color: var(--dark-eyebrow);
    font-style: italic;
  }

  .pres-v2-rest__copy {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 600px;
    text-align: center;
  }

  .pres-v2-rest__copy p {
    font-family: "Roboto", sans-serif;
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.78);
    line-height: 158%;
    margin: 0;
  }

  .pres-v2-rest__chart {
    margin-top: 0.75rem;
  }

  .pres-v2-rest__close {
    font-family: "Roboto", sans-serif;
    font-size: 1.0625rem;
    color: #ffffff;
    line-height: 155%;
    text-align: center;
    margin: 0.5rem 0 0;
    max-width: 560px;
  }

  .pres-v2-rest__jump {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--dark-eyebrow);
    text-decoration: none;
    line-height: 1.4;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .pres-v2-rest__jump:hover {
    color: #ffffff;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media only screen and (min-width: 600px) {
    .pres-v2-rest__container {
      padding: 4.5rem 2rem;
      gap: 1.75rem;
    }

    .pres-v2-rest__heading {
      font-size: 2.75rem;
    }

    .pres-v2-rest__copy p {
      font-size: 1.125rem;
    }

    .pres-v2-rest__close {
      font-size: 1.125rem;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-v2-rest__container {
      padding: 5.5rem 2rem;
    }

    .pres-v2-rest__heading {
      font-size: 3.25rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .pres-v2-rest__heading {
      font-size: 3.5rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    .pres-v2-rest__container {
      max-width: 1440px;
      padding: 6.5rem 6rem;
    }
  }
</style>
