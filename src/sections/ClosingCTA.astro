---
import DualCTA from "../components/DualCTA.astro";
---

<style>
  section {
    background: var(--dark-bg);
    border-top: 1px solid var(--dark-border);
    padding: 0;
    margin: 0;
    position: relative;
    overflow: hidden;
  }

  .staircase-svg {
    position: absolute;
    top: 0;
    right: 0;
    width: 400px;
    height: 400px;
    pointer-events: none;
    z-index: 0;
  }

  .staircase-svg rect {
    fill: none;
    stroke: rgba(255, 255, 255, 0.07);
    stroke-width: 1;
  }

  .cta-section-container {
    position: relative;
    z-index: 1;
    padding: 64px 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
  }

  h2 {
    font-family: "Roboto Serif", serif;
    font-size: 32px;
    font-weight: 500;
    color: var(--dark-text-heading);
    margin: 0;
    line-height: 125%;
  }

  p {
    font-family: "Roboto", sans-serif;
    font-size: 20px;
    font-weight: 400;
    color: var(--dark-text-body);
    line-height: 150%;
    margin: 0;
    max-width: 512px;
  }

  @media only screen and (min-width: 600px) {
    .cta-section-container {
      padding: 80px 32px;
    }

    h2 {
      font-size: 40px;
    }
  }

  @media only screen and (min-width: 1136px) {
    .cta-section-container {
      padding: 96px 112px;
    }

    .staircase-svg {
      width: 560px;
      height: 560px;
    }
  }
</style>

