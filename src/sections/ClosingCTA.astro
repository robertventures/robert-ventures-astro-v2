<script is:inline>
  (function () {
    function initAnimation() {
      if (!window.gsapLoaded || typeof window.gsap === "undefined") {
        return;
      }

      var gsapLib = window.gsap;
      var svg = document.getElementById("closing-cta-staircase-svg");
      if (!svg) return;

      var rects = svg.querySelectorAll("rect");
      if (rects.length === 0) return;

      gsapLib.set(rects, { stroke: "rgba(255, 255, 255, 0.07)" });

      var tl = gsapLib.timeline({ repeat: -1 });

      tl.to({}, { duration: 3 });

      tl.to(rects, {
        stroke: "rgba(255, 255, 255, 0.15)",
        duration: 0.2,
        stagger: {
          amount: 0.5,
          from: "start",
        },
      });

      tl.to(rects, {
        stroke: "rgba(255, 255, 255, 0.07)",
        duration: 0.5,
        stagger: {
          amount: 1,
          from: "start",
        },
      });
    }

    function startAnimation() {
      if (window.gsapLoaded && typeof window.gsap !== "undefined") {
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initAnimation);
        } else {
          initAnimation();
        }
      } else {
        window.addEventListener("gsapLoaded", function () {
          if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initAnimation);
          } else {
            initAnimation();
          }
        });
      }
    }

    startAnimation();
  })();
</script>
