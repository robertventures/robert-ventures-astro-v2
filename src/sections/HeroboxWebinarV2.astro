---
import FormWebinarV2 from "../components/FormWebinarV2.astro";
---

<style>
  section {
    background: linear-gradient(to bottom, #ffffff, #f4f6f5);
    position: relative;
    color: var(--text-heading);
    padding: 0;
    margin: 0;
    overflow: hidden;
  }

  .section-container {
    position: relative;
    z-index: 1;
    padding: 48px 16px;
    background: transparent;
    border-radius: 0;
    text-align: center;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }

  #main-form .section-content {
    margin: 0;
    margin-left: 0;
    margin-right: 0;
    width: 100%;
    max-width: 100%;
    height: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    align-items: start;
  }

  .content-column {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: none;
    gap: 12px;
  }

  .content-column p {
    font-family: "Roboto", sans-serif;
    font-weight: 400;
    line-height: 150%;
    font-size: 20px;
    margin-bottom: 0;
  }

  .form-column {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: none;
    margin-left: auto;
  }

  h1 {
    font-size: 48px;
    margin: 0;
    margin-left: 0;
    margin-right: 0;
    margin-bottom: 0;
    text-align: left;
    font-weight: 500;
    color: var(--text-heading);
  }

  h1 span {
    color: var(--green-brand);
    background: none;
    background-clip: unset;
    -webkit-background-clip: unset;
    -webkit-text-fill-color: var(--green-brand);
  }

  .form-cta {
    width: 100%;
  }

  .pre-form-headline {
    color: var(--text-body);
    font-family: "Roboto", sans-serif;
    font-size: 20px;
    font-weight: 400;
    line-height: 150%;

    margin-bottom: 0;
    margin-top: 0;
    margin-left: 0;
    margin-right: 0;

    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    text-align: left;
  }

  .pre-form-cta {
    font-family: "Roboto", sans-serif;
    font-size: 20px;
    font-weight: 600;
    line-height: 150%;
    color: var(--text-heading);
    margin: 0;
    text-align: left;
  }

  svg {
    display: inline-block;
    max-height: 100%;
    width: auto;
  }

  span {
    color: var(--green-brand);
    background: none;
    background-clip: unset;
    -webkit-background-clip: unset;
    -webkit-text-fill-color: var(--green-brand);
  }

  @media only screen and (min-width: 768px) {
    section {
      padding: 0;
      margin: 0;
    }
  }

  @media only screen and (min-width: 600px) and (max-width: 1135px) {
    .section-container {
      padding: 64px 32px;
    }

    .content-column {
      max-width: none;
    }

    .form-column {
      max-width: none;
    }
  }

  @media only screen and (min-width: 1136px) {
    .section-container {
      padding: 96px 112px;
      margin: 0;
      width: 100%;
    }

    .content-column {
      max-width: 640px;
    }

    .form-column {
      max-width: 480px;
      margin-left: auto;
    }
  }

  @media only screen and (min-width: 1920px) {
    .section-container {
      padding: 96px 312px;
    }
  }

  @media only screen and (max-width: 1135px) {
    #main-form .section-content {
      grid-template-columns: 1fr;
    }
  }

  @media only screen and (min-width: 1136px) {
    h1 {
      margin-bottom: 0;
      font-size: 48px;
      text-align: left;
      font-weight: 500;
    }
  }

  input,
  select {
    background-color: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 6px;
    padding: 12px 16px;
    font-size: 16px;
    color: #1a1a1a;
    width: 100%;
  }

  input::placeholder,
  select::placeholder {
    color: #6b7280;
  }

  input:focus,
  select:focus {
    outline: none;
    border-color: #1e40af;
    box-shadow: 0 0 0 3px rgba(30, 64, 175, 0.1);
  }
</style>

<section>
  <div id="main-form" class="section-container">
    <div class="section-content">
      <div class="content-column">
        <h1>Built on the Outer Banks. <span>Stacked in Bitcoin.</span></h1>

        <p class="pre-form-headline">10% Compounded Monthly — Up to 17% Avg. Annual Returns.</p>
        <p class="pre-form-cta">Join Our Exclusive Investor Webinar</p>
      </div>

      <div class="form-column">
        <div class="form-cta">
          <FormWebinarV2 />
        </div>
      </div>
    </div>
  </div>
</section>
