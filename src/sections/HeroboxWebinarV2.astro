---
const isDev = import.meta.env.DEV;
---

<style>
  section {
    background: linear-gradient(to bottom, #ffffff, #f4f6f5);
    position: relative;
    color: var(--text-heading);
    padding: 0;
    margin: 0;
    overflow: hidden;
  }

  .section-container {
    position: relative;
    z-index: 1;
    padding: 48px 16px 24px;
    background: transparent;
    border-radius: 0;
    text-align: center;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }

  #main-form .section-content {
    margin: 0 auto;
    width: 100%;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 16px;
  }

  @media only screen and (min-width: 1136px) {
    #main-form .section-content {
      max-width: 100%;
      display: grid;
      grid-template-columns: 4fr 5fr;
      grid-template-rows: auto auto;
      gap: 16px 48px;
      align-items: center;
    }

    .content-column {
      grid-column: 1;
      grid-row: 1;
    }

    .video-column {
      grid-column: 2;
      grid-row: 1 / 3;
    }

    .get-started-btn {
      grid-column: 1;
      grid-row: 2;
    }
  }

  .content-column {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .video-column {
    width: 100%;
  }

  h1 {
    font-size: 42px;
    margin: 0;
    text-align: left;
    font-weight: 500;
    color: var(--text-heading);
  }

  @media only screen and (max-width: 413px) {
    h1 {
      font-size: clamp(32px, 10vw, 42px);
    }
  }

  @media only screen and (min-width: 600px) {
    h1 {
      font-size: 48px;
    }
  }

  .accent {
    position: relative;
    display: inline-block;
  }

  .underline {
    position: absolute;
    bottom: 2px;
    left: 0;
    width: 100%;
    height: 5px;
    background: var(--green-brand);
    transform: scaleX(0);
    transform-origin: left;
    animation: underline-in 0.6s ease-out 0.3s forwards;
  }

  @keyframes underline-in {
    to {
      transform: scaleX(1);
    }
  }

  .subtitle {
    color: var(--text-body);
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 160%;
    margin: 0;
    text-align: left;
  }

  .video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #152429;
    border-radius: 8px;
  }

  .video-container mux-player {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    --media-object-fit: cover;
    --media-object-position: center;
  }

  .video-fallback {
    display: none;
    position: absolute;
    inset: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #152429;
  }

  .video-fallback img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.7;
  }

  .video-fallback .fallback-cta {
    position: absolute;
    bottom: 24px;
    background-color: var(--green-brand);
    border: 1px solid var(--green-brand);
    color: #ffffff;
    border-radius: 8px;
    padding: 12px 32px;
    font-size: 16px;
    font-weight: 600;
    font-family: "Roboto", sans-serif;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .video-fallback .fallback-cta:hover {
    background-color: var(--green-hover);
    border-color: var(--green-hover);
  }

  .get-started-btn {
    background-color: var(--green-brand);
    border: 1px solid var(--green-brand);
    color: #ffffff;
    border-radius: 8px;
    width: 100%;
    padding: 14px 48px;
    text-align: center;
    font-size: 18px;
    font-weight: 600;
    line-height: 100%;
    font-family: "Roboto", sans-serif;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .get-started-btn:hover {
    background-color: var(--green-hover);
    border-color: var(--green-hover);
  }

  @media only screen and (min-width: 768px) {
    section {
      padding: 0;
      margin: 0;
    }
  }

  @media only screen and (min-width: 600px) and (max-width: 1135px) {
    .section-container {
      padding: 64px 32px;
    }
  }

  @media only screen and (min-width: 1136px) {
    .section-container {
      padding: 96px 112px;
      margin: 0;
      width: 100%;
    }
  }

  @media only screen and (min-width: 1920px) {
    .section-container {
      padding: 96px 312px;
    }
  }
</style>

<section>
  <div id="main-form" class="section-container">
    <div class="section-content">
      <div class="content-column">
        <h1>
          Two Hard Assets.<br />One Strategy.<br /><span class="accent"
            >Up to 17% a Year.<span class="underline"></span></span
          >
        </h1>

        <p class="subtitle">
          We build coastal properties on the Outer Banks and hold Bitcoin as an institutional-grade
          digital reserve.
        </p>
      </div>

      <div class="video-column">
        <div class="video-container">
          <mux-player
            id="wf-mux-player"
            playback-id="w7IiFxqJcprmmknK1o7ubdU4cyjgr4XEM3MyuAGfVQw"
            env-key="hr9aevib299lcvfdoip01jd60"
            metadata-video-title="landing_video_04_25"
            metadata-viewer-user-id="anonymous"
            preload="metadata"
            stream-type="on-demand"
            poster="https://image.mux.com/w7IiFxqJcprmmknK1o7ubdU4cyjgr4XEM3MyuAGfVQw/thumbnail.webp?time=2&width=960"
            placeholder="https://image.mux.com/w7IiFxqJcprmmknK1o7ubdU4cyjgr4XEM3MyuAGfVQw/thumbnail.webp?time=2&width=16"
            disable-tracking={isDev || undefined}
            default-show-captions></mux-player>
          <div class="video-fallback" id="video-fallback">
            <img
              src="https://image.mux.com/w7IiFxqJcprmmknK1o7ubdU4cyjgr4XEM3MyuAGfVQw/thumbnail.webp?time=2&width=960"
              alt="Investment strategy presentation"
              width="960"
              height="540"
            />
            <button class="fallback-cta" data-modal-open="webinar-modal">
              Watch the Full Presentation
            </button>
          </div>
        </div>
      </div>

      <button class="get-started-btn" data-modal-open="webinar-modal">
        Join the Free Webinar
      </button>
    </div>
  </div>
</section>

<script>
  (function () {
    const player = document.getElementById("wf-mux-player") as HTMLMediaElement | null;
    if (!player) return;

    const VIDEO_ID = "landing-video";
    let playCount = 0;
    let totalWatchTime = 0;
    let lastTimeUpdate = 0;
    let lastReportedProgress = 0;

    // Play event
    player.addEventListener("play", () => {
      playCount++;

      // Preserve existing localStorage flag for registration form
      if (playCount === 1) {
        localStorage.setItem("landing_video", "Yes");
      }

      if ((window as any).posthogTrack) {
        (window as any).posthogTrack("video_play", {
          video_id: VIDEO_ID,
          play_count: playCount,
          is_first_play: playCount === 1,
          current_time: Math.round(player.currentTime || 0),
        });
      }
    });

    // Pause event (ignore when video ends naturally)
    player.addEventListener("pause", () => {
      if (player.ended) return;

      if ((window as any).posthogTrack) {
        (window as any).posthogTrack("video_pause", {
          video_id: VIDEO_ID,
          current_time: Math.round(player.currentTime || 0),
          duration: Math.round(player.duration || 0),
          percent_watched: player.duration
            ? Math.round((player.currentTime / player.duration) * 100)
            : 0,
          total_watch_time: Math.round(totalWatchTime),
        });
      }
    });

    // Completed event
    player.addEventListener("ended", () => {
      if ((window as any).posthogTrack) {
        (window as any).posthogTrack("video_completed", {
          video_id: VIDEO_ID,
          duration: Math.round(player.duration || 0),
          total_watch_time: Math.round(totalWatchTime),
        });
      }
    });

    // Timeupdate — track cumulative watch time and milestone progress
    player.addEventListener("timeupdate", () => {
      const now = Date.now();
      if (lastTimeUpdate && now - lastTimeUpdate < 2000) {
        totalWatchTime += (now - lastTimeUpdate) / 1000;
      }
      lastTimeUpdate = now;

      if (!player.duration) return;
      const pct = Math.round((player.currentTime / player.duration) * 100);
      const milestones = [25, 50, 75, 100];
      for (const milestone of milestones) {
        if (pct >= milestone && lastReportedProgress < milestone) {
          lastReportedProgress = milestone;
          if ((window as any).posthogTrack) {
            (window as any).posthogTrack("video_progress", {
              video_id: VIDEO_ID,
              milestone,
              current_time: Math.round(player.currentTime),
              duration: Math.round(player.duration),
              total_watch_time: Math.round(totalWatchTime),
            });
          }
        }
      }
    });

    function showFallback() {
      const fallback = document.getElementById("video-fallback");
      if (fallback) fallback.style.display = "flex";
      if (player) player.style.display = "none";
    }

    // In-app webviews (Instagram, Facebook) have unreliable HLS support.
    // Skip the player entirely and show the fallback CTA upfront.
    const ua = navigator.userAgent || "";
    const isInAppBrowser = /Instagram|FBAN|FBAV/i.test(ua);
    if (isInAppBrowser) {
      showFallback();
      return;
    }

    player.addEventListener("error", () => {
      const mediaError = (player as any).error || {};
      const errorCode = mediaError.code || 0;
      const errorMessage = mediaError.message || "unknown";

      if ((window as any).posthogTrack) {
        (window as any).posthogTrack("video_error", {
          video_id: VIDEO_ID,
          error_code: errorCode,
          error_message: errorMessage,
          user_agent: ua,
          connection_type: (navigator as any).connection?.effectiveType || "unknown",
          current_time: Math.round(player.currentTime || 0),
        });
      }

      showFallback();
    });
  })();
</script>
