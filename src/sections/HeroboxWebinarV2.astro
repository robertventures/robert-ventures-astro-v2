<style>
  section {
    background: linear-gradient(to bottom, #ffffff, #f4f6f5);
    position: relative;
    color: var(--text-heading);
    padding: 0;
    margin: 0;
    overflow: hidden;
  }

  .section-container {
    position: relative;
    z-index: 1;
    padding: 48px 16px 24px;
    background: transparent;
    border-radius: 0;
    text-align: center;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }

  #main-form .section-content {
    margin: 0 auto;
    width: 100%;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 16px;
  }

  @media only screen and (min-width: 1136px) {
    #main-form .section-content {
      max-width: 100%;
      display: grid;
      grid-template-columns: 4fr 5fr;
      grid-template-rows: auto auto;
      gap: 16px 48px;
      align-items: center;
    }

    .content-column {
      grid-column: 1;
      grid-row: 1;
    }

    .video-column {
      grid-column: 2;
      grid-row: 1 / 3;
    }

    .get-started-btn {
      grid-column: 1;
      grid-row: 2;
    }
  }

  .content-column {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .video-column {
    width: 100%;
  }

  h1 {
    font-size: 42px;
    margin: 0;
    text-align: left;
    font-weight: 500;
    color: var(--text-heading);
  }

  @media only screen and (max-width: 413px) {
    h1 {
      font-size: clamp(32px, 10vw, 42px);
    }
  }

  @media only screen and (min-width: 600px) {
    h1 {
      font-size: 48px;
    }
  }

  .accent {
    position: relative;
    display: inline-block;
  }

  .underline {
    position: absolute;
    bottom: 2px;
    left: 0;
    width: 100%;
    height: 5px;
    background: var(--green-brand);
    transform: scaleX(0);
    transform-origin: left;
    animation: underline-in 0.6s ease-out 0.3s forwards;
  }

  @keyframes underline-in {
    to {
      transform: scaleX(1);
    }
  }

  .subtitle {
    color: var(--text-body);
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 160%;
    margin: 0;
    text-align: left;
  }

  .video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #152429;
    border-radius: 8px;
  }

  .video-container mux-player {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    --media-object-fit: cover;
    --media-object-position: center;
  }

  .get-started-btn {
    background-color: var(--green-brand);
    border: 1px solid var(--green-brand);
    color: #ffffff;
    border-radius: 8px;
    width: 100%;
    padding: 14px 48px;
    text-align: center;
    font-size: 18px;
    font-weight: 600;
    line-height: 100%;
    font-family: "Roboto", sans-serif;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease;
  }

  .get-started-btn:hover {
    background-color: var(--green-hover);
    border-color: var(--green-hover);
  }

  @media only screen and (min-width: 768px) {
    section {
      padding: 0;
      margin: 0;
    }
  }

  @media only screen and (min-width: 600px) and (max-width: 1135px) {
    .section-container {
      padding: 64px 32px;
    }
  }

  @media only screen and (min-width: 1136px) {
    .section-container {
      padding: 96px 112px;
      margin: 0;
      width: 100%;
    }
  }

  @media only screen and (min-width: 1920px) {
    .section-container {
      padding: 96px 312px;
    }
  }
</style>

<section>
  <div id="main-form" class="section-container">
    <div class="section-content">
      <div class="content-column">
        <h1>
          Two Hard Assets.<br />One Strategy.<br /><span class="accent"
            >Up to 17% a Year.<span class="underline"></span></span
          >
        </h1>

        <p class="subtitle">
          We build coastal properties on the Outer Banks and hold Bitcoin as an institutional-grade
          digital reserve.
        </p>
      </div>

      <div class="video-column">
        <div class="video-container">
          <mux-player
            id="wf-mux-player"
            playback-id="w7IiFxqJcprmmknK1o7ubdU4cyjgr4XEM3MyuAGfVQw"
            env-key="hr9aevib299lcvfdoip01jd60"
            metadata-video-title="landing_video_04_25"
            metadata-viewer-user-id="anonymous"
            preload="metadata"
            stream-type="on-demand"
            default-show-captions></mux-player>
        </div>
      </div>

      <button class="get-started-btn" data-modal-open="webinar-modal"> Get Started </button>
    </div>
  </div>
</section>
