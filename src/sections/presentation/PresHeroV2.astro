---

<section class="pres-herov2">
  <div class="pres-herov2__container">
    <div class="pres-herov2__content">
      <h1 class="pres-herov2__heading">Earn up to 10% through one SEC-qualified bond.</h1>
      <p class="pres-herov2__subhead">
        Your capital funds Outer Banks real estate development and Bitcoin accumulation, on fixed
        terms, with no fund layer and no management fees.
      </p>
    </div>
    <div class="pres-herov2__media">
      <div class="pres-herov2__video-wrapper">
        <div class="pres-herov2__video-container">
          <mux-player
            id="pres-mux-player"
            playback-id="2kydH8elhtjcMNOw5vFG01trfl01JFLA52ou7ZD8eQ2zI"
            env-key="hr9aevib299lcvfdoip01jd60"
            preload="metadata"
            stream-type="on-demand"
            max-resolution="1080p"
            rendition-order="desc"
            poster="https://image.mux.com/2kydH8elhtjcMNOw5vFG01trfl01JFLA52ou7ZD8eQ2zI/thumbnail.png?width=214&height=121&time=5"
            placeholder="https://image.mux.com/2kydH8elhtjcMNOw5vFG01trfl01JFLA52ou7ZD8eQ2zI/thumbnail.webp?time=5&width=16"
            muted
            playsinline
            default-show-captions></mux-player>
          <div class="pres-herov2__mux-overlay" id="pres-mux-overlay" role="button" tabindex="0">
            <div class="pres-herov2__mux-overlay-pill">
              <svg
                class="pres-herov2__mux-overlay-icon pres-herov2__mux-overlay-icon--unmute"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"
                  fill="#ffffff"></path>
              </svg>
              <svg
                class="pres-herov2__mux-overlay-icon pres-herov2__mux-overlay-icon--play"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M8 5v14l11-7z" fill="#ffffff"></path>
              </svg>
              <span class="pres-herov2__mux-overlay-text pres-herov2__mux-overlay-text--unmute">
                Your video is playing. Click to unmute.
              </span>
              <span class="pres-herov2__mux-overlay-text pres-herov2__mux-overlay-text--play">
                Click to play
              </span>
            </div>
          </div>
        </div>
      </div>
      <p class="pres-herov2__caption">
        <span class="pres-herov2__caption-name">Joe Robert</span>
        <span class="pres-herov2__caption-sep" aria-hidden="true">&middot;</span>
        <span class="pres-herov2__caption-role">Manager &amp; Founder</span>
      </p>
    </div>
  </div>
</section>

<style>
  .pres-herov2 {
    background: var(--bg-primary);
    padding: 0;
    margin: 0;
  }

  .pres-herov2__container {
    max-width: 1136px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
  }

  .pres-herov2__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    max-width: 720px;
  }

  .pres-herov2__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2.25rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 115%;
    text-align: center;
    margin: 0;
    font-variant-numeric: lining-nums;
  }

  .pres-herov2__subhead {
    font-family: "Roboto", sans-serif;
    font-size: 1.125rem;
    color: #555555;
    line-height: 150%;
    text-align: center;
    margin: 0;
  }

  .pres-herov2__heading + .pres-herov2__subhead {
    margin-top: -0.5rem;
  }

  .pres-herov2__media {
    width: 100%;
    max-width: 720px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .pres-herov2__video-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 12px;
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.06),
      0 24px 48px rgba(0, 0, 0, 0.08);
  }

  .pres-herov2__video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #152429;
  }

  .pres-herov2__video-container :global(mux-player) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    --media-object-fit: cover;
    --media-object-position: center;
    --time-range: none;
  }

  .pres-herov2__video-container :global(mux-player[mediaisfullscreen]) {
    --time-range: initial;
  }

  .pres-herov2__mux-overlay {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
    background: rgba(0, 0, 0, 0.18);
  }

  .pres-herov2__mux-overlay.is-active {
    display: flex;
  }

  .pres-herov2__mux-overlay:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: -4px;
  }

  .pres-herov2__mux-overlay-pill {
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 999px;
    padding: 0.625rem 1rem 0.625rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.01em;
    white-space: nowrap;
    animation: pres-herov2-mux-pill-glow 2.4s ease-in-out infinite;
    pointer-events: none;
  }

  .pres-herov2__mux-overlay-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .pres-herov2__mux-overlay-icon--play {
    display: none;
    margin-left: 2px;
  }

  .pres-herov2__mux-overlay-text--play {
    display: none;
  }

  .pres-herov2__mux-overlay.is-play-mode .pres-herov2__mux-overlay-icon--unmute,
  .pres-herov2__mux-overlay.is-play-mode .pres-herov2__mux-overlay-text--unmute {
    display: none;
  }

  .pres-herov2__mux-overlay.is-play-mode .pres-herov2__mux-overlay-icon--play,
  .pres-herov2__mux-overlay.is-play-mode .pres-herov2__mux-overlay-text--play {
    display: inline-block;
  }

  @keyframes pres-herov2-mux-pill-glow {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(103, 183, 143, 0.55);
    }
    70% {
      box-shadow: 0 0 0 14px rgba(103, 183, 143, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pres-herov2__mux-overlay-pill {
      animation: none;
    }
  }

  .pres-herov2__caption {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 6px;
    flex-wrap: wrap;
  }

  .pres-herov2__caption-name {
    font-family: "Roboto Serif", serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 130%;
  }

  .pres-herov2__caption-sep {
    color: var(--text-muted);
    font-size: 18px;
    line-height: 130%;
  }

  .pres-herov2__caption-role {
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    color: var(--text-body);
    line-height: 130%;
  }

  .pres-herov2__trustline {
    margin: 0.5rem 0 0;
    font-family: "Roboto", sans-serif;
    font-size: 12px;
    color: var(--text-muted);
    line-height: 160%;
    text-align: center;
    max-width: 560px;
  }

  .pres-herov2__trustline-link {
    color: var(--green-dark);
    text-decoration: underline;
  }

  .pres-herov2__trustline-link:hover {
    color: var(--green-hover);
  }

  @media (min-width: 600px) {
    .pres-herov2__mux-overlay-pill {
      padding: 0.75rem 1.25rem 0.75rem 1rem;
      font-size: 0.9375rem;
    }

    .pres-herov2__mux-overlay-icon {
      width: 24px;
      height: 24px;
    }
  }

  @media only screen and (min-width: 600px) {
    .pres-herov2__container {
      padding: 3rem 2rem;
      gap: 2.5rem;
    }

    .pres-herov2__content {
      gap: 1.5rem;
      max-width: 780px;
    }

    .pres-herov2__heading {
      font-size: 3rem;
    }

    .pres-herov2__media {
      max-width: 780px;
    }

    .pres-herov2__trustline {
      font-size: 13px;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-herov2__container {
      padding: 4rem 2rem;
      gap: 3rem;
    }

    .pres-herov2__content {
      max-width: 880px;
    }

    .pres-herov2__heading {
      font-size: 3.75rem;
      line-height: 110%;
      letter-spacing: -0.01em;
    }

    .pres-herov2__subhead {
      font-size: 1.125rem;
      max-width: 640px;
    }

    .pres-herov2__media {
      max-width: 820px;
    }
  }

  @media only screen and (min-width: 1136px) {
    .pres-herov2__heading {
      font-size: 4rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    .pres-herov2__container {
      max-width: 1440px;
      padding: 6rem 6rem;
    }

    .pres-herov2__heading {
      font-size: 4.75rem;
    }
  }
</style>
