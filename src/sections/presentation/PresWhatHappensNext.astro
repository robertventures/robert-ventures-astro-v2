---
const steps = [
  { n: "1", t: "Create or log into InvestorDesk", d: "Free to create. No commitment until you sign and fund." },
  { n: "2", t: "Choose your bond term", d: "1-year at 8% APY or 3-year at 10% APY." },
  { n: "3", t: "Choose monthly distributions or compounding", d: "Cash flow each month, or let interest compound through the term." },
  { n: "4", t: "Enter your investment amount", d: "$1,000 minimum. No upper limit." },
  { n: "5", t: "Sign the bond agreement", d: "Reviewed on screen, signed electronically." },
  { n: "6", t: "Fund your bond", d: "ACH, wire, credit card, or IRA process. Interest accrues the day after funds are confirmed." },
];
---

<section class="pres-next">
  <div class="pres-next__container">
    <div class="pres-next__intro">
      <p class="pres-next__eyebrow">After you click the button</p>
      <h2 class="pres-next__heading">What happens next inside <em>InvestorDesk.</em></h2>
      <p class="pres-next__body">
        InvestorDesk is the secure portal where you sign and fund your bond. You can stop at any
        step before signing. No card or bank info is needed to create the account.
      </p>
    </div>

    <ol class="pres-next__steps" aria-label="Investment process">
      {
        steps.map((s) => (
          <li class="pres-next__step">
            <span class="pres-next__step-num">{s.n}</span>
            <div class="pres-next__step-text">
              <span class="pres-next__step-title">{s.t}</span>
              <span class="pres-next__step-desc">{s.d}</span>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .pres-next {
    background: var(--bg-secondary);
    padding: 0;
    margin: 0;
  }

  .pres-next__container {
    max-width: 1136px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .pres-next__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
  }

  .pres-next__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 130%;
    text-align: center;
  }

  .pres-next__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 120%;
    text-align: center;
    margin: 0;
  }

  .pres-next__heading em {
    color: var(--green-dark);
    font-style: italic;
  }

  .pres-next__body {
    font-family: "Roboto", sans-serif;
    font-size: 1.125rem;
    color: #555555;
    line-height: 150%;
    text-align: center;
    margin: 0;
  }

  .pres-next__heading + .pres-next__body {
    margin-top: -0.5rem;
  }

  .pres-next__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    counter-reset: step;
  }

  .pres-next__step {
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 18px 22px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .pres-next__step-num {
    width: 32px;
    height: 32px;
    border-radius: 999px;
    background: var(--green-tint);
    color: var(--green-dark);
    font-family: "Roboto Serif", serif;
    font-weight: 700;
    font-size: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-variant-numeric: lining-nums;
  }

  .pres-next__step-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pres-next__step-title {
    font-family: "Roboto Serif", serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 130%;
  }

  .pres-next__step-desc {
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    color: var(--text-body);
    line-height: 150%;
  }

  @media only screen and (min-width: 600px) {
    .pres-next__container {
      padding: 4rem 2rem;
      gap: 40px;
    }

    .pres-next__intro {
      gap: 1.5rem;
    }

    .pres-next__heading {
      font-size: 2.5rem;
    }

    .pres-next__steps {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-next__container {
      padding: 5rem 2rem;
    }

    .pres-next__heading {
      font-size: 2.75rem;
    }

    .pres-next__steps {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media only screen and (min-width: 1136px) {
    .pres-next__heading {
      font-size: 3rem;
    }
  }
</style>
