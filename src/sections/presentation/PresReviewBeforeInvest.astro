---
const documents = [
  {
    title: "Offering Circular",
    type: "PDF attachment",
    href: "https://l.robertventures.com/OfferingCircular",
    slug: "offering_circular",
    icon: "pdf",
  },
  {
    title: "Sample Bond Agreement",
    type: "PDF attachment",
    href: "/documents/sample-bond-agreement.pdf",
    slug: "sample_bond_agreement",
    icon: "pdf",
  },
  {
    title: "Delaware Initial Filing",
    type: "PDF attachment",
    href: "/documents/delaware-initial-filing.pdf",
    slug: "delaware_initial_filing",
    icon: "pdf",
  },
  {
    title: "Full history of SEC filings",
    type: "View on SEC.gov",
    href: "https://www.sec.gov/edgar/browse/?CIK=1991519",
    slug: "sec_filings_history",
    icon: "external",
  },
];
---

<section class="pres-review">
  <div class="pres-review__container">
    <div class="pres-review__intro">
      <p class="pres-review__eyebrow">On the public record</p>
      <h2 class="pres-review__heading">Offering Documents</h2>
      <p class="pres-review__body">
        No account needed. The core offering documents are publicly available.
      </p>
    </div>

    <ul class="pres-review__list" aria-label="Offering documents">
      {
        documents.map((doc) => (
          <li class="pres-review__item">
            <a
              class="pres-review__link"
              href={doc.href}
              target="_blank"
              rel="noopener"
              data-track-document={doc.slug}
              data-track-location="review_block"
            >
              <span class={`pres-review__icon pres-review__icon--${doc.icon}`} aria-hidden="true">
                {doc.icon === "pdf" ? (
                  <svg
                    width="20"
                    height="24"
                    viewBox="0 0 20 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M2 0C0.895 0 0 0.895 0 2V22C0 23.105 0.895 24 2 24H18C19.105 24 20 23.105 20 22V7L13 0H2Z"
                      fill="#F5F5F5"
                      stroke="#D9D9D9"
                      stroke-width="0.5"
                    />
                    <path d="M13 0V7H20L13 0Z" fill="#E8E8E8" />
                    <rect x="2" y="11" width="16" height="9" rx="1.5" fill="#E63946" />
                    <text
                      x="10"
                      y="17.6"
                      text-anchor="middle"
                      font-family="Roboto, sans-serif"
                      font-size="5"
                      font-weight="700"
                      fill="#ffffff"
                    >
                      PDF
                    </text>
                  </svg>
                ) : (
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M14 3H21V10"
                      stroke="#1a1a1a"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M21 3L10 14"
                      stroke="#1a1a1a"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M19 13V19C19 20.105 18.105 21 17 21H5C3.895 21 3 20.105 3 19V7C3 5.895 3.895 5 5 5H11"
                      stroke="#1a1a1a"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                )}
              </span>
              <span class="pres-review__text">
                <span class="pres-review__link-title">{doc.title}</span>
                <span class="pres-review__link-desc">{doc.type}</span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .pres-review {
    background: var(--bg-secondary);
    padding: 0;
    margin: 0;
  }

  .pres-review__container {
    max-width: 1136px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .pres-review__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
  }

  .pres-review__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 130%;
    text-align: center;
  }

  .pres-review__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 120%;
    text-align: center;
    margin: 0;
  }

  .pres-review__heading em {
    color: var(--green-dark);
    font-style: italic;
  }

  .pres-review__body {
    font-family: "Roboto", sans-serif;
    font-size: 1.125rem;
    color: #555555;
    line-height: 150%;
    text-align: center;
    margin: 0;
  }

  .pres-review__heading + .pres-review__body {
    margin-top: -0.5rem;
  }

  .pres-review__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 640px;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .pres-review__item {
    display: flex;
  }

  .pres-review__link {
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 16px 18px;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .pres-review__link:hover {
    border-color: var(--green-brand);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    transform: translateY(-1px);
  }

  .pres-review__icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: var(--bg-secondary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .pres-review__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .pres-review__link-title {
    font-family: "Roboto", sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: var(--text-heading);
    line-height: 130%;
  }

  .pres-review__link-desc {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    color: var(--text-muted);
    line-height: 140%;
  }

  @media only screen and (min-width: 600px) {
    .pres-review__container {
      padding: 4rem 2rem;
      gap: 36px;
    }

    .pres-review__intro {
      gap: 1.5rem;
    }

    .pres-review__heading {
      font-size: 2.5rem;
    }

    .pres-review__link {
      padding: 18px 22px;
    }

    .pres-review__link-title {
      font-size: 17px;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-review__container {
      padding: 5rem 2rem;
    }

    .pres-review__heading {
      font-size: 2.75rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .pres-review__heading {
      font-size: 3rem;
    }
  }
</style>
