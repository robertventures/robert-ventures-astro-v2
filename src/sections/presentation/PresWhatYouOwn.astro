---
import { Image } from "astro:assets";
import PresDualCTA from "./PresDualCTA.astro";
import obx2 from "../../assets/outer-banks/outer-banks-2.jpg";
import obx3 from "../../assets/outer-banks/outer-banks-3.jpg";
import obx4 from "../../assets/outer-banks/outer-banks-4.jpg";
import obx5 from "../../assets/outer-banks/outer-banks-5.jpg";

const obxPhotos = [
  { src: obx2, alt: "Outer Banks coastal home built by Robert Ventures" },
  { src: obx3, alt: "Outer Banks oceanfront property" },
  { src: obx4, alt: "Outer Banks beach house exterior" },
  { src: obx5, alt: "Outer Banks coastal land site" },
];
---

<section class="pres-own">
  <div class="pres-own__container">
    <div class="pres-own__intro">
      <p class="pres-own__eyebrow">What you actually own</p>
      <h2 class="pres-own__heading">Three things, all real.</h2>
      <p class="pres-own__body">
        When you invest, you hold a fixed-rate contract. That contract is built on three real
        things you can point to.
      </p>
    </div>

    <ol class="pres-own__list">
      <li class="pres-own__item">
        <span class="pres-own__num">1</span>
        <div class="pres-own__item-text">
          <h3 class="pres-own__item-title">A signed contract.</h3>
          <p class="pres-own__item-body">
            Your rate is set the moment you invest. It does not move with the market. You hold the
            paper. We hold the assets behind it.
          </p>
        </div>
      </li>
      <li class="pres-own__item pres-own__item--media">
        <span class="pres-own__num">2</span>
        <div class="pres-own__item-text">
          <h3 class="pres-own__item-title">Coastal land in the Outer Banks.</h3>
          <p class="pres-own__item-body">
            88% of Dare County is federally protected. Land we already own and build on. Real
            collateral. Photos of every site.
          </p>
          <div class="pres-own__photos" aria-label="Outer Banks property photos">
            {
              obxPhotos.map((p) => (
                <div class="pres-own__photo">
                  <Image
                    src={p.src}
                    alt={p.alt}
                    widths={[320, 480, 720]}
                    sizes="(min-width: 600px) 200px, 45vw"
                    format="webp"
                    quality={75}
                    loading="lazy"
                  />
                </div>
              ))
            }
          </div>
        </div>
      </li>
      <li class="pres-own__item">
        <span class="pres-own__num">3</span>
        <div class="pres-own__item-text">
          <h3 class="pres-own__item-title">Bitcoin held at a U.S. federally chartered bank.</h3>
          <p class="pres-own__item-body">
            Custodied at BitGo. $250M insured by Lloyd's of London. We hold long-term. We do not
            trade.
          </p>
        </div>
      </li>
    </ol>

    <p class="pres-own__close">
      No fund layer. No middlemen. Nothing complicated hiding the simple thing you are buying.
    </p>

    <div class="pres-own__cta">
      <p class="pres-own__cta-label">Want to see the assets in detail?</p>
      <PresDualCTA primary="call" location="what_you_own" />
    </div>
  </div>
</section>

<style>
  .pres-own {
    background: var(--bg-primary);
    padding: 0;
    margin: 0;
  }

  .pres-own__container {
    max-width: 880px;
    margin: 0 auto;
    padding: 72px 20px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .pres-own__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 600px;
    margin: 0 auto;
    width: 100%;
  }

  .pres-own__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 130%;
    text-align: center;
  }

  .pres-own__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 120%;
    text-align: center;
    margin: 0;
  }

  .pres-own__body {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: #555555;
    line-height: 150%;
    text-align: center;
    margin: 0;
  }

  .pres-own__heading + .pres-own__body {
    margin-top: -0.5rem;
  }

  .pres-own__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .pres-own__item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    padding: 24px;
    background: var(--bg-secondary);
    border-radius: 12px;
  }

  .pres-own__num {
    font-family: "Roboto Serif", serif;
    font-size: 28px;
    font-weight: 500;
    color: var(--green-brand);
    line-height: 100%;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--green-tint);
    border-radius: 50%;
  }

  .pres-own__item-text {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .pres-own__item-title {
    font-family: "Roboto Serif", serif;
    font-size: 22px;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 130%;
    margin: 0;
  }

  .pres-own__item-body {
    font-family: "Roboto", sans-serif;
    font-size: 16px;
    color: var(--text-body);
    line-height: 165%;
    margin: 0;
  }

  .pres-own__photos {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    margin-top: 16px;
  }

  .pres-own__photo {
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--bg-secondary);
  }

  .pres-own__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media only screen and (min-width: 600px) {
    .pres-own__photos {
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }
  }

  .pres-own__close {
    font-family: "Roboto Serif", serif;
    font-size: 20px;
    font-style: italic;
    color: var(--text-heading);
    line-height: 150%;
    margin: 0;
    padding-top: 8px;
    border-top: 1px solid var(--border-light);
    padding-top: 24px;
  }

  .pres-own__cta {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  .pres-own__cta-label {
    font-family: "Roboto", sans-serif;
    font-size: 16px;
    color: var(--text-heading);
    font-weight: 500;
    margin: 0;
  }

  @media only screen and (min-width: 600px) {
    .pres-own__container {
      padding: 96px 32px;
      gap: 48px;
    }

    .pres-own__intro {
      gap: 1.5rem;
    }

    .pres-own__heading {
      font-size: 2.75rem;
    }

    .pres-own__item-title {
      font-size: 24px;
    }
  }

  @media only screen and (min-width: 1136px) {
    .pres-own__container {
      padding: 120px 48px;
    }

    .pres-own__heading {
      font-size: 3.25rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    .pres-own__heading {
      font-size: 3.75rem;
    }
  }
</style>
