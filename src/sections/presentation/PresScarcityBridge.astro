---
import { Image } from "astro:assets";
import outerBanks1 from "../../assets/outer-banks/outer-banks-1.jpg";
import outerBanks2 from "../../assets/outer-banks/outer-banks-2.jpg";
import outerBanks3 from "../../assets/outer-banks/outer-banks-3.jpg";
import outerBanks4 from "../../assets/outer-banks/outer-banks-4.jpg";
import outerBanks5 from "../../assets/outer-banks/outer-banks-5.jpg";
import outerBanks6 from "../../assets/outer-banks/outer-banks-6.jpg";
import outerBanks7 from "../../assets/outer-banks/outer-banks-7.jpg";

const photos = [
  { src: outerBanks1, alt: "Outer Banks construction photo 1" },
  { src: outerBanks2, alt: "Outer Banks construction photo 2" },
  { src: outerBanks3, alt: "Outer Banks construction photo 3" },
  { src: outerBanks4, alt: "Outer Banks construction photo 4" },
  { src: outerBanks5, alt: "Outer Banks construction photo 5" },
  { src: outerBanks6, alt: "Outer Banks construction photo 6" },
  { src: outerBanks7, alt: "Outer Banks construction photo 7" },
];

const photoSizes =
  "(min-width: 1920px) 720px, (min-width: 1136px) 640px, (min-width: 600px) 560px, 90vw";
const photoWidths = [600, 1000, 1400];
---

<section class="pres-scarcity">
  <div class="pres-scarcity__container">
    <h2 class="pres-scarcity__heading">Two scarce assets. <em>One Corporate bond.</em></h2>
    <p class="pres-scarcity__body">
      Buildable Outer Banks land is limited by geography and regulation. Bitcoin is limited by code
      to 21 million total. Robert Ventures accumulates both through one fixed-rate bond structure.
    </p>

    <div
      class="pres-scarcity__slideshow splide"
      id="pres-scarcity-slideshow"
      aria-label="Outer Banks construction progress photos"
    >
      <div class="splide__track">
        <ul class="splide__list">
          {
            photos.map((photo, index) => (
              <li class="splide__slide">
                <Image
                  src={photo.src}
                  alt={photo.alt}
                  widths={photoWidths}
                  sizes={photoSizes}
                  format="webp"
                  quality={75}
                  loading={index === 0 ? "eager" : "lazy"}
                  class="pres-scarcity__photo"
                />
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="pres-scarcity__split">
      <article class="pres-scarcity__col">
        <span class="pres-scarcity__col-tag">Outer Banks</span>
        <span class="pres-scarcity__col-stat">Finite by geography</span>
        <p class="pres-scarcity__col-body">
          A barrier-island market with strict zoning, limited buildable lots, and rising replacement
          cost.
        </p>
      </article>
      <article class="pres-scarcity__col">
        <span class="pres-scarcity__col-tag">Bitcoin</span>
        <span class="pres-scarcity__col-stat">21,000,000 total supply</span>
        <p class="pres-scarcity__col-body">
          A protocol-enforced cap that no committee, central bank, or company can change.
        </p>
      </article>
    </div>

    <div class="pres-scarcity__playbook">
      <p class="pres-scarcity__playbook-eyebrow">How we put them together</p>

      <ol class="pres-scarcity__playbook-list">
        <li class="pres-scarcity__playbook-step">
          <span class="pres-scarcity__playbook-num">1</span>
          <span class="pres-scarcity__playbook-title">Build on land we already own.</span>
        </li>
        <li class="pres-scarcity__playbook-step">
          <span class="pres-scarcity__playbook-num">2</span>
          <span class="pres-scarcity__playbook-title">Hold Bitcoin as a long-term reserve.</span>
        </li>
        <li class="pres-scarcity__playbook-step">
          <span class="pres-scarcity__playbook-num">3</span>
          <span class="pres-scarcity__playbook-title">You earn a fixed 8% or 10%.</span>
        </li>
      </ol>

      <p class="pres-scarcity__playbook-vision">
        The bigger picture is simple. We're building a long-term position in two assets the world
        cannot make more of. You collect a predictable return today, while that position quietly
        compounds in the background.
      </p>
    </div>
  </div>
</section>

<style>
  .pres-scarcity {
    background: var(--bg-primary);
    padding: 0;
    margin: 0;
  }

  .pres-scarcity__container {
    max-width: 1136px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .pres-scarcity__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 130%;
    text-align: center;
  }

  .pres-scarcity__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2.25rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 115%;
    text-align: center;
    margin: 0;
    max-width: 720px;
  }

  .pres-scarcity__heading em {
    color: var(--green-dark);
    font-style: italic;
  }

  .pres-scarcity__body {
    font-family: "Roboto", sans-serif;
    font-size: 1.125rem;
    color: #555555;
    line-height: 150%;
    text-align: center;
    margin: 0;
    max-width: 640px;
  }

  .pres-scarcity__slideshow {
    width: 100%;
    max-width: 720px;
    border-radius: 12px;
    overflow: hidden;
    margin-top: 4px;
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.06),
      0 24px 48px rgba(0, 0, 0, 0.08);
  }

  .pres-scarcity__photo {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .pres-scarcity__split {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    margin-top: 12px;
  }

  .pres-scarcity__col {
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .pres-scarcity__col-tag {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 130%;
  }

  .pres-scarcity__col-stat {
    font-family: "Roboto Serif", serif;
    font-size: 22px;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 130%;
    font-variant-numeric: lining-nums;
  }

  .pres-scarcity__col-body {
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    color: var(--text-body);
    line-height: 150%;
    margin: 0;
  }

  .pres-scarcity__playbook {
    width: 100%;
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .pres-scarcity__playbook-eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 130%;
    text-align: center;
  }

  .pres-scarcity__playbook-list {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pres-scarcity__playbook-step {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: var(--bg-primary);
    border: 1px solid var(--border-light);
    border-radius: 12px;
  }

  .pres-scarcity__playbook-num {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--green-dark);
    color: #ffffff;
    font-family: "Roboto Serif", serif;
    font-size: 14px;
    font-weight: 500;
    line-height: 1;
  }

  .pres-scarcity__playbook-title {
    font-family: "Roboto Serif", serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 130%;
  }

  .pres-scarcity__playbook-vision {
    font-family: "Roboto", sans-serif;
    font-size: 1.125rem;
    color: var(--text-body);
    line-height: 155%;
    text-align: center;
    margin: 8px 0 0;
    max-width: 600px;
  }

  @media only screen and (min-width: 600px) {
    .pres-scarcity__container {
      padding: 4rem 2rem;
      gap: 28px;
    }

    .pres-scarcity__heading {
      font-size: 3rem;
    }

    .pres-scarcity__split {
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .pres-scarcity__col-stat {
      font-size: 24px;
    }

    .pres-scarcity__playbook {
      margin-top: 20px;
      gap: 16px;
    }

    .pres-scarcity__playbook-list {
      flex-direction: row;
      gap: 12px;
    }

    .pres-scarcity__playbook-step {
      flex: 1;
      padding: 16px 18px;
    }

    .pres-scarcity__playbook-vision {
      font-size: 1.125rem;
      margin-top: 12px;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-scarcity__container {
      padding: 5rem 2rem;
    }

    .pres-scarcity__heading {
      font-size: 3.5rem;
    }

    .pres-scarcity__playbook-title {
      font-size: 18px;
    }
  }

  @media only screen and (min-width: 1136px) {
    .pres-scarcity__heading {
      font-size: 3.75rem;
    }

    .pres-scarcity__slideshow {
      max-width: 880px;
    }
  }
</style>

<script is:inline>
  (function () {
    function initPresScarcityCarousel() {
      const carousel = document.getElementById("pres-scarcity-slideshow");
      if (carousel && typeof Splide !== "undefined") {
        new Splide(carousel, {
          type: "fade",
          rewind: true,
          autoplay: true,
          interval: 3000,
          speed: 1000,
          pauseOnHover: false,
          arrows: false,
          pagination: false,
        }).mount();
      }
    }

    function loadSplide() {
      if (typeof Splide !== "undefined") {
        initPresScarcityCarousel();
      } else {
        const splideScript = document.createElement("script");
        splideScript.src = "https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/js/splide.min.js";
        splideScript.onload = initPresScarcityCarousel;
        document.head.appendChild(splideScript);
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", loadSplide);
    } else {
      loadSplide();
    }
  })();
</script>
