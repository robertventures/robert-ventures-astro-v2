---

<section class="rational-structure" aria-labelledby="rational-structure-heading">
  <div class="rational-structure__container">
    <div class="rational-structure__header">
      <p class="rational-structure__eyebrow">Structure</p>
      <h2 id="rational-structure-heading" class="rational-structure__heading">
        How the offering is structured.
      </h2>
    </div>

    <div class="rational-structure__grid">
      {
        facts.map((fact) => (
          <div class="rational-structure__card">
            <div class="rational-structure__icon" set:html={fact.icon} />
            <div class="rational-structure__card-content">
              <h3 class="rational-structure__card-title">{fact.title}</h3>
              <p class="rational-structure__card-text">{fact.text}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .rational-structure {
    background: var(--bg-secondary);
    padding: 0;
    margin: 0;
  }

  .rational-structure__container {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  .rational-structure__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .rational-structure__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--green-brand, #67b78f);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
    line-height: 130%;
  }

  .rational-structure__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 120%;
    margin: 0;
  }

  .rational-structure__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    width: 100%;
  }

  .rational-structure__card {
    background: var(--bg-primary, #ffffff);
    border: 1px solid var(--border-light, #e5e5e5);
    border-radius: 16px;
    padding: 1.25rem;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 1rem;
    transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }

  .rational-structure__card:hover {
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.04);
    border-color: var(--green-brand, #67b78f);
    transform: translateY(-2px);
  }

  .rational-structure__icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--green-tint, #ebf5ef);
    color: var(--green-brand, #67b78f);
  }

  .rational-structure__icon :global(svg) {
    width: 24px;
    height: 24px;
    stroke-width: 2;
  }

  .rational-structure__card-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .rational-structure__card-title {
    font-family: "Roboto", sans-serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-heading, #1a1a1a);
    margin: 0;
    line-height: 140%;
  }

  .rational-structure__card-text {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: var(--text-body, #555555);
    margin: 0;
    line-height: 150%;
  }

  @media only screen and (min-width: 600px) {
    .rational-structure__container {
      padding: 4rem 2rem;
      gap: 3rem;
    }

    .rational-structure__heading {
      font-size: 2.5rem;
    }

    .rational-structure__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .rational-structure__card {
      flex-direction: column;
      padding: 1.75rem;
      gap: 1.25rem;
    }

    .rational-structure__card-content {
      gap: 0.5rem;
    }
  }

  @media only screen and (min-width: 1024px) {
    .rational-structure__container {
      padding: 5rem 2rem;
      gap: 3.5rem;
    }

    .rational-structure__heading {
      font-size: 3rem;
    }

    .rational-structure__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    .rational-structure__container {
      padding: 7rem 2rem;
    }

    .rational-structure__heading {
      font-size: 3.5rem;
    }
  }
</style>
