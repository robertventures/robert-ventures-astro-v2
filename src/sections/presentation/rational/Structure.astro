//     annual SEC reporting, contractual rate paid from company cash flows.
//   - Reg A+ qualification is referenced across the broader site as the
//     offering framework.

const facts = [
  {
    title: "SEC Qualified",
    text: "Qualified under SEC Regulation A+",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`,
  },
  {
