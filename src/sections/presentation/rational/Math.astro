---
// Section 3 of the rational-tone diligence page.
// Visual: line chart of $10,000 compounded monthly over 10 years at 4% (CD),
// 8% (1-year bond), and 10% (3-year bond). The widening gap between the
// lines is the argument; the CD endpoint of $14,908 is the benchmark.
// Numbers sourced from marketing-context/offer.md (compound math L67-88).

const PRINCIPAL = 10_000;
const YEARS = 10;
const MONTHS = YEARS * 12;

const series = [
  { id: "cd", label: "4% CD or savings", rate: 0.04, colorClass: "cd" },
  { id: "bond8", label: "1-year bond, 8% APY", rate: 0.08, colorClass: "bond8" },
  { id: "bond10", label: "3-year bond, 10% APY", rate: 0.1, colorClass: "bond10" },
].map((s) => {
  const monthly = [];
  for (let m = 0; m <= MONTHS; m++) {
    monthly.push({ m, value: PRINCIPAL * Math.pow(1 + s.rate / 12, m) });
  }
  const yearly = [];
  for (let y = 0; y <= YEARS; y++) {
    yearly.push({ y, value: PRINCIPAL * Math.pow(1 + s.rate / 12, 12 * y) });
  }
  return { ...s, monthly, yearly, endpoint: monthly[monthly.length - 1].value };
});

// SVG geometry. Wide viewBox so axis text stays readable when the chart
// scales down on mobile (font-size in SVG units shrinks proportionally).
const W = 880;
const H = 540;
const PAD_L = 72;
const PAD_R = 220;
const PAD_T = 40;
const PAD_B = 68;
const plotW = W - PAD_L - PAD_R;
const plotH = H - PAD_T - PAD_B;

const Y_MIN = 0;
const Y_MAX = 30_000;

const xFor = (month: number) => PAD_L + (month / MONTHS) * plotW;
const yFor = (value: number) => PAD_T + plotH - ((value - Y_MIN) / (Y_MAX - Y_MIN)) * plotH;

const seriesWithPath = series.map((s) => {
  const d = s.monthly
    .map((p, i) => `${i === 0 ? "M" : "L"}${xFor(p.m).toFixed(2)},${yFor(p.value).toFixed(2)}`)
    .join(" ");
  return { ...s, d, endX: xFor(MONTHS), endY: yFor(s.endpoint) };
});

const yTicks = [0, 10_000, 20_000, 30_000];
const xTicks = [0, 2, 4, 6, 8, 10];

const fmt = (v: number) => `$${Math.round(v).toLocaleString()}`;
const fmtCompact = (v: number) => (v === 0 ? "$0" : `$${(v / 1000).toFixed(0)}K`);
---

<section class="rational-math offer-slide" aria-labelledby="rational-math-heading">
  <div class="rational-math__container">
    <div class="rational-math__header">
      <p class="rational-math__eyebrow">The compound math</p>
      <h2 id="rational-math-heading" class="rational-math__heading">
        $10,000, three places, 10 years.
      </h2>
      <p class="rational-math__subhead">
        Take the 8% and 10% from the contract and run them forward. Compounded monthly. Not a
        projection. Just math.
      </p>
    </div>

    <ul class="rational-math__legend" role="list">
      {
        seriesWithPath.map((s) => (
          <li class:list={["rational-math__legend-item", `is-${s.colorClass}`]}>
            <span class="rational-math__legend-swatch" aria-hidden="true" />
            <span class="rational-math__legend-label">{s.label}</span>
          </li>
        ))
      }
    </ul>

    <div class="rational-math__chart-wrap">
      <svg
        class="rational-math__chart"
        viewBox={`0 0 ${W} ${H}`}
        role="img"
        aria-labelledby="rational-math-chart-title rational-math-chart-desc"
        preserveAspectRatio="xMidYMid meet"
      >
        <title id="rational-math-chart-title">
          Growth of $10,000 over 10 years at 4%, 8%, and 10% compounded monthly.
        </title>
        <desc id="rational-math-chart-desc">
          A 4% CD reaches $14,908. The 1-year bond at 8% reaches $22,196. The 3-year bond at 10%
          reaches $27,070.
        </desc>

        {
          yTicks.map((v) => (
            <g class="rational-math__grid">
              <line x1={PAD_L} x2={W - PAD_R} y1={yFor(v)} y2={yFor(v)} />
              <text class="rational-math__y-label" x={PAD_L - 12} y={yFor(v) + 7} text-anchor="end">
                {fmtCompact(v)}
              </text>
            </g>
          ))
        }

        {
          xTicks.map((y) => (
            <text
              class="rational-math__x-label"
              x={xFor(y * 12)}
              y={H - PAD_B + 30}
              text-anchor="middle"
            >
              {y === 0 ? "Year 0" : `Yr ${y}`}
            </text>
          ))
        }

        {
          seriesWithPath.map((s) => (
            <path
              class:list={["rational-math__line", `is-${s.colorClass}`]}
              d={s.d}
              fill="none"
              data-line={s.id}
            />
          ))
        }

        {
          seriesWithPath.map((s) => (
            <g class:list={["rational-math__endpoint", `is-${s.colorClass}`]}>
              <circle cx={s.endX} cy={s.endY} r="6" />
              <text class="rational-math__endpoint-label" x={s.endX + 14} y={s.endY + 7}>
                {fmt(s.endpoint)}
              </text>
            </g>
          ))
        }
      </svg>

      <table class="rational-math__sr-only">
        <caption>$10,000 compounded monthly, year-end values</caption>
        <thead>
          <tr>
            <th>Year</th>
            {series.map((s) => <th>{s.label}</th>)}
          </tr>
        </thead>
        <tbody>
          {
            Array.from({ length: YEARS + 1 }, (_, y) => (
              <tr>
                <td>{y}</td>
                {series.map((s) => (
                  <td>{fmt(s.yearly[y].value)}</td>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p class="rational-math__callout">
      The 3-year bond turns $10,000 into <strong>$27,070</strong>. A 4% CD turns it into
      <strong>$14,908</strong>.
    </p>

    <p class="rational-math__disclaimer">
      For illustrative purposes only. Not APY. Not IRR. Compound interest at the stated rate,
      monthly, on the original $10,000.
    </p>
  </div>
</section>

<style>
  .rational-math {
    background: var(--bg-primary);
    margin: 0;
  }

  .rational-math__container {
    max-width: 1136px;
    margin: 0 auto;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .rational-math__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    max-width: 720px;
  }

  .rational-math__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
    line-height: 130%;
  }

  .rational-math__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 120%;
    margin: 0;
  }

  .rational-math__subhead {
    font-family: "Roboto Serif", serif;
    font-size: 1rem;
    font-style: italic;
    color: var(--text-muted);
    line-height: 150%;
    margin: 0;
  }

  .rational-math__legend {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 20px;
  }

  .rational-math__legend-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: var(--text-body);
    line-height: 130%;
  }

  .rational-math__legend-swatch {
    width: 18px;
    height: 3px;
    border-radius: 2px;
    background: var(--text-muted);
  }

  .rational-math__legend-item.is-bond8 .rational-math__legend-swatch {
    background: var(--green-brand, #67b78f);
  }

  .rational-math__legend-item.is-bond10 .rational-math__legend-swatch {
    background: var(--green-dark);
  }

  .rational-math__chart-wrap {
    width: 100%;
    max-width: 960px;
    position: relative;
  }

  .rational-math__chart {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .rational-math__grid line {
    stroke: var(--border-light);
    stroke-width: 1;
  }

  .rational-math__y-label,
  .rational-math__x-label {
    font-family: "Roboto", sans-serif;
    font-size: 22px;
    fill: var(--text-muted);
  }

  .rational-math__line {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .rational-math__line.is-cd {
    stroke: var(--text-muted);
    stroke-width: 2.5;
    opacity: 0.7;
  }

  .rational-math__line.is-bond8 {
    stroke: var(--green-brand, #67b78f);
    stroke-width: 3;
  }

  .rational-math__line.is-bond10 {
    stroke: var(--green-dark);
    stroke-width: 3.5;
  }

  .rational-math__endpoint circle {
    stroke: var(--bg-primary);
    stroke-width: 2;
  }

  .rational-math__endpoint.is-cd circle {
    fill: var(--text-muted);
  }

  .rational-math__endpoint.is-bond8 circle {
    fill: var(--green-brand, #67b78f);
  }

  .rational-math__endpoint.is-bond10 circle {
    fill: var(--green-dark);
  }

  .rational-math__endpoint-label {
    font-family: "Roboto", sans-serif;
    font-size: 26px;
    font-weight: 600;
    fill: var(--text-heading);
    font-variant-numeric: lining-nums;
  }

  .rational-math__endpoint.is-cd .rational-math__endpoint-label {
    fill: var(--text-muted);
    font-weight: 500;
  }

  .rational-math__endpoint.is-bond10 .rational-math__endpoint-label {
    fill: var(--green-dark);
    font-size: 30px;
  }

  /* Line-draw animation on scroll. Length set per-line via inline style by JS. */
  .rational-math__chart-wrap.is-js .rational-math__line {
    stroke-dasharray: var(--line-length, 4000);
    stroke-dashoffset: var(--line-length, 4000);
    transition: stroke-dashoffset 1.8s ease-out;
  }

  .rational-math__chart-wrap.is-js .rational-math__endpoint {
    opacity: 0;
    transition: opacity 0.4s ease-out;
  }

  .rational-math__chart-wrap.is-js.is-visible .rational-math__line {
    stroke-dashoffset: 0;
  }

  .rational-math__chart-wrap.is-js.is-visible .rational-math__line.is-bond8 {
    transition-delay: 0.15s;
  }

  .rational-math__chart-wrap.is-js.is-visible .rational-math__line.is-bond10 {
    transition-delay: 0.3s;
  }

  .rational-math__chart-wrap.is-js.is-visible .rational-math__endpoint {
    opacity: 1;
    transition-delay: 1.6s;
  }

  .rational-math__chart-wrap.is-js.is-visible .rational-math__endpoint.is-bond8 {
    transition-delay: 1.75s;
  }

  .rational-math__chart-wrap.is-js.is-visible .rational-math__endpoint.is-bond10 {
    transition-delay: 1.9s;
  }

  @media (prefers-reduced-motion: reduce) {
    .rational-math__chart-wrap.is-js .rational-math__line,
    .rational-math__chart-wrap.is-js .rational-math__endpoint {
      stroke-dashoffset: 0;
      opacity: 1;
      transition: none;
    }
  }

  .rational-math__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .rational-math__callout {
    font-family: "Roboto Serif", serif;
    font-size: 1.125rem;
    color: var(--text-body);
    line-height: 155%;
    margin: 0.5rem 0 0;
    max-width: 720px;
    text-align: center;
    font-variant-numeric: lining-nums;
  }

  .rational-math__callout strong {
    color: var(--green-dark);
    font-weight: 600;
  }

  .rational-math__disclaimer {
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    font-style: italic;
    color: var(--text-muted);
    line-height: 150%;
    margin: 0;
    max-width: 720px;
    text-align: center;
  }

  @media only screen and (min-width: 600px) {
    .rational-math__container {
      gap: 2rem;
    }

    .rational-math__heading {
      font-size: 2.75rem;
    }

    .rational-math__subhead {
      font-size: 1.125rem;
    }

    .rational-math__legend-item {
      font-size: 0.9375rem;
    }

    .rational-math__callout {
      font-size: 1.25rem;
    }

    .rational-math__disclaimer {
      font-size: 0.875rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .rational-math__container {
      gap: 2.5rem;
    }

    .rational-math__heading {
      font-size: 3.25rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    .rational-math__heading {
      font-size: 3.75rem;
    }
  }
</style>

<script>
  (function () {
    function init() {
      const wrap = document.querySelector(".rational-math__chart-wrap");
      if (!wrap) return;

      const lines = wrap.querySelectorAll(".rational-math__line");
      lines.forEach(function (line) {
        try {
          const length = (line as SVGPathElement).getTotalLength();
          (line as SVGPathElement).style.setProperty("--line-length", String(length));
        } catch (e) {
          // getTotalLength can fail on detached SVG, fall back to a safe default
        }
      });

      wrap.classList.add("is-js");

      if (!("IntersectionObserver" in window)) {
        wrap.classList.add("is-visible");
        return;
      }

      const io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              wrap.classList.add("is-visible");
              io.disconnect();
            }
          });
        },
        { threshold: 0.25 }
      );
      io.observe(wrap);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
