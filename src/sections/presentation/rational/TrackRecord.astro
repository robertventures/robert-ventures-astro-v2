---
// Section 5 of 7 on the rational-tone offer page. Trust anchor.
// Combines: header, Video 2 placeholder (not yet filmed), 25-yr/$150M/200+/1,500+ stat grid,
// $750K alignment callout (capital contribution, senior claim language), structure facts
// (SEC Qualified, Audited Financials, Zero Fees, 100% On-Time), and a small operating record strip.
//
// Fact sources:
//   - proof-points.md (Joe track record, team credibility)
//   - offer.md (founder alignment, SEC + portfolio numbers)
//   - brand-voice.md (senior claim wording verbatim)
//
// Voice rules enforced here: no em-dashes, no "backed by", no "guarantee",
// $750K = capital contribution (never investment/bond), Joe = 25 years, RV launched Oct 2024.

const stats = [
  { value: "$1.23M", label: "Raised to date" },
  { value: "75", label: "Active investors across 21+ states" },
  { value: "27%", label: "Reinvest at maturity" },
  { value: "100%", label: "On-time distributions since Oct 2024" },
];

const facts = [
  {
    title: "SEC Qualified",
    text: "Reg A, Tier 2. File No. 024-12331.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`,
  },
  {
    title: "Audited Financials",
    text: "Verified by independent accountants, June 30, 2025.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>`,
  },
  {
    title: "Zero Fees",
    text: "No management fee, no acquisition fee, no salary.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line></svg>`,
  },
  {
    title: "100% On-Time",
    text: "Every monthly distribution since October 2024.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>`,
  },
];
---

<section class="rational-track offer-slide" aria-labelledby="rational-track-heading">
  <div class="rational-track__container">
    <!-- Block 1: Header -->
    <header class="rational-track__header">
      <p class="rational-track__eyebrow">25 years of experience</p>
      <h2 id="rational-track-heading" class="rational-track__heading">
        25 years. $150M managed.
      </h2>
      <p class="rational-track__subhead">
        Joe Robert built and managed real assets for two and a half decades before he raised a
        dollar from the public. Here's the record, the structure, and the alignment.
      </p>
    </header>

    <!-- Block 2: Video 2 placeholder -->
    <!-- TODO: replace placeholder with mux-player when track record explainer (Video 2) is filmed. Match the player + overlay pattern from PresFounder.astro lines 17-67 and the player setup script lines 482-619. -->
    <div class="rational-track__video">
      <div class="rational-track__frame" role="img" aria-label="Track record video placeholder">
        <div class="rational-track__placeholder">
          Track record explainer video. To be filmed and placed here (Video 2).
        </div>
      </div>
      <p class="rational-track__caption">
        <span class="rational-track__caption-name">Joe Robert</span>
        <span class="rational-track__caption-sep" aria-hidden="true">&middot;</span>
        <span class="rational-track__caption-role">Founder &amp; Manager</span>
      </p>
    </div>

    <!-- Block 3: Stat grid -->
    <ul class="rational-track__stats" aria-label="Track record statistics">
      {
        stats.map((s) => (
          <li class="rational-track__stat">
            <span class="rational-track__stat-value">{s.value}</span>
            <span class="rational-track__stat-label">{s.label}</span>
          </li>
        ))
      }
    </ul>

    <!-- Block 4: Alignment callout -->
    <div class="rational-track__align" role="note">
      <p class="rational-track__align-body">
        Joe has contributed $750,000 of personal capital to Robert Ventures Holdings LLC. It is a
        capital contribution, not a bond. He earns no fixed return on it. Bond holders hold a senior
        claim. <strong class="rational-track__align-emphasis"
          >You get paid before his contributed capital does.</strong
        > His $750K is last in line. Yours is first.
      </p>
    </div>

    <!-- Block 5: Structure facts grid -->
    <div class="rational-track__facts">
      {
        facts.map((fact) => (
          <div class="rational-track__fact">
            <div class="rational-track__fact-icon" set:html={fact.icon} />
            <div class="rational-track__fact-content">
              <h3 class="rational-track__fact-title">{fact.title}</h3>
              <p class="rational-track__fact-text">{fact.text}</p>
            </div>
          </div>
        ))
      }
    </div>

  </div>
</section>

<style>
  .rational-track {
    background: var(--bg-primary);
    margin: 0;
  }

  .rational-track__container {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  /* Block 1: Header */
  .rational-track__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    max-width: 760px;
  }

  .rational-track__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--green-brand, #67b78f);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
    line-height: 130%;
  }

  .rational-track__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 120%;
    margin: 0;
  }

  .rational-track__subhead {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    color: var(--text-body);
    line-height: 155%;
    margin: 0;
  }

  /* Block 2: Video placeholder */
  .rational-track__video {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .rational-track__frame {
    width: 100%;
    max-width: 780px;
    aspect-ratio: 16 / 9;
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.04),
      0 24px 48px rgba(0, 0, 0, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    box-sizing: border-box;
  }

  .rational-track__placeholder {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 150%;
    text-align: center;
    max-width: 420px;
  }

  .rational-track__caption {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .rational-track__caption-name {
    font-family: "Roboto Serif", serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 130%;
  }

  .rational-track__caption-sep {
    color: var(--text-muted);
    font-size: 18px;
    line-height: 130%;
  }

  .rational-track__caption-role {
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    color: var(--text-body);
    line-height: 130%;
  }

  /* Block 3: Stat grid */
  .rational-track__stats {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  .rational-track__stat {
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.35rem;
  }

  .rational-track__stat-value {
    font-family: "Roboto Serif", serif;
    font-size: clamp(1.5rem, 1.25rem + 1.1vw, 2rem);
    font-weight: 700;
    color: var(--green-dark);
    font-variant-numeric: lining-nums;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .rational-track__stat-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: var(--text-body);
    line-height: 140%;
    margin: 0;
  }

  /* Block 4: Alignment callout */
  .rational-track__align {
    width: 100%;
    max-width: 820px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 1.5rem 1.25rem;
    box-sizing: border-box;
  }

  .rational-track__align-body {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    color: var(--text-body);
    line-height: 165%;
    margin: 0;
  }

  .rational-track__align-emphasis {
    display: inline-block;
    margin: 0.35rem 0;
    font-family: "Roboto Serif", serif;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-heading);
    line-height: 145%;
  }

  /* Block 5: Structure facts grid */
  .rational-track__facts {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .rational-track__fact {
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: 16px;
    padding: 1.25rem;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 1rem;
    transition:
      box-shadow 0.3s ease,
      border-color 0.3s ease,
      transform 0.3s ease;
  }

  .rational-track__fact:hover {
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.04);
    border-color: var(--green-brand, #67b78f);
    transform: translateY(-2px);
  }

  .rational-track__fact-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--green-tint, #ebf5ef);
    color: var(--green-brand, #67b78f);
  }

  .rational-track__fact-icon :global(svg) {
    width: 22px;
    height: 22px;
    stroke-width: 2;
  }

  .rational-track__fact-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .rational-track__fact-title {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-heading, #1a1a1a);
    margin: 0;
    line-height: 140%;
  }

  .rational-track__fact-text {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-body, #555555);
    margin: 0;
    line-height: 150%;
  }

  /* Block 6: Operating record strip */
  .rational-track__strip {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 160%;
    letter-spacing: 0.02em;
    margin: 0;
    text-align: center;
    max-width: 820px;
  }

  @media only screen and (min-width: 600px) {
    .rational-track__container {
      gap: 2rem;
    }

    .rational-track__heading {
      font-size: 2.75rem;
    }

    .rational-track__subhead {
      font-size: 1.125rem;
    }

    .rational-track__stats {
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }

    .rational-track__stat {
      padding: 1.5rem 1rem;
    }

    .rational-track__stat-label {
      font-size: 0.9375rem;
    }

    .rational-track__align {
      padding: 1.75rem 2rem;
    }

    .rational-track__align-body {
      font-size: 1.125rem;
    }

    .rational-track__align-emphasis {
      font-size: 1.25rem;
    }

    .rational-track__facts {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }

    .rational-track__strip {
      font-size: 0.9375rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .rational-track__container {
      gap: 2.5rem;
    }

    .rational-track__heading {
      font-size: 3.25rem;
    }

    .rational-track__stat-value {
      font-size: 2.25rem;
    }

    .rational-track__stat-label {
      font-size: 1rem;
    }

    .rational-track__facts {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
    }

    .rational-track__fact {
      flex-direction: column;
      padding: 1.5rem;
      gap: 1rem;
    }

    .rational-track__align {
      padding: 2rem 2.5rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    .rational-track__heading {
      font-size: 3.75rem;
    }
  }
</style>
