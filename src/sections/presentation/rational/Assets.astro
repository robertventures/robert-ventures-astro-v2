---
import { Image } from "astro:assets";
import outerBanks1 from "../../../assets/outer-banks/outer-banks-1.jpg";
import outerBanks2 from "../../../assets/outer-banks/outer-banks-2.jpg";
import outerBanks3 from "../../../assets/outer-banks/outer-banks-3.jpg";
import outerBanks4 from "../../../assets/outer-banks/outer-banks-4.jpg";
import outerBanks5 from "../../../assets/outer-banks/outer-banks-5.jpg";
import outerBanks6 from "../../../assets/outer-banks/outer-banks-6.jpg";
import outerBanks7 from "../../../assets/outer-banks/outer-banks-7.jpg";

const outerBanksPhotos = [
  { src: outerBanks1, alt: "Outer Banks construction photo 1" },
  { src: outerBanks2, alt: "Outer Banks construction photo 2" },
  { src: outerBanks3, alt: "Outer Banks construction photo 3" },
  { src: outerBanks4, alt: "Outer Banks construction photo 4" },
  { src: outerBanks5, alt: "Outer Banks construction photo 5" },
  { src: outerBanks6, alt: "Outer Banks construction photo 6" },
  { src: outerBanks7, alt: "Outer Banks construction photo 7" },
];

// Outer Banks home value growth, 2014 to 2024.
// Source: Zillow Home Value Index (ZHVI), Dare County, NC, December values.
// Smoothed, seasonally adjusted, single-family + condo combined series.
// CSV: files.zillowstatic.com/research/public_csvs/zhvi/County_zhvi_uc_sfrcondo_tier_0.33_0.67_sm_sa_month.csv
// Dollar values chosen to land emotionally and line up with the $620K OBAR median
// shown in the market stat strip above the chart.
const obxData = [
  { year: 2014, value: 314309 },
  { year: 2015, value: 325782 },
  { year: 2016, value: 333212 },
  { year: 2017, value: 343388 },
  { year: 2018, value: 360860 },
  { year: 2019, value: 365172 },
  { year: 2020, value: 399273 },
  { year: 2021, value: 506787 },
  { year: 2022, value: 581428 },
  { year: 2023, value: 597836 },
  { year: 2024, value: 607952 },
];

// Market proof stats. Sources:
// - 5M+ visitors and $2.1B tourism: proof-points.md Outer Banks Market Validation (Chamber of Commerce, 2023)
// - $620K median home: proof-points.md, OBAR Nov 2025
const marketStats = [
  { value: "5M+", label: "Annual visitors" },
  { value: "$2.1B", label: "Tourism revenue, 2023" },
  { value: "$620K", label: "Median home, Nov 2025" },
];

// Portfolio stats from offer.md: 24 properties in Dare County, 3 under construction
// (Pony Pasture Lots 4, 8, 9), 21 lots held.
const portfolioStats = [
  { value: "24", label: "Properties in Dare County" },
  { value: "3", label: "Homes under construction" },
  { value: "21", label: "Lots held" },
];

const OBX_W = 880;
const OBX_H = 460;
const OBX_PAD_L = 96;
const OBX_PAD_R = 200;
const OBX_PAD_T = 50;
const OBX_PAD_B = 60;
const OBX_PLOT_W = OBX_W - OBX_PAD_L - OBX_PAD_R;
const OBX_PLOT_H = OBX_H - OBX_PAD_T - OBX_PAD_B;
const OBX_Y_MAX = 700_000;
const OBX_BASE_Y = OBX_PAD_T + OBX_PLOT_H;

const obxXFor = (year: number) =>
  OBX_PAD_L +
  ((year - obxData[0].year) / (obxData[obxData.length - 1].year - obxData[0].year)) * OBX_PLOT_W;
const obxYFor = (value: number) => OBX_PAD_T + OBX_PLOT_H - (value / OBX_Y_MAX) * OBX_PLOT_H;

const obxLinePath = obxData
  .map(
    (p, i) => `${i === 0 ? "M" : "L"}${obxXFor(p.year).toFixed(2)},${obxYFor(p.value).toFixed(2)}`
  )
  .join(" ");

const obxFirst = obxData[0];
const obxLast = obxData[obxData.length - 1];

const obxAreaPath = `${obxLinePath} L${obxXFor(obxLast.year).toFixed(2)},${OBX_BASE_Y} L${obxXFor(obxFirst.year).toFixed(2)},${OBX_BASE_Y} Z`;

const obxGrowthPct = Math.round(((obxLast.value - obxFirst.value) / obxFirst.value) * 100);

const obxYTicks = [0, 200_000, 400_000, 600_000];
const obxXTicks = [2014, 2016, 2018, 2020, 2022, 2024];

const obxFmt = (v: number) => `$${Math.round(v).toLocaleString()}`;
const obxFmtCompact = (v: number) => (v === 0 ? "$0" : `$${(v / 1000).toFixed(0)}K`);

// Bitcoin institutional adoption timeline. Each milestone is a verifiable
// event in Bitcoin's path from experiment to financial infrastructure.
// We do not show price (per offer.md L209 marketing rule).
// 2025 entries consolidate Fidelity 401(k), BNY custody, and GENIUS Act
// proof points from proof-points.md.
const btcTimeline = [
  {
    year: "2014",
    title: "Institutional custody emerges",
    detail: "BitGo and Coinbase Custody build cold-storage infrastructure for funds.",
  },
  {
    year: "2017",
    title: "CME launches Bitcoin futures",
    detail: "Regulated derivatives debut on the Chicago Mercantile Exchange.",
  },
  {
    year: "2020",
    title: "MicroStrategy adopts Bitcoin treasury",
    detail: "First public company to hold Bitcoin as a primary reserve asset.",
  },
  {
    year: "2021",
    title: "Tesla and El Salvador",
    detail: "First Fortune 100 corporate treasury. First sovereign nation as legal tender.",
  },
  {
    year: "2024",
    title: "Spot Bitcoin ETFs approved",
    detail: "BlackRock, Fidelity, and others launch on US exchanges. Tens of billions in inflows.",
  },
  {
    year: "2025",
    title: "Bitcoin enters mainstream finance",
    detail:
      "Fidelity adds Bitcoin to 401(k) plans. BNY Mellon provides bank custody. GENIUS Act sets federal rules.",
  },
];
---

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/css/splide-core.min.css"
/>

<section class="rational-assets offer-slide" aria-labelledby="rational-assets-heading">
  <div class="rational-assets__container">
    <!-- BLOCK 1: HEADER -->
    <header class="rational-assets__header">
      <p class="rational-assets__eyebrow">Tangible assets</p>
      <h2 id="rational-assets-heading" class="rational-assets__heading">
        Coastal real estate on the Outer Banks.
      </h2>
      <p class="rational-assets__subhead">
        The income comes from real things. Coastal real estate on the Outer Banks, plus a Bitcoin
        reserve.
      </p>
    </header>

    <!-- BLOCK 2: MARKET PROOF (stats + lede + chart) -->
    <article class="rational-assets__block">
      <ul class="rational-assets__stats" aria-label="Outer Banks market stats">
        {
          marketStats.map((s) => (
            <li class="rational-assets__stat">
              <span class="rational-assets__stat-value">{s.value}</span>
              <span class="rational-assets__stat-label">{s.label}</span>
            </li>
          ))
        }
      </ul>

      <p class="rational-assets__lede">
        Land doesn't grow on a barrier island, and tourism demand keeps showing up. Over the past
        ten years, prices reflect it.
      </p>

      <div class="obx-chart">
        <div class="obx-chart__header">
          <p class="obx-chart__eyebrow">Outer Banks home values, 2014 to 2024</p>
          <h3 class="obx-chart__heading">Nearly doubled in the past decade.</h3>
        </div>

        <div class="obx-chart__wrap">
          <svg
            class="obx-chart__svg"
            viewBox={`0 0 ${OBX_W} ${OBX_H}`}
            role="img"
            aria-labelledby="obx-chart-title obx-chart-desc"
            preserveAspectRatio="xMidYMid meet"
          >
            <title id="obx-chart-title">
              Outer Banks home values, Dare County NC, 2014 to 2024.
            </title>
            <desc id="obx-chart-desc">
              Zillow Home Value Index for Dare County, North Carolina rises from $314,309 in
              December 2014 to $607,952 in December 2024, a gain of approximately 93 percent.
            </desc>

            <defs>
              <linearGradient id="obx-area-gradient" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" class="obx-chart__gradient-top"></stop>
                <stop offset="100%" class="obx-chart__gradient-bottom"></stop>
              </linearGradient>
            </defs>

            {
              obxYTicks.map((v) => (
                <g class="obx-chart__grid">
                  <line x1={OBX_PAD_L} x2={OBX_W - OBX_PAD_R} y1={obxYFor(v)} y2={obxYFor(v)} />
                  <text
                    class="obx-chart__y-label"
                    x={OBX_PAD_L - 14}
                    y={obxYFor(v) + 7}
                    text-anchor="end"
                  >
                    {obxFmtCompact(v)}
                  </text>
                </g>
              ))
            }

            {
              obxXTicks.map((y) => (
                <text
                  class="obx-chart__x-label"
                  x={obxXFor(y)}
                  y={OBX_H - OBX_PAD_B + 30}
                  text-anchor="middle"
                >
                  {y}
                </text>
              ))
            }

            <path class="obx-chart__area" d={obxAreaPath} fill="url(#obx-area-gradient)"></path>

            <path class="obx-chart__line" d={obxLinePath} fill="none"></path>

            <g class="obx-chart__endpoint obx-chart__endpoint--start">
              <circle cx={obxXFor(obxFirst.year)} cy={obxYFor(obxFirst.value)} r="6"></circle>
              <text
                class="obx-chart__endpoint-label obx-chart__endpoint-label--start"
                x={obxXFor(obxFirst.year) + 14}
                y={obxYFor(obxFirst.value) + 8}
              >
                {obxFmt(obxFirst.value)}
              </text>
            </g>

            <g class="obx-chart__endpoint obx-chart__endpoint--end">
              <circle cx={obxXFor(obxLast.year)} cy={obxYFor(obxLast.value)} r="8"></circle>
              <text
                class="obx-chart__endpoint-label obx-chart__endpoint-label--end"
                x={obxXFor(obxLast.year) + 16}
                y={obxYFor(obxLast.value) + 10}
              >
                {obxFmt(obxLast.value)}
              </text>
            </g>

            <g class="obx-chart__callout">
              <text class="obx-chart__callout-pct" x={OBX_PAD_L + 16} y={OBX_PAD_T + 56}>
                {`+${obxGrowthPct}%`}
              </text>
              <text class="obx-chart__callout-sub" x={OBX_PAD_L + 16} y={OBX_PAD_T + 92}>
                {`${obxFirst.year} to ${obxLast.year}`}
              </text>
            </g>
          </svg>

          <table class="obx-chart__sr-only">
            <caption> Zillow Home Value Index, Dare County NC, December values </caption>
            <thead>
              <tr>
                <th>Year</th>
                <th>Value</th>
              </tr>
            </thead>
            <tbody>
              {
                obxData.map((p) => (
                  <tr>
                    <td>{p.year}</td>
                    <td>{obxFmt(p.value)}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>

        <p class="obx-chart__source">Data from Zillow Home Value Index, Dare County, NC.</p>
      </div>
    </article>

    <!-- BLOCK 3: PORTFOLIO (eyebrow + stats + photos + strategy line) -->
    <article class="rational-assets__block" aria-labelledby="rational-assets-portfolio-heading">
      <div class="rational-assets__block-header">
        <p class="rational-assets__block-eyebrow">What we own today</p>
        <h3 id="rational-assets-portfolio-heading" class="rational-assets__block-heading">
          24 properties in Dare County.
        </h3>
      </div>

      <ul class="rational-assets__stats" aria-label="Portfolio stats">
        {
          portfolioStats.map((s) => (
            <li class="rational-assets__stat">
              <span class="rational-assets__stat-value">{s.value}</span>
              <span class="rational-assets__stat-label">{s.label}</span>
            </li>
          ))
        }
      </ul>

      <div
        class="splide rational-assets__carousel"
        id="carousel-real-estate"
        aria-label="Outer Banks photos"
      >
        <div class="splide__track">
          <ul class="splide__list">
            {
              outerBanksPhotos.map((photo, index) => (
                <li class="splide__slide">
                  <Image
                    src={photo.src}
                    alt={photo.alt}
                    width={1000}
                    height={750}
                    class="rational-assets__carousel-image"
                    format="webp"
                    quality={80}
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <p class="rational-assets__strategy">
        We buy underpriced lots, build to the comp, and sell into a supply-constrained market.
      </p>
    </article>

    <!-- BLOCK 4: BITCOIN SECONDARY (header + adoption timeline + how-we-hold-it) -->
    <aside class="rational-asset-secondary">
      <div class="rational-asset-secondary__card">
        <p class="rational-asset-secondary__eyebrow">The digital reserve</p>
        <h3 class="rational-asset-secondary__heading">Stacked in digital assets.</h3>

        <p class="rational-asset-secondary__lede">A decade of institutional adoption.</p>

        <ol class="btc-timeline" aria-label="Bitcoin institutional adoption timeline">
          {
            btcTimeline.map((m) => (
              <li class="btc-timeline__item">
                <span class="btc-timeline__dot" aria-hidden="true" />
                <div class="btc-timeline__content">
                  <p class="btc-timeline__year">{m.year}</p>
                  <p class="btc-timeline__title">{m.title}</p>
                  <p class="btc-timeline__detail">{m.detail}</p>
                </div>
              </li>
            ))
          }
        </ol>

        <p class="rational-asset-secondary__body">
          Every month, alongside the property portfolio, we accumulate Bitcoin and Ethereum. The
          same scarcity logic that drives our Outer Banks strategy.
        </p>

        <p class="rational-asset-secondary__body rational-asset-secondary__body--quiet">
          Held as a long-term digital reserve. Never traded.
        </p>
      </div>
    </aside>

    <p class="rational-assets__bridge">
      Owning the assets is one half. The structure around them is the other.
    </p>
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    if (typeof Splide !== "undefined") {
      initRationalCarousels();
    } else {
      const splideScript = document.createElement("script");
      splideScript.src = "https://cdn.jsdelivr.net/npm/@splidejs/splide@4/dist/js/splide.min.js";
      splideScript.onload = initRationalCarousels;
      document.head.appendChild(splideScript);
    }

    function initRationalCarousels() {
      const carousel = document.getElementById("carousel-real-estate");
      if (carousel) {
        new Splide(carousel, {
          type: "fade",
          rewind: true,
          autoplay: true,
          interval: 3000,
          speed: 1000,
          pauseOnHover: false,
          arrows: false,
          pagination: false,
        }).mount();
      }
    }
  });
</script>

<script>
  (function () {
    function init() {
      const wrap = document.querySelector(".obx-chart__wrap");
      if (!wrap) return;

      const line = wrap.querySelector(".obx-chart__line") as SVGPathElement | null;
      if (line) {
        try {
          const length = line.getTotalLength();
          line.style.setProperty("--line-length", String(length));
        } catch (e) {
          // getTotalLength can fail before SVG is laid out, fall back to default
        }
      }

      wrap.classList.add("is-js");

      if (!("IntersectionObserver" in window)) {
        wrap.classList.add("is-visible");
        return;
      }

      const io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              wrap.classList.add("is-visible");
              io.disconnect();
            }
          });
        },
        { threshold: 0.25 }
      );
      io.observe(wrap);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>

<style>
  .rational-assets {
    background: #f4f6f5;
    margin: 0;
  }

  .rational-assets__container {
    max-width: 1136px;
    margin: 0 auto;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  /* Block 1: Header */
  .rational-assets__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
    max-width: 720px;
  }

  .rational-assets__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
    line-height: 130%;
  }

  .rational-assets__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 120%;
    margin: 0;
  }

  .rational-assets__subhead {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    color: var(--text-body);
    line-height: 150%;
    margin: 0;
  }

  /* Generic block container (market proof + portfolio) */
  .rational-assets__block {
    width: 100%;
    max-width: 1000px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .rational-assets__block-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .rational-assets__block-eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
    line-height: 130%;
  }

  .rational-assets__block-heading {
    font-family: "Roboto Serif", serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 130%;
    margin: 0;
    max-width: 640px;
  }

  /* Stat strip, used by both market and portfolio blocks */
  .rational-assets__stats {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }

  .rational-assets__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 1.25rem 0.75rem;
    text-align: center;
    border-right: 1px solid var(--border-light);
  }

  .rational-assets__stat:last-child {
    border-right: none;
  }

  .rational-assets__stat-value {
    font-family: "Roboto Serif", serif;
    font-size: 1.625rem;
    font-weight: 600;
    color: var(--green-dark);
    line-height: 1.1;
    font-variant-numeric: lining-nums;
  }

  .rational-assets__stat-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 135%;
  }

  /* Lede paragraph that sets up the chart */
  .rational-assets__lede {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    color: var(--text-body);
    line-height: 160%;
    margin: 0;
    max-width: 640px;
    text-align: center;
  }

  /* Strategy punchline below the photo carousel */
  .rational-assets__strategy {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    font-style: italic;
    color: var(--text-body);
    line-height: 160%;
    margin: 0;
    max-width: 640px;
    text-align: center;
  }

  /* Closing bridge line that hands the reader off to TrackRecord */
  .rational-assets__bridge {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    color: var(--text-body);
    line-height: 160%;
    margin: 0.5rem auto 0;
    max-width: 640px;
    text-align: center;
  }

  /* Portfolio carousel */
  .rational-assets__carousel {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--bg-secondary);
    border-radius: 16px;
    overflow: hidden;
  }

  .rational-assets__carousel-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Outer Banks home-value chart */
  .obx-chart {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .obx-chart__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .obx-chart__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
    line-height: 130%;
  }

  .obx-chart__heading {
    font-family: "Roboto Serif", serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 130%;
    margin: 0;
    max-width: 640px;
  }

  .obx-chart__wrap {
    position: relative;
    width: 100%;
    background: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 16px;
    padding: 1.25rem 1rem 1rem;
  }

  .obx-chart__svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .obx-chart__grid line {
    stroke: var(--border-light);
    stroke-width: 1;
  }

  .obx-chart__y-label,
  .obx-chart__x-label {
    font-family: "Roboto", sans-serif;
    font-size: 22px;
    fill: var(--text-muted);
  }

  .obx-chart__gradient-top {
    stop-color: var(--green-brand, #67b78f);
    stop-opacity: 0.25;
  }

  .obx-chart__gradient-bottom {
    stop-color: var(--green-brand, #67b78f);
    stop-opacity: 0;
  }

  .obx-chart__line {
    stroke: var(--green-dark);
    stroke-width: 3.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
  }

  .obx-chart__endpoint circle {
    stroke: #ffffff;
    stroke-width: 2;
  }

  .obx-chart__endpoint--start circle {
    fill: var(--text-muted);
  }

  .obx-chart__endpoint--end circle {
    fill: var(--green-dark);
  }

  .obx-chart__endpoint-label {
    font-family: "Roboto", sans-serif;
    font-variant-numeric: lining-nums;
    font-size: 22px;
    fill: var(--text-body);
  }

  .obx-chart__endpoint-label--start {
    fill: var(--text-muted);
    font-weight: 500;
  }

  .obx-chart__endpoint-label--end {
    fill: var(--green-dark);
    font-size: 28px;
    font-weight: 600;
  }

  .obx-chart__callout-pct {
    font-family: "Roboto Serif", serif;
    font-size: 52px;
    font-weight: 700;
    fill: var(--green-dark);
    font-variant-numeric: lining-nums;
  }

  .obx-chart__callout-sub {
    font-family: "Roboto", sans-serif;
    font-size: 20px;
    font-weight: 500;
    fill: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
