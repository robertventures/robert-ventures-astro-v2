---
// Two tiers, two rates. Numbers sourced from PresTermsSnapshot:
//   1-year lock-up at 8% APY, 3-year lock-up at 10% APY.
//   Both pay monthly ACH or compound. $1,000 minimum. IRA-compatible.
// Both bonds mature in 10 years; we surface lock-up term in the ladder.

const tiers = [
  {
    term: "1-year lock-up",
    rate: "8% APY",
    payout: "Monthly or compounding",
  },
  {
    term: "3-year lock-up",
    rate: "10% APY",
    payout: "Monthly or compounding",
  },
];
---

<section class="rational-terms offer-slide" aria-labelledby="rational-terms-heading">
  <div class="rational-terms__container">
    <div class="rational-terms__lead">
      <p class="rational-terms__eyebrow">Predictable income</p>
      <h2 id="rational-terms-heading" class="rational-terms__heading">Two terms. Two rates.</h2>

      <p class="rational-terms__liquidity">
        After your minimum term, you are liquid with 90 days notice, or you keep earning at the same
        rate month-to-month until the bond matures at 10 years.
      </p>
    </div>

    <ul class="rational-terms__ladder" aria-label="Bond terms and rates">
      {
        tiers.map((t) => (
          <li class="rational-terms__tier">
            <span class="rational-terms__tier-term">{t.term}</span>
            <span class="rational-terms__tier-rate">{t.rate}</span>
            <span class="rational-terms__tier-payout">{t.payout}</span>
          </li>
        ))
      }
    </ul>

    <p class="rational-terms__strip">
      $1,000 minimum &middot; IRA-compatible &middot; Both bonds mature in 10 years &middot; Zero fees
    </p>
  </div>
</section>

<style>
  .rational-terms {
    background: #f4f6f5;
    margin: 0;
  }

  .rational-terms__container {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }

  .rational-terms__lead {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
  }

  .rational-terms__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
    line-height: 130%;
  }

  .rational-terms__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 120%;
    margin: 0;
  }

  .rational-terms__ladder {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    width: 100%;
    max-width: 720px;
  }

  .rational-terms__tier {
    background: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .rational-terms__tier-term {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-body);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 130%;
  }

  .rational-terms__tier-rate {
    font-family: "Roboto Serif", serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--green-dark);
    line-height: 110%;
    font-variant-numeric: lining-nums;
  }

  .rational-terms__tier-payout {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 140%;
  }

  .rational-terms__liquidity {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    color: var(--text-body);
    line-height: 155%;
    margin: 0;
    max-width: 640px;
    text-align: center;
  }

  .rational-terms__monthly {
    background: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 720px;
  }

  .rational-terms__monthly-eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 130%;
    margin: 0;
    text-align: center;
  }

  .rational-terms__monthly-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .rational-terms__monthly-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: 1px solid var(--border-light);
  }

  .rational-terms__monthly-row:last-child {
    border-bottom: none;
  }

  .rational-terms__monthly-amount {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    color: var(--text-body);
    font-variant-numeric: lining-nums;
  }

  .rational-terms__monthly-payout {
    font-family: "Roboto Serif", serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--green-dark);
    font-variant-numeric: lining-nums;
  }

  .rational-terms__strip {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 150%;
    letter-spacing: 0.04em;
    margin: 0.25rem 0 0;
  }

  @media only screen and (min-width: 600px) {
    .rational-terms__container,
    .rational-terms__lead {
      gap: 1.5rem;
    }

    .rational-terms__heading {
      font-size: 2.75rem;
    }

    .rational-terms__ladder {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .rational-terms__tier-rate {
      font-size: 3rem;
    }

    .rational-terms__liquidity {
      font-size: 1.125rem;
    }

    .rational-terms__monthly {
      padding: 26px 32px;
    }

    .rational-terms__monthly-amount {
      font-size: 1rem;
    }

    .rational-terms__monthly-payout {
      font-size: 1.25rem;
    }

    .rational-terms__strip {
      font-size: 0.9375rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    /* Two-column: lead (heading + copy) left, rate cards right, fine-print strip full-width below */
    .rational-terms__container {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      grid-template-areas:
        "lead cards"
        "strip strip";
      align-items: center;
      column-gap: 2.75rem;
      row-gap: 1.75rem;
      text-align: left;
    }

    .rational-terms__lead {
      grid-area: lead;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .rational-terms__liquidity {
      text-align: left;
      max-width: none;
    }

    .rational-terms__ladder {
      grid-area: cards;
      grid-template-columns: 1fr;
      max-width: none;
      margin: 0;
      gap: 16px;
      align-self: center;
    }

    .rational-terms__strip {
      grid-area: strip;
      text-align: center;
    }

    .rational-terms__heading {
      font-size: 2.5rem;
    }

    .rational-terms__tier-rate {
      font-size: 3.5rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    .rational-terms__heading {
      font-size: 2.625rem;
    }
  }
</style>
