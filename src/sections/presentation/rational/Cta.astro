---
// Final CTA section on the offer page. Heading + subhead + a green "Get Started"
// button (routes to /invest) paired with a subtle "Book a
// 10-minute call" secondary button (routes to /offer/book-call), over a soft
// gradient background with the staircase decoration and a 5-star/testimonial
// social-proof block below. Staircase and social-proof are shared components
// also used on the invest page so styling stays in sync.
import StaircaseDecoration from "../../../components/StaircaseDecoration.astro";
import CtaSocialProof from "../../../components/CtaSocialProof.astro";
---

<section class="rational-cta offer-slide" aria-labelledby="rational-cta-heading">
  <StaircaseDecoration />

  <div class="rational-cta__container">
    <div class="rational-cta__lead">
      <p class="rational-cta__eyebrow">You've seen the case.</p>
      <h2 id="rational-cta-heading" class="rational-cta__heading">Start investing today.</h2>
      <p class="rational-cta__sub">
        Open your account and place your first investment in under two minutes, or schedule a call
        if you'd like help getting set up.
      </p>

      <div class="rational-cta__buttons">
        <a
          class="rational-cta__btn"
          href="/invest"
          data-track-cta="get_started"
          data-track-location="rational_cta_section"
        >
          Get Started
        </a>
        <a
          class="rational-cta__btn-secondary"
          href="/offer/book-call"
          data-track-cta="book_followup_call"
          data-track-location="rational_cta_section"
        >
          Book a 10-minute call
        </a>
      </div>
    </div>

    <CtaSocialProof />
  </div>
</section>

<style>
  .rational-cta {
    background: linear-gradient(to bottom, #ffffff, #f4f6f5);
    margin: 0;
    /* Extra vertical breathing room for the closing CTA, overrides the
       shared section.offer-slide padding (scoped selector wins on specificity). */
    padding-top: 4rem;
    padding-bottom: 4rem;
    position: relative;
    overflow: hidden;
  }

  .rational-cta__container {
    position: relative;
    z-index: 1;
    max-width: 600px;
    margin: 0 auto;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }

  .rational-cta__lead {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
  }

  .rational-cta__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
    line-height: 130%;
  }

  .rational-cta__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 120%;
    margin: 0;
  }

  .rational-cta__sub {
    font-family: "Roboto", sans-serif;
    font-size: 1.0625rem;
    color: var(--text-body);
    line-height: 150%;
    margin: 0;
    max-width: 560px;
  }

  .rational-cta__buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 320px;
    align-items: stretch;
    margin-top: 1rem;
  }

  /* Primary CTA button, mirrors the intro page's .intro-slide__cta */
  .rational-cta__btn {
    font-family: "Roboto", sans-serif;
    font-size: 1.0625rem;
    font-weight: 500;
    color: #ffffff;
    background: var(--green-brand);
    border: 1px solid var(--green-brand);
    border-radius: 8px;
    padding: 1.125rem 1.5rem;
    cursor: pointer;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    box-sizing: border-box;
    transition:
      background 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
    box-shadow: 0 8px 22px rgba(103, 183, 143, 0.4);
  }

  .rational-cta__btn:hover {
    background: var(--green-hover);
    border-color: var(--green-hover);
    color: #ffffff;
    transform: translateY(-1px);
    box-shadow: 0 12px 28px rgba(103, 183, 143, 0.5);
  }

  .rational-cta__btn:active {
    transform: translateY(0);
    box-shadow: 0 5px 14px rgba(103, 183, 143, 0.4);
  }

  /* Subtle secondary button, light gray fill with dark text so it reads
     as a real second option without competing with the green primary. */
  .rational-cta__btn-secondary {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-heading);
    background: #eef0ef;
    border: 1px solid #e3e7e5;
    border-radius: 8px;
    padding: 0.875rem 1.5rem;
    cursor: pointer;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    box-sizing: border-box;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .rational-cta__btn-secondary:hover {
    background: #e3e7e5;
    color: var(--text-heading);
  }

  @media only screen and (min-width: 600px) {
    .rational-cta {
      padding-top: 5.5rem;
      padding-bottom: 5.5rem;
    }

    .rational-cta__container,
    .rational-cta__lead {
      gap: 1.5rem;
    }

    .rational-cta__container {
      max-width: 640px;
    }

    .rational-cta__heading {
      font-size: 2.75rem;
    }

    .rational-cta__sub {
      font-size: 1.125rem;
    }

    .rational-cta__btn {
      font-size: 1.1875rem;
      padding: 1.25rem 1.5rem;
    }

    .rational-cta__btn-secondary {
      font-size: 1rem;
      padding: 1rem 1.5rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .rational-cta {
      padding-top: 7rem;
      padding-bottom: 7rem;
    }

    /* Two-column: text + buttons left, stars + testimonial right */
    .rational-cta__container {
      max-width: var(--content-max);
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: center;
      column-gap: 2.75rem;
      text-align: left;
    }

    .rational-cta__lead {
      align-items: flex-start;
      text-align: left;
      gap: 1.75rem;
    }

    /* Both CTAs span the full left column on desktop. */
    .rational-cta__buttons {
      max-width: none;
    }

    .rational-cta__heading {
      font-size: 2.5rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    .rational-cta__heading {
      font-size: 2.625rem;
    }
  }
</style>
