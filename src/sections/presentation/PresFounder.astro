---
// Offer page hero. The primary CTA uses the shared GetStartedCta cluster
// (homepage-style button + avatars/stars/"Join N+ investors" proof) so the
// hero CTA matches the homepage.
import GetStartedCta from "../../components/GetStartedCta.astro";
---

<section class="pres-founder offer-slide">
  <div class="pres-founder__container">
    <div class="pres-founder__hero">
      <div class="pres-founder__text">
        <h2 class="pres-founder__heading">
          Predictable income. Tangible assets. <span class="pres-founder__heading-accent"
            >25 years of experience.</span
          >
        </h2>
      </div>

      <div class="pres-founder__video-wrapper">
        <div class="pres-founder__video-container">
          <mux-player
            id="pres-founder-mux-player"
            playback-id="02V4Xj64PQinKENPL018mrEuU00bs3T4thfSecE01pxCLVk"
            env-key="hr9aevib299lcvfdoip01jd60"
            preload="metadata"
            stream-type="on-demand"
            max-resolution="1080p"
            rendition-order="desc"
            poster="https://image.mux.com/02V4Xj64PQinKENPL018mrEuU00bs3T4thfSecE01pxCLVk/thumbnail.png?width=214&height=121&time=5"
            placeholder="https://image.mux.com/02V4Xj64PQinKENPL018mrEuU00bs3T4thfSecE01pxCLVk/thumbnail.webp?time=5&width=16"
            muted
            playsinline
            default-show-captions></mux-player>
          <div
            class="pres-founder__mux-overlay"
            id="pres-founder-mux-overlay"
            role="button"
            tabindex="0"
          >
            <div class="pres-founder__mux-overlay-pill">
              <svg
                class="pres-founder__mux-overlay-icon pres-founder__mux-overlay-icon--unmute"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"
                  fill="#ffffff"></path>
              </svg>
              <svg
                class="pres-founder__mux-overlay-icon pres-founder__mux-overlay-icon--play"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M8 5v14l11-7z" fill="#ffffff"></path>
              </svg>
              <span class="pres-founder__mux-overlay-text pres-founder__mux-overlay-text--unmute">
                Your video is playing. Click to unmute.
              </span>
              <span class="pres-founder__mux-overlay-text pres-founder__mux-overlay-text--play">
                Click to play
              </span>
            </div>
          </div>
        </div>
      </div>

      <ul class="pres-founder__stats">
        <li class="pres-founder__stat">
          <span class="pres-founder__stat-value">25+</span>
          <span class="pres-founder__stat-label">Years of experience</span>
        </li>
        <li class="pres-founder__stat">
          <span class="pres-founder__stat-value">$150M+</span>
          <span class="pres-founder__stat-label">Assets managed</span>
        </li>
        <li class="pres-founder__stat">
          <span class="pres-founder__stat-value">200+</span>
          <span class="pres-founder__stat-label">Properties</span>
        </li>
        <li class="pres-founder__stat">
          <span class="pres-founder__stat-value">1,500+</span>
          <span class="pres-founder__stat-label">Mortgage investments</span>
        </li>
      </ul>

      <div class="pres-founder__cta">
        <GetStartedCta trackCta="get_started" trackLocation="offer_hero" href="/invest" />
      </div>
    </div>
  </div>
</section>

<style>
  .pres-founder {
    background: var(--bg-primary);
    margin: 0;
  }

  .pres-founder__container {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .pres-founder__hero {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.25rem;
  }

  .pres-founder__text {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.25rem;
  }

  .pres-founder__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2.375rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 116%;
    letter-spacing: -0.015em;
    text-align: center;
    text-wrap: balance;
    margin: 0;
    max-width: 600px;
  }

  .pres-founder__heading-accent {
    color: #1a1a1a;
    text-decoration: underline;
    text-decoration-color: var(--green-brand);
    text-decoration-thickness: 4px;
    text-underline-offset: 6px;
  }

  .pres-founder__subhead {
    font-family: "Roboto", sans-serif;
    font-size: 1.125rem;
    color: #555555;
    line-height: 150%;
    text-align: center;
    margin: 0;
    max-width: 600px;
  }

  .pres-founder__heading + .pres-founder__subhead {
    margin-top: -0.5rem;
  }

  .pres-founder__stats {
    width: 100%;
  }

  .pres-founder__video-wrapper {
    width: 100%;
    overflow: hidden;
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.06),
      0 24px 48px rgba(0, 0, 0, 0.08);
  }

  .pres-founder__video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #152429;
  }

  .pres-founder__video-container :global(mux-player) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    --media-object-fit: cover;
    --media-object-position: center;
    --time-range: none;
  }

  .pres-founder__video-container :global(mux-player[mediaisfullscreen]) {
    --time-range: initial;
  }

  .pres-founder__mux-overlay {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
    background: rgba(0, 0, 0, 0.18);
  }

  .pres-founder__mux-overlay.is-active {
    display: flex;
  }

  .pres-founder__mux-overlay:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: -4px;
  }

  .pres-founder__mux-overlay-pill {
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 999px;
    padding: 0.625rem 1rem 0.625rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.01em;
    white-space: nowrap;
    animation: pres-founder-mux-pill-glow 2.4s ease-in-out infinite;
    pointer-events: none;
  }

  .pres-founder__mux-overlay-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .pres-founder__mux-overlay-icon--play {
    display: none;
    margin-left: 2px;
  }

  .pres-founder__mux-overlay-text--play {
    display: none;
  }

  .pres-founder__mux-overlay.is-play-mode .pres-founder__mux-overlay-icon--unmute,
  .pres-founder__mux-overlay.is-play-mode .pres-founder__mux-overlay-text--unmute {
    display: none;
  }

  .pres-founder__mux-overlay.is-play-mode .pres-founder__mux-overlay-icon--play,
  .pres-founder__mux-overlay.is-play-mode .pres-founder__mux-overlay-text--play {
    display: inline-block;
  }

  @keyframes pres-founder-mux-pill-glow {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(103, 183, 143, 0.55);
    }
    70% {
      box-shadow: 0 0 0 14px rgba(103, 183, 143, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pres-founder__mux-overlay-pill {
      animation: none;
    }
  }

  @media (min-width: 600px) {
    .pres-founder__mux-overlay-pill {
      padding: 0.75rem 1.25rem 0.75rem 1rem;
      font-size: 0.9375rem;
    }

    .pres-founder__mux-overlay-icon {
      width: 24px;
      height: 24px;
    }
  }

  /* Single 4-across highlights stripe at every breakpoint, hairline dividers
     between columns and a top/bottom rule framing the band. */
  .pres-founder__stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }

  .pres-founder__stat {
    padding: 1rem 0.4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.4rem;
    border-right: 1px solid var(--border-light);
  }

  .pres-founder__stat:last-child {
    border-right: none;
  }

  .pres-founder__stat-value {
    font-family: "Roboto Serif", serif;
    font-size: clamp(1.25rem, 0.9rem + 1.7vw, 2.25rem);
    font-weight: 600;
    color: var(--green-dark);
    font-variant-numeric: lining-nums;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .pres-founder__stat-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.625rem;
    color: #888888;
    line-height: 130%;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  /* Primary CTA below the hero: the shared GetStartedCta cluster, centered. */
  .pres-founder__cta {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  @media only screen and (min-width: 600px) {
    .pres-founder__hero,
    .pres-founder__text {
      gap: 3rem;
    }

    .pres-founder__heading {
      font-size: 3rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    /* All info stacks in the left column: headline, then the 4-across
       highlights stripe, then the CTA. The video sits on the right, spanning
       the full height of the left stack. */
    .pres-founder__hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
      grid-template-areas:
        "text  video"
        "stats video"
        "cta   video";
      align-items: start;
      column-gap: 3.5rem;
      row-gap: 1.75rem;
    }

    .pres-founder__text {
      grid-area: text;
      align-items: flex-start;
    }

    .pres-founder__video-wrapper {
      grid-area: video;
      align-self: center;
    }

    .pres-founder__stats {
      grid-area: stats;
    }

    .pres-founder__cta {
      grid-area: cta;
      justify-content: flex-start;
    }

    /* Span the full left column so the button lines up with the stats band
       above it. Removes the shared CTA block's 384px cap on desktop only;
       mobile/tablet keep the capped, centered button. */
    .pres-founder__cta :global(.gs-cta-block) {
      max-width: none;
    }

    .pres-founder__heading,
    .pres-founder__subhead {
      text-align: left;
      max-width: none;
    }

    /* Stripe now lives in the narrower left column, so keep values compact. */
    .pres-founder__stat {
      padding: 1.25rem 0.5rem;
    }

    .pres-founder__stat-value {
      font-size: 1.75rem;
      line-height: 1;
    }

    .pres-founder__stat-label {
      font-size: 0.625rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .pres-founder__heading {
      font-size: 3rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    .pres-founder__heading {
      font-size: 3.5rem;
    }
  }
</style>

<script is:inline>
  (function () {
    function setupFounderInlineVideo() {
      const player = document.getElementById("pres-founder-mux-player");
      const overlay = document.getElementById("pres-founder-mux-overlay");
      if (!player) return;

      let autoplayState = "pending";
      let isAutoplayPlay = false;
      let engaged = false;

      function showOverlayUnmuteMode() {
        if (!overlay) return;
        overlay.classList.add("is-active");
        overlay.classList.remove("is-play-mode");
        overlay.setAttribute("aria-label", "Your video is playing. Click to unmute.");
      }

      function showOverlayPlayMode() {
        if (!overlay) return;
        overlay.classList.add("is-active", "is-play-mode");
        overlay.setAttribute("aria-label", "Click to play");
      }

      function dismissOverlay() {
        if (!overlay) return;
        overlay.classList.remove("is-active");
      }

      // Video autoplays muted. The interaction worth tracking is the user
      // clicking the video (unmutes it, or restarts it unmuted if ended).
      // We treat that single interaction as the "video_play".
      function markEngaged() {
        if (engaged) return;
        engaged = true;
        dismissOverlay();
        if (window.posthogTrack) {
          window.posthogTrack("video_play", {
            video_id: "offer-founder",
            current_time: Math.round(player.currentTime || 0),
          });
        }
      }

      function attemptAutoplay() {
        if (autoplayState !== "pending") return;
        autoplayState = "trying";
        try {
          player.muted = true;
        } catch (e) {}
        isAutoplayPlay = true;
        const promise = player.play();
        if (promise && typeof promise.then === "function") {
          promise
            .then(function () {
              autoplayState = "playing";
              if (!engaged) showOverlayUnmuteMode();
            })
            .catch(function () {
              isAutoplayPlay = false;
              autoplayState = "failed";
              if (!engaged) showOverlayPlayMode();
            });
        } else {
          autoplayState = "playing";
          if (!engaged) showOverlayUnmuteMode();
        }
      }

      function engageFromOverlay(e) {
        if (!overlay || !overlay.classList.contains("is-active")) return;
        e.preventDefault();
        e.stopPropagation();
        try {
          player.muted = false;
        } catch (err) {}
        markEngaged();
        dismissOverlay();
      }

      if (overlay) {
        overlay.addEventListener("click", engageFromOverlay);
        overlay.addEventListener("keydown", function (e) {
          if (e.key === "Enter" || e.key === " ") engageFromOverlay(e);
        });
      }

      player.addEventListener("play", function () {
        const wasAutoplay = isAutoplayPlay;
        isAutoplayPlay = false;
        if (!wasAutoplay) markEngaged();
      });

      player.addEventListener("volumechange", function () {
        if (engaged) return;
        if (player.muted) return;
        try {
          player.pause();
          player.currentTime = 0;
        } catch (e) {}
        const result = player.play();
        if (result && typeof result.catch === "function") result.catch(function () {});
        markEngaged();
      });

      if ("IntersectionObserver" in window) {
        const videoIo = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.intersectionRatio >= 0.5) {
                if (autoplayState === "pending") {
                  attemptAutoplay();
                } else if (autoplayState === "playing" && player.paused && !engaged) {
                  isAutoplayPlay = true;
                  const result = player.play();
                  if (result && typeof result.catch === "function") {
                    result.catch(function () {
                      isAutoplayPlay = false;
                    });
                  }
                }
              } else if (!player.paused) {
                player.pause();
              }
            });
          },
          { threshold: [0, 0.5, 1] }
        );
        videoIo.observe(player);
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupFounderInlineVideo);
    } else {
      setupFounderInlineVideo();
    }
  })();
</script>
