---
import PresDualCTA from "./PresDualCTA.astro";
---

<section class="pres-founder">
  <div class="pres-founder__container">
    <div class="pres-founder__media">
      <div class="pres-founder__video">
        <mux-player
          id="pres-mux-player"
          playback-id="zcQwBRwPYkk7H68jKSAKzUtBLukN4yls02dvyVv4TrP00"
          env-key="hr9aevib299lcvfdoip01jd60"
          preload="metadata"
          stream-type="on-demand"
          max-resolution="1080p"
          rendition-order="desc"
          poster="https://image.mux.com/zcQwBRwPYkk7H68jKSAKzUtBLukN4yls02dvyVv4TrP00/thumbnail.png?width=720&height=405&time=5"
          placeholder="https://image.mux.com/zcQwBRwPYkk7H68jKSAKzUtBLukN4yls02dvyVv4TrP00/thumbnail.webp?time=5&width=16"
          muted
          playsinline
          default-show-captions></mux-player>
        <div class="pres-founder__mux-overlay" id="pres-mux-overlay" role="button" tabindex="0">
          <div class="pres-founder__mux-overlay-pill">
            <svg
              class="pres-founder__mux-overlay-icon pres-founder__mux-overlay-icon--unmute"
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"
                fill="#ffffff"></path>
            </svg>
            <svg
              class="pres-founder__mux-overlay-icon pres-founder__mux-overlay-icon--play"
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path d="M8 5v14l11-7z" fill="#ffffff"></path>
            </svg>
            <span class="pres-founder__mux-overlay-text pres-founder__mux-overlay-text--unmute">
              Your video is playing. Click to unmute.
            </span>
            <span class="pres-founder__mux-overlay-text pres-founder__mux-overlay-text--play">
              Click to play
            </span>
          </div>
        </div>
      </div>
      <div class="pres-founder__caption">
        <span class="pres-founder__name">Joe Robert</span>
        <span class="pres-founder__role">Manager and Founder</span>
      </div>
    </div>

    <div class="pres-founder__content">
      <p class="pres-founder__eyebrow">Built by a person, not a fund</p>
      <h2 class="pres-founder__heading">Same person, every call.</h2>
      <p class="pres-founder__subhead">
        Joe Robert has been doing this for 25 years. 200 deals. $10 million raised from private
        investors. Every offering completed. Every payment made.
      </p>

      <ul class="pres-founder__stats">
        <li class="pres-founder__stat">
          <span class="pres-founder__stat-value">25+</span>
          <span class="pres-founder__stat-label">Years of experience</span>
        </li>
        <li class="pres-founder__stat">
          <span class="pres-founder__stat-value">100%</span>
          <span class="pres-founder__stat-label">Payments record</span>
        </li>
        <li class="pres-founder__stat">
          <span class="pres-founder__stat-value">$10M+</span>
          <span class="pres-founder__stat-label">Raised from private investors</span>
        </li>
        <li class="pres-founder__stat">
          <span class="pres-founder__stat-value">200+</span>
          <span class="pres-founder__stat-label">Properties sold</span>
        </li>
      </ul>

      <p class="pres-founder__close">
        When you call Robert Ventures, you do not get a script. You get a person who has answered
        this exact question for 25 years.
      </p>

      <PresDualCTA primary="call" location="founder" />
    </div>
  </div>
</section>

<style>
  .pres-founder {
    background: var(--bg-primary);
    padding: 0;
    margin: 0;
  }

  .pres-founder__container {
    max-width: 1136px;
    margin: 0 auto;
    padding: 72px 20px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .pres-founder__media {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
  }

  .pres-founder__video {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
  }

  .pres-founder__video :global(mux-player) {
    width: 100%;
    height: 100%;
    --media-object-fit: cover;
  }

  /* One-shot UX nudge: covers the video while muted; click anywhere to engage. */
  .pres-founder__mux-overlay {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
    background: rgba(0, 0, 0, 0.18);
  }

  .pres-founder__mux-overlay.is-active {
    display: flex;
  }

  .pres-founder__mux-overlay:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: -4px;
  }

  .pres-founder__mux-overlay-pill {
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 999px;
    padding: 0.625rem 1rem 0.625rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.01em;
    white-space: nowrap;
    animation: pres-mux-pill-glow 2.4s ease-in-out infinite;
    pointer-events: none;
  }

  .pres-founder__mux-overlay-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .pres-founder__mux-overlay-icon--play {
    display: none;
    margin-left: 2px;
  }

  .pres-founder__mux-overlay-text--play {
    display: none;
  }

  .pres-founder__mux-overlay.is-play-mode .pres-founder__mux-overlay-icon--unmute,
  .pres-founder__mux-overlay.is-play-mode .pres-founder__mux-overlay-text--unmute {
    display: none;
  }

  .pres-founder__mux-overlay.is-play-mode .pres-founder__mux-overlay-icon--play,
  .pres-founder__mux-overlay.is-play-mode .pres-founder__mux-overlay-text--play {
    display: inline-block;
  }

  @keyframes pres-mux-pill-glow {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(103, 183, 143, 0.55);
    }
    70% {
      box-shadow: 0 0 0 14px rgba(103, 183, 143, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pres-founder__mux-overlay-pill {
      animation: none;
    }
  }

  @media (min-width: 600px) {
    .pres-founder__mux-overlay-pill {
      padding: 0.75rem 1.25rem 0.75rem 1rem;
      font-size: 0.9375rem;
    }

    .pres-founder__mux-overlay-icon {
      width: 24px;
      height: 24px;
    }
  }

  .pres-founder__caption {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pres-founder__name {
    font-family: "Roboto Serif", serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--text-heading);
  }

  .pres-founder__role {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    color: var(--text-body);
  }

  .pres-founder__content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .pres-founder__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 130%;
  }

  .pres-founder__heading {
    font-family: "Roboto Serif", serif;
    font-size: 36px;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 115%;
    margin: 0;
  }

  .pres-founder__subhead {
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    color: var(--text-body);
    line-height: 165%;
    margin: 0;
  }

  .pres-founder__stats {
    list-style: none;
    padding: 20px 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }

  .pres-founder__stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pres-founder__stat-value {
    font-family: "Roboto Serif", serif;
    font-size: 28px;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 100%;
    font-variant-numeric: lining-nums;
  }

  .pres-founder__stat-label {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    color: var(--text-body);
    line-height: 140%;
  }

  .pres-founder__close {
    font-family: "Roboto Serif", serif;
    font-size: 20px;
    font-style: italic;
    color: var(--text-heading);
    line-height: 150%;
    margin: 0;
  }

  @media only screen and (min-width: 600px) {
    .pres-founder__container {
      padding: 96px 32px;
    }

    .pres-founder__heading {
      font-size: 44px;
    }

    .pres-founder__stats {
      grid-template-columns: repeat(4, 1fr);
    }

    .pres-founder__stat-value {
      font-size: 32px;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-founder__container {
      flex-direction: row;
      align-items: center;
      gap: 64px;
      padding: 120px 48px;
    }

    .pres-founder__media {
      flex: 1;
      max-width: 540px;
    }

    .pres-founder__content {
      flex: 1;
    }

    .pres-founder__stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media only screen and (min-width: 1280px) {
    .pres-founder__stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
