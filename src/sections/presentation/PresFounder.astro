---

---

<section class="pres-founder">
  <div class="pres-founder__container">
    <div class="pres-founder__content">
      <p class="pres-founder__eyebrow">Built by a person, not a fund</p>
      <h2 class="pres-founder__heading">One name on <em>every deal.</em></h2>
      <p class="pres-founder__subhead">
        Joe Robert has been doing this for 25 years. 200 deals. $10 million raised from private
        investors. Every offering completed. Every payment made.
      </p>

      <div class="pres-founder__video-wrapper">
        <div class="pres-founder__video-container">
          <mux-player
            id="pres-founder-mux-player"
            playback-id="zcQwBRwPYkk7H68jKSAKzUtBLukN4yls02dvyVv4TrP00"
            env-key="hr9aevib299lcvfdoip01jd60"
            preload="metadata"
            stream-type="on-demand"
            max-resolution="1080p"
            rendition-order="desc"
            poster="https://image.mux.com/zcQwBRwPYkk7H68jKSAKzUtBLukN4yls02dvyVv4TrP00/thumbnail.png?width=214&height=121&time=5"
            placeholder="https://image.mux.com/zcQwBRwPYkk7H68jKSAKzUtBLukN4yls02dvyVv4TrP00/thumbnail.webp?time=5&width=16"
            muted
            playsinline
            default-show-captions
          ></mux-player>
          <div
            class="pres-founder__mux-overlay"
            id="pres-founder-mux-overlay"
            role="button"
            tabindex="0"
          >
            <div class="pres-founder__mux-overlay-pill">
              <svg
                class="pres-founder__mux-overlay-icon pres-founder__mux-overlay-icon--unmute"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"
                  fill="#ffffff"></path>
              </svg>
              <svg
                class="pres-founder__mux-overlay-icon pres-founder__mux-overlay-icon--play"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M8 5v14l11-7z" fill="#ffffff"></path>
              </svg>
              <span
                class="pres-founder__mux-overlay-text pres-founder__mux-overlay-text--unmute"
              >
                Your video is playing. Click to unmute.
              </span>
              <span class="pres-founder__mux-overlay-text pres-founder__mux-overlay-text--play">
                Click to play
              </span>
            </div>
          </div>
        </div>
      </div>

      <ul class="pres-founder__stats">
        <li class="pres-founder__stat">
          <span class="pres-founder__stat-value">25+</span>
          <span class="pres-founder__stat-label">Years of experience</span>
        </li>
        <li class="pres-founder__stat">
          <span class="pres-founder__stat-value">100%</span>
          <span class="pres-founder__stat-label">Payments record</span>
        </li>
        <li class="pres-founder__stat">
          <span class="pres-founder__stat-value">$10M+</span>
          <span class="pres-founder__stat-label">From private investors</span>
        </li>
        <li class="pres-founder__stat">
          <span class="pres-founder__stat-value">200+</span>
          <span class="pres-founder__stat-label">Properties sold</span>
        </li>
      </ul>

      <div class="pres-founder__align">
        <p class="pres-founder__align-eyebrow">Why my name is on every offering</p>
        <p class="pres-founder__align-body">
          For 25 years, my name has been on every deal. Robert Ventures has a team built to
          support investors at every step, but I founded the firm, I lead it, and I am personally
          accountable for every offering we put in front of you. The capital we raise funds the
          projects I underwrite, and the track record below is mine to defend.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .pres-founder {
    background: var(--bg-primary);
    padding: 0;
    margin: 0;
  }

  .pres-founder__container {
    max-width: 1136px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .pres-founder__content {
    max-width: 880px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .pres-founder__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 130%;
    text-align: center;
  }

  .pres-founder__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 120%;
    text-align: center;
    margin: 0;
    max-width: 600px;
  }

  .pres-founder__heading em {
    color: var(--green-dark);
    font-style: italic;
  }

  .pres-founder__subhead {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: #555555;
    line-height: 150%;
    text-align: center;
    margin: 0;
    max-width: 600px;
  }

  .pres-founder__heading + .pres-founder__subhead {
    margin-top: -0.5rem;
  }

  .pres-founder__stats,
  .pres-founder__align,
  .pres-founder__close {
    width: 100%;
  }

  .pres-founder__video-wrapper {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
  }

  .pres-founder__video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #152429;
  }

  .pres-founder__video-container :global(mux-player) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    --media-object-fit: cover;
    --media-object-position: center;
    --time-range: none;
  }

  .pres-founder__video-container :global(mux-player[mediaisfullscreen]) {
    --time-range: initial;
  }

  .pres-founder__mux-overlay {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
    background: rgba(0, 0, 0, 0.18);
  }

  .pres-founder__mux-overlay.is-active {
    display: flex;
  }

  .pres-founder__mux-overlay:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: -4px;
  }

  .pres-founder__mux-overlay-pill {
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 999px;
    padding: 0.625rem 1rem 0.625rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.01em;
    white-space: nowrap;
    animation: pres-founder-mux-pill-glow 2.4s ease-in-out infinite;
    pointer-events: none;
  }

  .pres-founder__mux-overlay-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .pres-founder__mux-overlay-icon--play {
    display: none;
    margin-left: 2px;
  }

  .pres-founder__mux-overlay-text--play {
    display: none;
  }

  .pres-founder__mux-overlay.is-play-mode .pres-founder__mux-overlay-icon--unmute,
  .pres-founder__mux-overlay.is-play-mode .pres-founder__mux-overlay-text--unmute {
    display: none;
  }

  .pres-founder__mux-overlay.is-play-mode .pres-founder__mux-overlay-icon--play,
  .pres-founder__mux-overlay.is-play-mode .pres-founder__mux-overlay-text--play {
    display: inline-block;
  }

  @keyframes pres-founder-mux-pill-glow {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(103, 183, 143, 0.55);
    }
    70% {
      box-shadow: 0 0 0 14px rgba(103, 183, 143, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pres-founder__mux-overlay-pill {
      animation: none;
    }
  }

  @media (min-width: 600px) {
    .pres-founder__mux-overlay-pill {
      padding: 0.75rem 1.25rem 0.75rem 1rem;
      font-size: 0.9375rem;
    }

    .pres-founder__mux-overlay-icon {
      width: 24px;
      height: 24px;
    }
  }

  .pres-founder__stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  .pres-founder__stat {
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 14px 12px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pres-founder__stat-value {
    font-family: "Roboto Serif", serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--text-heading);
    font-variant-numeric: lining-nums;
  }

  .pres-founder__stat-label {
    font-family: "Roboto", sans-serif;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .pres-founder__align {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 22px 24px;
    background: linear-gradient(to right, rgba(235, 245, 239, 0.5), transparent);
    border-left: 3px solid var(--green-brand);
    border-radius: 0 8px 8px 0;
  }

  .pres-founder__align-eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 130%;
  }

  .pres-founder__align-body {
    font-family: "Roboto Serif", serif;
    font-size: 17px;
    color: var(--text-heading);
    line-height: 160%;
    margin: 0;
  }

  .pres-founder__close {
    font-family: "Roboto Serif", serif;
    font-size: 20px;
    font-style: italic;
    color: var(--text-heading);
    line-height: 150%;
    margin: 0;
  }

  @media only screen and (min-width: 600px) {
    .pres-founder__container {
      padding: 4rem 2rem;
    }

    .pres-founder__content {
      gap: 1.5rem;
    }

    .pres-founder__heading {
      font-size: 2.75rem;
    }

    .pres-founder__stats {
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }

    .pres-founder__stat-value {
      font-size: 22px;
    }

    .pres-founder__align {
      padding: 28px;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-founder__container {
      padding: 5rem 2rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .pres-founder__heading {
      font-size: 3.25rem;
    }
  }

  @media only screen and (min-width: 1920px) {
    .pres-founder__heading {
      font-size: 3.75rem;
    }
  }
</style>

<script is:inline>
  (function () {
    function setupFounderInlineVideo() {
      const player = document.getElementById("pres-founder-mux-player");
      const overlay = document.getElementById("pres-founder-mux-overlay");
      if (!player) return;

      let autoplayState = "pending";
      let isAutoplayPlay = false;
      let engaged = false;

      function showOverlayUnmuteMode() {
        if (!overlay) return;
        overlay.classList.add("is-active");
        overlay.classList.remove("is-play-mode");
        overlay.setAttribute("aria-label", "Your video is playing. Click to unmute.");
      }

      function showOverlayPlayMode() {
        if (!overlay) return;
        overlay.classList.add("is-active", "is-play-mode");
        overlay.setAttribute("aria-label", "Click to play");
      }

      function dismissOverlay() {
        if (!overlay) return;
        overlay.classList.remove("is-active");
      }

      function attemptAutoplay() {
        if (autoplayState !== "pending") return;
        autoplayState = "trying";
        try {
          player.muted = true;
        } catch (e) {}
        isAutoplayPlay = true;
        const promise = player.play();
        if (promise && typeof promise.then === "function") {
          promise
            .then(function () {
              autoplayState = "playing";
              if (!engaged) showOverlayUnmuteMode();
            })
            .catch(function () {
              isAutoplayPlay = false;
              autoplayState = "failed";
              if (!engaged) showOverlayPlayMode();
            });
        } else {
          autoplayState = "playing";
          if (!engaged) showOverlayUnmuteMode();
        }
      }

      function engageFromOverlay(e) {
        if (!overlay || !overlay.classList.contains("is-active")) return;
        e.preventDefault();
        e.stopPropagation();
        const isPlayMode = overlay.classList.contains("is-play-mode");
        try {
          player.muted = false;
        } catch (err) {}
        if (isPlayMode) {
          const result = player.play();
          if (result && typeof result.catch === "function") result.catch(function () {});
        }
        dismissOverlay();
      }

      if (overlay) {
        overlay.addEventListener("click", engageFromOverlay);
        overlay.addEventListener("keydown", function (e) {
          if (e.key === "Enter" || e.key === " ") engageFromOverlay(e);
        });
      }

      player.addEventListener("play", function () {
        const wasAutoplay = isAutoplayPlay;
        isAutoplayPlay = false;
        if (!wasAutoplay) {
          engaged = true;
          dismissOverlay();
        }
      });

      player.addEventListener("volumechange", function () {
        if (engaged) return;
        if (player.muted) return;
        engaged = true;
        dismissOverlay();
        if (window.posthogTrack) {
          window.posthogTrack("video_unmuted", {
            video_id: "offer-founder",
            current_time: Math.round(player.currentTime || 0),
            autoplay_succeeded: autoplayState === "playing",
          });
        }
      });

      if ("IntersectionObserver" in window) {
        const videoIo = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.intersectionRatio >= 0.5) {
                if (autoplayState === "pending") {
                  attemptAutoplay();
                } else if (autoplayState === "playing" && player.paused && !engaged) {
                  isAutoplayPlay = true;
                  const result = player.play();
                  if (result && typeof result.catch === "function") {
                    result.catch(function () {
                      isAutoplayPlay = false;
                    });
                  }
                }
              } else if (!player.paused) {
                player.pause();
              }
            });
          },
          { threshold: [0, 0.5, 1] }
        );
        videoIo.observe(player);
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupFounderInlineVideo);
    } else {
      setupFounderInlineVideo();
    }
  })();
</script>
