---
const bonds = [
  {
    rate: "8% APY",
    lockup: "1 year",
    payout: "Monthly ACH or compounding",
  },
  {
    rate: "10% APY",
    lockup: "3 years",
    payout: "Monthly ACH or compounding",
  },
];

const terms = [
  { k: "Minimum", v: "$1,000" },
  { k: "After lock-up", v: "Continues month-to-month with 90-day redemption notice" },
  { k: "IRA-compatible", v: "Yes. IRA investors compound through the term" },
  { k: "Interest accrual", v: "Begins the day after funds are confirmed" },
];
---

<section class="pres-terms">
  <div class="pres-terms__container">
    <div class="pres-terms__intro">
      <p class="pres-terms__eyebrow">Corporate bonds</p>
      <h2 class="pres-terms__heading">Choose how long your money is <em>committed.</em></h2>
      <p class="pres-terms__body">
        Both bonds mature in 10 years. Pick the minimum commitment that fits.
      </p>
    </div>

    <div class="pres-terms__grid" aria-label="Bond options">
      {
        bonds.map((b) => (
          <article class="pres-terms__card">
            <header class="pres-terms__card-head">
              <span class="pres-terms__card-label">{b.label}</span>
              <span class="pres-terms__card-rate">{b.rate}</span>
            </header>
            <dl class="pres-terms__card-meta">
              <div class="pres-terms__card-row">
                <dt>Lock-up</dt>
                <dd>{b.lockup}</dd>
              </div>
              <div class="pres-terms__card-row">
                <dt>Payout</dt>
                <dd>{b.payout}</dd>
              </div>
            </dl>
          </article>
        ))
      }
    </div>

    <ul class="pres-terms__details" aria-label="Additional terms">
      {
        terms.map((t) => (
          <li class="pres-terms__detail">
            <span class="pres-terms__detail-k">{t.k}</span>
            <span class="pres-terms__detail-v">{t.v}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .pres-terms {
    background: var(--bg-primary);
    padding: 0;
    margin: 0;
  }

  .pres-terms__container {
    max-width: 1136px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .pres-terms__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
  }

  .pres-terms__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 130%;
    text-align: center;
  }

  .pres-terms__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 120%;
    text-align: center;
    margin: 0;
  }

  .pres-terms__heading em {
    color: var(--green-dark);
    font-style: italic;
  }

  .pres-terms__body {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: #555555;
    line-height: 150%;
    text-align: center;
    margin: 0;
  }

  .pres-terms__heading + .pres-terms__body {
    margin-top: -0.5rem;
  }

  .pres-terms__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }

  .pres-terms__card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .pres-terms__card-head {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pres-terms__card-label {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-body);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 130%;
  }

  .pres-terms__card-rate {
    font-family: "Roboto Serif", serif;
    font-size: 40px;
    font-weight: 700;
    color: var(--green-dark);
    line-height: 110%;
    font-variant-numeric: lining-nums;
  }

  .pres-terms__card-meta {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pres-terms__card-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    border-top: 1px solid var(--border-light);
    padding-top: 10px;
  }

  .pres-terms__card-row dt {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    color: var(--text-body);
    margin: 0;
  }

  .pres-terms__card-row dd {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-heading);
    margin: 0;
    text-align: right;
  }

  .pres-terms__details {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }

  .pres-terms__detail {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 8px;
    background: var(--bg-secondary);
  }

  .pres-terms__detail-k {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    color: var(--text-body);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }

  .pres-terms__detail-v {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-heading);
    text-align: right;
    line-height: 140%;
  }

  @media only screen and (min-width: 600px) {
    .pres-terms__container {
      padding: 4rem 2rem;
      gap: 40px;
    }

    .pres-terms__intro {
      gap: 1.5rem;
    }

    .pres-terms__heading {
      font-size: 2.5rem;
    }

    .pres-terms__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .pres-terms__card-rate {
      font-size: 48px;
    }

    .pres-terms__details {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-terms__container {
      padding: 5rem 2rem;
    }

    .pres-terms__heading {
      font-size: 2.75rem;
    }

    .pres-terms__details {
      grid-template-columns: repeat(4, 1fr);
    }

    .pres-terms__detail {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
    }

    .pres-terms__detail-v {
      text-align: left;
    }
  }

  @media only screen and (min-width: 1136px) {
    .pres-terms__heading {
      font-size: 3rem;
    }
  }
</style>
