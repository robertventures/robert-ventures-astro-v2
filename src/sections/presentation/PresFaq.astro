---
import Opener from "../../images/icons/caretdown.svg";

const formatAnswer = (raw: string) => {
  if (!raw) return "";
  const normalized = String(raw).trim().replace(/\r\n/g, "\n");
  const paragraphs = normalized.split(/\n{2,}/);
  return paragraphs.map((p) => `<p>${p.trim().replace(/\n/g, "<br />")}</p>`).join("");
};

const faqs = [
  {
    question: "Is it FDIC-insured? What's the real risk?",
    slug: "fdic_insured",
    answer: `FDIC insurance only applies to bank deposits, such as savings accounts, not to most investments people already own, including stocks, bonds, mutual funds, and REITs.<br/>
        Like any investment, there's risk. We mitigate this risk through diversification in real estate and blue-chip digital assets. Additionally, our CEO, Joe Robert, has over 25 years of experience, has raised over $10 million in past offerings, and has never missed a payment. One in four investors reinvest within ~40 days, typically with four times their initial amount.`,
  },
  {
    question: "How can we realistically pay 10% in this market?",
    slug: "how_pay_10_percent",
    answer: `Our real estate projects in the Outer Banks target annualized returns of 10% or more, and we also generate long-term growth from investments in Bitcoin and Ethereum. Both sectors have delivered double-digit returns over time, and we don't rely on leverage.<br/>
        The 10% rate is achievable because we operate efficiently, investing only when the timing and demand are right. We build on lots as the market demands it, and if conditions cool, we can shift capital into digital assets instead of being forced to deploy it like significant funds.`,
  },
  {
    question: "Are there any fees?",
    slug: "fees",
    answer: `No. Our bonds are designed with zero intermediary or management fees, so nothing is taken from your monthly payments. This structure ensures that your returns are sent directly to you and reflects our commitment to transparency and aligning our interests with yours.`,
  },
  {
    question: "How are my investments taxed?",
    slug: "taxes",
    answer: `Robert Ventures' investments are taxed the same as any other high-yield bond or interest-bearing investment. You will receive a Form 1099-INT at the beginning of every tax year for the previous year, covering all interest paid during the calendar/tax year.`,
  },
  {
    question: "How experienced is Robert Ventures?",
    slug: "experience",
    answer: `Although this offering is relatively new, having been launched to the public in October 2024 after a year of SEC qualification, it's backed by extensive experience. Over the last 25 years, our manager, Joe Robert, has secured over $10 million from 60 private investors through various partnerships, including Silver Bay Capital. During that time, he has managed 1,500 mortgages and sold 200 properties, completing every offering and repaying investors in full.<br/>
        Now operating under Robert Ventures, he works directly with investors, offering full transparency, eliminating middlemen, and potentially achieving better yields.`,
  },
  {
    question: "Why digital assets are part of our treasuries?",
    slug: "digital_assets",
    answer: `We only hold Bitcoin and Ethereum, the top two digital assets now used and owned by governments (including the US), pensions, and asset managers like BlackRock, the biggest globally. We don't trade, but hold those assets in our treasuries, like large institutions do.<br/>
        They've been the best-performing assets of the past decade and complement the stability of our real estate. We're preparing ourselves for a digital economy.`,
  },
];
---

<section class="pres-faq">
  <div class="pres-faq__container">
    <div class="pres-faq__intro">
      <p class="pres-faq__eyebrow">Before you click invest</p>
      <h2 class="pres-faq__heading">The questions investors ask <em>most often.</em></h2>
    </div>

    <div class="pres-faq__list">
      {
        faqs.map((faq, index) => (
          <div class="pres-faq__item">
            <button
              class="pres-faq__btn"
              type="button"
              aria-expanded="false"
              aria-controls={`pres-faq-panel-${index}`}
              id={`pres-faq-button-${index}`}
              data-faq-slug={faq.slug}
            >
              <span class="pres-faq__btn-text">{faq.question}</span>
              <Opener class="pres-faq__btn-icon" />
            </button>
            <div
              class="pres-faq__panel"
              id={`pres-faq-panel-${index}`}
              role="region"
              aria-labelledby={`pres-faq-button-${index}`}
            >
              <div class="pres-faq__panel-inner" set:html={formatAnswer(faq.answer)} />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .pres-faq {
    background: var(--bg-primary);
    padding: 0;
    margin: 0;
  }

  .pres-faq__container {
    max-width: 860px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .pres-faq__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
  }

  .pres-faq__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 130%;
    text-align: center;
  }

  .pres-faq__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 120%;
    text-align: center;
    margin: 0;
  }

  .pres-faq__heading em {
    color: var(--green-dark);
    font-style: italic;
  }

  .pres-faq__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .pres-faq__item {
    background: var(--bg-secondary);
    border-radius: 8px;
    border: 1px solid var(--border-light);
  }

  .pres-faq__btn {
    width: 100%;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    padding: 16px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 140%;
  }

  .pres-faq__btn-text {
    flex: 1;
  }

  .pres-faq__btn-icon {
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .pres-faq__btn.is-active .pres-faq__btn-icon {
    transform: rotate(180deg);
  }

  .pres-faq__panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  .pres-faq__panel-inner {
    padding: 0 18px 16px 18px;
  }

  .pres-faq__panel-inner :global(p) {
    margin: 0;
    font-family: "Roboto", sans-serif;
    font-size: 18px;
    color: var(--text-body);
    line-height: 165%;
  }

  .pres-faq__panel-inner :global(p + p) {
    margin-top: 0.75rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .pres-faq__panel {
      transition: none;
    }

    .pres-faq__btn-icon {
      transition: none;
    }
  }

  @media only screen and (min-width: 600px) {
    .pres-faq__container {
      padding: 4rem 2rem;
      gap: 36px;
    }

    .pres-faq__intro {
      gap: 1.5rem;
    }

    .pres-faq__heading {
      font-size: 2.5rem;
    }

    .pres-faq__btn {
      font-size: 19px;
      padding: 18px 22px;
    }

    .pres-faq__panel-inner {
      padding: 0 22px 18px 22px;
    }

    .pres-faq__panel-inner :global(p) {
      font-size: 18px;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-faq__container {
      padding: 5rem 2rem;
    }

    .pres-faq__heading {
      font-size: 2.75rem;
    }
  }
</style>

<script>
  function triggerEvent(eventName: string, eventData: Record<string, string> = {}) {
    if ((window as any).dataLayer) {
      (window as any).dataLayer.push({
        event: eventName,
        ...eventData,
      });
    }
  }

  document.addEventListener("DOMContentLoaded", function () {
    const list = document.querySelector(".pres-faq__list");
    if (!list) return;

    const allPanels = list.querySelectorAll(".pres-faq__panel");
    allPanels.forEach((panel) => {
      (panel as HTMLElement).style.maxHeight = "0";
    });

    list.addEventListener("transitionend", function (event) {
      const panel = event.target as HTMLElement;
      if (!panel.classList.contains("pres-faq__panel")) return;
      if (panel.classList.contains("is-open")) {
        panel.style.maxHeight = "none";
      }
    });

    list.addEventListener("click", function (event) {
      const target = event.target;
      const button = target instanceof Element ? target.closest("button.pres-faq__btn") : null;
      if (!button || !list.contains(button)) return;

      const clickedPanel = button.nextElementSibling as HTMLElement | null;
      if (!clickedPanel) return;

      const isCurrentlyOpen = button.classList.contains("is-active");
      const allButtons = list.querySelectorAll("button.pres-faq__btn");
      const allPanels = list.querySelectorAll(".pres-faq__panel");

      allButtons.forEach((btn) => {
        if (btn !== button) {
          btn.classList.remove("is-active");
          btn.setAttribute("aria-expanded", "false");
        }
      });

      allPanels.forEach((panel) => {
        if (panel !== clickedPanel) {
          const el = panel as HTMLElement;
          if (panel.classList.contains("is-open")) {
            el.style.maxHeight = el.scrollHeight + "px";
            el.offsetHeight;
            el.style.maxHeight = "0";
            panel.classList.remove("is-open");
          }
        }
      });

      if (isCurrentlyOpen) {
        button.classList.remove("is-active");
        button.setAttribute("aria-expanded", "false");
        clickedPanel.style.maxHeight = clickedPanel.scrollHeight + "px";
        clickedPanel.offsetHeight;
        clickedPanel.style.maxHeight = "0";
        clickedPanel.classList.remove("is-open");
      } else {
        button.classList.add("is-active");
        button.setAttribute("aria-expanded", "true");
        clickedPanel.classList.add("is-open");
        clickedPanel.style.maxHeight = clickedPanel.scrollHeight + "px";

        const faqSlug = (button as HTMLElement).dataset.faqSlug || "unknown";
        triggerEvent("faq_clicked", {
          faq_question: faqSlug,
          faq_location: "offer_v2",
        });
      }
    });
  });
</script>
