---

<section class="pres-closing">
  <div class="pres-closing__container">
    <p class="pres-closing__eyebrow">The next step</p>
    <h2 class="pres-closing__heading">Ready to get <em>started?</em></h2>
    <p class="pres-closing__body">
      Create your InvestorDesk account to choose your bond term, choose monthly distributions or
      compounding, enter your investment amount, sign the bond agreement, and fund your bond. If
      you still have a question, book a 10-minute call first.
    </p>

    <div class="pres-closing__actions">
      <a
        class="pres-closing__btn pres-closing__btn--primary"
        href="https://invest.robertventures.com/"
        data-track-cta="create_account"
        data-track-location="closing_cta"
      >
        Create your account
      </a>
      <a
        class="pres-closing__btn pres-closing__btn--ghost"
        href="/offer/book-call"
        data-track-cta="book_call"
        data-track-location="closing_cta"
      >
        Book a 10-minute call
      </a>
    </div>

    <p class="pres-closing__trustline">
      SEC-qualified under Regulation A, Tier 2. Not FDIC-insured. Investing involves risk,
      including possible loss of principal.
    </p>
  </div>
</section>

<style>
  .pres-closing {
    background: var(--bg-secondary);
    padding: 0;
    margin: 0;
  }

  .pres-closing__container {
    max-width: 1136px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }

  .pres-closing__eyebrow {
    font-family: "Roboto", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--green-dark);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 130%;
    text-align: center;
  }

  .pres-closing__heading {
    font-family: "Roboto Serif", serif;
    font-size: 2.25rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 115%;
    text-align: center;
    margin: 0;
  }

  .pres-closing__heading em {
    color: var(--green-dark);
    font-style: italic;
  }

  .pres-closing__body {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: #555555;
    line-height: 160%;
    text-align: center;
    margin: 0;
    max-width: 600px;
  }

  .pres-closing__actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 100%;
    max-width: 480px;
    margin-top: 8px;
  }

  .pres-closing__btn {
    flex: 1;
    text-align: center;
    text-decoration: none;
    border-radius: 8px;
    font-family: "Roboto", sans-serif;
    font-size: 16px;
    font-weight: 600;
    line-height: 100%;
    padding: 14px 20px;
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .pres-closing__btn--primary {
    background-color: var(--green-brand);
    border: 1px solid var(--green-brand);
    color: #ffffff;
  }

  .pres-closing__btn--primary:hover {
    background-color: var(--green-hover);
    border-color: var(--green-hover);
  }

  .pres-closing__btn--ghost {
    background-color: transparent;
    border: 1px solid var(--text-heading);
    color: var(--text-heading);
  }

  .pres-closing__btn--ghost:hover {
    background-color: var(--text-heading);
    color: #ffffff;
  }

  .pres-closing__trustline {
    margin: 8px 0 0;
    font-family: "Roboto", sans-serif;
    font-size: 12px;
    color: var(--text-muted);
    line-height: 160%;
    text-align: center;
    max-width: 560px;
  }

  @media only screen and (min-width: 600px) {
    .pres-closing__container {
      padding: 4rem 2rem;
      gap: 22px;
    }

    .pres-closing__heading {
      font-size: 3rem;
    }

    .pres-closing__actions {
      flex-direction: row;
    }

    .pres-closing__trustline {
      font-size: 13px;
    }
  }

  @media only screen and (min-width: 1024px) {
    .pres-closing__container {
      padding: 5rem 2rem;
    }

    .pres-closing__heading {
      font-size: 3.5rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .pres-closing__heading {
      font-size: 3.75rem;
    }
  }
</style>
