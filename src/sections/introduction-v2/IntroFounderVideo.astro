<section class="intro-slide" id="intro-slide-about">
  <div class="intro-slide__content">
    <div class="intro-slide__media">
      <div class="intro-slide__video-wrapper">
        <div class="intro-slide__video-container">
          <mux-player
            id="intro-mux-player"
            playback-id="zcQwBRwPYkk7H68jKSAKzUtBLukN4yls02dvyVv4TrP00"
            env-key="hr9aevib299lcvfdoip01jd60"
            preload="metadata"
            stream-type="on-demand"
            max-resolution="1080p"
            rendition-order="desc"
            poster="https://image.mux.com/zcQwBRwPYkk7H68jKSAKzUtBLukN4yls02dvyVv4TrP00/thumbnail.png?width=214&height=121&time=5"
            placeholder="https://image.mux.com/zcQwBRwPYkk7H68jKSAKzUtBLukN4yls02dvyVv4TrP00/thumbnail.webp?time=5&width=16"
            default-show-captions
          ></mux-player>
        </div>
        <div class="intro-slide__photo-caption">
          <span class="intro-slide__photo-name">Joe Robert</span>
          <span class="intro-slide__photo-role">Manager & Founder</span>
        </div>
      </div>
    </div>

    <div class="intro-slide__text">
      <h2 class="intro-slide__heading">Managed by its founder.</h2>
      <p class="intro-slide__subheading">
        25 years in asset management. 200 deals. $10 million returned.
      </p>

      <div class="intro-slide__stats-grid">
        <div class="intro-slide__stat">
          <span class="intro-slide__stat-value">25+</span>
          <span class="intro-slide__stat-label">Years of Experience</span>
        </div>
        <div class="intro-slide__stat">
          <span class="intro-slide__stat-value">100%</span>
          <span class="intro-slide__stat-label">Payments Record</span>
        </div>
        <div class="intro-slide__stat">
          <span class="intro-slide__stat-value">$10M+</span>
          <span class="intro-slide__stat-label">Raised from Private Investors</span>
        </div>
        <div class="intro-slide__stat">
          <span class="intro-slide__stat-value">200+</span>
          <span class="intro-slide__stat-label">Properties Sold</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .intro-slide {
    height: 100svh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    margin: 0;
    padding: 8rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  .intro-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    max-width: 480px;
    opacity: 0;
  }

  /* Photo wrapper */
  .intro-slide__media {
    width: 100%;
  }

  .intro-slide__video-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .intro-slide__video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #152429;
  }

  .intro-slide__video-container mux-player {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    --media-object-fit: cover;
    --media-object-position: center;
  }

  .intro-slide__photo-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 0.75rem 1rem;
    background: linear-gradient(
      to top right,
      rgba(26, 26, 26, 0.85),
      rgba(26, 26, 26, 0)
    );
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .intro-slide__photo-caption.is-hidden {
    opacity: 0;
  }

  .intro-slide__photo-name {
    font-family: "Roboto Serif", serif;
    color: #ffffff;
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 130%;
  }

  .intro-slide__photo-role {
    font-family: "Roboto", sans-serif;
    color: #67b78f;
    font-size: 0.8125rem;
    font-weight: 400;
    line-height: 130%;
  }

  /* Text & stats */
  .intro-slide__text {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .intro-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 1.75rem;
    font-weight: 500;
    line-height: 130%;
    margin: 0;
    text-align: center;
  }

  .intro-slide__subheading {
    font-family: "Roboto", sans-serif;
    color: #555555;
    text-align: center;
    margin: 0;
    font-weight: 400;
    font-size: 1rem;
    line-height: 150%;
  }

  .intro-slide__heading + .intro-slide__subheading {
    margin-top: -0.5rem;
  }

  .intro-slide__stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .intro-slide__stat {
    background: linear-gradient(to right, rgba(235, 245, 239, 0.5), transparent);
    border-left: 3px solid #67b78f;
    padding: 0.625rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .intro-slide__stat-value {
    font-family: "Roboto Serif", serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 100%;
  }

  .intro-slide__stat-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.6875rem;
    color: #555555;
    line-height: 130%;
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .intro-slide {
      padding: 0 2rem;
    }

    .intro-slide__content {
      gap: 2rem;
      max-width: 520px;
    }

    .intro-slide__heading {
      font-size: 2.5rem;
    }

    .intro-slide__subheading {
      font-size: 1.25rem;
    }

    .intro-slide__stats-grid {
      gap: 1rem;
    }

    .intro-slide__stat {
      padding: 1.25rem;
    }

    .intro-slide__stat-value {
      font-size: 2.25rem;
    }

    .intro-slide__stat-label {
      font-size: 0.9375rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .intro-slide__content {
      max-width: 520px;
    }

    .intro-slide__heading {
      font-size: 3.25rem;
    }

    .intro-slide__subheading {
      font-size: 1.5rem;
    }

    .intro-slide__stat-value {
      font-size: 2.5rem;
    }

    .intro-slide__stat-label {
      font-size: 1rem;
    }

    .intro-slide__photo-name {
      font-size: 1.375rem;
    }

    .intro-slide__photo-role {
      font-size: 0.9375rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .intro-slide__content {
      max-width: 560px;
    }

    .intro-slide__heading {
      font-size: 3.75rem;
    }

    .intro-slide__subheading {
      font-size: 1.75rem;
    }

    .intro-slide__stat-value {
      font-size: 2.75rem;
    }
  }
</style>
