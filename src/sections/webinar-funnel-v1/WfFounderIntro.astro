---

---

<section class="wf-slide" id="wf-slide-about">
  <div class="wf-slide__content">
    <div class="wf-slide__media">
      <div class="wf-slide__video-wrapper">
        <div class="wf-slide__video-container" id="wf-video-container">
          <mux-player
            id="wf-mux-player"
            playback-id="01OU5cTDLdaueb3uDOARyV8Wx5mXFzBq2lSNavSCtDBU"
            env-key="hr9aevib299lcvfdoip01jd60"
            preload="metadata"
            stream-type="on-demand"
            default-show-captions
          ></mux-player>
        </div>
        <div class="wf-slide__photo-caption">
          <span class="wf-slide__photo-name">Joe Robert</span>
          <span class="wf-slide__photo-role">Manager & Founder</span>
        </div>
      </div>
    </div>

    <div class="wf-slide__text">
      <h2 class="wf-slide__heading">Hello, I'm Joe Robert</h2>
      <p class="wf-slide__subheading">Manager & Founder of Robert Ventures</p>

      <div class="wf-slide__stats-grid">
        <div class="wf-slide__stat">
          <span class="wf-slide__stat-value">20+</span>
          <span class="wf-slide__stat-label">Years of Experience</span>
        </div>
        <div class="wf-slide__stat">
          <span class="wf-slide__stat-value">100%</span>
          <span class="wf-slide__stat-label">Payments Record</span>
        </div>
        <div class="wf-slide__stat">
          <span class="wf-slide__stat-value">$10M+</span>
          <span class="wf-slide__stat-label">Raised from Private Investors</span>
        </div>
        <div class="wf-slide__stat">
          <span class="wf-slide__stat-value">200+</span>
          <span class="wf-slide__stat-label">Properties Sold</span>
        </div>
      </div>
    </div>

    <button type="button" class="wf-slide__chevron" data-next-slide="2" aria-label="Scroll to next slide">
      <span class="wf-slide__chevron-arrow"></span>
      <span class="wf-slide__chevron-arrow"></span>
    </button>
  </div>
</section>

<style>
  .wf-slide {
    height: 100svh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    margin: 0;
    padding: 8rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  .wf-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    max-width: 480px;
    opacity: 0;
  }

  /* Photo wrapper */
  .wf-slide__media {
    width: 100%;
  }

  .wf-slide__video-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .wf-slide__video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #152429;
  }

  .wf-slide__video-container mux-player {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    --media-object-fit: cover;
    --media-object-position: center;
  }

.wf-slide__photo-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem;
    background: linear-gradient(to top, rgba(26, 26, 26, 0.8), transparent);
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    transition: opacity 0.3s ease;
  }

  .wf-slide__photo-caption.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .wf-slide__photo-name {
    font-family: "Roboto Serif", serif;
    color: #ffffff;
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 130%;
  }

  .wf-slide__photo-role {
    font-family: "Roboto", sans-serif;
    color: #67b78f;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 130%;
  }

  /* Text & stats */
  .wf-slide__text {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .wf-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 1.75rem;
    font-weight: 500;
    line-height: 130%;
    margin: 0;
    text-align: center;
  }

  .wf-slide__subheading {
    font-family: "Roboto", sans-serif;
    color: #555555;
    text-align: center;
    margin: -1.65rem 0 0;
    font-weight: 400;
    font-size: 1rem;
  }

  .wf-slide__stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .wf-slide__stat {
    background: linear-gradient(to right, rgba(235, 245, 239, 0.5), transparent);
    border-left: 3px solid #67b78f;
    padding: 0.625rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .wf-slide__stat-value {
    font-family: "Roboto Serif", serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 100%;
  }

  .wf-slide__stat-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.6875rem;
    color: #555555;
    line-height: 130%;
  }

  /* Scroll chevron */
  .wf-slide__chevron {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    animation: wf-chevron-bounce 1.5s ease-in-out infinite;
  }

  .wf-slide__chevron-arrow {
    display: block;
    width: 14px;
    height: 14px;
    border-right: 2.5px solid #555555;
    border-bottom: 2.5px solid #555555;
    transform: rotate(45deg);
    margin-top: -6px;
  }

  .wf-slide__chevron-arrow:first-child {
    margin-top: 0;
    opacity: 0.4;
  }

  @keyframes wf-chevron-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(8px);
    }
  }

  @media only screen and (min-width: 600px) {
    .wf-slide__chevron-arrow {
      width: 16px;
      height: 16px;
      border-right-width: 3px;
      border-bottom-width: 3px;
      margin-top: -7px;
    }

    .wf-slide__chevron-arrow:first-child {
      margin-top: 0;
    }
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .wf-slide {
      padding: 0 2rem;
    }

    .wf-slide__content {
      gap: 2rem;
      max-width: 520px;
    }

    .wf-slide__heading {
      font-size: 2.5rem;
    }

    .wf-slide__subheading {
      font-size: 1.25rem;
    }

    .wf-slide__stats-grid {
      gap: 1rem;
    }

    .wf-slide__stat {
      padding: 1.25rem;
    }

    .wf-slide__stat-value {
      font-size: 2.25rem;
    }

    .wf-slide__stat-label {
      font-size: 0.9375rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .wf-slide__content {
      max-width: 520px;
    }

    .wf-slide__heading {
      font-size: 3.25rem;
    }

    .wf-slide__subheading {
      font-size: 1.5rem;
    }

    .wf-slide__stat-value {
      font-size: 2.5rem;
    }

    .wf-slide__stat-label {
      font-size: 1rem;
    }

    .wf-slide__photo-name {
      font-size: 1.5rem;
    }

    .wf-slide__photo-role {
      font-size: 1rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .wf-slide__content {
      max-width: 560px;
    }

    .wf-slide__heading {
      font-size: 3.75rem;
    }

    .wf-slide__subheading {
      font-size: 1.75rem;
    }

    .wf-slide__stat-value {
      font-size: 2.75rem;
    }
  }
</style>
