<section class="wf-slide" id="wf-slide-4">
  <div class="wf-slide__content">
    <div class="wf-slide__header">
      <h2 class="wf-slide__heading">Let's Personalize Your Experience</h2>
    </div>

    <div class="wf-slide__fields">
      <p class="wf-slide__question-label">How much capital are you looking to allocate?</p>
      <div class="wf-slide__options" id="wf-invest-amount">
        <button type="button" class="wf-slide__option-btn" data-value="1000">$1,000</button>
        <button type="button" class="wf-slide__option-btn" data-value="5000">$5,000</button>
        <button type="button" class="wf-slide__option-btn" data-value="10000">$10,000</button>
        <button type="button" class="wf-slide__option-btn" data-value="25000">$25,000</button>
        <button type="button" class="wf-slide__option-btn" data-value="50000">$50,000</button>
        <button type="button" class="wf-slide__option-btn" data-value="100000+">$100,000+</button>
      </div>
      <input type="hidden" name="invest_intent" id="wf-invest-value" />

      <p class="wf-slide__field-error"></p>

      <button type="button" class="wf-slide__continue" data-next-slide="4">Continue</button>

      <p class="wf-slide__footnote">This is just to understand your interest — no commitment required.</p>
    </div>

  </div>
</section>

<style>
  .wf-slide {
    height: 100svh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: linear-gradient(to bottom, #f4f6f5, #ffffff);
    margin: 0;
    padding: 5rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  .wf-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 480px;
    width: 100%;
    opacity: 0;
  }

  .wf-slide__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .wf-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 2rem;
    font-weight: 500;
    line-height: 120%;
    margin: 0;
  }

  .wf-slide__fields {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    position: relative;
  }

  .wf-slide__question-label {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: #333333;
    margin: 0;
    text-align: center;
  }

  .wf-slide__options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    width: 100%;
  }

  .wf-slide__option-btn {
    padding: 0.875rem 0.5rem;
    border: 1.5px solid #e5e5e5;
    border-radius: 0.75rem;
    background: #ffffff;
    cursor: pointer;
    text-align: center;
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #1a1a1a;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  @media (hover: hover) {
    .wf-slide__option-btn:hover {
      border-color: var(--green-brand);
      background: rgba(235, 245, 239, 0.3);
    }
  }

  .wf-slide__option-btn.is-selected {
    border-color: var(--green-brand);
    background: #ebf5ef;
  }

  .wf-slide__field-error {
    display: none;
    color: red;
    text-align: center;
    margin: 0;
    font-size: 0.875rem;
    font-family: "Roboto", sans-serif;
  }

  .wf-slide__continue {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
    background: var(--green-brand);
    border: none;
    border-radius: 8px;
    padding: 1rem;
    width: 100%;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
    text-align: center;
    box-sizing: border-box;
  }

  @media (hover: hover) {
    .wf-slide__continue:hover {
      background-color: var(--green-hover);
    }
  }

  .wf-slide__continue:active {
    transform: translateY(1px);
  }

  .wf-slide__footnote {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    color: #888888;
    text-align: center;
    line-height: 150%;
    margin: 0;
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .wf-slide {
      padding: 5rem 2rem 1.5rem;
    }

    .wf-slide__heading {
      font-size: 2.5rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .wf-slide__content {
      max-width: 520px;
    }

    .wf-slide__heading {
      font-size: 2.75rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .wf-slide__content {
      max-width: 560px;
    }

    .wf-slide__heading {
      font-size: 3rem;
    }
  }
</style>
