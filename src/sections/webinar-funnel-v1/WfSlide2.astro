---

<section class="wf-slide" id="wf-slide-intro">
  <div class="wf-slide__content">
    <span class="wf-slide__tag">Free Live Webinar</span>

    <h1 class="wf-slide__heading">
      How Everyday Investors Are Earning <span class="wf-slide__accent">10% Fixed Returns</span>
    </h1>

    <p class="wf-slide__subtitle">
      Join a 30-minute session to learn our SEC-qualified strategy — and how to get started.
    </p>

    <div class="wf-slide__highlights">
      <span class="wf-slide__highlight">SEC Qualified</span>
      <span class="wf-slide__highlight-divider"></span>
      <span class="wf-slide__highlight">Real Estate & Digital Assets</span>
      <span class="wf-slide__highlight-divider"></span>
      <span class="wf-slide__highlight">Monthly Payouts</span>
    </div>

    <button type="button" class="wf-slide__continue" data-next-slide="1">Get Started</button>
  </div>
</section>

<style>
  .wf-slide {
    height: 100svh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: linear-gradient(to bottom, #ffffff, #f4f6f5);
    margin: 0;
    padding: 5rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  .wf-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 480px;
    width: 100%;
    opacity: 0;
  }

  .wf-slide__tag {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green-brand);
    background: #ebf5ef;
    padding: 0.375rem 1rem;
    border-radius: 100px;
  }

  .wf-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 2rem;
    font-weight: 500;
    line-height: 125%;
    text-align: center;
    margin: 0;
  }

  .wf-slide__accent {
    color: #1a1a1a;
    position: relative;
    display: inline-block;
  }

  .wf-slide__accent::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: var(--green-brand);
  }

  .wf-slide__subtitle {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: #555555;
    text-align: center;
    text-wrap: balance;
    line-height: 160%;
    margin: 0;
  }

  /* Highlights row */
  .wf-slide__highlights {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .wf-slide__highlight {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    color: #555555;
    letter-spacing: 0.02em;
  }

  .wf-slide__highlight-divider {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #bbbbbb;
    flex-shrink: 0;
  }

  /* CTA */
  .wf-slide__continue {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
    background: var(--green-brand);
    border: none;
    border-radius: 8px;
    padding: 1rem;
    width: 100%;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
    text-align: center;
    box-sizing: border-box;
  }

  @media (hover: hover) {
    .wf-slide__continue:hover {
      background-color: var(--green-hover);
    }
  }

  .wf-slide__continue:active {
    transform: translateY(1px);
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .wf-slide {
      padding: 5rem 2rem 1.5rem;
    }

    .wf-slide__heading {
      font-size: 2.75rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .wf-slide__content {
      max-width: 520px;
    }

    .wf-slide__heading {
      font-size: 3.25rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .wf-slide__content {
      max-width: 560px;
    }

    .wf-slide__heading {
      font-size: 3.5rem;
    }
  }
</style>
