<style>
  .wf-slide {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: linear-gradient(to bottom, #ffffff, #f4f6f5);
    margin: 0;
    padding: 2rem 1.5rem 2rem;
    box-sizing: border-box;
  }

  /* Staircase SVG — background animation */
  .wf-slide__staircase {
    position: absolute;
    bottom: -200px;
    right: -200px;
    width: 800px;
    height: 800px;
    min-width: 800px;
    min-height: 800px;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .wf-slide__staircase rect {
    fill: none;
    stroke: #bbbbbb;
    stroke-opacity: 0.15;
    stroke-width: 1;
  }

  .wf-slide__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 480px;
    width: 100%;
    opacity: 0;
  }

  .wf-slide__tag {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green-brand);
    background: #ebf5ef;
    padding: 0.375rem 1rem;
    border-radius: 100px;
  }

  .wf-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 2.25rem;
    font-weight: 500;
    line-height: 135%;
    text-align: center;
    margin: 0;
  }

  .wf-slide__accent {
    color: #1a1a1a;
    position: relative;
    display: inline-block;
  }

  .wf-slide__underline {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 5px;
    background: var(--green-brand);
    transform: scaleX(0);
    transform-origin: left;
  }

  /* Founder video, sits between the heading and the subtitle */
  .wf-slide__media {
    width: 100%;
  }

  .wf-slide__video-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .wf-slide__video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #152429;
  }

  .wf-slide__video-container mux-player {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    --media-object-fit: cover;
    --media-object-position: center;
    --time-range: none;
  }

  .wf-slide__video-container mux-player[mediaisfullscreen] {
    --time-range: initial;
  }

  /* One-shot UX nudge that covers the video while it's muted (or paused
     after autoplay rejection). Click anywhere on the overlay to engage:
     unmutes (and starts playback if needed). Removed forever after the
     first engagement, then Mux's native UI handles pause/play/replay. */
  .wf-slide__mux-overlay {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
    background: rgba(0, 0, 0, 0.18);
  }

  .wf-slide__mux-overlay.is-active {
    display: flex;
  }

  .wf-slide__mux-overlay:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: -4px;
  }

  .wf-slide__mux-overlay-pill {
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 999px;
    padding: 0.625rem 1rem 0.625rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.01em;
    white-space: nowrap;
    animation: wf-mux-pill-glow 2.4s ease-in-out infinite;
    pointer-events: none;
  }

  .wf-slide__mux-overlay-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .wf-slide__mux-overlay-icon--play {
    display: none;
    margin-left: 2px;
  }

  .wf-slide__mux-overlay-text--play {
    display: none;
  }

  .wf-slide__mux-overlay.is-play-mode .wf-slide__mux-overlay-icon--unmute,
  .wf-slide__mux-overlay.is-play-mode .wf-slide__mux-overlay-text--unmute {
    display: none;
  }

  .wf-slide__mux-overlay.is-play-mode .wf-slide__mux-overlay-icon--play,
  .wf-slide__mux-overlay.is-play-mode .wf-slide__mux-overlay-text--play {
    display: inline-block;
  }

  @keyframes wf-mux-pill-glow {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(103, 183, 143, 0.55);
    }
    70% {
      box-shadow: 0 0 0 14px rgba(103, 183, 143, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wf-slide__mux-overlay-pill {
      animation: none;
    }
  }

  .wf-slide__photo-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem;
    background: linear-gradient(to top, rgba(26, 26, 26, 0.8), transparent);
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    transition: opacity 0.3s ease;
  }

  .wf-slide__photo-caption.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .wf-slide__photo-name {
    font-family: "Roboto Serif", serif;
    color: #ffffff;
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 130%;
  }

  .wf-slide__photo-role {
    font-family: "Roboto", sans-serif;
    color: #67b78f;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 130%;
  }

  .wf-slide__subtitle {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: #555555;
    text-align: center;
    text-wrap: balance;
    line-height: 160%;
    margin: 0;
  }

  /* Highlights row */
  .wf-slide__highlights {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .wf-slide__highlight {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    color: #555555;
    letter-spacing: 0.02em;
  }

  .wf-slide__highlight-divider {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #bbbbbb;
    flex-shrink: 0;
  }

  /* Scroll chevron */
  .wf-slide__chevron {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    animation: wf-chevron-bounce 1.5s ease-in-out infinite;
  }

  .wf-slide__chevron-arrow {
    display: block;
    width: 14px;
    height: 14px;
    border-right: 2.5px solid #555555;
    border-bottom: 2.5px solid #555555;
    transform: rotate(45deg);
    margin-top: -6px;
  }

  .wf-slide__chevron-arrow:first-child {
    margin-top: 0;
    opacity: 0.4;
  }

  @keyframes wf-chevron-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(8px);
    }
  }

  @media only screen and (min-width: 600px) {
    .wf-slide__chevron-arrow {
      width: 16px;
      height: 16px;
      border-right-width: 3px;
      border-bottom-width: 3px;
      margin-top: -7px;
    }

    .wf-slide__chevron-arrow:first-child {
      margin-top: 0;
    }
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .wf-slide {
      padding: 1.5rem 2rem 2rem;
    }

    .wf-slide__heading {
      font-size: 3rem;
    }

    .wf-slide__mux-overlay-pill {
      padding: 0.75rem 1.25rem 0.75rem 1rem;
      font-size: 0.9375rem;
    }

    .wf-slide__mux-overlay-icon {
      width: 24px;
      height: 24px;
    }

    .wf-slide__photo-name {
      font-size: 1.5rem;
    }

    .wf-slide__photo-role {
      font-size: 1rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .wf-slide {
      padding: 4rem 2rem;
    }

    .wf-slide__content {
      max-width: 560px;
    }

    .wf-slide__heading {
      font-size: 2.75rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .wf-slide {
      padding: 5rem 2rem;
    }

    .wf-slide__content {
      max-width: 600px;
    }

    .wf-slide__heading {
      font-size: 3rem;
    }
  }
</style>

<script is:inline>
  (function () {
    function initStaircaseAnimation() {
      if (!window.gsapLoaded || typeof window.gsap === "undefined") return;

      var gsapLib = window.gsap;
      var svg = document.getElementById("wf2-staircase-svg");
      if (!svg) return;

      var rects = svg.querySelectorAll("rect");
      if (rects.length === 0) return;

      gsapLib.set(rects, { strokeOpacity: 0.15 });

      var tl = gsapLib.timeline({ repeat: -1 });

      // Pause before shimmer
      tl.to({}, { duration: 3 });

      // Shimmer forward — rects brighten
      tl.to(rects, {
        strokeOpacity: 0.6,
        duration: 0.2,
        stagger: { amount: 0.5, from: "start" },
      });

      // Fade back — rects dim
      tl.to(rects, {
        strokeOpacity: 0.15,
        duration: 0.5,
        stagger: { amount: 1, from: "start" },
      });
    }

    function startAnimation() {
      if (window.gsapLoaded && typeof window.gsap !== "undefined") {
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initStaircaseAnimation);
        } else {
          initStaircaseAnimation();
        }
      } else {
        window.addEventListener("gsapLoaded", function () {
          if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initStaircaseAnimation);
          } else {
            initStaircaseAnimation();
          }
        });
      }
    }

    startAnimation();
  })();
</script>
