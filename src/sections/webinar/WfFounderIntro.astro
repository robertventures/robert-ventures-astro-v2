---

---

<section class="wf-slide" id="wf-slide-about">
  <div class="wf-slide__content">
    <div class="wf-slide__media">
      <div class="wf-slide__video-wrapper">
        <div class="wf-slide__video-container" id="wf-video-container">
          <mux-player
            id="wf-mux-player"
            playback-id="GuU2ludOvs0200GxdEzz02zPLKRpHUD00oXKV9tFfRoMxfk"
            env-key="hr9aevib299lcvfdoip01jd60"
            preload="metadata"
            stream-type="on-demand"
            max-resolution="1080p"
            rendition-order="desc"
            muted
            playsinline
            default-show-captions></mux-player>
          <button
            type="button"
            id="wf-custom-play-btn"
            class="wf-slide__custom-play is-pending"
            aria-label="Play video"
          >
            <span class="wf-slide__custom-play-ring"></span>
            <span class="wf-slide__custom-play-ring wf-slide__custom-play-ring--delayed"></span>
            <span class="wf-slide__custom-play-inner">
              <svg
                class="wf-slide__custom-play-icon wf-slide__custom-play-icon--play"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M8 5v14l11-7z" fill="#ffffff"></path>
              </svg>
              <svg
                class="wf-slide__custom-play-icon wf-slide__custom-play-icon--unmute"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"
                  fill="#ffffff"></path>
              </svg>
            </span>
            <span class="wf-slide__custom-play-label">
              Your video is playing. Click to unmute.
            </span>
          </button>
        </div>
        <div class="wf-slide__photo-caption">
          <span class="wf-slide__photo-name">Joe Robert</span>
          <span class="wf-slide__photo-role">Manager & Founder</span>
        </div>
      </div>
    </div>

    <div class="wf-slide__text">
      <h2 class="wf-slide__heading">Hello, I'm Joe Robert</h2>
      <p class="wf-slide__subheading">
        25+ years in real estate. Manager & Founder of Robert Ventures.
      </p>

      <div class="wf-slide__stats-grid">
        <div class="wf-slide__stat">
          <span class="wf-slide__stat-value">25+</span>
          <span class="wf-slide__stat-label">Years in Real Estate</span>
        </div>
        <div class="wf-slide__stat">
          <span class="wf-slide__stat-value">100%</span>
          <span class="wf-slide__stat-label">Payments Record</span>
        </div>
        <div class="wf-slide__stat">
          <span class="wf-slide__stat-value">$10M+</span>
          <span class="wf-slide__stat-label">Raised from Private Investors</span>
        </div>
        <div class="wf-slide__stat">
          <span class="wf-slide__stat-value">200+</span>
          <span class="wf-slide__stat-label">Properties Sold</span>
        </div>
      </div>
    </div>

    <button
      type="button"
      class="wf-slide__chevron"
      data-next-slide="2"
      aria-label="Scroll to next slide"
    >
      <span class="wf-slide__chevron-arrow"></span>
      <span class="wf-slide__chevron-arrow"></span>
    </button>
  </div>
</section>

<style>
  .wf-slide {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    padding: 3rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  .wf-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    max-width: 480px;
    opacity: 0;
  }

  /* Photo wrapper */
  .wf-slide__media {
    width: 100%;
  }

  .wf-slide__video-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .wf-slide__video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #152429;
  }

  .wf-slide__video-container mux-player {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    --media-object-fit: cover;
    --media-object-position: center;
    /* Hide Mux's default center play button. Our custom button replaces it. */
    --center-play-button: none;
  }

  /* Custom oversized play button, absolutely centered over the Mux player.
     Built to draw attention so users actually click play, instead of the
     video looking like a static photo. Hidden after first play. */
  .wf-slide__custom-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 88px;
    height: 88px;
    border: none;
    padding: 0;
    background: transparent;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    transition: opacity 0.35s ease;
  }

  .wf-slide__custom-play:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: 4px;
  }

  .wf-slide__custom-play.is-hidden,
  .wf-slide__custom-play.is-pending {
    opacity: 0;
    pointer-events: none;
  }

  .wf-slide__custom-play-inner {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: #67b78f;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.35);
    animation: wf-play-breath 2.4s ease-in-out infinite;
  }

  .wf-slide__custom-play:hover .wf-slide__custom-play-inner {
    background: #5aa37e;
  }

  .wf-slide__custom-play-icon {
    width: 36px;
    height: 36px;
  }

  .wf-slide__custom-play-icon--play {
    margin-left: 4px; /* optical centering for triangle */
  }

  .wf-slide__custom-play-icon--unmute {
    display: none;
  }

  .wf-slide__custom-play.is-unmute-mode .wf-slide__custom-play-icon--play {
    display: none;
  }

  .wf-slide__custom-play.is-unmute-mode .wf-slide__custom-play-icon--unmute {
    display: block;
  }

  /* Unmute mode: rectangular pill with semi-transparent dark bg + label.
     Replaces the circular play button entirely. Rings are hidden, the
     inner circle becomes a transparent icon container, and a text label
     appears next to the speaker icon. */
  .wf-slide__custom-play-label {
    display: none;
  }

  .wf-slide__custom-play.is-unmute-mode {
    width: auto;
    height: auto;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.625rem 1rem 0.625rem 0.75rem;
    flex-direction: row;
    gap: 0.5rem;
    animation: wf-pill-pulse 2.6s ease-in-out infinite;
  }

  .wf-slide__custom-play.is-unmute-mode .wf-slide__custom-play-ring {
    display: none;
  }

  .wf-slide__custom-play.is-unmute-mode .wf-slide__custom-play-inner {
    width: 22px;
    height: 22px;
    background: transparent;
    box-shadow: none;
    border-radius: 0;
    animation: none;
  }

  .wf-slide__custom-play.is-unmute-mode:hover .wf-slide__custom-play-inner {
    background: transparent;
  }

  .wf-slide__custom-play.is-unmute-mode .wf-slide__custom-play-icon--unmute {
    width: 22px;
    height: 22px;
    margin: 0;
  }

  .wf-slide__custom-play.is-unmute-mode .wf-slide__custom-play-label {
    display: inline-block;
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.2;
    color: #ffffff;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  @keyframes wf-pill-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.78;
    }
  }

  .wf-slide__custom-play-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 4px solid #67b78f;
    pointer-events: none;
    animation: wf-play-ring 2.2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  .wf-slide__custom-play-ring--delayed {
    animation-delay: 1.1s;
  }

  @keyframes wf-play-breath {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.06);
    }
  }

  @keyframes wf-play-ring {
    0% {
      transform: scale(1);
      opacity: 1;
    }
    100% {
      transform: scale(2.2);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wf-slide__custom-play-inner,
    .wf-slide__custom-play-ring {
      animation: none;
    }
  }

  .wf-slide__photo-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem;
    background: linear-gradient(to top, rgba(26, 26, 26, 0.8), transparent);
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    transition: opacity 0.3s ease;
  }

  .wf-slide__photo-caption.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .wf-slide__photo-name {
    font-family: "Roboto Serif", serif;
    color: #ffffff;
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 130%;
  }

  .wf-slide__photo-role {
    font-family: "Roboto", sans-serif;
    color: #67b78f;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 130%;
  }

  /* Text & stats */
  .wf-slide__text {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .wf-slide__tag {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green-brand);
    background: #ebf5ef;
    padding: 0.375rem 1rem;
    border-radius: 100px;
  }

  .wf-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 1.75rem;
    font-weight: 500;
    line-height: 130%;
    margin: 0;
    text-align: center;
  }

  .wf-slide__subheading {
    font-family: "Roboto", sans-serif;
    color: #555555;
    text-align: center;
    margin: -0.25rem 0 0;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
  }

  .wf-slide__stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    width: 100%;
    margin-top: 0.5rem;
  }

  .wf-slide__stat {
    background: linear-gradient(to right, rgba(235, 245, 239, 0.5), transparent);
    border-left: 3px solid #67b78f;
    padding: 0.625rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .wf-slide__stat-value {
    font-family: "Roboto Serif", serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 100%;
  }

  .wf-slide__stat-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.6875rem;
    color: #555555;
    line-height: 130%;
  }

  /* Scroll chevron */
  .wf-slide__chevron {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-top: 2.5rem;
    animation: wf-chevron-bounce 1.5s ease-in-out infinite;
  }

  .wf-slide__chevron-arrow {
    display: block;
    width: 14px;
    height: 14px;
    border-right: 2.5px solid #555555;
    border-bottom: 2.5px solid #555555;
    transform: rotate(45deg);
    margin-top: -6px;
  }

  .wf-slide__chevron-arrow:first-child {
    margin-top: 0;
    opacity: 0.4;
  }

  @keyframes wf-chevron-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(8px);
    }
  }

  @media only screen and (min-width: 600px) {
    .wf-slide__chevron-arrow {
      width: 16px;
      height: 16px;
      border-right-width: 3px;
      border-bottom-width: 3px;
      margin-top: -7px;
    }

    .wf-slide__chevron-arrow:first-child {
      margin-top: 0;
    }
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .wf-slide {
      padding: 1.5rem 2rem 2rem;
    }

    .wf-slide__content {
      gap: 2rem;
      max-width: 520px;
    }

    .wf-slide__heading {
      font-size: 2.5rem;
    }

    .wf-slide__subheading {
      font-size: 1.25rem;
    }

    .wf-slide__stats-grid {
      gap: 1rem;
    }

    .wf-slide__stat {
      padding: 1.25rem;
    }

    .wf-slide__stat-value {
      font-size: 2.25rem;
    }

    .wf-slide__stat-label {
      font-size: 0.9375rem;
    }

    .wf-slide__custom-play {
      width: 104px;
      height: 104px;
    }

    .wf-slide__custom-play-icon {
      width: 44px;
      height: 44px;
    }

    .wf-slide__custom-play.is-unmute-mode {
      width: auto;
      height: auto;
      padding: 0.75rem 1.25rem 0.75rem 1rem;
    }

    .wf-slide__custom-play.is-unmute-mode .wf-slide__custom-play-icon--unmute {
      width: 24px;
      height: 24px;
    }

    .wf-slide__custom-play.is-unmute-mode .wf-slide__custom-play-inner {
      width: 24px;
      height: 24px;
    }

    .wf-slide__custom-play.is-unmute-mode .wf-slide__custom-play-label {
      font-size: 0.9375rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .wf-slide {
      padding: 4rem 2rem;
    }

    .wf-slide__content {
      flex-direction: row;
      align-items: center;
      gap: 4rem;
      max-width: 1200px;
    }

    .wf-slide__media {
      flex: 1 1 0;
      min-width: 0;
      order: 2;
    }

    .wf-slide__text {
      flex: 1 1 0;
      min-width: 0;
      order: 1;
      align-items: flex-start;
    }

    .wf-slide__heading,
    .wf-slide__subheading {
      text-align: left;
    }

    .wf-slide__heading {
      font-size: 2.5rem;
    }

    .wf-slide__subheading {
      font-size: 1.25rem;
    }

    .wf-slide__stat-value {
      font-size: 2.5rem;
    }

    .wf-slide__stat-label {
      font-size: 1rem;
    }

    .wf-slide__photo-name {
      font-size: 1.5rem;
    }

    .wf-slide__photo-role {
      font-size: 1rem;
    }

    .wf-slide__chevron {
      display: none;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .wf-slide {
      padding: 5rem 2rem;
    }

    .wf-slide__content {
      max-width: 1400px;
    }

    .wf-slide__heading {
      font-size: 3rem;
    }

    .wf-slide__subheading {
      font-size: 1.5rem;
    }

    .wf-slide__stat-value {
      font-size: 2.75rem;
    }
  }
</style>
