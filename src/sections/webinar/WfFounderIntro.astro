---

---

<section class="wf-slide" id="wf-slide-about">
  <div class="wf-slide__content">
    <div class="wf-slide__media">
      <div class="wf-slide__video-wrapper">
        <div class="wf-slide__video-container" id="wf-video-container">
          <mux-player
            id="wf-mux-player"
            playback-id="GuU2ludOvs0200GxdEzz02zPLKRpHUD00oXKV9tFfRoMxfk"
            env-key="hr9aevib299lcvfdoip01jd60"
            preload="metadata"
            stream-type="on-demand"
            max-resolution="1080p"
            rendition-order="desc"
            muted
            playsinline
            default-show-captions></mux-player>
          <div class="wf-slide__mux-overlay" id="wf-mux-overlay" role="button" tabindex="0">
            <div class="wf-slide__mux-overlay-pill">
              <svg
                class="wf-slide__mux-overlay-icon wf-slide__mux-overlay-icon--unmute"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"
                  fill="#ffffff"></path>
              </svg>
              <svg
                class="wf-slide__mux-overlay-icon wf-slide__mux-overlay-icon--play"
                viewBox="0 0 24 24"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M8 5v14l11-7z" fill="#ffffff"></path>
              </svg>
              <span class="wf-slide__mux-overlay-text wf-slide__mux-overlay-text--unmute">
                Your video is playing. Click to unmute.
              </span>
              <span class="wf-slide__mux-overlay-text wf-slide__mux-overlay-text--play">
                Click to play
              </span>
            </div>
          </div>
        </div>
        <div class="wf-slide__photo-caption">
          <span class="wf-slide__photo-name">Joe Robert</span>
          <span class="wf-slide__photo-role">Manager & Founder</span>
        </div>
      </div>
    </div>

    <div class="wf-slide__text">
      <h2 class="wf-slide__heading">Hello, I'm Joe Robert</h2>
      <p class="wf-slide__subheading">
        25+ years in real estate. Manager & Founder of Robert Ventures.
      </p>

      <div class="wf-slide__stats-grid">
        <div class="wf-slide__stat">
          <span class="wf-slide__stat-value">25+</span>
          <span class="wf-slide__stat-label">Years in Real Estate</span>
        </div>
        <div class="wf-slide__stat">
          <span class="wf-slide__stat-value">100%</span>
          <span class="wf-slide__stat-label">Payments Record</span>
        </div>
        <div class="wf-slide__stat">
          <span class="wf-slide__stat-value">$10M+</span>
          <span class="wf-slide__stat-label">Raised from Private Investors</span>
        </div>
        <div class="wf-slide__stat">
          <span class="wf-slide__stat-value">200+</span>
          <span class="wf-slide__stat-label">Properties Sold</span>
        </div>
      </div>
    </div>

    <button
      type="button"
      class="wf-slide__chevron"
      data-next-slide="2"
      aria-label="Scroll to next slide"
    >
      <span class="wf-slide__chevron-arrow"></span>
      <span class="wf-slide__chevron-arrow"></span>
    </button>
  </div>
</section>

<style>
  .wf-slide {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    padding: 3rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  .wf-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    max-width: 480px;
    opacity: 0;
  }

  /* Photo wrapper */
  .wf-slide__media {
    width: 100%;
  }

  .wf-slide__video-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .wf-slide__video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #152429;
  }

  .wf-slide__video-container mux-player {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    --media-object-fit: cover;
    --media-object-position: center;
  }

  /* One-shot UX nudge that covers the video while it's muted (or paused
     after autoplay rejection). Click anywhere on the overlay to engage:
     unmutes (and starts playback if needed). Removed forever after the
     first engagement, then Mux's native UI handles pause/play/replay. */
  .wf-slide__mux-overlay {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
    background: rgba(0, 0, 0, 0.18);
  }

  .wf-slide__mux-overlay.is-active {
    display: flex;
  }

  .wf-slide__mux-overlay:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: -4px;
  }

  .wf-slide__mux-overlay-pill {
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 999px;
    padding: 0.625rem 1rem 0.625rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.01em;
    white-space: nowrap;
    animation: wf-mux-pill-glow 2.4s ease-in-out infinite;
    pointer-events: none;
  }

  .wf-slide__mux-overlay-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .wf-slide__mux-overlay-icon--play {
    display: none;
    margin-left: 2px;
  }

  .wf-slide__mux-overlay-text--play {
    display: none;
  }

  .wf-slide__mux-overlay.is-play-mode .wf-slide__mux-overlay-icon--unmute,
  .wf-slide__mux-overlay.is-play-mode .wf-slide__mux-overlay-text--unmute {
    display: none;
  }

  .wf-slide__mux-overlay.is-play-mode .wf-slide__mux-overlay-icon--play,
  .wf-slide__mux-overlay.is-play-mode .wf-slide__mux-overlay-text--play {
    display: inline-block;
  }

  @keyframes wf-mux-pill-glow {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(103, 183, 143, 0.55);
    }
    70% {
      box-shadow: 0 0 0 14px rgba(103, 183, 143, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wf-slide__mux-overlay-pill {
      animation: none;
    }
  }

  .wf-slide__photo-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem;
    background: linear-gradient(to top, rgba(26, 26, 26, 0.8), transparent);
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    transition: opacity 0.3s ease;
  }

  .wf-slide__photo-caption.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .wf-slide__photo-name {
    font-family: "Roboto Serif", serif;
    color: #ffffff;
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 130%;
  }

  .wf-slide__photo-role {
    font-family: "Roboto", sans-serif;
    color: #67b78f;
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 130%;
  }

  /* Text & stats */
  .wf-slide__text {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .wf-slide__tag {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green-brand);
    background: #ebf5ef;
    padding: 0.375rem 1rem;
    border-radius: 100px;
  }

  .wf-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 1.75rem;
    font-weight: 500;
    line-height: 130%;
    margin: 0;
    text-align: center;
  }

  .wf-slide__subheading {
    font-family: "Roboto", sans-serif;
    color: #555555;
    text-align: center;
    margin: -0.25rem 0 0;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
  }

  .wf-slide__stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    width: 100%;
    margin-top: 0.5rem;
  }

  .wf-slide__stat {
    background: linear-gradient(to right, rgba(235, 245, 239, 0.5), transparent);
    border-left: 3px solid #67b78f;
    padding: 0.625rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .wf-slide__stat-value {
    font-family: "Roboto Serif", serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 100%;
  }

  .wf-slide__stat-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.6875rem;
    color: #555555;
    line-height: 130%;
  }

  /* Scroll chevron */
  .wf-slide__chevron {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-top: 2.5rem;
    animation: wf-chevron-bounce 1.5s ease-in-out infinite;
  }

  .wf-slide__chevron-arrow {
    display: block;
    width: 14px;
    height: 14px;
    border-right: 2.5px solid #555555;
    border-bottom: 2.5px solid #555555;
    transform: rotate(45deg);
    margin-top: -6px;
  }

  .wf-slide__chevron-arrow:first-child {
    margin-top: 0;
    opacity: 0.4;
  }

  @keyframes wf-chevron-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(8px);
    }
  }

  @media only screen and (min-width: 600px) {
    .wf-slide__chevron-arrow {
      width: 16px;
      height: 16px;
      border-right-width: 3px;
      border-bottom-width: 3px;
      margin-top: -7px;
    }

    .wf-slide__chevron-arrow:first-child {
      margin-top: 0;
    }
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .wf-slide {
      padding: 1.5rem 2rem 2rem;
    }

    .wf-slide__content {
      gap: 2rem;
      max-width: 520px;
    }

    .wf-slide__heading {
      font-size: 2.5rem;
    }

    .wf-slide__subheading {
      font-size: 1.25rem;
    }

    .wf-slide__stats-grid {
      gap: 1rem;
    }

    .wf-slide__stat {
      padding: 1.25rem;
    }

    .wf-slide__stat-value {
      font-size: 2.25rem;
    }

    .wf-slide__stat-label {
      font-size: 0.9375rem;
    }

    .wf-slide__mux-overlay-pill {
      padding: 0.75rem 1.25rem 0.75rem 1rem;
      font-size: 0.9375rem;
    }

    .wf-slide__mux-overlay-icon {
      width: 24px;
      height: 24px;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .wf-slide {
      padding: 4rem 2rem;
    }

    .wf-slide__content {
      flex-direction: row;
      align-items: center;
      gap: 4rem;
      max-width: 1200px;
    }

    .wf-slide__media {
      flex: 1 1 0;
      min-width: 0;
      order: 2;
    }

    .wf-slide__text {
      flex: 1 1 0;
      min-width: 0;
      order: 1;
      align-items: flex-start;
    }

    .wf-slide__heading,
    .wf-slide__subheading {
      text-align: left;
    }

    .wf-slide__heading {
      font-size: 2.5rem;
    }

    .wf-slide__subheading {
      font-size: 1.25rem;
    }

    .wf-slide__stat-value {
      font-size: 2.5rem;
    }

    .wf-slide__stat-label {
      font-size: 1rem;
    }

    .wf-slide__photo-name {
      font-size: 1.5rem;
    }

    .wf-slide__photo-role {
      font-size: 1rem;
    }

    .wf-slide__chevron {
      display: none;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .wf-slide {
      padding: 5rem 2rem;
    }

    .wf-slide__content {
      max-width: 1400px;
    }

    .wf-slide__heading {
      font-size: 3rem;
    }

    .wf-slide__subheading {
      font-size: 1.5rem;
    }

    .wf-slide__stat-value {
      font-size: 2.75rem;
    }
  }
</style>
