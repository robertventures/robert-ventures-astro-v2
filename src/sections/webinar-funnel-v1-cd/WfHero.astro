<style>
  .wf-slide {
    height: 100svh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: linear-gradient(to bottom, #ffffff, #f4f6f5);
    margin: 0;
    padding: 5rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  /* Staircase SVG — background animation */
  .wf-slide__staircase {
    position: absolute;
    bottom: -200px;
    right: -200px;
    width: 800px;
    height: 800px;
    min-width: 800px;
    min-height: 800px;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .wf-slide__staircase rect {
    fill: none;
    stroke: #bbbbbb;
    stroke-opacity: 0.15;
    stroke-width: 1;
  }

  .wf-slide__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 480px;
    width: 100%;
    opacity: 0;
  }

  .wf-slide__tag {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green-brand);
    background: #ebf5ef;
    padding: 0.375rem 1rem;
    border-radius: 100px;
  }

  .wf-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 2.5rem;
    font-weight: 500;
    line-height: 125%;
    text-align: center;
    margin: 0;
  }

  .wf-slide__accent {
    color: #1a1a1a;
    position: relative;
    display: inline-block;
  }

  .wf-slide__underline {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 5px;
    background: var(--green-brand);
    transform: scaleX(0);
    transform-origin: left;
  }

  .wf-slide__subtitle {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: #555555;
    text-align: center;
    text-wrap: balance;
    line-height: 160%;
    margin: 0;
  }

  /* Highlights row */
  .wf-slide__highlights {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .wf-slide__highlight {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    color: #555555;
    letter-spacing: 0.02em;
  }

  .wf-slide__highlight-divider {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #bbbbbb;
    flex-shrink: 0;
  }

  /* Scroll chevron */
  .wf-slide__chevron {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    animation: wf-chevron-bounce 1.5s ease-in-out infinite;
  }

  .wf-slide__chevron-arrow {
    display: block;
    width: 14px;
    height: 14px;
    border-right: 2.5px solid #555555;
    border-bottom: 2.5px solid #555555;
    transform: rotate(45deg);
    margin-top: -6px;
  }

  .wf-slide__chevron-arrow:first-child {
    margin-top: 0;
    opacity: 0.4;
  }

  @keyframes wf-chevron-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(8px);
    }
  }

  @media only screen and (min-width: 600px) {
    .wf-slide__chevron-arrow {
      width: 16px;
      height: 16px;
      border-right-width: 3px;
      border-bottom-width: 3px;
      margin-top: -7px;
    }

    .wf-slide__chevron-arrow:first-child {
      margin-top: 0;
    }
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .wf-slide {
      padding: 5rem 2rem 1.5rem;
    }

    .wf-slide__heading {
      font-size: 3rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .wf-slide__content {
      max-width: 520px;
    }

    .wf-slide__heading {
      font-size: 3.5rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .wf-slide__content {
      max-width: 560px;
    }

    .wf-slide__heading {
      font-size: 3.75rem;
    }
  }
</style>

<script is:inline>
  (function () {
    function initStaircaseAnimation() {
      if (!window.gsapLoaded || typeof window.gsap === "undefined") return;

      var gsapLib = window.gsap;
      var svg = document.getElementById("wf2-staircase-svg");
      if (!svg) return;

      var rects = svg.querySelectorAll("rect");
      if (rects.length === 0) return;

      gsapLib.set(rects, { strokeOpacity: 0.15 });

      var tl = gsapLib.timeline({ repeat: -1 });

      // Pause before shimmer
      tl.to({}, { duration: 3 });

      // Shimmer forward — rects brighten
      tl.to(rects, {
        strokeOpacity: 0.6,
        duration: 0.2,
        stagger: { amount: 0.5, from: "start" },
      });

      // Fade back — rects dim
      tl.to(rects, {
        strokeOpacity: 0.15,
        duration: 0.5,
        stagger: { amount: 1, from: "start" },
      });
    }

    function startAnimation() {
      if (window.gsapLoaded && typeof window.gsap !== "undefined") {
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initStaircaseAnimation);
        } else {
          initStaircaseAnimation();
        }
      } else {
        window.addEventListener("gsapLoaded", function () {
          if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initStaircaseAnimation);
          } else {
            initStaircaseAnimation();
          }
        });
      }
    }

    startAnimation();
  })();
</script>
