<section class="intro-slide" id="intro-slide-fixed-yield">
  <div class="intro-slide__content">
    <h2 class="intro-slide__heading">You hold the contract. We hold the assets.</h2>
    <p class="intro-slide__subtitle">
      Your interest is fixed the moment you invest. A manager with 25+ years in real estate runs
      the strategy.
    </p>

    <ul class="intro-slide__benefits">
      <li class="intro-slide__benefit">
        <span class="intro-slide__benefit-title">Your side</span>
        <span class="intro-slide__benefit-desc">
          A fixed-rate contract. Pick monthly payouts or let it compound.
        </span>
      </li>
      <li class="intro-slide__benefit">
        <span class="intro-slide__benefit-title">Our side</span>
        <span class="intro-slide__benefit-desc">
          Real estate and digital assets working as collateral and growth engine.
        </span>
      </li>
      <li class="intro-slide__benefit">
        <span class="intro-slide__benefit-title">Market-proof</span>
        <span class="intro-slide__benefit-desc">
          Prices can swing in either market. Your interest is set by contract and paid on schedule.
        </span>
      </li>
    </ul>
    <p class="intro-slide__source">Two options ahead. Pick the one that fits your timeline.</p>
  </div>
</section>

<style>
  .intro-slide {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    box-sizing: border-box;
  }

  .intro-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    max-width: 480px;
    width: 100%;
    opacity: 0;
  }

  .intro-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1a1a1a;
    font-size: 2rem;
    font-weight: 500;
    line-height: 120%;
    text-align: center;
    margin: 0;
  }

  .intro-slide__subtitle {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: #555555;
    text-align: center;
    margin: 0;
    line-height: 150%;
  }

  .intro-slide__heading + .intro-slide__subtitle {
    margin-top: -0.5rem;
  }

  .intro-slide__benefits {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .intro-slide__benefit {
    background: linear-gradient(to right, rgba(235, 245, 239, 0.5), transparent);
    border-left: 3px solid #67b78f;
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .intro-slide__benefit-title {
    font-family: "Roboto Serif", serif;
    font-size: 1.125rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 130%;
  }

  .intro-slide__benefit-desc {
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    color: #555555;
    line-height: 140%;
  }

  .intro-slide__source {
    font-family: "Roboto", sans-serif;
    font-size: 0.6875rem;
    color: #888888;
    text-align: center;
    font-style: italic;
    margin: 0;
    line-height: 140%;
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .intro-slide__content {
      gap: 1.5rem;
      max-width: 520px;
    }

    .intro-slide__heading {
      font-size: 2.75rem;
    }

    .intro-slide__benefits {
      gap: 1rem;
    }

    .intro-slide__benefit {
      padding: 1rem 1.25rem;
    }

    .intro-slide__benefit-title {
      font-size: 1.25rem;
    }

    .intro-slide__benefit-desc {
      font-size: 0.9375rem;
    }

    .intro-slide__source {
      font-size: 0.75rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .intro-slide__heading {
      font-size: 3.25rem;
    }

    .intro-slide__content {
      max-width: 560px;
    }

    .intro-slide__benefit-title {
      font-size: 1.375rem;
    }

    .intro-slide__benefit-desc {
      font-size: 1rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .intro-slide__heading {
      font-size: 3.75rem;
    }

    .intro-slide__content {
      max-width: 600px;
    }

    .intro-slide__benefit-title {
      font-size: 1.5rem;
    }

    .intro-slide__benefit-desc {
      font-size: 1.0625rem;
    }
  }
</style>
