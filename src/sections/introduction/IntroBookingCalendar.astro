---
// Self-contained booking calendar.
// Renders the multi-state booking UI (loading, picking-day, picking-time,
// confirming, booked). Consumes /api/booking-slots and /api/book-appointment.
// Identity comes from `ghl_contact_id` in localStorage (set during /webinar
// registration); a fallback dev contact is used if absent.
---

<p class="booking__note">
  A member of our team will call you at the time you select. Please only reserve a slot
  you can commit to.
</p>

<div class="booking" data-booking-root data-state="loading">
  <!-- Loading state -->
  <div class="booking__panel" data-panel="loading">
    <div class="booking__spinner" aria-hidden="true"></div>
    <p class="booking__muted">Loading available times...</p>
  </div>

  <!-- Day picker -->
  <div class="booking__panel" data-panel="picking-day">
    <div class="booking__header">
      <p class="booking__label">Pick a day</p>
      <p class="booking__tz-label" data-booking-tz-label></p>
    </div>
    <div class="booking__days" data-booking-days></div>
    <p class="booking__muted booking__empty" data-booking-empty hidden>
      No slots available today or tomorrow. Please check back soon.
    </p>
  </div>

  <!-- Time picker -->
  <div class="booking__panel" data-panel="picking-time">
    <button type="button" class="booking__back-inline" data-booking-to-days>
      <span class="booking__back-arrow" aria-hidden="true"></span>
      Back to days
    </button>
    <p class="booking__label" data-booking-day-label></p>
    <div class="booking__times" data-booking-times></div>
  </div>

  <!-- Confirming -->
  <div class="booking__panel" data-panel="confirming">
    <p class="booking__label">Confirm your call</p>
    <div class="booking__summary" data-booking-summary></div>
    <button type="button" class="booking__confirm" data-booking-confirm>
      Confirm booking
    </button>
    <button type="button" class="booking__back-inline" data-booking-to-time>
      Pick a different time
    </button>
    <p class="booking__error" data-booking-error hidden></p>
  </div>

  <!-- Booked / thank you -->
  <div class="booking__panel" data-panel="booked">
    <div class="booking__check" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
    </div>
    <p class="booking__label booking__label--center">You're booked</p>
    <p class="booking__summary" data-booking-booked-summary></p>
    <p class="booking__muted booking__muted--center">
      We'll call you at the number you registered with. Feel free to close this page.
    </p>
  </div>
</div>

<!--
  Global styles for the custom booking UI.
  Astro scopes `<style>` by default, but we build the day/time nodes via
  document.createElement in JS so they never receive Astro's scope attribute
  and scoped selectors can't match them. `is:global` avoids the problem
  without per-rule `:global(...)` wrapping. Class names are prefixed with
  `booking__` to avoid collisions.
-->
<style is:global>
  .booking__note {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: #555555;
    line-height: 150%;
    margin: 0 0 0.75rem;
    text-align: center;
    text-wrap: balance;
  }

  .booking__back-arrow {
    width: 8px;
    height: 8px;
    border-left: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(45deg);
    display: inline-block;
  }

  .booking {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 520px;
    margin: 0 auto;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    padding: 1.25rem;
    box-sizing: border-box;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .booking__panel {
    display: none;
    flex-direction: column;
    gap: 0.75rem;
  }

  .booking[data-state="loading"] [data-panel="loading"],
  .booking[data-state="picking-day"] [data-panel="picking-day"],
  .booking[data-state="picking-time"] [data-panel="picking-time"],
  .booking[data-state="confirming"] [data-panel="confirming"],
  .booking[data-state="booked"] [data-panel="booked"] {
    display: flex;
  }

  .booking__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .booking__label {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: #1a1a1a;
    margin: 0;
  }

  .booking__label--center {
    text-align: center;
  }

  .booking__muted {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: #555555;
    margin: 0;
    line-height: 150%;
  }

  .booking__muted--center {
    text-align: center;
  }

  .booking__tz-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    color: #555555;
    margin: 0;
  }

  .booking__days {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .booking__day {
    font-family: "Roboto", sans-serif;
    color: #1a1a1a;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 10px;
    padding: 1rem 1.125rem;
    cursor: pointer;
    text-align: left;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    line-height: 130%;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      transform 0.15s ease,
      box-shadow 0.2s ease;
  }

  .booking__day:hover {
    border-color: #152429;
    background: #f4f6f5;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(21, 36, 41, 0.08);
  }

  .booking__day-main {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .booking__day-weekday {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: #1a1a1a;
    line-height: 120%;
  }

  .booking__day-date {
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    font-weight: 400;
    color: #555555;
    line-height: 120%;
  }

  .booking__day-chevron {
    width: 8px;
    height: 8px;
    border-right: 1.5px solid #555555;
    border-top: 1.5px solid #555555;
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  .booking__times {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .booking__period {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .booking__period-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: #555555;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
  }

  .booking__period-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.4rem;
  }

  .booking__time {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: #1a1a1a;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 8px;
    padding: 0.625rem 0.35rem;
    cursor: pointer;
    line-height: 120%;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  .booking__time:hover {
    border-color: #152429;
    background: #f4f6f5;
    box-shadow: 0 2px 6px rgba(21, 36, 41, 0.08);
  }

  .booking__back-inline {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #555555;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem 0;
  }

  .booking__back-inline:hover {
    color: #1a1a1a;
  }

  .booking__summary {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: #1a1a1a;
    margin: 0;
    padding: 0.75rem 0.9rem;
    background: #f4f6f5;
    border-radius: 8px;
    line-height: 150%;
  }

  .booking__confirm {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: #ffffff;
    background: #152429;
    border: none;
    border-radius: 8px;
    padding: 0.875rem 1.5rem;
    cursor: pointer;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .booking__confirm:hover {
    opacity: 0.95;
    transform: translateY(-1px);
  }

  .booking__confirm:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .booking__error {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: #b00020;
    margin: 0;
  }

  .booking__link {
    font-family: "Roboto", sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #67b78f;
    text-decoration: none;
    align-self: flex-start;
  }

  .booking__link:hover {
    text-decoration: underline;
  }

  .booking__check {
    align-self: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #e9f5ee;
    color: #2a7a4a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .booking__spinner {
    align-self: center;
    width: 24px;
    height: 24px;
    border: 2.5px solid rgba(21, 36, 41, 0.15);
    border-top-color: #152429;
    border-radius: 50%;
    animation: booking-spin 0.8s linear infinite;
  }

  @keyframes booking-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .booking__spinner {
      animation: none;
    }
    .booking__confirm:hover {
      transform: none;
    }
  }

  @media only screen and (min-width: 480px) {
    .booking__period-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media only screen and (min-width: 600px) {
    .booking__note {
      font-size: 0.9375rem;
    }
  }
</style>

<script is:inline data-astro-rerun>
  // Custom booking flow for the Webinar Q&A Call calendar.
  // Slots come from /api/booking-slots (proxies GHL v2 free-slots).
  // Booking calls /api/book-appointment with the ghl_contact_id stored
  // on registration at /webinar. All calendar rules (4-day window,
  // 2h lead, 15-min granularity, no double-booking) are enforced by GHL.
  (function () {
    var root = document.querySelector("[data-booking-root]");
    if (!root) return;

    var tzLabelEl = root.querySelector("[data-booking-tz-label]");
    var daysEl = root.querySelector("[data-booking-days]");
    var emptyEl = root.querySelector("[data-booking-empty]");
    var timesEl = root.querySelector("[data-booking-times]");
    var dayLabelEl = root.querySelector("[data-booking-day-label]");
    var summaryEl = root.querySelector("[data-booking-summary]");
    var bookedSummaryEl = root.querySelector("[data-booking-booked-summary]");
    var confirmBtn = root.querySelector("[data-booking-confirm]");
    var errorEl = root.querySelector("[data-booking-error]");
    var toDaysBtn = root.querySelector("[data-booking-to-days]");
    var toTimeBtn = root.querySelector("[data-booking-to-time]");

    // Default fallback is Eastern (America/New_York) whenever no explicit
    // timezone is available, so slot times always have a sensible frame.
    function detectTimezone() {
      try {
        var saved = localStorage.getItem("user_timezone");
        if (saved) return saved;
      } catch (e) {}
      try {
        var session = JSON.parse(localStorage.getItem("webinarSession") || "{}");
        if (session && session.timeZone) return session.timeZone;
      } catch (e) {}
      try {
        var browserTz = Intl.DateTimeFormat().resolvedOptions().timeZone;
        if (browserTz) return browserTz;
      } catch (e) {}
      return "America/New_York";
    }

    var state = {
      slotsByDay: {},
      selectedDate: null,
      selectedSlot: null,
      timezone: detectTimezone(),
      hasLoaded: false,
    };

    function setState(s) {
      root.setAttribute("data-state", s);
    }

    function getContactId() {
      try {
        return localStorage.getItem("ghl_contact_id");
      } catch (e) {
        return null;
      }
    }

    // Returns "YYYY-MM-DD" for a given Date in the user's timezone.
    function toDateKey(d) {
      var parts = new Intl.DateTimeFormat("en-CA", {
        timeZone: state.timezone,
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
      }).formatToParts(d);
      var y = "", m = "", dd = "";
      for (var i = 0; i < parts.length; i++) {
        if (parts[i].type === "year") y = parts[i].value;
        if (parts[i].type === "month") m = parts[i].value;
        if (parts[i].type === "day") dd = parts[i].value;
      }
      return y + "-" + m + "-" + dd;
    }

    // Returns 0 (Sun) - 6 (Sat) for a date key in the user's timezone.
    function weekdayIndex(dateKey) {
      var parts = dateKey.split("-");
      // Noon UTC avoids DST edge-cases when converting to the user's tz
      var d = new Date(Date.UTC(Number(parts[0]), Number(parts[1]) - 1, Number(parts[2]), 12, 0, 0));
      var wd = new Intl.DateTimeFormat("en-US", {
        timeZone: state.timezone,
        weekday: "short",
      }).format(d);
      var map = { Sun: 0, Mon: 1, Tue: 2, Wed: 3, Thu: 4, Fri: 5, Sat: 6 };
      return map[wd];
    }

    // Pick the first 2 days from GHL's response that actually have bookable
    // slots, skipping Sunday. GHL already applies the 2-hour lead time, so if
    // today's slots are all in the past it won't appear in the response and
    // we'll naturally roll forward to tomorrow + the next day.
    function acceptableDateKeys() {
      var allDates = Object.keys(state.slotsByDay)
        .filter(function (k) {
          if (!/^\d{4}-\d{2}-\d{2}$/.test(k)) return false;
          if (weekdayIndex(k) === 0) return false;
          var v = state.slotsByDay[k];
          return v && Array.isArray(v.slots) && v.slots.length > 0;
        })
        .sort();
      return allDates.slice(0, 2);
    }

    function formatWeekday(dateStr) {
      var parts = dateStr.split("-");
      var d = new Date(
        Date.UTC(Number(parts[0]), Number(parts[1]) - 1, Number(parts[2]), 12, 0, 0)
      );
      return d.toLocaleDateString("en-US", {
        timeZone: state.timezone,
        weekday: "short",
      });
    }

    function formatDayNumber(dateStr) {
      var parts = dateStr.split("-");
      var d = new Date(
        Date.UTC(Number(parts[0]), Number(parts[1]) - 1, Number(parts[2]), 12, 0, 0)
      );
      return d.toLocaleDateString("en-US", {
        timeZone: state.timezone,
        month: "short",
        day: "numeric",
      });
    }

    function formatTime(isoString) {
      var d = new Date(isoString);
      return d.toLocaleTimeString("en-US", {
        timeZone: state.timezone,
        hour: "numeric",
        minute: "2-digit",
      });
    }

    function formatTzAbbrev() {
      try {
        var parts = new Intl.DateTimeFormat("en-US", {
          timeZone: state.timezone,
          timeZoneName: "short",
        }).formatToParts(new Date());
        for (var i = 0; i < parts.length; i++) {
          if (parts[i].type === "timeZoneName") return parts[i].value;
        }
      } catch (e) {}
      return "";
    }

    function renderDays() {
      daysEl.innerHTML = "";

      var accept = acceptableDateKeys();
      var acceptSet = {};
      accept.forEach(function (k) {
        acceptSet[k] = true;
      });

      var dates = Object.keys(state.slotsByDay)
        .filter(function (k) {
          if (!acceptSet[k]) return false;
          var v = state.slotsByDay[k];
          return v && Array.isArray(v.slots) && v.slots.length > 0;
        })
        .sort();

      if (dates.length === 0) {
        emptyEl.hidden = false;
        return;
      }
      emptyEl.hidden = true;

      dates.forEach(function (date) {
        var btn = document.createElement("button");
        btn.type = "button";
        btn.className = "booking__day";
        btn.setAttribute("data-date", date);

        var main = document.createElement("div");
        main.className = "booking__day-main";

        var weekday = document.createElement("span");
        weekday.className = "booking__day-weekday";
        weekday.textContent = relativeDayLabel(date);

        var day = document.createElement("span");
        day.className = "booking__day-date";
        day.textContent = formatDayNumber(date);

        main.appendChild(weekday);
        main.appendChild(day);

        var chevron = document.createElement("span");
        chevron.className = "booking__day-chevron";
        chevron.setAttribute("aria-hidden", "true");

        btn.appendChild(main);
        btn.appendChild(chevron);

        btn.addEventListener("click", function () {
          state.selectedDate = date;
          renderTimes(date);
          setState("picking-time");
        });

        daysEl.appendChild(btn);
      });
    }

    // "Today", "Tomorrow", or the weekday name — based on real date math,
    // not position in the list (so the label stays correct even when today's
    // slots are unavailable and we roll forward).
    function relativeDayLabel(dateKey) {
      var now = new Date();
      var todayKey = toDateKey(now);
      var tomorrowKey = toDateKey(new Date(now.getTime() + 24 * 60 * 60 * 1000));
      if (dateKey === todayKey) return "Today";
      if (dateKey === tomorrowKey) return "Tomorrow";
      return formatWeekday(dateKey);
    }

    // Extract hour (0-23) of an ISO slot in the user's timezone.
    function hourInTz(iso) {
      var d = new Date(iso);
      var parts = new Intl.DateTimeFormat("en-US", {
        timeZone: state.timezone,
        hour: "2-digit",
        hour12: false,
      }).formatToParts(d);
      for (var i = 0; i < parts.length; i++) {
        if (parts[i].type === "hour") {
          var h = parseInt(parts[i].value, 10);
          // 24 can appear for midnight; normalize to 0
          return h === 24 ? 0 : h;
        }
      }
      return 0;
    }

    function periodOf(hour) {
      if (hour < 12) return "Morning";
      if (hour < 17) return "Afternoon";
      return "Evening";
    }

    function renderTimes(date) {
      timesEl.innerHTML = "";
      dayLabelEl.textContent =
        relativeDayLabel(date) + ", " + formatDayNumber(date) + " (" + formatTzAbbrev() + ")";

      var slots = (state.slotsByDay[date] && state.slotsByDay[date].slots) || [];

      // Group by period, preserving chronological order within each group
      var groups = { Morning: [], Afternoon: [], Evening: [] };
      slots.forEach(function (iso) {
        groups[periodOf(hourInTz(iso))].push(iso);
      });

      ["Morning", "Afternoon", "Evening"].forEach(function (label) {
        var items = groups[label];
        if (items.length === 0) return;

        var wrap = document.createElement("div");
        wrap.className = "booking__period";

        var heading = document.createElement("p");
        heading.className = "booking__period-label";
        heading.textContent = label;
        wrap.appendChild(heading);

        var grid = document.createElement("div");
        grid.className = "booking__period-grid";

        items.forEach(function (iso) {
          var btn = document.createElement("button");
          btn.type = "button";
          btn.className = "booking__time";
          btn.textContent = formatTime(iso);
          btn.addEventListener("click", function () {
            state.selectedSlot = iso;
            summaryEl.textContent =
              relativeDayLabel(date) +
              ", " +
              formatDayNumber(date) +
              " at " +
              formatTime(iso) +
              " (" +
              formatTzAbbrev() +
              ")";
            errorEl.hidden = true;
            errorEl.textContent = "";
            setState("confirming");
          });
          grid.appendChild(btn);
        });

        wrap.appendChild(grid);
        timesEl.appendChild(wrap);
      });
    }

    function updateTzLabel() {
      if (!tzLabelEl) return;
      var abbr = formatTzAbbrev();
      tzLabelEl.textContent = abbr ? "Times shown in " + abbr : "";
    }

    async function loadSlots() {
      setState("loading");
      updateTzLabel();
      try {
        var res = await fetch(
          "/api/booking-slots?timezone=" + encodeURIComponent(state.timezone),
          { headers: { Accept: "application/json" } }
        );
        if (!res.ok) throw new Error("HTTP " + res.status);
        var data = await res.json();

        // Strip non-date keys like "traceId"
        var clean = {};
        Object.keys(data || {}).forEach(function (k) {
          if (/^\d{4}-\d{2}-\d{2}$/.test(k) && data[k] && Array.isArray(data[k].slots)) {
            clean[k] = data[k];
          }
        });
        state.slotsByDay = clean;
        state.hasLoaded = true;

        renderDays();
        setState("picking-day");
      } catch (err) {
        console.error("Failed to load slots:", err);
        state.slotsByDay = {};
        renderDays();
        setState("picking-day");
      }
    }

    // TEMPORARY: Fallback identity used when the visitor didn't go through
    // /webinar registration (e.g. dev testing, incognito, cleared
    // storage). The server upserts this into GHL so the booking still lands
    // against a real contact.
    var FALLBACK_CONTACT = {
      name: "E Tester",
      email: "e.test@rv.com",
      phone: "5555555555",
    };

    async function confirmBooking() {
      if (!state.selectedSlot) return;
      var contactId = getContactId();

      confirmBtn.disabled = true;
      errorEl.hidden = true;
      errorEl.textContent = "";

      var payload = {
        selectedSlot: state.selectedSlot,
        timezone: state.timezone,
      };
      if (contactId) {
        payload.ghl_contact_id = contactId;
      } else {
        payload.contactInfo = FALLBACK_CONTACT;
      }

      try {
        var res = await fetch("/api/book-appointment", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        var data = null;
        try {
          data = await res.json();
        } catch (e) {}

        if (res.status === 409) {
          errorEl.textContent =
            "That slot was just taken. Please pick another time.";
          errorEl.hidden = false;
          confirmBtn.disabled = false;
          // Re-fetch slots so the stale one disappears
          await loadSlots();
          return;
        }
        if (!res.ok) {
          errorEl.textContent =
            (data && data.error) || "Something went wrong. Please try again.";
          errorEl.hidden = false;
          confirmBtn.disabled = false;
          return;
        }

        bookedSummaryEl.textContent =
          relativeDayLabel(state.selectedDate) +
          ", " +
          formatDayNumber(state.selectedDate) +
          " at " +
          formatTime(state.selectedSlot) +
          " (" +
          formatTzAbbrev() +
          ")";
        setState("booked");

        // Analytics: PostHog + GA dataLayer
        try {
          if (window.posthogTrack) {
            window.posthogTrack("appointment_booked", {
              calendar: "webinar_qa_call",
              slot: state.selectedSlot,
              timezone: state.timezone,
              session_page: window.location.pathname,
            });
          }
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            event: "appointmentBooked",
            calendar: "webinar_qa_call",
            slot: state.selectedSlot,
            timezone: state.timezone,
          });
        } catch (e) {}

        try {
          localStorage.setItem(
            "booked_call_slot",
            JSON.stringify({ slot: state.selectedSlot, timezone: state.timezone })
          );
        } catch (e) {}

        if (window.rvNavigate) window.rvNavigate("/webinar/confirmation");
        else window.location.href = "/webinar/confirmation";
      } catch (err) {
        errorEl.textContent = "Network error. Please try again.";
        errorEl.hidden = false;
        confirmBtn.disabled = false;
      }
    }

    // Wire events
    toDaysBtn.addEventListener("click", function () {
      setState("picking-day");
    });

    toTimeBtn.addEventListener("click", function () {
      if (state.selectedDate) {
        renderTimes(state.selectedDate);
        setState("picking-time");
      } else {
        setState("picking-day");
      }
    });

    confirmBtn.addEventListener("click", confirmBooking);

    // Load slots immediately on page load.
    loadSlots();
  })();
</script>
