<section class="intro-slide" id="intro-slide-8">
  <div class="intro-slide__content">
    <h2 class="intro-slide__heading">Let's Discuss Your Investment</h2>
    <p class="intro-slide__subtitle">Schedule a call with our team to explore the right plan for your goals.</p>

    <button class="intro-slide__cta" type="button">Book a Call</button>
  </div>
</section>

<style>
  .intro-slide {
    height: 100svh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    margin: 0;
    padding: 5rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  .intro-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 600px;
    width: 100%;
    opacity: 0;
  }

  .intro-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1A1A1A;
    font-size: 2.5rem;
    font-weight: 500;
    line-height: 120%;
    text-align: center;
    margin: 0;
  }

  .intro-slide__subtitle {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    color: #555555;
    text-align: center;
    margin: 0;
    line-height: 150%;
  }

  .intro-slide__cta {
    font-family: "Roboto", sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: #ffffff;
    background: #152429;
    border: none;
    border-radius: 8px;
    padding: 1rem 2.5rem;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
    margin-top: 0.5rem;
  }

  .intro-slide__cta:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .intro-slide__cta:active {
    transform: translateY(0);
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .intro-slide {
      padding: 5rem 2rem 1.5rem;
    }

    .intro-slide__heading {
      font-size: 3rem;
    }

    .intro-slide__cta {
      font-size: 1.125rem;
      padding: 1.125rem 3rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .intro-slide__heading {
      font-size: 3.75rem;
    }

    .intro-slide__content {
      max-width: 700px;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .intro-slide__heading {
      font-size: 4.25rem;
    }

    .intro-slide__content {
      max-width: 800px;
    }
  }
</style>
