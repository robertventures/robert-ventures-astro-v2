    transition: opacity 0.6s ease-in-out;
    width: 100%;
    box-sizing: border-box;
    /* Reserve space for the tallest possible card (3-line quote +
       read-more + footer + paddings) so layout doesn't jump as
       testimonials cycle. */
    min-height: 10rem;
  }

  .cta-review-card.visible {
    opacity: 1;
  }

  .cta-quote {
