  .cta-social-proof__stat {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cta-stars {
    display: inline-flex;
    gap: 2px;
    align-items: center;
