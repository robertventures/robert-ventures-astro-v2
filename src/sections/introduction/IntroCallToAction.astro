    font-size: 0.9375rem;
    font-weight: 400;
    color: #1a1a1a;
    line-height: 150%;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .cta-quote.expanded {
    display: block;
    -webkit-line-clamp: unset;
  }

  .cta-read-more {
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    font-weight: 400;
    color: #67b78f;
    cursor: pointer;
