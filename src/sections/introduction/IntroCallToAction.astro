<style>
  .intro-slide {
    width: 100%;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: linear-gradient(to bottom, #ffffff, #f4f6f5);
    box-sizing: border-box;
    padding-bottom: 6rem;
    /* Kill global.css `section { margin-bottom: 1.5rem }` so there's no
       white strip below the page. */
    margin-bottom: 0;
  }

  /* Staircase SVG — background animation (matches WfHero) */
  .intro-slide__staircase {
    position: absolute;
    bottom: -200px;
    right: -200px;
    width: 800px;
    height: 800px;
    min-width: 800px;
    min-height: 800px;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
