  .intro-slide__cta {
    font-family: "Roboto", sans-serif;
    font-size: 1.0625rem;
    font-weight: 500;
    color: #ffffff;
    background: #152429;
    border: none;
    border-radius: 8px;
    padding: 1.125rem 3rem;
    cursor: pointer;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
    margin-top: 1.5rem;
    margin-bottom: 1rem;
    box-shadow: 0 6px 18px rgba(21, 36, 41, 0.18);
  }

  .intro-slide__cta:hover {
    opacity: 0.95;
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(21, 36, 41, 0.24);
  }

  .intro-slide__cta:active {
    transform: translateY(0);
    box-shadow: 0 4px 12px rgba(21, 36, 41, 0.18);
  }

  /* ── Pre-booking vs booking state swap ── */
  .intro-slide__cta-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    /* Transition props for the exit animation; entrance uses a keyframe. */
    transition:
      opacity 0.18s ease,
      transform 0.18s ease;
  }

  .intro-slide__calendar {
    display: none;
    flex-direction: column;
    align-items: stretch;
    gap: 0.75rem;
    width: 100%;
    max-width: 520px;
    margin: 0 auto;
    transition:
      opacity 0.18s ease,
      transform 0.18s ease;
  }

  /* Exit animation — applied by JS on the outgoing panel just before the
     .is-booking class swap. Short and snappy. */
  .intro-slide__cta-group.is-leaving,
  .intro-slide__calendar.is-leaving {
    opacity: 0;
    transform: translateY(-6px);
    pointer-events: none;
  }

  /* Entrance animation — plays whenever the incoming panel becomes visible
     via the .is-booking class toggling on the slide. */
  @keyframes intro-booking-fade-up {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .intro-slide.is-booking {
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    align-items: flex-start;
    padding-top: 5rem;
  }

  .intro-slide.is-booking .intro-slide__cta-group {
    display: none;
  }

  .intro-slide.is-booking .intro-slide__calendar {
    display: flex;
  }

  /* Hide the decorative staircase in booking mode. It's positioned absolutely
     and extends ~600px below the slide, which inflates scrollHeight once the
     slide becomes overflow-y: auto and creates a lot of dead scroll space. */
  .intro-slide.is-booking .intro-slide__staircase {
    display: none;
  }

  /* Entrance animation is class-gated so it only runs when JS toggles the
     panel (not on initial page load or slide mount). */
  .intro-slide__cta-group.is-entering,
  .intro-slide__calendar.is-entering {
    animation: intro-booking-fade-up 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .intro-slide__cta-group,
    .intro-slide__calendar {
      transition: none;
    }
    .intro-slide__cta-group.is-entering,
    .intro-slide__calendar.is-entering {
      animation: none;
    }
  }

  .intro-slide.is-booking .intro-slide__subtitle {
    display: none;
  }

  .intro-slide.is-booking .intro-slide__heading {
    font-size: 1.5rem;
  }

  .intro-slide__calendar-back {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: #555555;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem 0;
    transition: color 0.2s ease;
  }

  .intro-slide__calendar-back:hover {
    color: #1a1a1a;
  }

  .intro-slide__calendar-back-arrow {
    width: 8px;
    height: 8px;
    border-left: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(45deg);
    display: inline-block;
  }

  .intro-slide__calendar-note {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: #555555;
    line-height: 150%;
    margin: 0 0 0.25rem;
    text-align: center;
    text-wrap: balance;
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .intro-slide {
      padding-bottom: 7rem;
    }

    .intro-slide__content {
      gap: 1.25rem;
    }

    .intro-slide__heading {
      font-size: 2.75rem;
    }

    .intro-slide__subtitle {
      font-size: 1rem;
    }

    .cta-quote {
      font-size: 1rem;
    }

    .cta-stat-text {
      font-size: 0.9375rem;
