<style>
  .intro-slide {
    height: 100svh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: linear-gradient(to bottom, #FFFFFF, #F4F6F5);
    margin: 0;
    padding: 0 1.5rem;
    box-sizing: border-box;
  }

  /* Staircase SVG — background animation */
  #intro-staircase-svg {
    position: absolute;
    bottom: -200px;
    right: -200px;
    width: 800px;
    height: 800px;
    min-width: 800px;
    min-height: 800px;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    opacity: 1;
  }

  #intro-staircase-svg rect {
    fill: none;
    stroke: #BBBBBB;
    stroke-opacity: 0.15;
    stroke-width: 1;
  }

  .intro-slide__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    width: 100%;
    max-width: 1136px;
    text-align: center;
  }

  .intro-slide__text {
    opacity: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .intro-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1A1A1A;
    font-size: 12vw;
    font-weight: 500;
    line-height: 130%;
    margin: 0;
  }

  .intro-slide__accent {
    color: #1A1A1A;
    position: relative;
    display: inline-block;
  }

  .intro-slide__underline {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 5px;
    background: #3EB278;
    transform: scaleX(0);
    transform-origin: left;
  }

  .intro-slide__statements {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .intro-slide__statement {
    font-family: "Roboto Serif", serif;
    color: #555555;
    font-size: 6vw;
    font-weight: 400;
    line-height: 140%;
    margin: 0;
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .intro-slide {
      padding: 0 2rem;
    }

    .intro-slide__heading {
      font-size: 8vw;
    }

    .intro-slide__statement {
      font-size: 3.25vw;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .intro-slide__heading {
      font-size: 6rem;
    }

    .intro-slide__statement {
      font-size: 2.25rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
