<section class="intro-slide" id="intro-slide-2">
  <div class="intro-slide__content">
    <h2 class="intro-slide__heading">How 10% APY Turns Into 17.07%</h2>

    <div class="intro-slide__cards">
      <div class="intro-slide__card">
        <p class="intro-slide__card-growth-label">With compounding, your effective rate grows:</p>

        <div class="intro-slide__growth-table">
          <div class="intro-slide__growth-row">
            <span class="intro-slide__growth-period">1 year</span>
            <span class="intro-slide__growth-pct">10.47% avg/yr</span>
          </div>
          <div class="intro-slide__growth-row">
            <span class="intro-slide__growth-period">3 years</span>
            <span class="intro-slide__growth-pct">11.61% avg/yr</span>
          </div>
          <div class="intro-slide__growth-row">
            <span class="intro-slide__growth-period">5 years</span>
            <span class="intro-slide__growth-pct">12.91% avg/yr</span>
          </div>
        </div>

        <div class="intro-slide__growth-hero">
          <span class="intro-slide__growth-hero-label">In 10 years</span>
          <span class="intro-slide__growth-hero-value">17.07%</span>
          <span class="intro-slide__growth-hero-effective">Average annual returns with compounding</span>

        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .intro-slide {
    height: 100svh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #F4F6F5;
    margin: 0;
    padding: 5rem 1.5rem 1.5rem;
    box-sizing: border-box;
  }

  .intro-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 600px;
    width: 100%;
    opacity: 0;
  }

  .intro-slide__heading {
    font-family: "Roboto Serif", serif;
    color: #1A1A1A;
    font-size: 2.5rem;
    font-weight: 500;
    line-height: 120%;
    text-align: center;
    margin: 0;
  }

  .intro-slide__cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
  }

  .intro-slide__card {
    background: #ffffff;
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid #E5E5E5;
  }

  .intro-slide__card-growth-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    color: #555555;
    text-align: center;
    margin: 0;
  }

  .intro-slide__growth-table {
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
  }

  .intro-slide__growth-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid #E5E5E5;
  }

  .intro-slide__growth-row:last-child {
    border-bottom: none;
  }

  .intro-slide__growth-period {
    font-family: "Roboto", sans-serif;
    font-size: 0.875rem;
    color: #BBBBBB;
  }

  .intro-slide__growth-pct {
    font-family: "Roboto Serif", serif;
    font-size: 1.125rem;
    color: #3EB278;
    font-weight: 500;
  }

  .intro-slide__growth-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    background: #EAF6EF;
    border-radius: 8px;
    padding: 1.25rem;
    width: 100%;
    box-sizing: border-box;
  }

  .intro-slide__growth-hero-label {
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    color: #1A1A1A;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .intro-slide__growth-hero-value {
    font-family: "Roboto Serif", serif;
    font-size: 2.5rem;
    font-weight: 500;
    color: #1A1A1A;
    line-height: 100%;
  }

  .intro-slide__growth-hero-effective {
    font-family: "Roboto", sans-serif;
    font-size: 0.8125rem;
    color: #1A1A1A;
  }

  /* Medium: 600px+ */
  @media only screen and (min-width: 600px) {
    .intro-slide {
      padding: 0 2rem;
    }

    .intro-slide__heading {
      font-size: 3rem;
    }

    .intro-slide__growth-pct {
      font-size: 1.25rem;
    }

    .intro-slide__growth-period {
      font-size: 1rem;
    }

    .intro-slide__growth-hero-value {
      font-size: 3rem;
    }
  }

  /* Large: 1136px+ */
  @media only screen and (min-width: 1136px) {
    .intro-slide__heading {
      font-size: 3.75rem;
    }

    .intro-slide__growth-pct {
      font-size: 1.375rem;
    }

    .intro-slide__growth-hero-value {
      font-size: 3.5rem;
    }
  }

  /* Extra Large: 1920px+ */
  @media only screen and (min-width: 1920px) {
    .intro-slide__content {
      max-width: 700px;
    }

    .intro-slide__heading {
      font-size: 4.25rem;
    }

    .intro-slide__growth-hero-value {
      font-size: 4rem;
    }
  }
</style>
