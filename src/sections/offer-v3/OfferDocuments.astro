---
// Real, public offering documents (same set + URLs as the /offer page). PDFs
// open in a new tab; the SEC link goes to EDGAR. Keep these in sync with
// src/sections/presentation/PresReviewBeforeInvest.astro if the URLs change.
const documents = [
  {
    title: "Offering Circular",
    type: "PDF attachment",
    href: "https://l.robertventures.com/OfferingCircular",
    slug: "offering_circular",
    icon: "pdf",
  },
  {
    title: "Sample Bond Agreement",
    type: "PDF attachment",
    href: "/documents/sample-bond-agreement.pdf",
    slug: "sample_bond_agreement",
    icon: "pdf",
  },
  {
    title: "Delaware Initial Filing",
    type: "PDF attachment",
    href: "/documents/delaware-initial-filing.pdf",
    slug: "delaware_initial_filing",
    icon: "pdf",
  },
  {
    title: "Full history of SEC filings",
    type: "View on SEC.gov",
    href: "https://www.sec.gov/edgar/browse/?CIK=1991519",
    slug: "sec_filings_history",
    icon: "external",
  },
];
const trackLocation = "offer_v3_documents";
---

<section class="intro-slide" id="intro-slide-documents">
  <div class="intro-slide__content">
    <p class="docs-eyebrow">On the public record</p>
    <h2 class="docs-heading">Offering Documents</h2>
    <p class="docs-sub">No account needed. The core offering documents are publicly available.</p>

    <ul class="docs-list" aria-label="Offering documents">
      {
        documents.map((doc) => (
          <li class="docs-item">
            <a
              class="doc-card"
              href={doc.href}
              target="_blank"
              rel="noopener"
              data-track-document={doc.slug}
              data-track-location={trackLocation}
            >
              <span class={`doc-card__icon doc-card__icon--${doc.icon}`} aria-hidden="true">
                {doc.icon === "pdf" ? (
                  <svg
                    width="20"
                    height="24"
                    viewBox="0 0 20 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M2 0C0.895 0 0 0.895 0 2V22C0 23.105 0.895 24 2 24H18C19.105 24 20 23.105 20 22V7L13 0H2Z"
                      fill="#F5F5F5"
                      stroke="#D9D9D9"
                      stroke-width="0.5"
                    />
                    <path d="M13 0V7H20L13 0Z" fill="#E8E8E8" />
                    <rect x="2" y="11" width="16" height="9" rx="1.5" fill="#E63946" />
                    <text
                      x="10"
                      y="17.6"
                      text-anchor="middle"
                      font-family="Roboto, sans-serif"
                      font-size="5"
                      font-weight="700"
                      fill="#ffffff"
                    >
                      PDF
                    </text>
                  </svg>
                ) : (
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M14 3H21V10"
                      stroke="#1a1a1a"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M21 3L10 14"
                      stroke="#1a1a1a"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <path
                      d="M19 13V19C19 20.105 18.105 21 17 21H5C3.895 21 3 20.105 3 19V7C3 5.895 3.895 5 5 5H11"
                      stroke="#1a1a1a"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                )}
              </span>
              <span class="doc-card__text">
                <span class="doc-card__title">{doc.title}</span>
                <span class="doc-card__meta">{doc.type}</span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .intro-slide {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: var(--bg-secondary);
    box-sizing: border-box;
    padding: 3rem 1.25rem 3rem 1.25rem;
  }

  .intro-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 560px;
    text-align: center;
  }

  .docs-eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #4e9a74;
    margin: 0;
  }

  .docs-heading {
    font-family: var(--font-heading);
    color: #1a1a1a;
    font-size: 1.875rem;
    font-weight: 500;
    line-height: 1.18;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .docs-sub {
    font-family: var(--font-body);
    color: #555555;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    max-width: 28rem;
  }

  .docs-list {
    list-style: none;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 0.75rem 0 0;
    padding: 0;
  }

  .docs-item {
    display: flex;
  }

  .doc-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex: 1;
    text-align: left;
    text-decoration: none;
    background: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 0.875rem 1rem;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .doc-card:hover {
    border-color: var(--green-brand);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    transform: translateY(-1px);
  }

  .doc-card__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 9px;
    background: var(--bg-secondary);
  }

  .doc-card__text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .doc-card__title {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.3;
  }

  .doc-card__meta {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: #8a969c;
    line-height: 1.3;
  }

  @media only screen and (min-width: 600px) {
    .docs-heading {
      font-size: 2.25rem;
    }
    .doc-card {
      padding: 1rem 1.125rem;
    }
    .doc-card__title {
      font-size: 1rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .docs-heading {
      font-size: 2.5rem;
    }
  }

  /* Self-contained outer spacing (previously provided by the page shell). */
  @media only screen and (min-width: 600px) {
    .intro-slide {
      padding: 4rem 2rem 4rem 2.5rem;
    }
  }
  @media only screen and (min-width: 1136px) {
    .intro-slide {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }
  }
  @media only screen and (min-width: 1920px) {
    .intro-slide {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }
  }
</style>
