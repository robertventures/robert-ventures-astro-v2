---
import { Image } from "astro:assets";
import outerBanks1 from "../../assets/outer-banks/outer-banks-1.jpg";
import outerBanks2 from "../../assets/outer-banks/outer-banks-2.jpg";
import outerBanks3 from "../../assets/outer-banks/outer-banks-3.jpg";
import outerBanks4 from "../../assets/outer-banks/outer-banks-4.jpg";
import outerBanks5 from "../../assets/outer-banks/outer-banks-5.jpg";

const slides = [outerBanks1, outerBanks2, outerBanks3, outerBanks4, outerBanks5];
---

<section class="rv3-section ob-slider" id="ob-slider">
  <div class="ob-slider__header" data-reveal-group>
    <p class="ob-slider__eyebrow rv3-reveal">Where it comes from</p>
    <h2 class="ob-slider__heading rv3-reveal" data-reveal="lines">
      How can we pay 10% when your bank pays 4%?
    </h2>
    <p class="ob-slider__body rv3-reveal">
      Because your money does different work. Your capital funds real homes on the Outer Banks,
      where buildable land is scarce and demand keeps rising, alongside a digital reserve with a
      hard supply cap.
    </p>
  </div>

  <div class="ob-slider__gallery" data-reveal-group>
    <ul class="ob-slider__track rv3-reveal" role="list" id="ob-track">
      {
        slides.map((img, i) => (
          <li class="ob-slider__card" data-card-index={i}>
            <Image
              src={img}
              alt="Outer Banks property funded through Robert Ventures"
              widths={[300, 600]}
              sizes="(min-width: 1136px) 340px, 300px"
              format="webp"
              quality={75}
              class="ob-slider__img"
            />
          </li>
        ))
      }
    </ul>

    <div
      class="ob-slider__dots rv3-reveal"
      role="tablist"
      aria-label="Outer Banks property photos"
      id="ob-dots"
    >
      {
        slides.map((_, i) => (
          <button
            type="button"
            class="ob-slider__dot"
            role="tab"
            aria-label={`Show photo ${i + 1}`}
            aria-selected={i === 0 ? "true" : "false"}
            data-dot-index={i}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .ob-slider {
    position: relative;
    width: 100%;
    box-sizing: border-box;
    background: #ffffff;
    overflow-x: clip;
    padding: 3.5rem 0 3.75rem;
  }

  .ob-slider__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.875rem;
    text-align: center;
    max-width: 520px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .ob-slider__eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--green-dark);
    margin: 0;
  }

  .ob-slider__heading {
    font-family: var(--font-heading);
    color: var(--text-heading);
    font-size: clamp(1.75rem, 7vw, 2rem);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .ob-slider__body {
    font-family: var(--font-body);
    color: var(--text-body);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
    max-width: 22.5rem;
  }

  /* Gallery */
  .ob-slider__gallery {
    margin-top: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .ob-slider__track {
    display: flex;
    gap: 0.875rem;
    list-style: none;
    margin: 0;
    padding: 0 3.75rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding: 0 3.75rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .ob-slider__track::-webkit-scrollbar {
    display: none;
  }

  .ob-slider__card {
    flex: 0 0 auto;
    width: 300px;
    height: 260px;
    border-radius: 16px;
    overflow: hidden;
    scroll-snap-align: center;
  }

  .ob-slider__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ob-slider__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .ob-slider__dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: rgba(26, 26, 26, 0.15);
    cursor: pointer;
    transition:
      background-color 0.25s ease,
      transform 0.25s ease;
  }
  .ob-slider__dot[aria-selected="true"] {
    background: var(--green-dark);
    transform: scale(1.15);
  }

  @media only screen and (min-width: 600px) {
    .ob-slider {
      padding: 4.5rem 0;
    }
    .ob-slider__heading {
      font-size: 2rem;
    }
    .ob-slider__body {
      font-size: 1rem;
    }
    .ob-slider__card {
      width: 340px;
      height: 280px;
    }
    .ob-slider__track {
      padding: 0 6rem;
      scroll-padding: 0 6rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .ob-slider {
      padding: 6rem 0;
    }
    .ob-slider__header {
      max-width: 600px;
    }
    .ob-slider__heading {
      font-size: 2.25rem;
    }
    .ob-slider__track {
      justify-content: center;
      padding: 0 calc(50% - 170px);
      scroll-padding: 0 calc(50% - 170px);
    }
    .ob-slider__card {
      width: 360px;
      height: 300px;
    }
  }
</style>

<script is:inline data-astro-rerun>
  (function () {
    function init() {
      const track = document.getElementById("ob-track");
      const dotsWrap = document.getElementById("ob-dots");
      if (!track || !dotsWrap) return;

      const cards = Array.prototype.slice.call(track.querySelectorAll(".ob-slider__card"));
      const dots = Array.prototype.slice.call(dotsWrap.querySelectorAll(".ob-slider__dot"));
      if (!cards.length || !dots.length) return;

      function setActive(index) {
        dots.forEach(function (dot, i) {
          dot.setAttribute("aria-selected", i === index ? "true" : "false");
        });
      }

      // Sync the active dot to whichever card is most centered in the scroller.
      const observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting && entry.intersectionRatio > 0.6) {
              const idx = Number(entry.target.getAttribute("data-card-index"));
              setActive(idx);
            }
          });
        },
        { root: track, threshold: [0.6, 0.75, 0.9] }
      );
      cards.forEach(function (card) {
        observer.observe(card);
      });

      dots.forEach(function (dot) {
        dot.addEventListener("click", function () {
          const idx = Number(dot.getAttribute("data-dot-index"));
          const card = cards[idx];
          if (!card) return;
          card.scrollIntoView({
            behavior: window.matchMedia("(prefers-reduced-motion: reduce)").matches
              ? "auto"
              : "smooth",
            inline: "center",
            block: "nearest",
          });
          setActive(idx);
        });
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
