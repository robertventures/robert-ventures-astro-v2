---
import { Image } from "astro:assets";
import outerBanks1 from "../../assets/outer-banks/outer-banks-1.jpg";
---

<section class="intro-slide" id="intro-slide-dream">
  <div class="intro-slide__content">
    <div class="dream-text">
      <h2 class="intro-slide__heading">What if your money worked as hard as you did?</h2>
      <p class="intro-slide__body">
        Open your account and watch it grow, every month, on its own. Income you can plan around. A
        number that climbs while you sleep.
      </p>
    </div>

    <div class="dream-media">
      <Image
        src={outerBanks1}
        alt="A finished Outer Banks home built by Robert Ventures"
        widths={[600, 1000, 1400]}
        sizes="(min-width: 1136px) 560px, 90vw"
        format="webp"
        quality={75}
        class="dream-media__img"
      />
      <div class="dream-media__badge">
        <span class="dream-media__badge-eyebrow">Real, and on the coast</span>
        <span class="dream-media__badge-title">Your capital builds homes like this.</span>
      </div>
    </div>

    <div class="dream-chips">
      <div class="dream-chip">
        <span class="dream-chip__value">Monthly</span>
        <span class="dream-chip__label">income you can plan around</span>
      </div>
      <div class="dream-chip">
        <span class="dream-chip__value">Fixed</span>
        <span class="dream-chip__label">rate, set the day you invest</span>
      </div>
    </div>
  </div>
</section>

<style>
  .intro-slide {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    background: #ffffff;
    box-sizing: border-box;
    padding: 3rem 1.25rem 3rem 1.25rem;
  }

  .intro-slide__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
    max-width: 480px;
  }

  .dream-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: 100%;
  }

  .intro-slide__heading {
    font-family: var(--font-heading);
    color: #1a1a1a;
    font-size: 2rem;
    font-weight: 500;
    line-height: 1.16;
    letter-spacing: -0.01em;
    margin: 0;
    text-align: center;
  }

  .intro-slide__body {
    font-family: var(--font-body);
    color: #555555;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    text-align: center;
  }

  .dream-chips {
    display: flex;
    gap: 0.75rem;
    width: 100%;
  }

  .dream-chip {
    flex: 1;
    background: var(--green-tint);
    border-radius: 13px;
    padding: 1rem 0.875rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.375rem;
  }

  .dream-chip__value {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--green-dark);
    line-height: 1;
  }

  .dream-chip__label {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: #4e7a63;
    line-height: 1.35;
  }

  .dream-media {
    position: relative;
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 16px 40px rgba(21, 36, 41, 0.18);
  }

  .dream-media__img {
    display: block;
    width: 100%;
    height: 260px;
    object-fit: cover;
  }

  .dream-media__badge {
    position: absolute;
    left: 16px;
    bottom: 16px;
    background: rgba(21, 36, 41, 0.78);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 11px;
    padding: 0.7rem 0.95rem;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .dream-media__badge-eyebrow {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9dbfc9;
  }

  .dream-media__badge-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: #ffffff;
  }

  @media only screen and (min-width: 600px) {
    .intro-slide__content {
      max-width: 520px;
      gap: 2rem;
    }
    .intro-slide__heading {
      font-size: 2.5rem;
    }
    .intro-slide__body {
      font-size: 1.125rem;
    }
    .dream-media__img {
      height: 340px;
    }
  }

  @media only screen and (min-width: 1136px) {
    .intro-slide__content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      column-gap: 4rem;
      row-gap: 1.5rem;
      max-width: var(--content-max-wide);
    }
    .dream-text {
      grid-column: 1;
      grid-row: 1;
      min-width: 0;
    }
    .dream-chips {
      grid-column: 1;
      grid-row: 2;
    }
    .dream-media {
      grid-column: 2;
      grid-row: 1 / 3;
      align-self: center;
      min-width: 0;
    }
    .intro-slide__heading,
    .intro-slide__body {
      text-align: left;
    }
    .intro-slide__heading {
      font-size: 2.75rem;
    }
    .dream-media__img {
      height: 420px;
    }
  }

  @media only screen and (min-width: 1920px) {
    .intro-slide__heading {
      font-size: 3rem;
    }
  }

  /* Self-contained outer spacing (previously provided by the page shell). */
  @media only screen and (min-width: 600px) {
    .intro-slide {
      padding: 4rem 2rem 4rem 2.5rem;
    }
  }
  @media only screen and (min-width: 1136px) {
    .intro-slide {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }
  }
  @media only screen and (min-width: 1920px) {
    .intro-slide {
      padding-top: 6rem;
      padding-bottom: 6rem;
    }
  }
</style>
