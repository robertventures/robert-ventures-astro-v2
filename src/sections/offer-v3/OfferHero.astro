---
import { Image } from "astro:assets";
import heroOuterBanks from "../../assets/offer-v3/hero-outer-banks.png";
import RvLogo from "../../images/brand/logo-horizontal-whitebg.svg";

const investUrl = "https://invest.robertventures.com/";
const trackLocation = "offer_v3_hero";
---

<section class="rv3-section offer-v3-hero" id="offer-v3-hero">
  <div class="offer-v3-hero__bg" aria-hidden="true">
    {/* REPLACE ME: hero background photo */}
    <Image
      src={heroOuterBanks}
      alt=""
      widths={[480, 828, 1400, 1920]}
      sizes="100vw"
      format="webp"
      quality={75}
      class="offer-v3-hero__img"
    />
    <div class="offer-v3-hero__scrim"></div>
  </div>

  <div class="offer-v3-hero__logo">
    <RvLogo />
  </div>

  <div class="offer-v3-hero__inner" data-reveal-group>
    <h1 class="offer-v3-hero__heading rv3-reveal" data-reveal="lines">
      You did everything right, but your money didn't.
    </h1>
    <p class="offer-v3-hero__body rv3-reveal">
      Savings are sitting still. A return smaller than last year. Money you worked for earning
      almost nothing back.
    </p>
    <a
      class="offer-v3-hero__cta rv3-reveal"
      href={investUrl}
      data-track-cta="create_account"
      data-track-location={trackLocation}
    >
      Start earning fixed passive income, up to 10% APY
    </a>
  </div>
</section>

<style>
  .offer-v3-hero {
    position: relative;
    width: 100%;
    height: clamp(560px, 92svh, 680px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--dark-bg, #152420);
    box-sizing: border-box;
    padding: 0 !important;
  }

  /* Background photo + scrim */
  .offer-v3-hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    will-change: transform;
  }
  .offer-v3-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
    transform: scale(1.08);
    transform-origin: center 30%;
  }
  .offer-v3-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(16, 26, 31, 0.25) 0%,
      rgba(16, 26, 31, 0.6) 50%,
      rgba(16, 26, 31, 0.88) 100%
    );
  }

  /* Logo, centered near the top */
  .offer-v3-hero__logo {
    position: absolute;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }
  .offer-v3-hero__logo :global(svg) {
    height: 30px;
    width: auto;
    display: block;
  }

  /* Content, anchored to the bottom */
  .offer-v3-hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 1.125rem;
    max-width: 620px;
    padding: 0 1.25rem 3.5rem;
  }

  .offer-v3-hero__heading {
    font-family: var(--font-heading);
    color: #ffffff;
    font-size: clamp(2.125rem, 8.5vw, 2.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.35);
  }

  .offer-v3-hero__body {
    font-family: var(--font-body);
    color: rgba(255, 255, 255, 0.9);
    font-size: 1rem;
    line-height: 1.5;
    margin: 0;
    max-width: 34rem;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
  }

  .offer-v3-hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.375rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    text-align: center;
    text-decoration: none;
    line-height: 1.3;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease;
  }
  .offer-v3-hero__cta:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.22);
    border-color: rgba(255, 255, 255, 0.42);
  }
  .offer-v3-hero__cta:active {
    transform: translateY(0);
  }

  @media only screen and (min-width: 600px) {
    .offer-v3-hero__logo {
      top: 2.5rem;
    }
    .offer-v3-hero__logo :global(svg) {
      height: 48px;
    }
    .offer-v3-hero__inner {
      padding: 0 2.5rem 4rem;
      gap: 1.375rem;
    }
    .offer-v3-hero__heading {
      font-size: clamp(2.5rem, 6vw, 3.25rem);
    }
    .offer-v3-hero__body {
      font-size: 1.0625rem;
    }
    .offer-v3-hero__cta {
      font-size: 0.875rem;
      padding: 1rem 1.625rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .offer-v3-hero__inner {
      max-width: 640px;
      padding: 0 4rem 4.5rem;
      margin: 0 auto;
    }
    .offer-v3-hero__heading {
      font-size: 2.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .offer-v3-hero__img {
      transform: none !important;
    }
  }
</style>

<script is:inline data-astro-rerun>
  (function () {
    const section = document.getElementById("offer-v3-hero");
    const img = section && section.querySelector(".offer-v3-hero__img");
    if (!section || !img) return;

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    let ctx = null;

    function init() {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      if (!window.gsap || !window.ScrollTrigger) return;

      const gsapLib = window.gsap;

      if (ctx) ctx.revert();
      ctx = gsapLib.context(function () {
        gsapLib.to(img, {
          scale: 1.18,
          yPercent: 6,
          ease: "none",
          scrollTrigger: {
            trigger: section,
            start: "top top",
            end: "bottom top",
            scrub: true,
          },
        });
      });
    }

    function start() {
      if (!window.gsapLoaded || !window.gsap) {
        window.addEventListener("gsapLoaded", start, { once: true });
        return;
      }
      if (window.ScrollTrigger || window.scrollTriggerLoaded) {
        init();
      } else {
        window.addEventListener("scrollTriggerLoaded", init, { once: true });
      }
    }

    start();
  })();
</script>
