---
import { Image } from "astro:assets";
import joeThumb from "../../assets/offer-v3/joe-thumbnail.png";

const trackLocation = "offer_v3_joe";

const chips = [
  "No missed payments in 25 years",
  "SEC-qualified, Reg A",
  "Independently audited",
  "$150M managed",
];
---

<section class="rv3-section joe-video" id="joe-video">
  <div class="joe-video__content" data-reveal-group>
    <p class="joe-video__eyebrow rv3-reveal">JOE ROBERT &middot; FOUNDER &amp; MANAGER</p>
    <h2 class="joe-video__heading rv3-reveal" data-reveal="lines">
      25 years investing in real assets. Now open to you.
    </h2>
    <p class="joe-video__body rv3-reveal">
      Joe Robert founded and manages Robert Ventures, and built the company to bring real estate,
      mortgage, and hard-asset investing to everyday investors.
    </p>

    <div class="joe-video__media rv3-reveal">
      <div class="joe-video__video-container">
        <!-- Fallback poster: always visible so the thumbnail shows immediately;
             the mux-player renders on top once it upgrades. -->
        <Image
          src={joeThumb}
          alt="Joe Robert, founder of Robert Ventures"
          widths={[400, 800]}
          sizes="(min-width: 1136px) 600px, 92vw"
          format="webp"
          quality={78}
          class="joe-video__poster"
        />
        <mux-player
          id="joe-mux-player"
          playback-id="zcQwBRwPYkk7H68jKSAKzUtBLukN4yls02dvyVv4TrP00"
          env-key="hr9aevib299lcvfdoip01jd60"
          preload="metadata"
          stream-type="on-demand"
          poster={joeThumb.src}
          muted
          playsinline></mux-player>
        <button
          class="joe-video__play-pill"
          id="joe-video-play-pill"
          type="button"
          aria-label="Watch: Joe on how it works"
        >
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
            <path d="M8 5v14l11-7z" fill="#ffffff"></path>
          </svg>
          <span>Watch: Joe on how it works</span>
        </button>
      </div>
    </div>

    <ul class="joe-video__chips rv3-reveal" aria-label="Track record highlights">
      {
        chips.map((chip) => (
          <li class="joe-video__chip">
            <span class="joe-video__chip-dot" aria-hidden="true" />
            {chip}
          </li>
        ))
      }
    </ul>

    <p class="joe-video__alignment rv3-reveal">
      Joe put $750,000 of his own capital into Robert Ventures, and it sits behind every bondholder.
      You get paid first.
    </p>

    <p class="joe-video__contact rv3-reveal">
      Have a question? <a
        href="/offer/book-call"
        data-track-cta="book_call"
        data-track-location={trackLocation}>Talk to a real person</a
      >
    </p>
  </div>
</section>

<style>
  .joe-video {
    width: 100%;
    background: #ffffff;
    box-sizing: border-box;
    padding: 3.5rem 1.25rem;
    display: flex;
    justify-content: center;
  }

  .joe-video__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    max-width: 480px;
    text-align: center;
  }

  .joe-video__eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--green-dark);
    margin: 0;
  }

  .joe-video__heading {
    font-family: var(--font-heading);
    color: var(--text-heading);
    font-size: 1.875rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .joe-video__body {
    font-family: var(--font-body);
    color: var(--text-body);
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0;
    max-width: 340px;
  }

  /* Video */
  .joe-video__media {
    width: 100%;
    margin-top: 0.5rem;
  }

  .joe-video__video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 16px;
    background: #152420;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
  }

  .joe-video__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .joe-video__video-container mux-player {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    z-index: 1;
    --media-object-fit: cover;
    --media-object-position: center;
  }

  .joe-video__play-pill {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.125rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.2;
    white-space: nowrap;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
  }

  .joe-video__play-pill:hover {
    background: rgba(255, 255, 255, 0.22);
    transform: translate(-50%, -50%) translateY(-1px);
  }

  .joe-video__play-pill.is-hidden {
    display: none;
  }

  /* Trust chips */
  .joe-video__chips {
    list-style: none;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.625rem;
    margin: 0.25rem 0 0;
    padding: 0;
  }

  .joe-video__chip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    background: var(--green-tint);
    border-radius: 999px;
    padding: 0.5rem 0.625rem;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-heading);
    line-height: 1.3;
    text-align: center;
  }

  .joe-video__chip-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green-brand);
  }

  .joe-video__alignment {
    font-family: var(--font-body);
    color: var(--text-body);
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0.25rem 0 0;
    max-width: 340px;
  }

  .joe-video__contact {
    font-family: var(--font-body);
    color: var(--text-body);
    font-size: 0.8125rem;
    margin: 0;
  }

  .joe-video__contact a {
    color: var(--green-dark);
    text-decoration: underline;
    font-weight: 500;
  }

  /* Tablet and up */
  @media only screen and (min-width: 600px) {
    .joe-video {
      padding: 5rem 2.5rem;
    }
    .joe-video__content {
      max-width: 560px;
      gap: 1.5rem;
    }
    .joe-video__heading {
      font-size: 2.25rem;
    }
    .joe-video__body,
    .joe-video__alignment {
      font-size: 1rem;
      max-width: 400px;
    }
    .joe-video__chips {
      max-width: 420px;
    }
    .joe-video__chip {
      font-size: 0.75rem;
      padding: 0.625rem 0.75rem;
    }
    .joe-video__contact {
      font-size: 0.875rem;
    }
    .joe-video__play-pill {
      padding: 0.875rem 1.375rem;
      font-size: 0.875rem;
    }
  }

  /* Desktop */
  @media only screen and (min-width: 1136px) {
    .joe-video {
      padding: 6rem 4rem;
    }
    .joe-video__content {
      max-width: 640px;
    }
    .joe-video__heading {
      font-size: 2.5rem;
    }
  }
</style>

<script is:inline data-astro-rerun>
  (function () {
    function init() {
      const container = document.getElementById("joe-video");
      if (!container) return;

      const player = document.getElementById("joe-mux-player");
      const pill = document.getElementById("joe-video-play-pill");
      if (!player || !pill) return;
      if (pill.dataset.joeBound) return;
      pill.dataset.joeBound = "1";

      pill.addEventListener("click", function () {
        try {
          player.muted = false;
          const playPromise = player.play();
          if (playPromise && typeof playPromise.catch === "function") {
            playPromise.catch(function () {});
          }
        } catch {}
        pill.classList.add("is-hidden");
      });
    }

    function start() {
      if (!window.gsapLoaded || !window.gsap) {
        window.addEventListener("gsapLoaded", start, { once: true });
        return;
      }
      init();
    }

    start();
  })();
</script>
