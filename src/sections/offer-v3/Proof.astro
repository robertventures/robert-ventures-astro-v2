---
const testimonials = [
  {
    quote:
      "I can always talk to a real person when I have questions. Everything isn't just online with a robot.",
    name: "Darlene K.",
    role: "investor",
  },
  {
    quote:
      "I'm receiving my payments on time and making money every month, just as it was explained.",
    name: "Michael F.",
    role: "investor",
  },
  {
    quote:
      "They're always available to answer any questions I have, and my interest shows up like clockwork.",
    name: "Ashesh P.",
    role: "investor",
  },
  {
    quote: "I did my due diligence, started small, and it has performed exactly as promised.",
    name: "Robert M.",
    role: "investor",
  },
];

// Duplicate the set so the marquee track can loop seamlessly (translateX
// from 0 to -50% lands exactly back on an identical copy of the cards).
const marqueeCards = [...testimonials, ...testimonials];

const trustPills = ["100% on-time", "BitGo custody", "Independently audited"];
---

<section class="rv3-section rv3-proof" id="offer-v3-proof">
  <div class="rv3-proof__content" data-reveal-group>
    <p class="rv3-proof__eyebrow rv3-reveal">TRUSTED BY 83+ INVESTORS</p>
    <h2 class="rv3-proof__heading rv3-reveal" data-reveal="lines">
      They started where you are. Now they're paid every month.
    </h2>

    <div class="rv3-proof__marquee-wrap rv3-reveal">
      <div class="rv3-proof__fade rv3-proof__fade--left" aria-hidden="true"></div>
      <div class="rv3-proof__fade rv3-proof__fade--right" aria-hidden="true"></div>
      <div class="rv3-proof__viewport">
        <ul class="rv3-proof__track" aria-label="Investor testimonials">
          {
            marqueeCards.map((t, i) => (
              <li
                class="rv3-proof__card"
                aria-hidden={i >= testimonials.length ? "true" : undefined}
              >
                <span class="rv3-proof__stars" aria-hidden="true">
                  ★★★★★
                </span>
                <p class="rv3-proof__quote">{t.quote}</p>
                <p class="rv3-proof__name">
                  {t.name} <span class="rv3-proof__role">· {t.role}</span>
                </p>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <ul class="rv3-proof__pills rv3-reveal" aria-label="Trust indicators">
      {trustPills.map((pill) => <li class="rv3-proof__pill">{pill}</li>)}
    </ul>
  </div>
</section>

<style>
  .rv3-proof {
    position: relative;
    width: 100%;
    box-sizing: border-box;
    background: var(--bg-secondary);
    overflow: hidden;
    padding: 3.5rem 0 3.5rem;
  }

  .rv3-proof__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.25rem;
    box-sizing: border-box;
    text-align: center;
  }

  .rv3-proof__eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--green-dark);
    margin: 0;
  }

  .rv3-proof__heading {
    font-family: var(--font-heading);
    color: var(--text-heading);
    font-size: 1.75rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
    max-width: 22rem;
  }

  /* Marquee wrap: full viewport width so the edge fades reach the page edges,
     even though the rest of the section content stays centered/max-width. */
  .rv3-proof__marquee-wrap {
    position: relative;
    width: 100vw;
    margin: 0.5rem calc(50% - 50vw) 0;
  }

  .rv3-proof__fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 28px;
    z-index: 2;
    pointer-events: none;
  }
  .rv3-proof__fade--left {
    left: 0;
    background: linear-gradient(90deg, var(--bg-secondary) 0%, rgba(244, 246, 248, 0) 100%);
  }
  .rv3-proof__fade--right {
    right: 0;
    background: linear-gradient(270deg, var(--bg-secondary) 0%, rgba(244, 246, 248, 0) 100%);
  }

  .rv3-proof__viewport {
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .rv3-proof__viewport::-webkit-scrollbar {
    display: none;
  }

  .rv3-proof__track {
    display: flex;
    gap: 0.875rem;
    list-style: none;
    margin: 0;
    padding: 0.25rem 1.25rem;
    width: max-content;
    will-change: transform;
  }

  /* Auto-scroll animation. Disabled (see reduced-motion + JS pause logic
     below) it just sits still as a static, horizontally scrollable row. */
  .rv3-proof--animate .rv3-proof__track {
    animation: rv3-proof-marquee 34s linear infinite;
  }
  .rv3-proof--paused .rv3-proof__track {
    animation-play-state: paused;
  }

  @keyframes rv3-proof-marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .rv3-proof__card {
    flex: 0 0 auto;
    width: 280px;
    box-sizing: border-box;
    background: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: left;
  }

  .rv3-proof__stars {
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    color: #e0a940;
    line-height: 1;
  }

  .rv3-proof__quote {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: #333333;
    margin: 0;
  }

  .rv3-proof__name {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: #555555;
    margin: 0;
  }

  .rv3-proof__role {
    color: #8a969c;
  }

  .rv3-proof__pills {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
  }

  .rv3-proof__pill {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-heading);
    background: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 999px;
    padding: 0.5rem 1rem;
    white-space: nowrap;
  }

  @media only screen and (min-width: 600px) {
    .rv3-proof {
      padding: 5rem 0 5rem;
    }
    .rv3-proof__content {
      gap: 1.5rem;
      padding: 0 2rem;
    }
    .rv3-proof__heading {
      font-size: 2rem;
      max-width: 32rem;
    }
    .rv3-proof__card {
      width: 320px;
      padding: 1.25rem;
    }
  }

  @media only screen and (min-width: 1136px) {
    .rv3-proof {
      padding: 6rem 0 6rem;
    }
    .rv3-proof__heading {
      font-size: 2.25rem;
      max-width: 38rem;
    }
  }

  /* Reduced motion: no animation class ever gets added by JS, but as a
     belt-and-suspenders guard also kill the keyframe here. */
  @media (prefers-reduced-motion: reduce) {
    .rv3-proof__track {
      animation: none !important;
    }
  }
</style>

<script is:inline data-astro-rerun>
  (function () {
    const section = document.getElementById("offer-v3-proof");
    if (!section) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const viewport = section.querySelector(".rv3-proof__viewport");
    const wrap = section.querySelector(".rv3-proof__marquee-wrap");

    if (reduceMotion || !wrap || !viewport) {
      // Leave it as a static, horizontally scrollable row. No animation class,
      // no listeners needed.
      return;
    }

    function init() {
      wrap.classList.add("rv3-proof--animate");

      const pause = () => wrap.classList.add("rv3-proof--paused");
      const resume = () => wrap.classList.remove("rv3-proof--paused");

      wrap.addEventListener("mouseenter", pause);
      wrap.addEventListener("mouseleave", resume);
      wrap.addEventListener("touchstart", pause, { passive: true });
      wrap.addEventListener("touchend", resume, { passive: true });
      wrap.addEventListener("touchcancel", resume, { passive: true });

      // If the user manually scrolls the track (it's a real overflow-x
      // container), pause the CSS animation while they're dragging so the
      // two motions don't fight each other.
      let scrollPauseTimer = null;
      viewport.addEventListener(
        "scroll",
        () => {
          pause();
          clearTimeout(scrollPauseTimer);
          scrollPauseTimer = setTimeout(resume, 1200);
        },
        { passive: true }
      );
    }

    // This is a pure-CSS animation (no GSAP dependency), so it doesn't need
    // the GSAP handshake gate: it has zero dependency on window.gsap.
    init();
  })();
</script>
